             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#WFP_CALLOUT>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#WFP_LAYER>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#WFP_SUB_LAYER>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#WFP_PROVIDER>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#WFP_PROVIDER_CONTEXT>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#OTHER> ] ;
          <uid> @linkml:String ?
       ) ;
       rdf:type [ <WinResource> ] ?
    )
}

<WinService> CLOSED {
    (  $<WinService_tes> (  &<Service_tes> ;
          rdf:type [ <Service> ] ? ;
          <cmd_line> @linkml:String ? ;
          <hosting_process> @<ProcessEntity> ? ;
          <load_order_group> @linkml:String ? ;
          <name> @linkml:String ;
          <service_category> @linkml:String ? ;
          <service_category_id> [ <https://w3id.org/lmodel/ocsf/WindowsServiceCategoryIdEnum#UNKNOWN>
             <https://w3id.org/lmodel/ocsf/WindowsServiceCategoryIdEnum#KERNEL_MODE>
             <https://w3id.org/lmodel/ocsf/WindowsServiceCategoryIdEnum#USER_MODE>
             <https://w3id.org/lmodel/ocsf/WindowsServiceCategoryIdEnum#OTHER> ] ? ;
          <service_dependencies> @linkml:String * ;
          <service_dll_file> @<File> ? ;
          <service_error_control> @linkml:String ? ;
          <service_error_control_id> [ <https://w3id.org/lmodel/ocsf/WindowsServiceErrorControlIdEnum#UNKNOWN>
             <https://w3id.org/lmodel/ocsf/WindowsServiceErrorControlIdEnum#IGNORE>
             <https://w3id.org/lmodel/ocsf/WindowsServiceErrorControlIdEnum#NORMAL>
             <https://w3id.org/lmodel/ocsf/WindowsServiceErrorControlIdEnum#SEVERE>
             <https://w3id.org/lmodel/ocsf/WindowsServiceErrorControlIdEnum#CRITICAL>
             <https://w3id.org/lmodel/ocsf/WindowsServiceErrorControlIdEnum#OTHER> ] ? ;
          <service_file> @<File> ? ;
          <service_start_name> @linkml:String ? ;
          <service_start_type> @linkml:String ? ;
          <service_start_type_id> [ <https://w3id.org/lmodel/ocsf/WindowsServiceStartTypeIdEnum#UNKNOWN>
             <https://w3id.org/lmodel/ocsf/WindowsServiceStartTypeIdEnum#BOOT>
             <https://w3id.org/lmodel/ocsf/WindowsServiceStartTypeIdEnum#SYSTEM>
             <https://w3id.org/lmodel/ocsf/WindowsServiceStartTypeIdEnum#AUTO>
             <https://w3id.org/lmodel/ocsf/WindowsServiceStartTypeIdEnum#DEMAND>
             <https://w3id.org/lmodel/ocsf/WindowsServiceStartTypeIdEnum#DISABLED>
             <https://w3id.org/lmodel/ocsf/WindowsServiceStartTypeIdEnum#OTHER> ] ? ;
          <service_type> @linkml:String ? ;
          <service_type_id> [ <https://w3id.org/lmodel/ocsf/WindowsServiceTypeIdEnum#UNKNOWN>
             <https://w3id.org/lmodel/ocsf/WindowsServiceTypeIdEnum#KERNEL_DRIVER>
             <https://w3id.org/lmodel/ocsf/WindowsServiceTypeIdEnum#FILE_SYSTEM_DRIVER>
             <https://w3id.org/lmodel/ocsf/WindowsServiceTypeIdEnum#OWN_PROCESS>
             <https://w3id.org/lmodel/ocsf/WindowsServiceTypeIdEnum#SHARE_PROCESS>
             <https://w3id.org/lmodel/ocsf/WindowsServiceTypeIdEnum#OTHER> ] ?
       ) ;
       rdf:type [ <WinService> ] ?
    )
}

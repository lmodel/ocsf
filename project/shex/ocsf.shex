       (  $<DiscoveryEvent_tes> (  &<BaseEvent_tes> ;
             rdf:type [ <BaseEvent> ] ? ;
             <activity_id> [ <https://w3id.org/lmodel/ocsf/ActivityIdEnum#UNKNOWN>
                <https://w3id.org/lmodel/ocsf/ActivityIdEnum#OTHER> ] ?
          ) ;
          rdf:type [ <DiscoveryEvent> ] ?
       )
    } OR @<CloudResourcesInventoryInfo> OR @<ConfigState> OR @<DeviceConfigStateChange> OR @<InventoryInfo> OR
    @<OsintInventoryInfo> OR @<PatchState> OR @<SoftwareInfo> OR @<UserInventory>
)

<DiscoveryResult>  (
    CLOSED {
       (  $<DiscoveryResult_tes> (  &<BaseEvent_tes> ;
             rdf:type [ <BaseEvent> ] ? ;
             <activity_id> [ <https://w3id.org/lmodel/ocsf/ActivityIdEnum#UNKNOWN>
                <https://w3id.org/lmodel/ocsf/ActivityIdEnum#OTHER> ] ? ;
             <query_info> @<QueryInfo> ? ;
             <query_result> @linkml:String ? ;
             <query_result_id> [ <https://w3id.org/lmodel/ocsf/QueryResultIdEnum#UNKNOWN>
                <https://w3id.org/lmodel/ocsf/QueryResultIdEnum#EXISTS> <https://w3id.org/lmodel/ocsf/QueryResultIdEnum#PARTIAL>
                <https://w3id.org/lmodel/ocsf/QueryResultIdEnum#DOES_NOT_EXIST>
                <https://w3id.org/lmodel/ocsf/QueryResultIdEnum#ERROR> <https://w3id.org/lmodel/ocsf/QueryResultIdEnum#UNSUPPORTED>
                <https://w3id.org/lmodel/ocsf/QueryResultIdEnum#OTHER> ]
          ) ;
          rdf:type [ <DiscoveryResult> ] ?
       )
    } OR @<AdminGroupQuery> OR @<EvidenceInfo> OR @<FileQuery> OR @<FolderQuery> OR @<JobQuery> OR @<KernelObjectQuery> OR
    @<ModuleQuery> OR @<NetworkConnectionQuery> OR @<NetworksQuery> OR @<PeripheralDeviceQuery> OR @<PrefetchQuery> OR
    @<ProcessQuery> OR @<RegistryKeyQuery> OR @<RegistryValueQuery> OR @<ServiceQuery> OR @<SessionQuery> OR @<StartupItemQuery> OR
    @<UserQuery>
)


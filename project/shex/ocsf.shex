# metamodel_version: 1.7.0
# version: 1.9.0-dev
BASE <https://w3id.org/lmodel/ocsf/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX linkml: <https://w3id.org/linkml/>


linkml:String xsd:string

linkml:Integer xsd:integer

linkml:Boolean xsd:boolean

linkml:Float xsd:float

linkml:Double xsd:double

linkml:Decimal xsd:decimal

linkml:Time xsd:time

linkml:Date xsd:date

linkml:Datetime xsd:dateTime

linkml:DateOrDatetime linkml:DateOrDatetime

linkml:Uriorcurie IRI

linkml:Curie xsd:string

linkml:Uri IRI

linkml:Ncname xsd:string

linkml:Objectidentifier IRI

linkml:Nodeidentifier NONLITERAL

linkml:Jsonpointer xsd:string

linkml:Jsonpath xsd:string

linkml:Sparqlpath xsd:string

<TimestampT> xsd:long

<UrlT> IRI

<IpT> xsd:string

<MacT> xsd:string

<EmailT> xsd:string

<HostnameT> xsd:string

<UsernameT> xsd:string

<FileNameT> xsd:string

<FilePathT> xsd:string

<PortT> xsd:integer

<UuidT> xsd:string

<SubnetT> xsd:string

<AccessAnalysisResult> CLOSED {
    (  $<AccessAnalysisResult_tes> (  &<Object_tes> ;
          rdf:type [ <Object> ] ? ;
          <access_level> @linkml:String ? ;
          <access_type> @linkml:String ? ;
          <accessors> @<User> + ;
          <additional_restrictions> @<AdditionalRestriction> * ;
          <condition_keys> @<KeyValueObject> * ;
          <granted_privileges> @linkml:String *
       ) ;
       rdf:type [ <AccessAnalysisResult> ] ?
    )
}

<Account> CLOSED {
    (  $<Account_tes> (  &<Entity_tes> ;
          rdf:type [ <Entity> ] ? ;
          <is_disabled> @linkml:Boolean ? ;
          <is_locked> @linkml:Boolean ? ;
          <is_on_premises_sync_enabled> @linkml:Boolean ? ;
          <labels> @linkml:String * ;
          <name> @linkml:String ? ;
          <tags> @<KeyValueObject> * ;
          <type> @linkml:String ? ;
          <type_id> [ <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#UNKNOWN>
             <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#LDAP_ACCOUNT>
             <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#WINDOWS_ACCOUNT>
             <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#AWS_IAM_USER>
             <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#AWS_IAM_ROLE>
             <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#GCP_ACCOUNT>
             <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#AZURE_AD_ACCOUNT>
             <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#MAC_OS_ACCOUNT>
             <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#APPLE_ACCOUNT>
             <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#LINUX_ACCOUNT>
             <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#AWS_ACCOUNT>
             <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#GCP_PROJECT>
             <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#OCI_COMPARTMENT>
             <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#AZURE_SUBSCRIPTION>
             <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#SALESFORCE_ACCOUNT>
             <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#GOOGLE_WORKSPACE>
             <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#SERVICENOW_INSTANCE>
             <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#M365_TENANT>
             <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#EMAIL_ACCOUNT>
             <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#ACTIVEDIRECTORY_ACCOUNT>
             <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#OTHER> ] ? ;
          <uid> @linkml:String ?
       ) ;
       rdf:type [ <Account> ] ?
    )
}

<AccountChange> CLOSED {
    (  $<AccountChange_tes> (  &<IamEvent_tes> ;
          rdf:type [ <IamEvent> ] ? ;
          <activity_id> [ <https://w3id.org/lmodel/ocsf/ActivityIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/ActivityIdEnum#OTHER>
             ] ? ;
          <auth_factors> @<AuthFactor> * ;
          <policies> @<Policy> * ;
          <policy> @<Policy> ? ;
          <user> @<User> ;
          <user_result> @<User> ?
       ) ;
       rdf:type [ <AccountChange> ] ?
    )
}

<Actor> CLOSED {
    (  $<Actor_tes> (  &<Object_tes> ;
          rdf:type [ <Object> ] ? ;
          <app_name> @linkml:String ? ;
          <app_uid> @linkml:String ? ;
          <authorizations> @<Authorization> * ;
          <idp> @<Idp> ? ;
          <invoked_by> @linkml:String ? ;
          <process> @<Process> ? ;
          <session> @<Session> ? ;
          <user> @<User> ?
       ) ;
       rdf:type [ <Actor> ] ?
    )
}

<AdditionalRestriction> CLOSED {
    (  $<AdditionalRestriction_tes> (  &<Object_tes> ;
          rdf:type [ <Object> ] ? ;
          <policy> @<Policy> ;
          <status> @linkml:String ? ;
          <status_id> [ <https://w3id.org/lmodel/ocsf/AdditionalRestrictionStatusIdEnum#APPLICABLE>
             <https://w3id.org/lmodel/ocsf/AdditionalRestrictionStatusIdEnum#INAPPLICABLE>
             <https://w3id.org/lmodel/ocsf/AdditionalRestrictionStatusIdEnum#EVALUATION_ERROR>
             <https://w3id.org/lmodel/ocsf/AdditionalRestrictionStatusIdEnum#UNKNOWN>
             <https://w3id.org/lmodel/ocsf/AdditionalRestrictionStatusIdEnum#OTHER> ] ?
       ) ;
       rdf:type [ <AdditionalRestriction> ] ?
    )
}

<AdminGroupQuery> CLOSED {
    (  $<AdminGroupQuery_tes> (  &<DiscoveryResult_tes> ;
          rdf:type [ <DiscoveryResult> ] ? ;
          <group> @<Group> ;
          <users> @<User> *
       ) ;
       rdf:type [ <AdminGroupQuery> ] ?
    )
}

<Advisory> CLOSED {
    (  $<Advisory_tes> (  &<Object_tes> ;
          rdf:type [ <Object> ] ? ;
          <avg_timespan> @<Timespan> ? ;
          <bulletin> @linkml:String ? ;
          <classification> @linkml:String ? ;
          <created_time> @<TimestampT> ? ;
          <desc> @linkml:String ? ;
          <install_state> @linkml:String ? ;
          <install_state_id> [ <https://w3id.org/lmodel/ocsf/InstallStateIdEnum#UNKNOWN>
             <https://w3id.org/lmodel/ocsf/InstallStateIdEnum#INSTALLED>
             <https://w3id.org/lmodel/ocsf/InstallStateIdEnum#NOT_INSTALLED>
             <https://w3id.org/lmodel/ocsf/InstallStateIdEnum#INSTALLED_PENDING_REBOOT>
             <https://w3id.org/lmodel/ocsf/InstallStateIdEnum#OTHER> ] ? ;
          <is_superseded> @linkml:Boolean ? ;
          <modified_time> @<TimestampT> ? ;
          <os> @<Os> ? ;
          <product> @<Product> ? ;
          <references> @linkml:String * ;
          <related_cves> @<Cve> * ;
          <related_cwes> @<Cwe> * ;
          <size> @linkml:Integer ? ;
          <src_url> @<UrlT> ? ;
          <title> @linkml:String ? ;
          <uid> @linkml:String
       ) ;
       rdf:type [ <Advisory> ] ?
    )
}

<AffectedCode> CLOSED {
    (  $<AffectedCode_tes> (  &<Object_tes> ;
          rdf:type [ <Object> ] ? ;
          <end_column> @linkml:Integer ? ;
          <end_line> @linkml:Integer ? ;
          <file> @<File> ;
          <owner> @<User> ? ;
          <remediation> @<Remediation> ? ;
          <rule> @<Rule> ? ;
          <start_column> @linkml:Integer ? ;
          <start_line> @linkml:Integer ?
       ) ;
       rdf:type [ <AffectedCode> ] ?
    )
}

<AffectedPackage> CLOSED {
    (  $<AffectedPackage_tes> (  &<Package_tes> ;
          rdf:type [ <Package> ] ? ;
          <fixed_in_version> @linkml:String ? ;
          <path> @linkml:String ? ;
          <remediation> @<Remediation> ?
       ) ;
       rdf:type [ <AffectedPackage> ] ?
    )
}

<Agent> CLOSED {
    (  $<Agent_tes> (  &<Object_tes> ;
          rdf:type [ <Object> ] ? ;
          <name> @linkml:String ? ;
          <policies> @<Policy> * ;
          <type> @linkml:String ? ;
          <type_id> [ <https://w3id.org/lmodel/ocsf/AgentTypeIdEnum#ENDPOINT_DETECTION_AND_RESPONSE>
             <https://w3id.org/lmodel/ocsf/AgentTypeIdEnum#DATA_LOSS_PREVENTION>
             <https://w3id.org/lmodel/ocsf/AgentTypeIdEnum#BACKUP_RECOVERY>
             <https://w3id.org/lmodel/ocsf/AgentTypeIdEnum#PERFORMANCE_MONITORING_OBSERVABILITY>
             <https://w3id.org/lmodel/ocsf/AgentTypeIdEnum#VULNERABILITY_MANAGEMENT>
             <https://w3id.org/lmodel/ocsf/AgentTypeIdEnum#LOG_FORWARDING>
             <https://w3id.org/lmodel/ocsf/AgentTypeIdEnum#MOBILE_DEVICE_MANAGEMENT>
             <https://w3id.org/lmodel/ocsf/AgentTypeIdEnum#CONFIGURATION_MANAGEMENT>
             <https://w3id.org/lmodel/ocsf/AgentTypeIdEnum#REMOTE_ACCESS> <https://w3id.org/lmodel/ocsf/AgentTypeIdEnum#UNKNOWN>
             <https://w3id.org/lmodel/ocsf/AgentTypeIdEnum#OTHER> ] ? ;
          <uid> @linkml:String ? ;
          <uid_alt> @linkml:String ? ;
          <vendor_name> @linkml:String ? ;
          <version> @linkml:String ?
       ) ;
       rdf:type [ <Agent> ] ?
    )
}

<AiModel> CLOSED {
    (  $<AiModel_tes> (  &<Entity_tes> ;
          rdf:type [ <Entity> ] ? ;
          <ai_provider> @linkml:String ;
          <name> @linkml:String ? ;
          <uid> @linkml:String ? ;
          <version> @linkml:String ?
       ) ;
       rdf:type [ <AiModel> ] ?
    )
}

<AiOperationProfile> {
    (  $<AiOperationProfile_tes> (  <ai_model> @<AiModel> ? ;
          <message_context> @<MessageContext> ?
       ) ;
       rdf:type [ <AiOperationProfile> ] ?
    )
}

<AirborneBroadcastActivity> CLOSED {
    (  $<AirborneBroadcastActivity_tes> (  &<UnmannedSystemsEvent_tes> ;
          rdf:type [ <UnmannedSystemsEvent> ] ? ;
          <activity_id> [ <https://w3id.org/lmodel/ocsf/ActivityIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/ActivityIdEnum#OTHER>
             ] ? ;
          <aircraft> @<Aircraft> ? ;
          <dst_endpoint> @<NetworkEndpoint> ? ;
          <protocol_name> @linkml:String ? ;
          <rssi> @linkml:Integer ? ;
          <src_endpoint> @<NetworkEndpoint> ? ;
          <traffic> @<NetworkTraffic> ? ;
          <unmanned_aerial_system> @<UnmannedAerialSystem> ;
          <unmanned_system_operating_area> @<UnmannedSystemOperatingArea> ? ;
          <unmanned_system_operator> @<User>
       ) ;
       rdf:type [ <AirborneBroadcastActivity> ] ?
    )
}

<Aircraft>  (
    CLOSED {
       (  $<Aircraft_tes> (  &<Entity_tes> ;
             rdf:type [ <Entity> ] ? ;
             <location> @<Location> ? ;
             <model> @linkml:String ? ;
             <name> @linkml:String ? ;
             <serial_number> @linkml:String ? ;
             <speed> @linkml:String ? ;
             <speed_accuracy> @linkml:String ? ;
             <track_direction> @linkml:String ? ;
             <uid> @linkml:String ? ;
             <uid_alt> @linkml:String ? ;
             <vertical_speed> @linkml:String ?
          ) ;
          rdf:type [ <Aircraft> ] ?
       )
    } OR @<UnmannedAerialSystem>
)

<AnalysisTarget> CLOSED {
    (  $<AnalysisTarget_tes> (  &<OcsfObject_tes> ;
          rdf:type [ <OcsfObject> ] ? ;
          <name> @linkml:String ;
          <type> @linkml:String ?
       ) ;
       rdf:type [ <AnalysisTarget> ] ?
    )
}

<Analytic> CLOSED {
    (  $<Analytic_tes> (  &<Entity_tes> ;
          rdf:type [ <Entity> ] ? ;
          <algorithm> @linkml:String ? ;
          <category> @linkml:String ? ;
          <desc> @linkml:String ? ;
          <name> @linkml:String ? ;
          <related_analytics> @<Analytic> * ;
          <state> @linkml:String ? ;
          <state_id> [ <https://w3id.org/lmodel/ocsf/AnalyticStateIdEnum#ACTIVE>
             <https://w3id.org/lmodel/ocsf/AnalyticStateIdEnum#SUPPRESSED>
             <https://w3id.org/lmodel/ocsf/AnalyticStateIdEnum#EXPERIMENTAL>
             <https://w3id.org/lmodel/ocsf/AnalyticStateIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/AnalyticStateIdEnum#OTHER> ]
          ? ;
          <type> @linkml:String ? ;
          <type_id> [ <https://w3id.org/lmodel/ocsf/AnalyticTypeIdEnum#UNKNOWN>
             <https://w3id.org/lmodel/ocsf/AnalyticTypeIdEnum#RULE> <https://w3id.org/lmodel/ocsf/AnalyticTypeIdEnum#BEHAVIORAL>
             <https://w3id.org/lmodel/ocsf/AnalyticTypeIdEnum#STATISTICAL>
             <https://w3id.org/lmodel/ocsf/AnalyticTypeIdEnum#LEARNING_ML_DL>
             <https://w3id.org/lmodel/ocsf/AnalyticTypeIdEnum#FINGERPRINTING>
             <https://w3id.org/lmodel/ocsf/AnalyticTypeIdEnum#TAGGING>
             <https://w3id.org/lmodel/ocsf/AnalyticTypeIdEnum#KEYWORD_MATCH>
             <https://w3id.org/lmodel/ocsf/AnalyticTypeIdEnum#REGULAR_EXPRESSIONS>
             <https://w3id.org/lmodel/ocsf/AnalyticTypeIdEnum#EXACT_DATA_MATCH>
             <https://w3id.org/lmodel/ocsf/AnalyticTypeIdEnum#PARTIAL_DATA_MATCH>
             <https://w3id.org/lmodel/ocsf/AnalyticTypeIdEnum#INDEXED_DATA_MATCH>
             <https://w3id.org/lmodel/ocsf/AnalyticTypeIdEnum#OTHER> ] ;
          <uid> @linkml:String ? ;
          <version> @linkml:String ?
       ) ;
       rdf:type [ <Analytic> ] ?
    )
}

<Anomaly> CLOSED {
    (  $<Anomaly_tes> (  &<Object_tes> ;
          rdf:type [ <Object> ] ? ;
          <observation_parameter> @linkml:String ;
          <observation_type> @linkml:String ? ;
          <observations> @<Observation> + ;
          <observed_pattern> @linkml:String ?
       ) ;
       rdf:type [ <Anomaly> ] ?
    )
}

<AnomalyAnalysis> CLOSED {
    (  $<AnomalyAnalysis_tes> (  &<OcsfObject_tes> ;
          rdf:type [ <OcsfObject> ] ? ;
          <analysis_targets> @<AnalysisTarget> + ;
          <anomalies> @<Anomaly> + ;
          <baselines> @<Baseline> *
       ) ;
       rdf:type [ <AnomalyAnalysis> ] ?
    )
}

<Api> CLOSED {
    (  $<Api_tes> (  &<Object_tes> ;
          rdf:type [ <Object> ] ? ;
          <group> @<Group> ? ;
          <operation> @linkml:String ;
          <request> @<Request> ? ;
          <response> @<Response> ? ;
          <service> @<Service> ? ;
          <token> @<Token> ? ;
          <version> @linkml:String ?
       ) ;
       rdf:type [ <Api> ] ?
    )
}

<ApiActivity> CLOSED {
    (  $<ApiActivity_tes> (  &<ApplicationEvent_tes> ;
          rdf:type [ <ApplicationEvent> ] ? ;
          &<TraceProfile_tes> ;
          rdf:type [ <TraceProfile> ] ? ;
          &<AiOperationProfile_tes> ;
          rdf:type [ <AiOperationProfile> ] ? ;
          <activity_id> [ <https://w3id.org/lmodel/ocsf/ActivityIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/ActivityIdEnum#OTHER>
             ] ? ;
          <actor> @<Actor> ;
          <api> @<Api> ? ;
          <dst_endpoint> @<NetworkEndpoint> ? ;
          <http_request> @<HttpRequest> ? ;
          <http_response> @<HttpResponse> ? ;
          <resources> @<ResourceDetails> * ;
          <src_endpoint> @<NetworkEndpoint> ;
          <trace> @<Trace> ? ;
          <ai_model> @<AiModel> ? ;
          <message_context> @<MessageContext> ?
       ) ;
       rdf:type [ <ApiActivity> ] ?
    )
}

<ApplicationError> CLOSED {
    (  $<ApplicationError_tes> (  &<ApplicationEvent_tes> ;
          rdf:type [ <ApplicationEvent> ] ? ;
          <activity_id> [ <https://w3id.org/lmodel/ocsf/ActivityIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/ActivityIdEnum#OTHER>
             ] ? ;
          <message> @linkml:String ?
       ) ;
       rdf:type [ <ApplicationError> ] ?
    )
}

<ApplicationEvent>  (
    CLOSED {
       (  $<ApplicationEvent_tes> (  &<BaseEvent_tes> ;
             rdf:type [ <BaseEvent> ] ?
          ) ;
          rdf:type [ <ApplicationEvent> ] ?
       )
    } OR @<ApiActivity> OR @<ApplicationError> OR @<ApplicationLifecycle> OR @<DatastoreActivity> OR @<FileHosting> OR
    @<ScanActivity> OR @<WebResourceAccessActivity> OR @<WebResourcesActivity>
)

<ApplicationLifecycle> CLOSED {
    (  $<ApplicationLifecycle_tes> (  &<ApplicationEvent_tes> ;
          rdf:type [ <ApplicationEvent> ] ? ;
          <activity_id> [ <https://w3id.org/lmodel/ocsf/ActivityIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/ActivityIdEnum#OTHER>
             ] ? ;
          <app> @<Product>
       ) ;
       rdf:type [ <ApplicationLifecycle> ] ?
    )
}

<ApplicationObject> CLOSED {
    (  $<ApplicationObject_tes> (  &<Object_tes> ;
          rdf:type [ <Object> ] ? ;
          <criticality> @linkml:String ? ;
          <data> @linkml:String ? ;
          <desc> @linkml:String ? ;
          <group> @<Group> ? ;
          <hostname> @<HostnameT> ? ;
          <labels> @linkml:String * ;
          <name> @linkml:String ? ;
          <owner> @<User> ? ;
          <region> @linkml:String ? ;
          <resource_relationship> @<Graph> ? ;
          <risk_level> @linkml:String ? ;
          <risk_level_id> [ <https://w3id.org/lmodel/ocsf/RiskLevelIdEnum#INFO> <https://w3id.org/lmodel/ocsf/RiskLevelIdEnum#LOW>
             <https://w3id.org/lmodel/ocsf/RiskLevelIdEnum#MEDIUM> <https://w3id.org/lmodel/ocsf/RiskLevelIdEnum#HIGH>
             <https://w3id.org/lmodel/ocsf/RiskLevelIdEnum#CRITICAL> <https://w3id.org/lmodel/ocsf/RiskLevelIdEnum#OTHER> ] ? ;
          <risk_score> @linkml:Integer ? ;
          <sbom> @<Sbom> ? ;
          <tags> @<KeyValueObject> * ;
          <type> @linkml:String ? ;
          <uid> @linkml:String ? ;
          <uid_alt> @linkml:String ? ;
          <url> @<Url> ? ;
          <version> @linkml:String ?
       ) ;
       rdf:type [ <ApplicationObject> ] ?
    )
}

<ApplicationSecurityPostureFinding> CLOSED {
    (  $<ApplicationSecurityPostureFinding_tes> (  &<Finding_tes> ;
          rdf:type [ <Finding> ] ? ;
          &<IncidentProfile_tes> ;
          rdf:type [ <IncidentProfile> ] ? ;
          <application> @<ApplicationObject> ? ;
          <compliance> @<Compliance> ? ;
          <remediation> @<Remediation> ? ;
          <resources> @<ResourceDetails> * ;
          <vulnerabilities> @<Vulnerability> *
       ) ;
       rdf:type [ <ApplicationSecurityPostureFinding> ] ?
    )
}

<Assessment> CLOSED {
    (  $<Assessment_tes> (  &<Entity_tes> ;
          rdf:type [ <Entity> ] ? ;
          <category> @linkml:String ? ;
          <desc> @linkml:String ? ;
          <meets_criteria> @linkml:Boolean ;
          <name> @linkml:String ? ;
          <policy> @<Policy> ? ;
          <uid> @linkml:String ?
       ) ;
       rdf:type [ <Assessment> ] ?
    )
}

<Attack> CLOSED {
    (  $<Attack_tes> (  &<Object_tes> ;
          rdf:type [ <Object> ] ? ;
          <mitigation> @<Mitigation> ? ;
          <sub_technique> @<SubTechnique> ? ;
          <tactic> @<Tactic> ? ;
          <tactics> @<Tactic> * ;
          <technique> @<Technique> ? ;
          <version> @linkml:String ?
       ) ;
       rdf:type [ <Attack> ] ?
    )
}

<Authentication> CLOSED {
    (  $<Authentication_tes> (  &<IamEvent_tes> ;
          rdf:type [ <IamEvent> ] ? ;
          <account_switch_type> @linkml:String ? ;
          <account_switch_type_id> [ <https://w3id.org/lmodel/ocsf/AccountSwitchTypeIdEnum#UNKNOWN>
             <https://w3id.org/lmodel/ocsf/AccountSwitchTypeIdEnum#SUBSTITUTE_USER>
             <https://w3id.org/lmodel/ocsf/AccountSwitchTypeIdEnum#IMPERSONATE>
             <https://w3id.org/lmodel/ocsf/AccountSwitchTypeIdEnum#OTHER> ] ? ;
          <activity_id> [ <https://w3id.org/lmodel/ocsf/ActivityIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/ActivityIdEnum#OTHER>
             ] ? ;
          <auth_factors> @<AuthFactor> * ;
          <auth_protocol> @linkml:String ? ;
          <auth_protocol_id> [ <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#UNKNOWN>
             <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#NTLM> <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#KERBEROS>
             <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#DIGEST> <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#OPENID>
             <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#SAML> <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#OAUTH_2_0>
             <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#PAP> <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#CHAP>
             <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#EAP> <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#RADIUS>
             <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#BASIC_AUTHENTICATION>
             <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#LDAP> <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#OTHER> ] ? ;
          <authentication_token> @<AuthenticationToken> ? ;
          <certificate> @<Certificate> ? ;
          <dst_endpoint> @<NetworkEndpoint> ? ;
          <is_cleartext> @linkml:Boolean ? ;
          <is_mfa> @linkml:Boolean ? ;
          <is_new_logon> @linkml:Boolean ? ;
          <is_remote> @linkml:Boolean ? ;
          <logon_process> @<Process> ? ;
          <logon_type> @linkml:String ? ;
          <logon_type_id> [ <https://w3id.org/lmodel/ocsf/LogonTypeIdEnum#UNKNOWN>
             <https://w3id.org/lmodel/ocsf/LogonTypeIdEnum#SYSTEM> <https://w3id.org/lmodel/ocsf/LogonTypeIdEnum#INTERACTIVE>
             <https://w3id.org/lmodel/ocsf/LogonTypeIdEnum#NETWORK> <https://w3id.org/lmodel/ocsf/LogonTypeIdEnum#BATCH>
             <https://w3id.org/lmodel/ocsf/LogonTypeIdEnum#OS_SERVICE> <https://w3id.org/lmodel/ocsf/LogonTypeIdEnum#UNLOCK>
             <https://w3id.org/lmodel/ocsf/LogonTypeIdEnum#NETWORK_CLEARTEXT>

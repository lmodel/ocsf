             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#FILTERCOMMUNICATIONPORT>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#EVENTPAIR>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#DRIVER>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#IOCOMPLETION>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#CONTROLLER>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#SYMBOLICLINK>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#WMIGUID>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#PROCESS>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#PROFILE>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#DESKTOP>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#KEYEDEVENT>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#ADAPTER> <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#KEY>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#WAITABLEPORT>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#CALLBACK>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#SEMAPHORE>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#JOB> <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#PORT>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#FILTERCONNECTIONPORT>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#ALPC_PORT>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#SAM_ALIAS>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#SAM_GROUP>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#SAM_USER>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#SAM_DOMAIN>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#SAM_SERVER>
             <https://w3id.org/lmodel/ocsf/WinResourceTypeIdEnum#ATOM>

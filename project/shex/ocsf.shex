             <packet_uid> @linkml:Integer ? ;
             <type> @linkml:String ?
          ) ;
          rdf:type [ <Dns> ] ?
       )
    } OR @<DnsAnswer> OR @<DnsQuery>
)

<DnsActivity> CLOSED {
    (  $<DnsActivity_tes> (  &<NetworkEvent_tes> ;
          rdf:type [ <NetworkEvent> ] ? ;
          <activity_id> [ <https://w3id.org/lmodel/ocsf/ActivityIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/ActivityIdEnum#OTHER>
             ] ? ;
          <answers> @<DnsAnswer> * ;
          <connection_info> @<NetworkConnectionInfo> ? ;
          <dst_endpoint> @<NetworkEndpoint> ? ;
          <query> @<DnsQuery> ? ;
          <query_time> @<TimestampT> ? ;
          <rcode> @linkml:String ? ;
          <rcode_id> [ <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#NOERROR>
             <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#FORMERROR>
             <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#SERVERROR>
             <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#NXDOMAIN>
             <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#NOTIMP>
             <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#REFUSED>
             <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#YXDOMAIN>
             <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#YXRRSET>
             <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#NXRRSET>
             <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#NOTAUTH>
             <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#NOTZONE>
             <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#DSOTYPENI>
             <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#BADSIG_VERS>
             <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#BADKEY>
             <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#BADTIME>
             <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#BADMODE>
             <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#BADNAME>
             <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#BADALG>
             <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#BADTRUNC>
             <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#BADCOOKIE>
             <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#UNASSIGNED>
             <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#RESERVED>
             <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#OTHER> ] ? ;
          <response_time> @<TimestampT> ? ;
          <traffic> @<NetworkTraffic> ?
       ) ;
       rdf:type [ <DnsActivity> ] ?
    )
}


    {
      "name": "Ticket",
      "definition_uri": "https://w3id.org/lmodel/ocsf/Ticket",
      "annotations": [
        {
          "tag": "ocsf_constraints",
          "value": "{\"at_least_one\": [\"src_url\", \"uid\"]}",
          "@type": "Annotation"
        }
      ],
      "description": "The Ticket object represents ticket in the customer's IT Service Management\n(ITSM) systems like ServiceNow, Jira, etc.",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "aliases": [
        "Ticket"
      ],
      "is_a": "Object",
      "slots": [
        "Ticket_src_url",
        "Ticket_status",
        "Ticket_status_details",
        "Ticket_status_id",
        "Ticket_title",
        "Ticket_type",
        "Ticket_type_id",
        "Ticket_uid"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/Ticket",
      "rules": [
        {
          "postconditions": {
            "any_of": [
              {
                "slot_conditions": [
                  {
                    "name": "src_url",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "uid",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "OCSF at_least_one: at least one of ['src_url', 'uid'] must be set.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
    {
      "name": "Timespan",
      "definition_uri": "https://w3id.org/lmodel/ocsf/Timespan",
      "annotations": [
        {
          "tag": "ocsf_constraints",
          "value": "{\"at_least_one\": [\"duration\", \"duration_days\", \"duration_hours\",\n\"duration_mins\", \"duration_months\", \"duration_secs\", \"duration_weeks\",\n\"duration_years\", \"end_time\", \"start_time\"]}",
          "@type": "Annotation"
        }
      ],
      "description": "The Time Span object represents different time period durations. If a timespan\nis fractional, i.e. crosses one period, e.g. a week and 3 days, more than one\nmay be populated since each member is of integral type. In that case\n<code>type_id</code> if present should be set to <code>Other.</code><P>A\ntimespan may also be defined by its time interval boundaries,\n<code>start_time</code> and <code>end_time</code>.",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "aliases": [
        "Time Span"
      ],
      "is_a": "Object",
      "slots": [
        "Timespan_duration",
        "Timespan_duration_days",
        "Timespan_duration_hours",
        "Timespan_duration_mins",
        "Timespan_duration_months",
        "Timespan_duration_secs",

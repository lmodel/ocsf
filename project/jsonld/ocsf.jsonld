        "NetworkEvent"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "connection_info",
      "range": "NetworkConnectionInfo",
      "recommended": true,
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "NetworkEvent_cumulative_traffic",
      "definition_uri": "https://w3id.org/lmodel/ocsf/cumulative_traffic",
      "annotations": [
        {
          "tag": "group",
          "value": "context",
          "@type": "Annotation"
        }
      ],
      "description": "The cumulative (running total) network traffic aggregated from the start of a\nflow or session. Use when reporting: (1) total accumulated bytes/packets since\nflow initiation, (2) combined aggregation models where both incremental deltas\nand running totals are reported together (populate both <code>traffic</code>\nfor the delta and this attribute for the cumulative total), or (3) final\nsummary metrics when a long-lived connection closes. This represents the sum of\nall activity from flow start to the current observation, not a delta or\npoint-in-time value.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Cumulative Traffic"
      ],
      "is_a": "cumulative_traffic",
      "domain": "NetworkEvent",
      "slot_uri": "https://w3id.org/lmodel/ocsf/cumulative_traffic",
      "alias": "cumulative_traffic",
      "owner": "NetworkEvent",
      "domain_of": [
        "NetworkEvent"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "cumulative_traffic",
      "range": "NetworkTraffic",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {

      "class_uri": "https://w3id.org/lmodel/ocsf/Packet",
      "@type": "ClassDefinition"
    },
    {
      "name": "Parameter",
      "definition_uri": "https://w3id.org/lmodel/ocsf/Parameter",
      "annotations": [
        {
          "tag": "ocsf_constraints",
          "value": "{\"at_least_one\": [\"name\", \"pre_value\", \"post_value\"]}",
          "@type": "Annotation"
        }
      ],
      "description": "The Parameter object provides details regarding a parameter of a a function.",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "aliases": [
        "Parameter"
      ],
      "is_a": "Object",
      "slots": [
        "Parameter_name",
        "Parameter_post_value",
        "Parameter_pre_value"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/Parameter",
      "rules": [
        {
          "postconditions": {
            "any_of": [
              {
                "slot_conditions": [
                  {
                    "name": "name",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "pre_value",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "post_value",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "OCSF at_least_one: at least one of ['name', 'pre_value', 'post_value'] must be\nset.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
    {
      "name": "PermissionAnalysisResult",
      "definition_uri": "https://w3id.org/lmodel/ocsf/PermissionAnalysisResult",
      "description": "The Permission Analysis object describes analysis results of permissions,\npolicies directly associated with an identity (user, role, or service account).\nThis evaluates what permissions an identity has been granted through attached\npolicies, which privileges are actively used versus unused, and identifies\npotential over-privileged access. Use this for identity-centric security\nassessments such as privilege audits, dormant permission discovery, and\nleast-privilege compliance analysis.",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "aliases": [
        "Permission Analysis Result"
      ],
      "is_a": "Object",
      "slots": [
        "PermissionAnalysisResult_analyzed_privileges_count",
        "PermissionAnalysisResult_condition_keys",
        "PermissionAnalysisResult_granted_privileges",
        "PermissionAnalysisResult_policy",
        "PermissionAnalysisResult_service_privilege_analysis_list",
        "PermissionAnalysisResult_total_potential_attacks_count",
        "PermissionAnalysisResult_unused_privileges_count",
        "PermissionAnalysisResult_unused_services_count"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/PermissionAnalysisResult",
      "@type": "ClassDefinition"
    },
    {
      "name": "PortInfo",
      "definition_uri": "https://w3id.org/lmodel/ocsf/PortInfo",
      "description": "The Port Information object describes a port and its associated protocol\ndetails.",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "aliases": [
        "Port Information"

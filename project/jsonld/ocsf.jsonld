      "range": "integer",
      "@type": "SlotDefinition"
    },
    {
      "name": "PermissionAnalysisResult_unused_services_count",
      "definition_uri": "https://w3id.org/lmodel/ocsf/unused_services_count",
      "description": "The total count of cloud services or resource types referenced in the policy\nthat have not been accessed or utilized within the analysis timeframe. This\nhelps identify unused service permissions that could be removed to reduce\nattack surface. Examples: AWS services like S3, SQS, IAM, Lambda; Azure\nservices like Storage, Compute, KeyVault; or GCP services like Cloud Storage,\nCompute Engine, BigQuery.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",

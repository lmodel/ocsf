    {
      "name": "Assessment",
      "definition_uri": "https://w3id.org/lmodel/ocsf/Assessment",
      "description": "The Assessment object describes a point-in-time assessment, check, or\nevaluation of a specific configuration or signal against an asset, entity,\nperson, or otherwise. For example, this can encapsulate <code>os_signals</code>\nfrom CrowdStrike Falcon Zero Trust Assessments, or account for\n<code>Datastore</code> configurations from Cyera, or capture details of\nMicrosoft Intune configuration policies.",
      "in_subset": [

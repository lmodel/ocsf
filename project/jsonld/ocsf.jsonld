    {
      "name": "token",
      "definition_uri": "https://w3id.org/lmodel/ocsf/token",
      "description": "The Token object is the base object for representing tokens, API keys, and\nauthentication credentials. This object provides common attributes for all\ntoken types and can be used directly in API activity events to represent API\ntokens (type_id: 7) or client tokens (type_id: 6) such as Okta API tokens or\nMicrosoft Entra ID Application Registration client secrets. The base\n<code>token</code> object is also extended by <code>authentication_token</code>\nfor protocol-specific authentication tokens in authentication events. Note: Use\n<code>authentication_token</code> (which extends <code>token</code>) for\nprotocol-specific authentication tokens (Kerberos, OIDC, SAML) in\nauthentication events, and <code>programmatic_credential</code> for tracking\ncredential lifecycle and usage patterns.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Token"
      ],
      "slot_uri": "https://w3id.org/lmodel/ocsf/token",
      "owner": "Api",
      "domain_of": [
        "Api"

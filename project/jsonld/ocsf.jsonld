            {
              "tag": "ocsf_uid",
              "value": "1"
            },
            {
              "tag": "caption",
              "value": "Valid"
            }
          ]
        },
        {
          "text": "EXPIRED",
          "description": "The digital signature is invalid because its timestamp does not fall within the\ncertificate's validity period.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "2"
            },
            {
              "tag": "caption",
              "value": "Expired"
            }
          ]
        },
        {
          "text": "REVOKED",
          "description": "The digital signature is invalid due to certificate revocation.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "3"
            },
            {
              "tag": "caption",
              "value": "Revoked"
            }
          ]
        },
        {
          "text": "SUSPENDED",
          "description": "The digital signature is invalid due to certificate suspension.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "4"
            },
            {
              "tag": "caption",
              "value": "Suspended"
            }
          ]
        },
        {
          "text": "PENDING",
          "description": "The digital signature state is pending.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "5"
            },
            {
              "tag": "caption",
              "value": "Pending"
            }
          ]
        },
        {
          "text": "UNTRUSTED",
          "description": "The digital signature is invalid because the certificate is rooted in an\nuntrusted CA or is an untrusted self-signed certificate.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "6"
            },
            {
              "tag": "caption",
              "value": "Untrusted"
            }
          ]
        },
        {
          "text": "DISTRUSTED",
          "description": "The digital signature is invalid because the certificate is explicitly\ndistrusted. Note that whereas revocation is global, distrust reflects local\nIT/security policy.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "7"
            },
            {
              "tag": "caption",
              "value": "Distrusted"
            }
          ]
        },
        {
          "text": "WRONGUSAGE",
          "description": "The digital signature is invalid because the certificate is not intended for\ncode signing purposes.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "8"
            },
            {
              "tag": "caption",
              "value": "WrongUsage"
            }
          ]
        },
        {

    {
      "name": "DetectionSystemIdEnum",
      "definition_uri": "https://w3id.org/lmodel/ocsf/DetectionSystemIdEnum",
      "description": "The type of data security tool or system that the finding, detection, or alert\noriginated from.",
      "from_schema": "https://w3id.org/lmodel/ocsf/enums",
      "permissible_values": [
        {
          "text": "UNKNOWN",
          "description": "The type is not mapped. See the <code>detection_system</code> attribute, which\ncontains a data source specific value.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "0"
            },
            {
              "tag": "caption",
              "value": "Unknown"
            }
          ]
        },
        {
          "text": "ENDPOINT",
          "description": "A dedicated agent or sensor installed on a device, either a dedicated data\nsecurity tool or an Endpoint Detection & Response (EDR) tool that can detect\nsensitive data and/or enforce data security policies. E.g., Forcepoint DLP,\nSymantec DLP, Microsoft Defender for Endpoint (MDE).",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "1"
            },
            {
              "tag": "caption",
              "value": "Endpoint"
            }
          ]
        },
        {
          "text": "DLP_GATEWAY",
          "description": "A Data Loss Prevention (DLP) gateway that is positioned in-line of an\ninformation store such as a network share, a database, or otherwise that can\ndetect sensitive data and/or enforce data security policies.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "2"
            },
            {
              "tag": "caption",
              "value": "DLP Gateway"
            }
          ]
        },
        {
          "text": "MOBILE_DEVICE_MANAGEMENT",
          "description": "A Mobile Device Management (MDM) or Enterprise Mobility Management (EMM) tool\nthat can detect sensitive data and/or enforce data security policies on mobile\ndevices (e.g., cellphones, tablets, End User Devices [EUDs]).",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "3"
            },
            {
              "tag": "caption",
              "value": "Mobile Device Management"
            }
          ]
        },
        {
          "text": "DATA_DISCOVERY_CLASSIFICATION",
          "description": "A tool that actively identifies and classifies sensitive data in digital media\nand information stores in accordance with a policy or automated functionality.\nE.g, Amazon Macie, Microsoft Purview.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "4"
            },
            {
              "tag": "caption",
              "value": "Data Discovery & Classification"
            }
          ]
        },
        {
          "text": "SECURE_WEB_GATEWAY",
          "description": "A Secure Web Gateway (SWG) is any tool that can detect sensitive data and/or\nenforce data security policies at a network-edge such as within a proxy or\nfirewall service.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "5"
            },
            {
              "tag": "caption",
              "value": "Secure Web Gateway"
            }
          ]
        },
        {
          "text": "SECURE_EMAIL_GATEWAY",
          "description": "A Secure Email Gateway (SEG) is any tool that can detect sensitive data and/or\nenforce data security policies within email systems. E.g., Microsoft Defender\nfor Office, Google Workspaces.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "6"
            },
            {
              "tag": "caption",
              "value": "Secure Email Gateway"
            }
          ]
        },
        {
          "text": "DIGITAL_RIGHTS_MANAGEMENT",
          "description": "A Digital Rights Management (DRM) or a dedicated Information Rights Management\n(IRM) are tools which can detect sensitive data and/or enforce data security\npolicies on digital media via policy or user access rights.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "7"
            },
            {
              "tag": "caption",
              "value": "Digital Rights Management"
            }
          ]
        },
        {
          "text": "CLOUD_ACCESS_SECURITY_BROKER",
          "description": "A Cloud Access Security Broker (CASB) that can detect sensitive data and/or\nenforce data security policies in-line to cloud systems such as the public\ncloud or Software-as-a-Service (SaaS) tool. E.g., Forcepoint CASB, SkyHigh\nSecurity.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "8"
            },
            {
              "tag": "caption",
              "value": "Cloud Access Security Broker"
            }
          ]
        },
        {
          "text": "DATABASE_ACTIVITY_MONITORING",
          "description": "A Database Activity Monitoring (DAM) tool that can detect sensitive data and/or\nenforce data security policies as part of a dedicated database or warehouse\nmonitoring solution.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "9"
            },
            {
              "tag": "caption",
              "value": "Database Activity Monitoring"
            }
          ]
        },
        {
          "text": "APPLICATION_LEVEL_DLP",
          "description": "A built in Data Loss Prevention (DLP) or other data security capability within\na tool or platform such as an Enterprise Resource Planning (ERP) or Customer\nRelations Management (CRM) tool that can detect sensitive data and/or enforce\ndata security policies.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "10"
            },
            {
              "tag": "caption",
              "value": "Application-Level DLP"
            }
          ]
        },
        {
          "text": "DEVELOPER_SECURITY",
          "description": "Any Developer Security tool such as an Infrastructure-as-Code (IAC) security\nscanner, Secrets Detection, or Secure Software Development Lifecycle (SSDLC)\ntool that can detect sensitive data and/or enforce data security policies.\nE.g., TruffleHog, GitGuardian, Git-Secrets.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "11"
            },
            {
              "tag": "caption",
              "value": "Developer Security"
            }
          ]
        },
        {
          "text": "DATA_SECURITY_POSTURE_MANAGEMENT",
          "description": "A Data Security Posture Management (DSPM) tool is a continuous monitoring and\ndata discovery solution that can detect sensitive data and/or enforce data\nsecurity policies for local and cloud environments. E.g., Cyera, Sentra, IBM\nPolar Security.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "12"
            },
            {
              "tag": "caption",
              "value": "Data Security Posture Management"
            }
          ]
        },
        {
          "text": "OTHER",
          "description": "Any other type of detection system or a multi-variate system made up of several\nother systems.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "99"
            },
            {
              "tag": "caption",
              "value": "Other"
            }
          ]
        }
      ]
    },
    {
      "name": "DirectionIdEnum",
      "definition_uri": "https://w3id.org/lmodel/ocsf/DirectionIdEnum",
      "description": "The normalized identifier of the direction of the initiated connection,\ntraffic, or email.",
      "from_schema": "https://w3id.org/lmodel/ocsf/enums",
      "permissible_values": [
        {
          "text": "UNKNOWN",
          "description": "The connection direction is unknown.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "0"
            },
            {
              "tag": "caption",
              "value": "Unknown"
            }
          ]
        },
        {
          "text": "INBOUND",
          "description": "Inbound network connection. The connection originated from the Internet or\noutside network, destined for services on the inside network.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "1"
            },
            {
              "tag": "caption",
              "value": "Inbound"
            }
          ]
        },
        {
          "text": "OUTBOUND",
          "description": "Outbound network connection. The connection originated from inside the network,\ndestined for services on the Internet or outside network.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "2"
            },
            {
              "tag": "caption",
              "value": "Outbound"
            }
          ]
        },
        {
          "text": "LATERAL",
          "description": "Lateral network connection. The connection originated from inside the network,\ndestined for services on the inside network.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "3"
            },
            {
              "tag": "caption",
              "value": "Lateral"
            }
          ]
        },
        {
          "text": "LOCAL",
          "description": "Local network connection (<code>localhost</code>). The connection is\nintra-device, originating from and destined for services running on the same\ndevice.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "4"
            },
            {
              "tag": "caption",
              "value": "Local"
            }
          ]
        },
        {
          "text": "OTHER",
          "description": "The direction is not mapped. See the <code>direction</code> attribute, which\ncontains a data source specific value.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "99"
            },
            {
              "tag": "caption",
              "value": "Other"
            }
          ]
        }
      ]
    },
    {
      "name": "DispositionIdEnum",
      "definition_uri": "https://w3id.org/lmodel/ocsf/DispositionIdEnum",
      "description": "Describes the outcome or action taken by a security control, such as access\ncontrol checks, malware detections or various types of policy violations.",
      "from_schema": "https://w3id.org/lmodel/ocsf/enums",
      "permissible_values": [
        {
          "text": "UNKNOWN",
          "description": "The disposition is unknown.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "0"
            },
            {
              "tag": "caption",
              "value": "Unknown"
            }
          ]
        },
        {
          "text": "ALLOWED",
          "description": "Granted access or allowed the action to the protected resource.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "1"
            },
            {
              "tag": "caption",
              "value": "Allowed"
            }
          ]
        },
        {
          "text": "BLOCKED",
          "description": "Denied access or blocked the action to the protected resource.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "2"
            },
            {
              "tag": "caption",
              "value": "Blocked"
            }
          ]
        },
        {
          "text": "QUARANTINED",
          "description": "A suspicious file or other content was moved to a benign location.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "3"
            },
            {
              "tag": "caption",
              "value": "Quarantined"
            }
          ]
        },
        {
          "text": "ISOLATED",
          "description": "A session was isolated on the network or within a browser.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "4"
            },
            {
              "tag": "caption",
              "value": "Isolated"
            }
          ]
        },
        {
          "text": "DELETED",
          "description": "A file or other content was deleted.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "5"
            },
            {
              "tag": "caption",
              "value": "Deleted"
            }
          ]
        },
        {
          "text": "DROPPED",
          "description": "The request was detected as a threat and resulted in the connection being\ndropped.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "6"
            },
            {
              "tag": "caption",
              "value": "Dropped"
            }
          ]
        },
        {
          "text": "CUSTOM_ACTION",
          "description": "A custom action was executed such as running of a command script. Use the\n<code>message</code> attribute of the base class for details.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "7"
            },
            {
              "tag": "caption",
              "value": "Custom Action"
            }
          ]
        },
        {
          "text": "APPROVED",
          "description": "A request or submission was approved. For example, when a form was properly\nfilled out and submitted. This is distinct from <code>1</code> 'Allowed'.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "8"
            },
            {
              "tag": "caption",
              "value": "Approved"
            }
          ]
        },
        {
          "text": "RESTORED",
          "description": "A quarantined file or other content was restored to its original location.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "9"
            },
            {
              "tag": "caption",
              "value": "Restored"
            }
          ]
        },
        {
          "text": "EXONERATED",
          "description": "A suspicious or risky entity was deemed to no longer be suspicious (re-scored).",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "10"
            },
            {
              "tag": "caption",
              "value": "Exonerated"
            }
          ]
        },
        {
          "text": "CORRECTED",
          "description": "A corrupt file or configuration was corrected.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "11"
            },
            {
              "tag": "caption",
              "value": "Corrected"
            }
          ]
        },
        {
          "text": "PARTIALLY_CORRECTED",
          "description": "A corrupt file or configuration was partially corrected.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "12"
            },
            {
              "tag": "caption",
              "value": "Partially Corrected"
            }
          ]
        },
        {
          "text": "UNCORRECTED",
          "description": "A corrupt file or configuration was not corrected.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "13"
            },
            {
              "tag": "caption",
              "value": "Uncorrected"
            }
          ]
        },
        {
          "text": "DELAYED",
          "description": "An operation was delayed, for example if a restart was required to finish the\noperation.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "14"
            },
            {
              "tag": "caption",
              "value": "Delayed"
            }
          ]
        },
        {
          "text": "DETECTED",
          "description": "Suspicious activity or a policy violation was detected without further action.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "15"
            },
            {
              "tag": "caption",
              "value": "Detected"
            }
          ]
        },
        {
          "text": "NO_ACTION",
          "description": "The outcome of an operation had no action taken.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "16"
            },
            {
              "tag": "caption",
              "value": "No Action"
            }
          ]
        },
        {
          "text": "LOGGED",
          "description": "The operation or action was logged without further action.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "17"
            },
            {
              "tag": "caption",
              "value": "Logged"
            }
          ]
        },
        {
          "text": "TAGGED",
          "description": "A file or other entity was marked with extended attributes.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "18"
            },
            {
              "tag": "caption",
              "value": "Tagged"
            }
          ]
        },
        {
          "text": "ALERT",
          "description": "The request or activity was detected as a threat and resulted in a notification\nbut request was not blocked.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "19"
            },
            {
              "tag": "caption",
              "value": "Alert"
            }
          ]
        },
        {
          "text": "COUNT",
          "description": "Counted the request or activity but did not determine whether to allow it or\nblock it.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "20"
            },
            {
              "tag": "caption",
              "value": "Count"
            }
          ]
        },
        {
          "text": "RESET",
          "description": "The request was detected as a threat and resulted in the connection being\nreset.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "21"
            },
            {
              "tag": "caption",
              "value": "Reset"
            }
          ]
        },
        {
          "text": "CAPTCHA",
          "description": "Required the end user to solve a CAPTCHA puzzle to prove that a human being is\nsending the request.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "22"
            },
            {
              "tag": "caption",
              "value": "Captcha"
            }
          ]
        },
        {
          "text": "CHALLENGE",
          "description": "Ran a silent challenge that required the client session to verify that it's a\nbrowser, and not a bot.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "23"
            },
            {
              "tag": "caption",
              "value": "Challenge"
            }
          ]
        },
        {
          "text": "ACCESS_REVOKED",
          "description": "The requestor's access has been revoked due to security policy enforcements.\nNote: use the <code>Host</code> profile if the <code>User</code> or\n<code>Actor</code> requestor is not present in the event class.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "24"
            },
            {
              "tag": "caption",
              "value": "Access Revoked"
            }
          ]
        },
        {
          "text": "REJECTED",
          "description": "A request or submission was rejected.  For example, when a form was improperly\nfilled out and submitted. This is distinct from <code>2</code> 'Blocked'.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "25"
            },
            {
              "tag": "caption",
              "value": "Rejected"
            }
          ]
        },
        {
          "text": "UNAUTHORIZED",
          "description": "An attempt to access a resource was denied due to an authorization check that\nfailed. This is a more specific disposition than <code>2</code> 'Blocked' and\ncan be complemented with the <code>authorizations</code> attribute for more\ndetail.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "26"
            },
            {
              "tag": "caption",
              "value": "Unauthorized"
            }
          ]
        },
        {
          "text": "ERROR",
          "description": "An error occurred during the processing of the activity or request. Use the\n<code>message</code> attribute of the base class for details.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "27"
            },
            {
              "tag": "caption",
              "value": "Error"
            }
          ]
        },
        {
          "text": "OTHER",
          "description": "The disposition is not mapped. See the <code>disposition</code> attribute,\nwhich contains a data source specific value.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "99"
            },
            {
              "tag": "caption",
              "value": "Other"
            }
          ]
        }
      ]
    },

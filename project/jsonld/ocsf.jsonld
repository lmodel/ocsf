        "BaseEvent_raw_data",
        "BaseEvent_raw_data_hash",
        "BaseEvent_raw_data_size",
        "BaseEvent_severity",
        "BaseEvent_severity_id",
        "BaseEvent_start_time",
        "BaseEvent_status",
        "BaseEvent_status_code",
        "BaseEvent_status_detail",
        "BaseEvent_status_id",
        "BaseEvent_time",
        "BaseEvent_timezone_offset",
        "BaseEvent_type_name",
        "BaseEvent_type_uid",
        "BaseEvent_unmapped",
        "CloudProfile_api",
        "actor",
        "HostProfile_device",
        "OsintProfile_osint",
        "SecurityControlProfile_action",
        "SecurityControlProfile_action_id",
        "attacks",
        "authorizations",
        "SecurityControlProfile_confidence",
        "SecurityControlProfile_confidence_id",
        "SecurityControlProfile_confidence_score",
        "disposition",
        "SecurityControlProfile_disposition_id",
        "SecurityControlProfile_firewall_rule",
        "SecurityControlProfile_is_alert",
        "malware",
        "malware_scan_info",
        "SecurityControlProfile_policy",
        "SecurityControlProfile_risk_details",
        "SecurityControlProfile_risk_level",
        "SecurityControlProfile_risk_level_id",
        "SecurityControlProfile_risk_score",
        "DiscoveryEvent_activity_id",
        "cloud",
        "CloudResourcesInventoryInfo_container",
        "CloudResourcesInventoryInfo_database",
        "CloudResourcesInventoryInfo_databucket",
        "CloudResourcesInventoryInfo_idp",
        "CloudResourcesInventoryInfo_region",
        "CloudResourcesInventoryInfo_resources",
        "CloudResourcesInventoryInfo_table",
        "CloudResourcesInventoryInfo_cloud"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/CloudResourcesInventoryInfo",
      "rules": [
        {
          "postconditions": {
            "any_of": [
              {
                "slot_conditions": [
                  {
                    "name": "cloud",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "container",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "database",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "databucket",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "idp",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "resources",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "table",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "OCSF at_least_one: at least one of ['cloud', 'container', 'database',\n'databucket', 'idp', 'resources', 'table'] must be set.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },

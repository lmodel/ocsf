      "usage_slot_name": "dst_endpoint",
      "range": "NetworkEndpoint",
      "recommended": true,
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "NetworkActivity_initiator",
      "definition_uri": "https://w3id.org/lmodel/ocsf/initiator",
      "description": "The endpoint that initiated the network communication, normalized to the\ncaption of <code>initiator_id</code>. In the case of <code>Other</code>, it is\ndefined by the event source.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Initiator"
      ],
      "is_a": "initiator",
      "domain": "NetworkActivity",
      "slot_uri": "https://w3id.org/lmodel/ocsf/initiator",
      "alias": "initiator",
      "owner": "NetworkActivity",
      "domain_of": [
        "NetworkActivity"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "initiator",
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "NetworkActivity_initiator_id",
      "definition_uri": "https://w3id.org/lmodel/ocsf/initiator_id",
      "annotations": [
        {
          "tag": "group",
          "value": "primary",
          "@type": "Annotation"
        }
      ],
      "description": "The normalized identifier of the endpoint that initiated the network\ncommunication. Use this field to disambiguate source and destination roles in\nbi-directional or asymmetric flow scenarios.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Initiator ID"
      ],
      "is_a": "initiator_id",
      "domain": "NetworkActivity",
      "slot_uri": "https://w3id.org/lmodel/ocsf/initiator_id",
      "alias": "initiator_id",
      "owner": "NetworkActivity",
      "domain_of": [
        "NetworkActivity"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "initiator_id",
      "range": "NetworkActivityInitiatorIdEnum",
      "recommended": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "NetworkActivity_is_src_dst_assignment_known",
      "definition_uri": "https://w3id.org/lmodel/ocsf/is_src_dst_assignment_known",
      "annotations": [
        {
          "tag": "group",
          "value": "primary",
          "@type": "Annotation"
        }
      ],
      "description": "<code>true</code> denotes that <code>src_endpoint</code> and\n<code>dst_endpoint</code> correctly identify the initiator and responder\nrespectively. <code>false</code> denotes that the event source has arbitrarily\nassigned one peer to <code>src_endpoint</code> and the other to\n<code>dst_endpoint</code>, in other words that initiator and responder are not\nbeing asserted. This can occur, for example, when the event source is a network\nappliance that has not observed the initiation of a given connection. In the\nabsence of this attribute, interpretation of the initiator and responder is\nimplementation-specific.",
      "deprecated": "Use <code>initiator_id</code> instead, which provides richer semantics for\nbi-flow and asymmetric flow scenarios.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Source/Destination Assignment Known"
      ],
      "is_a": "is_src_dst_assignment_known",
      "domain": "NetworkActivity",
      "slot_uri": "https://w3id.org/lmodel/ocsf/is_src_dst_assignment_known",
      "alias": "is_src_dst_assignment_known",
      "owner": "NetworkActivity",
      "domain_of": [
        "NetworkActivity"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "is_src_dst_assignment_known",
      "range": "boolean",
      "recommended": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "NetworkActivity_src_endpoint",
      "definition_uri": "https://w3id.org/lmodel/ocsf/src_endpoint",
      "description": "The source endpoint of the network activity \u2014 typically the initiator. In\nbi-flow or asymmetric flow scenarios, this endpoint may represent the response\nside of communication originally initiated by the destination. Use\n<code>initiator_id</code> to determine which endpoint actually initiated the\ncommunication.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Source Endpoint"
      ],
      "is_a": "NetworkEvent_src_endpoint",

          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "2"
            },
            {
              "tag": "caption",
              "value": "Non Standard"
            }
          ]
        },
        {
          "text": "SHELLCODE",
          "description": "A raw module in process memory that is READWRITE_EXECUTE and had a thread\nstarted in its range.",

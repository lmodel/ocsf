    {
      "name": "CloudResourcesInventoryInfo",
      "definition_uri": "https://w3id.org/lmodel/ocsf/CloudResourcesInventoryInfo",
      "annotations": [
        {
          "tag": "ocsf_constraints",
          "value": "{\"at_least_one\": [\"cloud\", \"container\", \"database\", \"databucket\", \"idp\",\n\"resources\", \"table\"]}",
          "@type": "Annotation"
        },
        {
          "tag": "ocsf_event_uid",
          "value": 23,
          "@type": "Annotation"
        }
      ],
      "description": "Cloud Resources Inventory Info events report cloud asset inventory data. This\ndata can be either logged or proactively collected. For example, use this event\nclass when creating an inventory of cloud resource information from a\nConfiguration Management Database (CMDB), Cyber Asset Attack Surface Management\n(CAASM), direct public cloud service provider APIs, Software-as-a-Service\n(SaaS) APIs, or otherwise.",
      "in_subset": [
        "discovery_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/events",
      "aliases": [
        "Cloud Resources Inventory Info"
      ],
      "is_a": "DiscoveryEvent",
      "slots": [
        "BaseEvent_activity_name",

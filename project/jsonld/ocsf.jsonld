      "description": "The analysis target defines the scope of monitored activities, specifying what\nentity, system or process is analyzed for activity patterns.",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",

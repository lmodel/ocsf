        "AccessAnalysisResult_condition_keys",
        "AccessAnalysisResult_granted_privileges"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/AccessAnalysisResult",
      "@type": "ClassDefinition"
    },
    {
      "name": "Account",
      "definition_uri": "https://w3id.org/lmodel/ocsf/Account",
      "description": "The Account object contains details about the account that initiated or\nperformed a specific activity within a system or application. Additionally, the\nAccount object refers to logical Cloud and Software-as-a-Service (SaaS) based\ncontainers such as AWS Accounts, Azure Subscriptions, Oracle Cloud\nCompartments, Google Cloud Projects, and otherwise.",
      "notes": [
        "D3FEND\u2122 Ontology d3f:UserAccount. \u2014\nhttps://d3fend.mitre.org/dao/artifact/d3f:UserAccount/",
        "D3FEND\u2122 Ontology d3f:CloudUserAccount. \u2014\nhttps://d3fend.mitre.org/dao/artifact/d3f:CloudUserAccount/"
      ],
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "see_also": [
        "https://d3fend.mitre.org/dao/artifact/d3f:UserAccount/",
        "https://d3fend.mitre.org/dao/artifact/d3f:CloudUserAccount/"
      ],
      "aliases": [
        "Account"
      ],
      "close_mappings": [
        "stix:UserAccount",
        "uco_master:Account"
      ],
      "is_a": "Entity",
      "slots": [

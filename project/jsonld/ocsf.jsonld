        "Account_name",
        "Account_uid"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/Account",
      "@type": "ClassDefinition"
    },
    {
      "name": "Actor",
      "definition_uri": "https://w3id.org/lmodel/ocsf/Actor",
      "annotations": [
        {
          "tag": "ocsf_constraints",
          "value": "{\"at_least_one\": [\"process\", \"user\", \"invoked_by\", \"session\", \"app_name\",\n\"app_uid\"]}",
          "@type": "Annotation"
        }
      ],
      "description": "The Actor object contains details about the user, role, application, service,\nor process that initiated or performed a specific activity. Note that Actor is\nnot the threat actor of a campaign but may be part of a campaign.",
      "notes": [
        "D3FEND\u2122 Ontology d3f:Agent. \u2014 https://next.d3fend.mitre.org/agent/d3f:Agent/"
      ],
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "see_also": [
        "https://next.d3fend.mitre.org/agent/d3f:Agent/"
      ],
      "aliases": [

    {
      "name": "Policy",
      "definition_uri": "https://w3id.org/lmodel/ocsf/Policy",
      "annotations": [
        {
          "tag": "ocsf_constraints",
          "value": "{\"at_least_one\": [\"name\", \"type\", \"uid\"]}",
          "@type": "Annotation"
        }
      ],
      "description": "The Policy object describes the policies that are applicable. <p>Policy\nattributes provide traceability to the operational state of the security\nproduct at the time that the event was captured, facilitating forensics,\ntroubleshooting, and policy tuning/adjustments.</p>",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",

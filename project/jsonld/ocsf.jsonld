      "@type": "ClassDefinition"
    },
    {
      "name": "SecurityControlProfile",
      "definition_uri": "https://w3id.org/lmodel/ocsf/SecurityControlProfile",
      "annotations": [
        {
          "tag": "ocsf_profile",
          "value": "security_control",
          "@type": "Annotation"
        },
        {
          "tag": "group",
          "value": "primary",
          "@type": "Annotation"
        }
      ],
      "description": "The attributes including disposition that represent the outcome of a security\ncontrol including but not limited to access control, malware or policy\nviolation, network proxy, intrusion detection, firewall, or data control.  The\nprofile is intended to augment activities or findings with an outcome when a\nsecurity control has observed or intervened. If the control detected a security\nviolation, and the <code>disposition_id</code> or <code>action_id</code> is an\nalertable outcome or action, the <code>is_alert</code> flag may be set to\n<code>true</code>.",
      "in_subset": [
        "security_control_profile_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/profiles",
      "aliases": [
        "Security Control"
      ],
      "mixin": true,
      "slots": [
        "SecurityControlProfile_action",
        "SecurityControlProfile_action_id",
        "attacks",
        "authorizations",
        "SecurityControlProfile_confidence",
        "SecurityControlProfile_confidence_id",
        "SecurityControlProfile_confidence_score",
        "disposition",
        "SecurityControlProfile_disposition_id",
        "SecurityControlProfile_firewall_rule",
        "SecurityControlProfile_is_alert",
        "malware",
        "malware_scan_info",
        "SecurityControlProfile_policy",
        "SecurityControlProfile_risk_details",
        "SecurityControlProfile_risk_level",
        "SecurityControlProfile_risk_level_id",
        "SecurityControlProfile_risk_score"

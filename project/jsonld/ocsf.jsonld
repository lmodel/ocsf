    {
      "name": "TunnelActivity",
      "definition_uri": "https://w3id.org/lmodel/ocsf/TunnelActivity",
      "annotations": [
        {
          "tag": "ocsf_constraints",
          "value": "{\"at_least_one\": [\"connection_info\", \"session\", \"src_endpoint\", \"traffic\",\n\"tunnel_interface\", \"tunnel_type_id\"]}",
          "@type": "Annotation"
        },
        {
          "tag": "ocsf_event_uid",
          "value": 14,
          "@type": "Annotation"
        },
        {
          "tag": "associations",
          "value": "{\"src_endpoint\": [\"user\"], \"user\": [\"src_endpoint\"]}",
          "@type": "Annotation"
        }
      ],
      "description": "Tunnel Activity events report secure tunnel establishment (such as VPN),\nteardowns, renewals, and other network tunnel specific actions.",
      "notes": [
        "D3FEND\u2122 Ontology d3f:TunnelEvent \u2014\nhttps://d3fend.mitre.org/event/d3f:TunnelEvent/"
      ],

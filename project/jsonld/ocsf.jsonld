    {
      "name": "Entity",
      "definition_uri": "https://w3id.org/lmodel/ocsf/Entity",
      "annotations": [
        {
          "tag": "ocsf_constraints",
          "value": "{\"at_least_one\": [\"name\", \"uid\"]}",
          "@type": "Annotation"
        }
      ],
      "description": "The Entity object is an unordered collection of attributes, with a name and\nunique identifier. It serves as a base object that defines a set of attributes\nand default constraints available in all objects that extend it.",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "aliases": [
        "Entity"
      ],
      "is_a": "Object",
      "slots": [

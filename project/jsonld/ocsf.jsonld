              "tag": "ocsf_uid",
              "value": "0"
            },
            {
              "tag": "caption",
              "value": "Unknown"
            }
          ]
        },
        {
          "text": "INFORMATIONAL",
          "description": "Informational message. No action required.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "1"
            },
            {
              "tag": "caption",
              "value": "Informational"
            }
          ]
        },
        {
          "text": "LOW",
          "description": "The user decides if action is needed.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "2"
            },
            {
              "tag": "caption",
              "value": "Low"
            }
          ]
        },
        {
          "text": "MEDIUM",
          "description": "Action is required but the situation is not serious at this time.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "3"
            },
            {
              "tag": "caption",
              "value": "Medium"
            }
          ]
        },
        {
          "text": "HIGH",
          "description": "Action is required immediately.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "4"
            },
            {
              "tag": "caption",
              "value": "High"
            }
          ]
        },
        {
          "text": "CRITICAL",
          "description": "Action is required immediately and the scope is broad.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "5"
            },
            {
              "tag": "caption",
              "value": "Critical"
            }
          ]
        },
        {
          "text": "FATAL",
          "description": "An error occurred but it is too late to take remedial action.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "6"
            },
            {
              "tag": "caption",
              "value": "Fatal"
            }
          ]

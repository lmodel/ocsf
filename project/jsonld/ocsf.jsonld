    {
      "name": "ancestry",
      "definition_uri": "https://w3id.org/lmodel/ocsf/ancestry",
      "description": "An array of Process Entities describing the extended parentage of this process\nobject. Direct parent information should be expressed through the\n<code>parent_process</code> attribute. The first array element is the direct\nparent of this process object. Subsequent list elements go up the process\nparentage hierarchy. That is, the array is sorted from newest to oldest\nprocess. It is recommended to only populate this field for the top-level\nprocess object.",
      "notes": [
        "Guidance on Representing Process Parentage \u2014\nhttps://github.com/ocsf/ocsf-docs/blob/main/articles/representing-process-parentage.md"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",

        "Scim_is_group_provisioning_enabled",
        "Scim_is_user_provisioning_enabled",
        "Scim_last_run_time",
        "Scim_modified_time",
        "Scim_name",
        "Scim_protocol_name",
        "Scim_rate_limit",
        "Scim_scim_group_schema",
        "Scim_scim_user_schema",
        "Scim_state",
        "Scim_state_id",
        "Scim_uid",
        "Scim_uid_alt",
        "Scim_url_string",
        "Scim_vendor_name",
        "Scim_version"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/Scim",
      "@type": "ClassDefinition"
    },
    {
      "name": "Script",
      "definition_uri": "https://w3id.org/lmodel/ocsf/Script",
      "description": "The Script object describes a script or command that can be executed by a\nshell, script engine, or interpreter. Examples include Bash, JavsScript,\nPowerShell, Python, VBScript, etc. Note that the term <em>script</em> here\ndenotes not only a script contained within a file but also a script or command\ntyped interactively by a user, supplied on the command line, or provided by\nsome other file-less mechanism.",
      "notes": [
        "D3FEND\u2122 Ontology d3f:ExecutableScript. \u2014\nhttps://d3fend.mitre.org/dao/artifact/d3f:ExecutableScript/"
      ],
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "see_also": [

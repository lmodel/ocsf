        {
          "text": "SWID",
          "description": "The International Organization for Standardization (ISO) and the International\nElectrotechnical Commission (IEC) publishes, ISO/IEC 19770-2, a standard for\nsoftware identification (SWID) tags that defines a structured metadata format\nfor describing a software product. A SWID tag document is composed of a\nstructured set of data elements that identify the software product",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "3"
            },
            {
              "tag": "caption",
              "value": "SWID"
            }
          ]
        },

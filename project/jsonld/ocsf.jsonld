            {
              "tag": "ocsf_uid",
              "value": "8"
            },
            {
              "tag": "caption",
              "value": "Network Cleartext"
            }
          ]
        },
        {
          "text": "NEW_CREDENTIALS",
          "description": "A caller cloned its current token and specified new credentials for outbound\nconnections. The new logon session has the same local identity, but uses\ndifferent credentials for other network connections.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "9"
            },
            {
              "tag": "caption",
              "value": "New Credentials"
            }
          ]
        },
        {
          "text": "REMOTE_INTERACTIVE",
          "description": "A remote logon using Terminal Services or remote desktop application.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "10"
            },
            {
              "tag": "caption",
              "value": "Remote Interactive"

    {
      "name": "AnalysisTarget_name",
      "definition_uri": "https://w3id.org/lmodel/ocsf/name",
      "description": "The specific name or identifier of the analysis target, such as the username of\na User Account, the name of a Kubernetes Cluster, the identifier of a Network\nNamespace, or the name of an Application Component.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Name"
      ],
      "is_a": "name",
      "domain": "AnalysisTarget",
      "slot_uri": "https://w3id.org/lmodel/ocsf/name",
      "alias": "name",
      "owner": "AnalysisTarget",
      "domain_of": [
        "AnalysisTarget"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "name",
      "range": "string",
      "required": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "AnalysisTarget_type",
      "definition_uri": "https://w3id.org/lmodel/ocsf/type",
      "description": "The category of the analysis target, such as User Account, Kubernetes Cluster,\nNetwork Namespace, or Application Component.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Type"
      ],
      "is_a": "type",
      "domain": "AnalysisTarget",
      "slot_uri": "https://w3id.org/lmodel/ocsf/type",
      "alias": "type",
      "owner": "AnalysisTarget",
      "domain_of": [
        "AnalysisTarget"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "type",
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "AnomalyAnalysis_analysis_targets",
      "definition_uri": "https://w3id.org/lmodel/ocsf/analysis_targets",
      "description": "The analysis targets define the scope of monitored activities, specifying what\nentities, systems or processes are analyzed for activity patterns.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Analysis Targets"
      ],
      "is_a": "analysis_targets",
      "domain": "AnomalyAnalysis",
      "slot_uri": "https://w3id.org/lmodel/ocsf/analysis_targets",
      "alias": "analysis_targets",
      "owner": "AnomalyAnalysis",
      "domain_of": [
        "AnomalyAnalysis"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "analysis_targets",
      "range": "AnalysisTarget",
      "required": true,
      "multivalued": true,
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "AnomalyAnalysis_anomalies",
      "definition_uri": "https://w3id.org/lmodel/ocsf/anomalies",
      "description": "List of detected activities that significantly deviate from the established\nbaselines. This can include unusual access patterns, unexpected user-agents,\nabnormal API usage, suspicious traffic spikes, unauthorized access attempts,\nand other activities that may indicate potential security threats or system\nissues.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Anomalies"
      ],
      "is_a": "anomalies",
      "domain": "AnomalyAnalysis",
      "slot_uri": "https://w3id.org/lmodel/ocsf/anomalies",
      "alias": "anomalies",
      "owner": "AnomalyAnalysis",
      "domain_of": [
        "AnomalyAnalysis"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "anomalies",
      "range": "Anomaly",
      "required": true,
      "multivalued": true,
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "AnomalyAnalysis_baselines",
      "definition_uri": "https://w3id.org/lmodel/ocsf/baselines",
      "description": "List of established patterns representing normal activity that serve as\nreference points for anomaly detection. This includes typical user interaction\npatterns like common user-agents, expected API access frequencies and patterns,\nstandard resource utilization levels, and regular traffic flows. These\nbaselines help establish what constitutes 'normal' activity in the system.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Baselines"
      ],
      "is_a": "baselines",
      "domain": "AnomalyAnalysis",
      "slot_uri": "https://w3id.org/lmodel/ocsf/baselines",
      "alias": "baselines",
      "owner": "AnomalyAnalysis",
      "domain_of": [
        "AnomalyAnalysis"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "baselines",
      "range": "Baseline",
      "recommended": true,
      "multivalued": true,
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "Observable_event_uid",
      "definition_uri": "https://w3id.org/lmodel/ocsf/event_uid",
      "description": "The unique identifier (<code>metadata.uid</code>) of the source OCSF event from\nwhich this observable was extracted. This field enables linking observables\nback to their originating event data when observables are stored in a separate\nlocation or system.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Event UID"
      ],
      "is_a": "event_uid",
      "domain": "Observable",
      "slot_uri": "https://w3id.org/lmodel/ocsf/event_uid",
      "alias": "event_uid",
      "owner": "Observable",
      "domain_of": [
        "Observable"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "event_uid",
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "Observable_name",
      "definition_uri": "https://w3id.org/lmodel/ocsf/name",
      "description": "The full name of the observable attribute. The <code>name</code> is a\npointer/reference to an attribute within the OCSF event data. For example:\n<code>file.name</code>. Array attributes may be represented in one of three\nways. For example: <code>resources.uid</code>, <code>resources[].uid</code>,\n<code>resources[0].uid</code>.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [

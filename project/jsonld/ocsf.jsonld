      "owner": "Cve",
      "domain_of": [
        "Cve"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "uid",
      "range": "string",
      "required": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "Cvss_base_score",
      "definition_uri": "https://w3id.org/lmodel/ocsf/base_score",

    {
      "name": "IamAnalysisFinding",
      "definition_uri": "https://w3id.org/lmodel/ocsf/IamAnalysisFinding",
      "annotations": [
        {
          "tag": "ocsf_constraints",
          "value": "{\"at_least_one\": [\"access_analysis_result\", \"applications\",\n\"identity_activity_metrics\", \"permission_analysis_results\"]}",
          "@type": "Annotation"
        },
        {
          "tag": "ocsf_event_uid",
          "value": 8,
          "@type": "Annotation"
        }
      ],
      "description": "This finding represents an IAM analysis result, which evaluates IAM policies,\naccess patterns, and IAM configurations for potential security risks. The\nanalysis can focus on either an identity (user, role, service account) or a\nresource to assess permissions, access patterns, and security posture within\nthe IAM domain. <br><strong>Note:</strong> Use\n<code>permission_analysis_results</code> for identity-centric analysis\n(evaluating what an identity can do) and <code>access_analysis_result</code>\nfor resource-centric analysis (evaluating who can access a resource). These\ncomplement each other for comprehensive IAM security\nassessment.<br><strong>Note:</strong> If the Finding is an incident, i.e.\nrequires incident workflow, also apply the <code>incident</code> profile or\naggregate this finding into an <code>Incident Finding</code>.",
      "in_subset": [
        "findings_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/events",
      "aliases": [
        "IAM Analysis Finding"
      ],
      "is_a": "Finding",
      "slots": [

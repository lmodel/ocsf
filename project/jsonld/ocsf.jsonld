    {
      "name": "Token_name",
      "definition_uri": "https://w3id.org/lmodel/ocsf/name",
      "description": "The human-friendly name of a token or key, if available, such as the\n<code>name</code> from the Okta API Token API.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",

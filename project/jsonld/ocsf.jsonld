          "value": "{\"at_least_one\": [\"actor\", \"api\", \"connection_info\", \"data\", \"database\",\n\"databucket\", \"device\", \"dst_endpoint\", \"email\", \"file\", \"process\", \"query\",\n\"resources\", \"src_endpoint\", \"url\", \"user\", \"job\", \"script\"]}",
          "@type": "Annotation"

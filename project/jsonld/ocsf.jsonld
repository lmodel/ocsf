            {
              "tag": "ocsf_uid",
              "value": "2"
            },
            {
              "tag": "caption",
              "value": "Medium"
            }
          ]
        },
        {
          "text": "HIGH",
          "description": "The magnitude of harm is high.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "3"
            },
            {
              "tag": "caption",
              "value": "High"
            }
          ]
        },
        {
          "text": "CRITICAL",
          "description": "The magnitude of harm is high and the scope is widespread.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "4"
            },
            {
              "tag": "caption",
              "value": "Critical"
            }
          ]
        },
        {
          "text": "OTHER",
          "description": "The impact is not mapped. See the <code>impact</code> attribute, which contains\na data source specific value.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "99"

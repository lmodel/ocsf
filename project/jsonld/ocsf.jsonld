    {
      "name": "VulnerabilityFinding",
      "definition_uri": "https://w3id.org/lmodel/ocsf/VulnerabilityFinding",
      "annotations": [
        {
          "tag": "ocsf_event_uid",
          "value": 2,
          "@type": "Annotation"
        }
      ],
      "description": "The Vulnerability Finding event is a notification about weakness in an\ninformation system, system security procedures, internal controls, or\nimplementation that could be exploited or triggered by a threat source. Note:\nif the event producer is a security control, the <code>security_control</code>\nprofile should be applied and its <code>attacks</code> information, if present,\nshould be duplicated into the <code>finding_info</code> object.\n<br><strong>Note: </strong>If the Finding is an incident, i.e. requires\nincident workflow, also apply the <code>incident</code> profile  or aggregate\nthis finding into an <code>Incident Finding</code>.",
      "in_subset": [
        "findings_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/events",
      "aliases": [
        "Vulnerability Finding"
      ],
      "close_mappings": [
        "cve:CVERecord",
        "iso27001:Risk",
        "kev_catalog:KevEntry",
        "nvd:NVDEntry",
        "core:Vulnerability"
      ],
      "related_mappings": [
        "capec:AttackPattern",
        "cwe:Weakness"
      ],

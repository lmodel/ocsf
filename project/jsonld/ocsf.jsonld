      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/CisBenchmarkResult",
      "@type": "ClassDefinition"
    },
    {
      "name": "CisControl",
      "definition_uri": "https://w3id.org/lmodel/ocsf/CisControl",
      "description": "The CIS Control (aka Critical Security Control) object describes a prioritized\nset of actions to protect your organization and data from cyber-attack vectors.\nThe <a target='_blank' href='https://www.cisecurity.org/controls'>CIS\nControls</a> are defined by the Center for Internet Security.",

    {
      "name": "BoundaryIdEnum",
      "definition_uri": "https://w3id.org/lmodel/ocsf/BoundaryIdEnum",
      "description": "<p>The normalized identifier of the boundary of the connection. </p><p> For\ncloud connections, this translates to the traffic-boundary (same VPC, through\nIGW, etc.). For traditional networks, this is described as Local, Internal, or\nExternal.</p>",
      "from_schema": "https://w3id.org/lmodel/ocsf/enums",
      "permissible_values": [
        {
          "text": "UNKNOWN",
          "description": "The connection boundary is unknown.",

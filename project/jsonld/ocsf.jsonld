    {
      "name": "AdditionalRestrictionStatusIdEnum",
      "definition_uri": "https://w3id.org/lmodel/ocsf/AdditionalRestrictionStatusIdEnum",
      "description": "The normalized status identifier indicating the applicability of this policy\nrestriction.",
      "from_schema": "https://w3id.org/lmodel/ocsf/enums",
      "permissible_values": [
        {
          "text": "APPLICABLE",
          "description": "This restriction is currently applicable and being enforced.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "1"
            },
            {
              "tag": "caption",
              "value": "Applicable"
            }
          ]
        },
        {
          "text": "INAPPLICABLE",
          "description": "This restriction is not applicable.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "2"
            },
            {
              "tag": "caption",
              "value": "Inapplicable"
            }
          ]
        },
        {
          "text": "EVALUATION_ERROR",
          "description": "This restriction could not be properly evaluated due to an error.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "3"
            },
            {
              "tag": "caption",
              "value": "Evaluation Error"
            }
          ]
        },
        {
          "text": "UNKNOWN",
          "description": "The status is unknown.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "0"
            },
            {
              "tag": "caption",
              "value": "Unknown"
            }
          ]
        },
        {
          "text": "OTHER",
          "description": "The status is not mapped. See the <code>status</code> attribute, which contains\na data source specific value.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "99"
            },
            {
              "tag": "caption",
              "value": "Other"
            }
          ]
        }
      ]
    },
    {
      "name": "AgentTypeIdEnum",
      "definition_uri": "https://w3id.org/lmodel/ocsf/AgentTypeIdEnum",
      "description": "The normalized representation of an agent or sensor. E.g., EDR, vulnerability\nmanagement, APM, backup & recovery, etc.",
      "from_schema": "https://w3id.org/lmodel/ocsf/enums",
      "permissible_values": [
        {
          "text": "ENDPOINT_DETECTION_AND_RESPONSE",
          "description": "Any EDR sensor or agent. Or any tool that provides similar threat detection,\nanti-malware, anti-ransomware, or similar capabilities. E.g., Crowdstrike\nFalcon, Microsoft Defender for Endpoint, Wazuh.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "1"
            },
            {
              "tag": "caption",
              "value": "Endpoint Detection and Response"
            }
          ]
        },
        {
          "text": "DATA_LOSS_PREVENTION",
          "description": "Any DLP sensor or agent. Or any tool that provides similar data classification,\ndata loss detection, and/or data loss prevention capabilities. E.g., Forcepoint\nDLP, Microsoft Purview, Symantec DLP.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "2"
            },
            {
              "tag": "caption",
              "value": "Data Loss Prevention"
            }
          ]
        },
        {
          "text": "BACKUP_RECOVERY",
          "description": "Any agent or sensor that provides backups, archival, or recovery capabilities.\nE.g., Azure Backup, AWS Backint Agent.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "3"
            },
            {
              "tag": "caption",
              "value": "Backup & Recovery"
            }
          ]
        },
        {
          "text": "PERFORMANCE_MONITORING_OBSERVABILITY",
          "description": "Any agent or sensor that provides Application Performance Monitoring (APM),\nactive tracing, profiling, or other observability use cases and optionally\nforwards the logs. E.g., New Relic Agent, Datadog Agent, Azure Monitor Agent.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "4"
            },
            {
              "tag": "caption",
              "value": "Performance Monitoring & Observability"
            }
          ]
        },
        {
          "text": "VULNERABILITY_MANAGEMENT",
          "description": "Any agent or sensor that provides vulnerability management or scanning\ncapabilities. E.g., Qualys VMDR, Microsoft Defender for Endpoint, Crowdstrike\nSpotlight, Amazon Inspector Agent.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "5"
            },
            {
              "tag": "caption",
              "value": "Vulnerability Management"
            }
          ]
        },
        {
          "text": "LOG_FORWARDING",
          "description": "Any agent or sensor that forwards logs to a 3rd party storage system such as a\ndata lake or SIEM. E.g., Splunk Universal Forwarder, Tenzir, FluentBit, Amazon\nCloudWatch Agent, Amazon Kinesis Agent.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "6"
            },
            {
              "tag": "caption",
              "value": "Log Forwarding"
            }
          ]
        },
        {
          "text": "MOBILE_DEVICE_MANAGEMENT",
          "description": "Any agent or sensor responsible for providing Mobile Device Management (MDM) or\nMobile Enterprise Management (MEM) capabilities. E.g., JumpCloud Agent, Esper\nAgent, Jamf Pro binary.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "7"
            },
            {
              "tag": "caption",
              "value": "Mobile Device Management"
            }
          ]
        },
        {
          "text": "CONFIGURATION_MANAGEMENT",
          "description": "Any agent or sensor that provides configuration management of a device, such as\nscanning for software, license management, or applying configurations. E.g.,\nAWS Systems Manager Agent, Flexera, ServiceNow MID Server.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "8"
            },
            {
              "tag": "caption",
              "value": "Configuration Management"
            }
          ]
        },
        {
          "text": "REMOTE_ACCESS",
          "description": "Any agent or sensor that provides remote access capabilities to a device. E.g.,\nBeyondTrust, Amazon Systems Manager Agent, Verkada Agent.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "9"
            },
            {
              "tag": "caption",
              "value": "Remote Access"
            }
          ]
        },
        {
          "text": "UNKNOWN",
          "description": "The type is unknown.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "0"
            },
            {
              "tag": "caption",
              "value": "Unknown"
            }
          ]
        },
        {
          "text": "OTHER",
          "description": "The type is not mapped. See the <code>type</code> attribute, which contains a\ndata source specific value.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "99"
            },
            {
              "tag": "caption",
              "value": "Other"
            }
          ]
        }
      ]
    },
    {
      "name": "AnalyticStateIdEnum",
      "definition_uri": "https://w3id.org/lmodel/ocsf/AnalyticStateIdEnum",
      "description": "The Analytic state identifier.",
      "from_schema": "https://w3id.org/lmodel/ocsf/enums",
      "permissible_values": [
        {
          "text": "ACTIVE",
          "description": "The Analytic is active.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "1"
            },
            {
              "tag": "caption",
              "value": "Active"
            }
          ]
        },
        {
          "text": "SUPPRESSED",
          "description": "The Analytic is suppressed. For example, a user/customer has suppressed a\nparticular detection signature in a security product.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "2"
            },
            {
              "tag": "caption",
              "value": "Suppressed"
            }
          ]
        },
        {
          "text": "EXPERIMENTAL",
          "description": "The Analytic is still under development and considered experimental.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "3"
            },
            {
              "tag": "caption",
              "value": "Experimental"
            }
          ]
        },
        {
          "text": "UNKNOWN",
          "description": "The state is unknown.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "0"
            },
            {
              "tag": "caption",
              "value": "Unknown"
            }
          ]
        },
        {
          "text": "OTHER",
          "description": "The state is not mapped. See the <code>state</code> attribute, which contains a\ndata source specific value.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "99"
            },
            {
              "tag": "caption",
              "value": "Other"
            }
          ]
        }
      ]
    },
    {
      "name": "AnalyticTypeIdEnum",
      "definition_uri": "https://w3id.org/lmodel/ocsf/AnalyticTypeIdEnum",
      "description": "The analytic type ID.",
      "from_schema": "https://w3id.org/lmodel/ocsf/enums",
      "permissible_values": [
        {
          "text": "UNKNOWN",
          "description": "Unknown",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "0"
            },
            {
              "tag": "caption",
              "value": "Unknown"
            }
          ]
        },
        {
          "text": "RULE",
          "description": "A Rule in security analytics refers to predefined criteria or conditions set to\nmonitor, alert, or enforce policies, playing a crucial role in access control,\nthreat detection, and regulatory compliance across security systems.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "1"
            },
            {
              "tag": "caption",
              "value": "Rule"
            }
          ]
        },
        {
          "text": "BEHAVIORAL",
          "description": "Behavioral analytics focus on monitoring and analyzing user or system actions\nto identify deviations from established patterns, aiding in the detection of\ninsider threats, fraud, and advanced persistent threats (APTs).",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "2"
            },
            {
              "tag": "caption",
              "value": "Behavioral"
            }
          ]
        },
        {
          "text": "STATISTICAL",
          "description": "Statistical analytics pertains to analyzing data patterns and anomalies using\nstatistical models to predict, detect, and respond to potential threats,\nenhancing overall security posture through informed decision-making.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "3"
            },
            {
              "tag": "caption",
              "value": "Statistical"
            }
          ]
        },
        {
          "text": "LEARNING_ML_DL",
          "description": "Learning (ML/DL) encompasses techniques that can \"learn\" from known data to\ncreate analytics that generalize to new data. There may be a statistical\ncomponent to these techniques, but it is not a requirement.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "4"
            },
            {
              "tag": "caption",
              "value": "Learning (ML/DL)"
            }
          ]
        },
        {
          "text": "FINGERPRINTING",
          "description": "Fingerprinting is the technique of collecting detailed system data, including\nsoftware versions and configurations, to enhance threat detection, data loss\nprevention (DLP), and endpoint detection and response (EDR) capabilities.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "5"
            },
            {
              "tag": "caption",
              "value": "Fingerprinting"
            }
          ]
        },
        {
          "text": "TAGGING",
          "description": "Tagging refers to the practice of assigning labels or identifiers to data,\nusers, assets, or activities to monitor, control access, and facilitate\nincident response across various security domains such as DLP and EDR.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "6"
            },
            {
              "tag": "caption",
              "value": "Tagging"
            }
          ]
        },
        {
          "text": "KEYWORD_MATCH",
          "description": "Keyword Match involves scanning content for specific terms to identify\nsensitive information, potential threats, or policy violations, aiding in DLP\nand compliance monitoring.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "7"
            },
            {
              "tag": "caption",
              "value": "Keyword Match"
            }
          ]
        },
        {
          "text": "REGULAR_EXPRESSIONS",
          "description": "Regular Expressions are used to define complex search patterns for identifying,\nvalidating, and extracting specific data sets or threats within digital\ncontent, enhancing DLP, EDR, and threat detection mechanisms.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "8"
            },
            {
              "tag": "caption",
              "value": "Regular Expressions"
            }
          ]
        },
        {
          "text": "EXACT_DATA_MATCH",
          "description": "Exact Data Match is a precise comparison technique used to detect the\nunauthorized use or exposure of specific, sensitive information, crucial for\nenforcing DLP policies and protecting against data breaches.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "9"
            },
            {
              "tag": "caption",
              "value": "Exact Data Match"
            }
          ]
        },
        {
          "text": "PARTIAL_DATA_MATCH",
          "description": "Partial Data Match involves identifying instances where segments of sensitive\ninformation or patterns match, facilitating nuanced DLP and threat detection\nwithout requiring complete data conformity.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "10"
            },
            {
              "tag": "caption",
              "value": "Partial Data Match"
            }
          ]
        },
        {
          "text": "INDEXED_DATA_MATCH",
          "description": "Indexed Data Match refers to comparing content against a pre-compiled index of\nsensitive information to efficiently detect and prevent unauthorized access or\nbreaches, streamlining DLP and compliance efforts.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "11"
            },
            {
              "tag": "caption",
              "value": "Indexed Data Match"
            }
          ]
        },
        {
          "text": "OTHER",
          "description": "Other",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "99"
            },
            {
              "tag": "caption",
              "value": "Other"
            }
          ]
        }
      ]
    },
    {
      "name": "AuthenticationTokenTypeIdEnum",
      "definition_uri": "https://w3id.org/lmodel/ocsf/AuthenticationTokenTypeIdEnum",
      "description": "The normalized authentication token type identifier. This attribute restricts\nthe base <code>token.type_id</code> enum to only protocol-specific\nauthentication token types (values 0, 1-5, 99). API tokens and client tokens\n(values 6-7) are not valid for <code>authentication_token</code> - use the base\n<code>token</code> object for those types.",
      "from_schema": "https://w3id.org/lmodel/ocsf/enums",
      "permissible_values": [
        {
          "text": "UNKNOWN",
          "description": "The Authentication token type is unknown.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "0"
            },
            {
              "tag": "caption",
              "value": "Unknown"
            }
          ]
        },
        {
          "text": "TICKET_GRANTING_TICKET",
          "description": "Ticket Granting Ticket (TGT) for Kerberos.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "1"
            },
            {
              "tag": "caption",
              "value": "Ticket Granting Ticket"
            }
          ]
        },
        {
          "text": "SERVICE_TICKET",
          "description": "Service Ticket (ST) for Kerberos.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "2"
            },
            {
              "tag": "caption",
              "value": "Service Ticket"
            }
          ]
        },
        {
          "text": "IDENTITY_TOKEN",
          "description": "Identity (ID) Token for OIDC.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "3"
            },
            {
              "tag": "caption",
              "value": "Identity Token"
            }
          ]
        },
        {
          "text": "REFRESH_TOKEN",
          "description": "Refresh Token for OIDC.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "4"
            },
            {
              "tag": "caption",
              "value": "Refresh Token"
            }
          ]
        },
        {
          "text": "SAML_ASSERTION",
          "description": "Authentication Assertion for SAML.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "5"
            },
            {
              "tag": "caption",
              "value": "SAML Assertion"
            }
          ]
        },
        {
          "text": "OTHER",
          "description": "Other",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "99"
            },
            {
              "tag": "caption",
              "value": "Other"
            }
          ]
        }
      ]
    },
    {
      "name": "CheckSeverityIdEnum",
      "definition_uri": "https://w3id.org/lmodel/ocsf/CheckSeverityIdEnum",
      "description": "The normalized severity identifier that maps severity levels to standard\nseverity levels. For example CIS Benchmark: <code>Level 2</code> maps to\n<code>4</code> (High), <code>Level 1</code> maps to <code>3</code> (Medium).\nFor DISA STIG: <code>CAT I</code> maps to <code>5</code> (Critical), <code>CAT\nII</code> maps to <code>4</code> (High), and <code>CAT III</code> maps to\n<code>3</code> (Medium).",
      "from_schema": "https://w3id.org/lmodel/ocsf/enums",
      "permissible_values": [
        {
          "text": "UNKNOWN",
          "description": "The severity is unknown.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "0"
            },
            {
              "tag": "caption",
              "value": "Unknown"
            }
          ]
        },
        {
          "text": "INFORMATIONAL",
          "description": "Informational message. No action required.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "1"
            },
            {
              "tag": "caption",
              "value": "Informational"
            }
          ]
        },
        {
          "text": "LOW",
          "description": "The user decides if action is needed.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "2"
            },
            {
              "tag": "caption",
              "value": "Low"
            }
          ]
        },
        {
          "text": "MEDIUM",
          "description": "Maps to CIS Benchmark <code>Level 1</code> - Essential security settings\nrecommended for all systems, or DISA STIG <code>CAT III</code> - Action is\nrequired but the situation is not serious at this time.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "3"
            },
            {
              "tag": "caption",
              "value": "Medium"
            }
          ]
        },
        {
          "text": "HIGH",
          "description": "Maps to CIS Benchmark <code>Level 2</code> - More restrictive and\nsecurity-focused settings for sensitive environments, or DISA STIG <code>CAT\nII</code> - Action is required immediately.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "4"
            },
            {
              "tag": "caption",
              "value": "High"
            }
          ]
        },
        {
          "text": "CRITICAL",
          "description": "Maps to DISA STIG <code>CAT I</code> - Action is required immediately and the\nscope is broad.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "5"
            },
            {
              "tag": "caption",
              "value": "Critical"
            }
          ]
        },
        {
          "text": "FATAL",
          "description": "An error occurred but it is too late to take remedial action.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "6"
            },
            {
              "tag": "caption",
              "value": "Fatal"
            }
          ]
        },
        {
          "text": "OTHER",
          "description": "The severity is not mapped. See the <code>severity</code> attribute, which\ncontains a data source specific value.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "99"
            },
            {
              "tag": "caption",
              "value": "Other"
            }
          ]
        }
      ]
    },
    {
      "name": "CheckStatusIdEnum",
      "definition_uri": "https://w3id.org/lmodel/ocsf/CheckStatusIdEnum",
      "description": "The normalized status identifier of the compliance check.",
      "from_schema": "https://w3id.org/lmodel/ocsf/enums",
      "permissible_values": [
        {

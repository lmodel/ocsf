              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "OCSF at_least_one: at least one of ['process', 'user', 'invoked_by', 'session',\n'app_name', 'app_uid'] must be set.",
          "@type": "ClassRule"

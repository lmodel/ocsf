      "alias": "tenant_uid",
      "owner": "Token",
      "domain_of": [
        "Token"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "tenant_uid",
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "Token_type",
      "definition_uri": "https://w3id.org/lmodel/ocsf/type",
      "description": "The type of the token, normalized to the caption of the <code>type_id</code>\nvalue. This indicates whether the token is a Client Token, API Token, or one of\nthe protocol-specific token types.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Type"
      ],
      "is_a": "type",
      "domain": "Token",
      "slot_uri": "https://w3id.org/lmodel/ocsf/type",
      "alias": "type",
      "owner": "Token",
      "domain_of": [
        "Token"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "type",
      "range": "string",
      "recommended": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "Token_type_id",
      "definition_uri": "https://w3id.org/lmodel/ocsf/type_id",
      "annotations": {
        "sibling": {
          "tag": "sibling",
          "value": "type",
          "extensions": {},
          "annotations": {}
        }
      },
      "description": "The normalized token type identifier. Valid values: 0 (Unknown), 1 (Ticket\nGranting Ticket - Kerberos), 2 (Service Ticket - Kerberos), 3 (Identity Token -\nOIDC), 4 (Refresh Token - OIDC), 5 (SAML Assertion), 6 (Client Token -\nIdP-issued), 7 (API Token - generic API keys), 99 (Other).",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Type ID"
      ],
      "is_a": "type_id",
      "domain": "Token",
      "slot_uri": "https://w3id.org/lmodel/ocsf/type_id",
      "alias": "type_id",
      "owner": "Token",
      "domain_of": [
        "Token"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "type_id",
      "range": "TokenTypeIdEnum",
      "recommended": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "Token_uid",
      "definition_uri": "https://w3id.org/lmodel/ocsf/uid",
      "description": "The unique ID of a token or key, if available, such as the <code>Secret\nID</code> of Entra ID Application Registration Client Secrets.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Unique ID"
      ],
      "is_a": "uid",
      "domain": "Token",
      "slot_uri": "https://w3id.org/lmodel/ocsf/uid",
      "alias": "uid",
      "owner": "Token",
      "domain_of": [
        "Token"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "uid",
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "Token_zone",
      "definition_uri": "https://w3id.org/lmodel/ocsf/zone",
      "description": "The network zone or geographic region that the token or key is authorized to be\nused from. This may represent network-based access restrictions, geographic\nlimitations, or other zone-based authorization policies. Examples include\nOkta's network zone restrictions or cloud provider region restrictions.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Network Zone"
      ],
      "is_a": "zone",
      "domain": "Token",
      "slot_uri": "https://w3id.org/lmodel/ocsf/zone",
      "alias": "zone",
      "owner": "Token",
      "domain_of": [
        "Token"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "zone",
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "Trace_duration",
      "definition_uri": "https://w3id.org/lmodel/ocsf/duration",
      "description": "The total time, in milliseconds, that the trace covers, calculated as the\ndifference between start_time and end_time. This duration helps assess the\noverall performance of a request as it travels across various services, and is\nessential for identifying latency and potential bottlenecks within the\ndistributed system. The trace duration may differ from individual span\ndurations due to the propagation and processing times of the trace as it spans\nmultiple components.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Duration Milliseconds"
      ],
      "is_a": "duration",
      "domain": "Trace",
      "slot_uri": "https://w3id.org/lmodel/ocsf/duration",
      "alias": "duration",
      "owner": "Trace",
      "domain_of": [
        "Trace"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "duration",
      "range": "integer",
      "@type": "SlotDefinition"
    },
    {
      "name": "Trace_end_time",
      "definition_uri": "https://w3id.org/lmodel/ocsf/end_time",
      "description": "The end timestamp of the trace, essential for identifying latency and\nperformance bottlenecks. Like the start time, this timestamp is normalized\nacross the trace system to ensure consistency, even when events are recorded\nacross distributed services with unsynchronized clocks. Normalized time allows\nfor accurate trace duration calculations and helps observability tools track\noverall performance across services, regardless of the individual system time\nsettings.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "End Time"
      ],
      "is_a": "end_time",
      "domain": "Trace",
      "slot_uri": "https://w3id.org/lmodel/ocsf/end_time",
      "alias": "end_time",
      "owner": "Trace",
      "domain_of": [
        "Trace"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "end_time",
      "range": "TimestampT",
      "@type": "SlotDefinition"
    },
    {
      "name": "Trace_flags",
      "definition_uri": "https://w3id.org/lmodel/ocsf/flags",
      "description": "The flags associated with the trace, used to indicate specific properties or\nbehaviors, such as whether the trace is sampled or if it has special handling.\nFlags help control how traces are processed, logged, and analyzed, providing\nvaluable context for tracing and observability tools in identifying trace\ncharacteristics or specific tracking requirements.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Flags"
      ],
      "is_a": "flags",
      "domain": "Trace",
      "slot_uri": "https://w3id.org/lmodel/ocsf/flags",
      "alias": "flags",
      "owner": "Trace",
      "domain_of": [
        "Trace"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "flags",
      "range": "string",
      "multivalued": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "Trace_service",
      "definition_uri": "https://w3id.org/lmodel/ocsf/service",
      "description": "Identifies the service or component generating the trace, helping to track and\ncorrelate the flow of requests through various parts of a distributed system.\nThis information is essential for understanding the role and performance of\nspecific services within the broader context of system operations and for\ndiagnosing issues across different components.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Service"
      ],
      "is_a": "service",
      "domain": "Trace",
      "slot_uri": "https://w3id.org/lmodel/ocsf/service",
      "alias": "service",
      "owner": "Trace",
      "domain_of": [
        "Trace"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "service",
      "range": "Service",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "Trace_span",
      "definition_uri": "https://w3id.org/lmodel/ocsf/span",
      "description": "Represents a single unit of work or operation within a distributed trace. A\nspan typically tracks the execution of a request across a service, capturing\nimportant details such as the operation, timestamps, and status. Spans help\nbreak down the overall trace into smaller, manageable parts, enabling detailed\nanalysis of the performance and behavior of specific operations within the\nsystem. They are crucial for understanding latency, dependencies, and\nbottlenecks in complex distributed systems.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Span"
      ],
      "is_a": "span",
      "domain": "Trace",
      "slot_uri": "https://w3id.org/lmodel/ocsf/span",
      "alias": "span",
      "owner": "Trace",
      "domain_of": [
        "Trace"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "span",
      "range": "Span",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "Trace_start_time",
      "definition_uri": "https://w3id.org/lmodel/ocsf/start_time",
      "description": "The start timestamp of the trace, essential for identifying latency and\nperformance bottlenecks. Like the end time, this timestamp is normalized across\nthe trace system to ensure consistency, even when events are recorded across\ndistributed services with unsynchronized clocks. Normalized time enables\naccurate trace duration calculations and helps observability tools track\nperformance across services, regardless of the individual system time settings.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Start Time"
      ],
      "is_a": "start_time",
      "domain": "Trace",
      "slot_uri": "https://w3id.org/lmodel/ocsf/start_time",
      "alias": "start_time",
      "owner": "Trace",
      "domain_of": [
        "Trace"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "start_time",
      "range": "TimestampT",
      "@type": "SlotDefinition"
    },
    {
      "name": "Trace_uid",
      "definition_uri": "https://w3id.org/lmodel/ocsf/uid",
      "description": "The unique identifier of the trace used in distributed systems and\nmicroservices architecture to track and correlate requests across various\ncomponents of an application.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Unique ID"
      ],
      "is_a": "uid",
      "domain": "Trace",
      "slot_uri": "https://w3id.org/lmodel/ocsf/uid",
      "alias": "uid",
      "owner": "Trace",
      "domain_of": [
        "Trace"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "uid",
      "range": "string",
      "required": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "Url_category_ids",
      "definition_uri": "https://w3id.org/lmodel/ocsf/category_ids",
      "annotations": {
        "sibling": {

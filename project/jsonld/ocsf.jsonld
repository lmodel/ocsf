          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "4"
            },
            {
              "tag": "caption",
              "value": "Exploitation"
            }
          ]
        },
        {
          "text": "INSTALLATION",
          "description": "The intruders install malware on the victim\u2019s system.",

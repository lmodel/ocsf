    {
      "name": "Certificate",
      "definition_uri": "https://w3id.org/lmodel/ocsf/Certificate",
      "description": "The Digital Certificate, also known as a Public Key Certificate, object\ncontains information about the ownership and usage of a public key. It serves\nas a means to establish trust in the authenticity and integrity of the public\nkey and the associated entity.",
      "notes": [
        "D3FEND\u2122 Ontology d3f:Certificate. \u2014\nhttps://d3fend.mitre.org/dao/artifact/d3f:Certificate/"
      ],
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",

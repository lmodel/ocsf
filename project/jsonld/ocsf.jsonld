    {
      "name": "AdditionalRestriction",
      "definition_uri": "https://w3id.org/lmodel/ocsf/AdditionalRestriction",
      "description": "The Additional Restriction object describes supplementary access controls and\nguardrails that constrain or limit granted permissions beyond the primary\npolicy. These restrictions are typically applied through hierarchical policy\nframeworks, organizational controls, or conditional access mechanisms. Examples\ninclude AWS Service Control Policies (SCPs), Resource Control Policies (RCPs),\nAzure Management Group policies, GCP Organization policies, conditional access\npolicies, IP restrictions, time-based constraints, and MFA requirements.",
      "in_subset": [
        "objects_subset"

    {
      "name": "LaunchTypeIdEnum",
      "definition_uri": "https://w3id.org/lmodel/ocsf/LaunchTypeIdEnum",
      "description": "The normalized identifier for the specific type of <code>Launch</code>\nactivity.",
      "from_schema": "https://w3id.org/lmodel/ocsf/enums",
      "permissible_values": [
        {
          "text": "UNKNOWN",
          "description": "The launch type is unknown or not specified.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "0"
            },
            {
              "tag": "caption",
              "value": "Unknown"
            }
          ]
        },
        {
          "text": "SPAWN",
          "description": "Denotes that the <code>Launch</code> event represents atomic creation of a new\nprocess on Windows. This launch type ID may also be used to represent both\nsteps of Unix process creation in a single <code>Launch</code> event.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "1"
            },
            {
              "tag": "caption",
              "value": "Spawn"
            }
          ]
        },
        {
          "text": "FORK",
          "description": "Denotes that the <code>Launch</code> event represents the \"fork\" step of Unix\nprocess creation, where a process creates a clone of itself in a parent-child\nrelationship. WSL1 pico processes on Windows also use the 2-step Unix model.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "2"
            },
            {
              "tag": "caption",
              "value": "Fork"
            }
          ]
        },
        {
          "text": "EXEC",
          "description": "Denotes that the <code>Launch</code> event represents the \"exec\" step of Unix\nprocess creation, where a process replaces its executable image, command line,\nand environment. WSL1 pico processes on Windows also use the 2-step Unix model.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "3"
            },
            {
              "tag": "caption",
              "value": "Exec"
            }
          ]
        },
        {
          "text": "OTHER",
          "description": "The launch type is not mapped. See the <code>launch_type</code> attribute,\nwhich contains a data source specific value.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "99"
            },
            {
              "tag": "caption",
              "value": "Other"
            }
          ]
        }
      ]
    },

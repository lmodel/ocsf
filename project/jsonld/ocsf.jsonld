              },
              {
                "slot_conditions": [
                  {
                    "name": "uid",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "OCSF at_least_one: at least one of ['name', 'uid'] must be set.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
    {
      "name": "Resource",
      "definition_uri": "https://w3id.org/lmodel/ocsf/Resource",
      "description": "The Resource object contains attributes that provide information about a\nparticular resource. It serves as a base object, offering attributes that help\nidentify and classify the resource effectively.",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",

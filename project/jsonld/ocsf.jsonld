              "value": "4"
            },
            {
              "tag": "caption",
              "value": "Mapped"
            }
          ]
        },
        {
          "text": "NONSTANDARD_BACKED",
          "description": "A module loaded in a non standard way. However, GetModuleFileName succeeds on\nthis allocation.",

    {
      "name": "Cvss_metrics",
      "definition_uri": "https://w3id.org/lmodel/ocsf/metrics",
      "description": "The Common Vulnerability Scoring System metrics. This attribute contains\ninformation on the CVE's impact. If the CVE has been analyzed, this attribute\nwill contain any CVSSv2 or CVSSv3 information associated with the\nvulnerability. For example: <code>{ {\"Access Vector\", \"Network\"}, {\"Access\nComplexity\", \"Low\"}, ...}</code>.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Metrics"
      ],
      "is_a": "metrics",
      "domain": "Cvss",

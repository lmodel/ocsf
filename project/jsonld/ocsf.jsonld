      "name": "ApplicationError",
      "definition_uri": "https://w3id.org/lmodel/ocsf/ApplicationError",
      "annotations": [
        {
          "tag": "ocsf_event_uid",
          "value": 8,
          "@type": "Annotation"
        }
      ],
      "description": "Application Error events describe issues with an applications. The error\nmessage should be put in the event's <code>message</code> attribute. The\n<code>metadata.product</code> attribute can be used to capture the originating\napplication information. The <code>host</code> profile can used to include the\ngenerating device information. This class is helpful for applications that\ngenerate or handle OCSF events and can also be used for errors in upstream\nproducts and services.",
      "in_subset": [
        "application_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/events",

      "rules": [
        {
          "postconditions": {
            "any_of": [
              {
                "slot_conditions": [
                  {
                    "name": "database",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "databucket",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "table",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "OCSF at_least_one: at least one of ['database', 'databucket', 'table'] must be\nset.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },

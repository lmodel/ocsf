        "Certificate_fingerprints",
        "Certificate_is_self_signed",
        "Certificate_issuer",
        "Certificate_sans",
        "Certificate_serial_number",
        "Certificate_subject",
        "Certificate_uid",
        "Certificate_version"
      ],
      "slot_usage": {},

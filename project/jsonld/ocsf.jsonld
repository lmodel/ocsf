    {
      "name": "ProcessActivityActivityIdEnum",
      "definition_uri": "https://w3id.org/lmodel/ocsf/ProcessActivityActivityIdEnum",
      "description": "ProcessActivity activity_id values.",
      "from_schema": "https://w3id.org/lmodel/ocsf/enums",
      "permissible_values": [
        {
          "text": "LAUNCH",
          "description": "A request by the actor to launch another process. Refer to the\n<code>launch_type_id</code> attribute for details of the specific launch type.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "1"
            },
            {
              "tag": "caption",
              "value": "Launch"
            }
          ]
        },
        {
          "text": "TERMINATE",
          "description": "A request by the actor to terminate a process. This activity is most commonly\nreflexive, this being the case when a process exits at its own initiation. Note\ntoo that Windows security products cannot always identify the actor in the case\nof inter-process termination. In this case, <code>actor.process</code> and\n<code>process</code> refer to the exiting process, i.e. indistinguishable from\nthe reflexive case.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "2"
            },
            {
              "tag": "caption",
              "value": "Terminate"
            }
          ]
        },
        {
          "text": "OPEN",
          "description": "A request by the actor to obtain a handle or descriptor to a process with the\naim of performing further actions upon that process. The target is usually a\ndifferent process but this activity can also be reflexive.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "3"
            },
            {
              "tag": "caption",
              "value": "Open"
            }
          ]
        },
        {
          "text": "INJECT",
          "description": "A request by the actor to execute code within the context of a process. The\ntarget is usually a different process but this activity can also be reflexive.\nRefer to the <code>injection_type_id</code> attribute for details of the\nspecific injection type.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "4"
            },
            {
              "tag": "caption",
              "value": "Inject"
            }
          ]
        },
        {
          "text": "SET_USER_ID",
          "description": "A request by the actor to change its user identity by invoking the\n<code>setuid()</code> system call. Common programs like <code>su</code> and\n<code>sudo</code> use this mechanism. Note that the <em>impersonation</em>\nmechanism on Windows is not directly equivalent because it acts at the thread\nlevel.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "5"
            },
            {
              "tag": "caption",
              "value": "Set User ID"
            }
          ]
        },
        {
          "text": "UNKNOWN",
          "description": "The event activity is unknown.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "0"
            },
            {
              "tag": "caption",
              "value": "Unknown"
            }
          ]
        },
        {
          "text": "OTHER",
          "description": "The event activity is not mapped. See the <code>activity_name</code> attribute,\nwhich contains a data source specific value.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "99"
            },
            {
              "tag": "caption",
              "value": "Other"
            }
          ]
        }
      ]
    },

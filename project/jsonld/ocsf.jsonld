    {
      "name": "AuthenticationToken",
      "definition_uri": "https://w3id.org/lmodel/ocsf/AuthenticationToken",
      "description": "The Authentication Token object extends the base <code>token</code> object and\nrepresents standardized authentication tokens, tickets, or assertions that\nconform to established authentication protocols such as Kerberos, OIDC, and\nSAML. This object inherits all attributes from <code>token</code> and adds\nprotocol-specific attributes (e.g., <code>kerberos_flags</code>,\n<code>encryption_details</code>) for authentication events. Use this object in\nauthentication events to represent protocol-specific tokens: Kerberos Ticket\nGranting Tickets (TGT) and Service Tickets (ST), OIDC Identity Tokens and\nRefresh Tokens, and SAML Assertions. These tokens are issued by authentication\nservers and identity providers and carry protocol-specific metadata, lifecycle\ninformation, and security attributes defined by their respective\nspecifications. When to use this object: Use <code>authentication_token</code>\nwhen representing protocol-specific authentication tokens (type_id values 1-5:\nKerberos TGT/ST, OIDC ID/Refresh tokens, SAML assertions) in authentication\nevents. When NOT to use this object: Do NOT use\n<code>authentication_token</code> for API tokens or client tokens (type_id\nvalues 6-7) used in API activity events - use the base <code>token</code>\nobject instead. Do NOT use <code>authentication_token</code> for generic API\nkeys - use the base <code>token</code> object instead.",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "aliases": [
        "Authentication Token"
      ],
      "is_a": "Token",
      "slots": [
        "Token_modified_time",
        "Token_name",
        "Token_tenant_uid",
        "Token_uid",
        "Token_zone",
        "created_time",
        "AuthenticationToken_encryption_details",
        "expiration_time",
        "is_renewable",
        "AuthenticationToken_kerberos_flags",
        "type",
        "type_id",
        "AuthenticationToken_created_time",
        "AuthenticationToken_expiration_time",
        "AuthenticationToken_is_renewable",
        "AuthenticationToken_type",
        "AuthenticationToken_type_id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/AuthenticationToken",
      "@type": "ClassDefinition"
    },
    {
      "name": "Authorization",
      "definition_uri": "https://w3id.org/lmodel/ocsf/Authorization",
      "description": "The Authorization Result object provides details about the authorization\noutcome and associated policies related to activity.",

    {
      "name": "Check_desc",
      "definition_uri": "https://w3id.org/lmodel/ocsf/desc",
      "description": "The detailed description of the compliance check, explaining the security\nrequirement, vulnerability, or configuration being assessed. For example, CIS:\n<code>The cramfs filesystem type is a compressed read-only Linux filesystem.\nRemoving support for unneeded filesystem types reduces the local attack\nsurface.</code> or DISA STIG: <code>Unauthorized access to the information\nsystem by foreign entities may result in loss or compromise of data.</code>",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Description"
      ],
      "is_a": "desc",
      "domain": "Check",
      "slot_uri": "https://w3id.org/lmodel/ocsf/desc",
      "alias": "desc",
      "owner": "Check",
      "domain_of": [
        "Check"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "desc",
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "Check_name",
      "definition_uri": "https://w3id.org/lmodel/ocsf/name",
      "description": "The name or title of the compliance check. For example, CIS: <code>Ensure\nmounting of cramfs filesystems is disabled</code> or DISA STIG: <code>The\nUbuntu operating system must implement DoD-approved encryption to protect the\nconfidentiality of remote access sessions</code>.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Name"
      ],
      "is_a": "name",
      "domain": "Check",
      "slot_uri": "https://w3id.org/lmodel/ocsf/name",
      "alias": "name",
      "owner": "Check",
      "domain_of": [
        "Check"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "name",
      "range": "string",
      "recommended": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "Check_resource",
      "definition_uri": "https://w3id.org/lmodel/ocsf/resource",
      "description": "Describes details about the resource that this check evaluated.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Resource"
      ],
      "is_a": "resource",
      "domain": "Check",
      "slot_uri": "https://w3id.org/lmodel/ocsf/resource",

          ]
        },
        {
          "text": "BOTH",
          "description": "Both the source and destination network endpoint are the observation point.\nThis typically occurs in localhost or internal communications where the source\nand destination are the same endpoint, often resulting in a\n<code>connection_info.direction</code> of <code>Local</code>.",
          "annotations": [
            {
              "tag": "ocsf_uid",

    {
      "name": "Anomaly_observed_pattern",
      "definition_uri": "https://w3id.org/lmodel/ocsf/observed_pattern",
      "description": "The specific pattern identified within the observation type. For Frequency\nAnalysis, this could be 'FREQUENT', 'INFREQUENT', 'RARE', or 'UNSEEN'. For Time\nPattern Analysis, this could be 'BUSINESS_HOURS', 'OFF_HOURS', or\n'UNUSUAL_TIME'. For Volume Analysis, this could be 'NORMAL_VOLUME',\n'HIGH_VOLUME', or 'SURGE'. The pattern values are specific to each observation\ntype and indicate how the observed behavior relates to the baseline.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",

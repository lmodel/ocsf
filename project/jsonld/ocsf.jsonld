      "annotations": [
        {
          "tag": "group",
          "value": "primary",
          "@type": "Annotation"
        }
      ],
      "description": "Indicates that the event is considered to be an alertable signal. For example,\nan <code>activity_id</code> of 'Create' could constitute an alertable signal\nand the value would be <code>true</code>, while 'Close' likely would not and\neither omit the attribute or set its value to <code>false</code>.  Note that\nother events with the <code>security_control</code> profile may also be deemed\nalertable signals and may also carry <code>is_alert = true</code> attributes.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Alert"
      ],

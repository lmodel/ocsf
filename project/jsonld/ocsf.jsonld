      ],
      "is_a": "IncidentProfile_impact_score",
      "domain": "IncidentFinding",
      "slot_uri": "https://w3id.org/lmodel/ocsf/impact_score",
      "alias": "impact_score",
      "owner": "IncidentFinding",
      "domain_of": [
        "IncidentFinding"

            {
              "tag": "caption",
              "value": "Unknown"
            }
          ]
        },
        {
          "text": "INBOUND",
          "description": "Email Inbound, from the Internet or outside network destined for an entity\ninside network.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "1"
            },
            {
              "tag": "caption",
              "value": "Inbound"
            }
          ]
        },
        {
          "text": "OUTBOUND",
          "description": "Email Outbound, from inside the network destined for an entity outside network.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "2"
            },
            {
              "tag": "caption",
              "value": "Outbound"
            }
          ]
        },
        {
          "text": "INTERNAL",
          "description": "Email Internal, from inside the network destined for an entity inside network.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "3"
            },
            {
              "tag": "caption",
              "value": "Internal"
            }
          ]
        },
        {
          "text": "OTHER",
          "description": "Other",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "99"
            },
            {
              "tag": "caption",
              "value": "Other"
            }
          ]
        },
        {
          "text": "LOCAL",
          "description": "Local network connection (<code>localhost</code>). The connection is\nintra-device, originating from and destined for services running on the same\ndevice.",
          "annotations": [

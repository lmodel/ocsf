    {
      "name": "Endpoint",
      "definition_uri": "https://w3id.org/lmodel/ocsf/Endpoint",
      "annotations": [
        {
          "tag": "ocsf_constraints",
          "value": "{\"at_least_one\": [\"ip\", \"uid\", \"name\", \"hostname\", \"instance_uid\",\n\"interface_uid\", \"interface_name\"]}",
          "@type": "Annotation"
        },
        {
          "tag": "observable_id",
          "value": 20,
          "@type": "Annotation"
        }
      ],
      "description": "The Endpoint object describes a physical or virtual device that connects to and\nexchanges information with a computer network. Some examples of endpoints are\nmobile devices, desktop computers, virtual machines, embedded devices, and\nservers. Internet-of-Things devices\u2014like cameras, lighting, refrigerators,\nsecurity systems, smart speakers, and thermostats\u2014are also endpoints.",
      "notes": [
        "D3FEND\u2122 Ontology d3f:Host. \u2014\nhttps://d3fend.mitre.org/dao/artifact/d3f:ComputerNetworkNode/"
      ],
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "see_also": [
        "https://d3fend.mitre.org/dao/artifact/d3f:ComputerNetworkNode/"
      ],
      "aliases": [
        "Endpoint"
      ],
      "broad_mappings": [
        "stix:Host",
        "uco_master:Device"
      ],
      "is_a": "Entity",
      "mixins": [
        "ContainerProfile"
      ],
      "slots": [
        "agent_list",
        "Endpoint_domain",
        "Endpoint_hostname",
        "hw_info",
        "Endpoint_instance_uid",
        "Endpoint_interface_name",
        "Endpoint_interface_uid",
        "Endpoint_ip",
        "Endpoint_location",
        "Endpoint_mac",
        "Endpoint_mac_vendor",
        "name",
        "Endpoint_os",
        "Endpoint_owner",
        "Endpoint_pool",
        "subnet_uid",
        "Endpoint_type",
        "Endpoint_type_id",
        "uid",
        "vlan_uid",
        "vpc_uid",
        "Endpoint_zone",
        "Endpoint_name",
        "Endpoint_uid",
        "ContainerProfile_container",
        "ContainerProfile_namespace_pid"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/Endpoint",
      "rules": [
        {
          "postconditions": {
            "any_of": [
              {
                "slot_conditions": [
                  {
                    "name": "ip",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "uid",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "name",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "hostname",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "instance_uid",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "interface_uid",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "interface_name",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "OCSF at_least_one: at least one of ['ip', 'uid', 'name', 'hostname',\n'instance_uid', 'interface_uid', 'interface_name'] must be set.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"

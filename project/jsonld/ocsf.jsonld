    {
      "name": "DataLifecycleStateIdEnum",
      "definition_uri": "https://w3id.org/lmodel/ocsf/DataLifecycleStateIdEnum",
      "description": "The stage or state that the data was in when it was assessed or scanned by a\ndata security tool.",
      "from_schema": "https://w3id.org/lmodel/ocsf/enums",
      "permissible_values": [
        {
          "text": "UNKNOWN",
          "description": "The data lifecycle state is unknown.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "0"
            },
            {
              "tag": "caption",
              "value": "Unknown"
            }
          ]
        },
        {
          "text": "DATA_AT_REST",
          "description": "The data was stored on physical or logical media and was not actively moving\nthrough the network nor was being processed. E.g., data stored in a database,\nPDF files in a file share, or EHR records in object storage.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "1"
            },
            {
              "tag": "caption",
              "value": "Data at-Rest"
            }
          ]
        },
        {
          "text": "DATA_IN_TRANSIT",
          "description": "The data was actively moving through the network or from one physical or\nlogical location to another. E.g., emails being send, data replication or\nChange Data Capture (CDC) streams, or sensitive data processed on an API.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "2"
            },
            {
              "tag": "caption",
              "value": "Data in-Transit"
            }
          ]
        },
        {
          "text": "DATA_IN_USE",
          "description": "The data was being processed, accessed, or read by a system, making it active\nin memory or CPU. E.g., sensitive data in a Business Intelligence tool, ePHI\nbeing processed in an EHR application or a user viewing data stored in a\nspreadsheet or PDF.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "3"
            },
            {
              "tag": "caption",
              "value": "Data in-Use"
            }
          ]
        },
        {
          "text": "OTHER",
          "description": "The data lifecycle state is not mapped. See the\n<code>data_lifecycle_state</code> attribute, which contains a data source\nspecific value.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "99"
            },
            {
              "tag": "caption",
              "value": "Other"
            }
          ]
        }
      ]
    },

    {
      "name": "NetworkActivity_dst_endpoint",
      "definition_uri": "https://w3id.org/lmodel/ocsf/dst_endpoint",
      "description": "The destination endpoint of the network activity \u2014 typically the responder. In\nbi-flow or asymmetric flow scenarios, this endpoint may represent the true\ninitiator of the original communication. Use <code>initiator_id</code> to\ndetermine which endpoint actually initiated the communication.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Destination Endpoint"
      ],
      "is_a": "NetworkEvent_dst_endpoint",
      "domain": "NetworkActivity",

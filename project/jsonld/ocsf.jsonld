    {
      "name": "Campaign",
      "definition_uri": "https://w3id.org/lmodel/ocsf/Campaign",
      "description": "Campaign represent organized efforts by threat actors to achieve malicious\nobjectives over a period, often characterized by shared tactics, techniques,\nand procedures (TTPs).",

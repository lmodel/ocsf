    {
      "name": "sender",
      "definition_uri": "https://w3id.org/lmodel/ocsf/sender",
      "description": "The machine readable email address of the system or server that actually\ntransmitted the email message, extracted from the email headers per RFC 5322.\nThis differs from the <code>from</code> field, which shows the message author.\nThe sender field is most commonly used when multiple addresses appear in the\n<code> from_list </code> field, or when the transmitting system is different\nfrom the message author (such as when sending on behalf of someone else).",
      "notes": [
        "RFC 5322 \u2014 https://www.rfc-editor.org/rfc/rfc5322"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "see_also": [
        "https://www.rfc-editor.org/rfc/rfc5322"
      ],
      "aliases": [
        "Sender"
      ],
      "slot_uri": "https://w3id.org/lmodel/ocsf/sender",
      "owner": "Email",
      "domain_of": [
        "Email"
      ],
      "range": "EmailT",
      "@type": "SlotDefinition"
    },
    {
      "name": "sender_mailbox",
      "definition_uri": "https://w3id.org/lmodel/ocsf/sender_mailbox",
      "description": "The human readable email address of the system or server that actually\ntransmitted the email message, extracted from the email headers per RFC 5322.\nThis differs from the <code>from_mailbox</code> field, which shows the message\nauthor. The sender mailbox field is most commonly used when multiple addresses\nappear in the <code> from_mailboxes </code> field, or when the transmitting\nsystem is different from the message author (such as when sending on behalf of\nsomeone else).",
      "notes": [
        "RFC 5322 \u2014 https://www.rfc-editor.org/rfc/rfc5322"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",

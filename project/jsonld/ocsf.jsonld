        "hosting_process",
        "WinService_load_order_group",
        "WinService_name",
        "service_category",
        "WinService_service_category_id",
        "WinService_service_dependencies",
        "service_dll_file",
        "service_error_control",
        "WinService_service_error_control_id",
        "WinService_service_file",
        "WinService_service_start_name",
        "service_start_type",
        "WinService_service_start_type_id",
        "service_type",
        "WinService_service_type_id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/WinService",
      "rules": [
        {
          "postconditions": {
            "any_of": [
              {
                "slot_conditions": [
                  {
                    "name": "cmd_line",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "service_category_id",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "service_dependencies",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "service_error_control_id",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "service_start_name",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "service_start_type_id",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "service_type_id",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "OCSF at_least_one: at least one of ['cmd_line', 'service_category_id',\n'service_dependencies', 'service_error_control_id', 'service_start_name',\n'service_start_type_id', 'service_type_id'] must be set.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"

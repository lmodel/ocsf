    {
      "name": "Osint",
      "definition_uri": "https://w3id.org/lmodel/ocsf/Osint",
      "description": "The OSINT (Open Source Intelligence) object contains details related to an\nindicator such as the indicator itself, related indicators, geolocation,\nregistrar information, subdomains, analyst commentary, and other contextual\ninformation. This information can be used to further enrich a detection or\nfinding by providing decisioning support to other analysts and engineers.",
      "in_subset": [

    {
      "name": "DataSecurityFinding",
      "definition_uri": "https://w3id.org/lmodel/ocsf/DataSecurityFinding",
      "annotations": [
        {
          "tag": "ocsf_event_uid",
          "value": 6,
          "@type": "Annotation"
        }
      ],
      "description": "A Data Security Finding describes detections or alerts generated by various\ndata security products such as Data Loss Prevention (DLP), Data Classification,\nSecrets Management, Digital Rights Management (DRM), Data Security Posture\nManagement (DSPM), and similar tools. These detections or alerts can be created\nusing fingerprinting, statistical analysis, machine learning or other\nmethodologies. The finding describes the actors and endpoints who accessed or\nown the sensitive data, as well as the resources which store the sensitive\ndata. Note: if the event producer is a security control, the\n<code>security_control</code> profile should be applied and its\n<code>attacks</code> information, if present, should be duplicated into the\n<code>finding_info</code> object. <br><strong>Note: </strong>If the Finding is\nan incident, i.e. requires incident workflow, also apply the\n<code>incident</code> profile  or aggregate this finding into an <code>Incident\nFinding</code>.",
      "in_subset": [
        "findings_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/events",
      "aliases": [
        "Data Security Finding"
      ],
      "is_a": "Finding",

    {
      "name": "AccessAnalysisResult_access_type",
      "definition_uri": "https://w3id.org/lmodel/ocsf/access_type",
      "description": "The type or category of access being granted to the identity. This describes\nthe nature of the access relationship, such as cross-account access, public\naccess, federated access, or third-party integration access. Examples include\n'Cross-Account', 'Public', 'Federated', 'Service-to-Service', etc.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Access Type"

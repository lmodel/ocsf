    {
      "name": "Agent",
      "definition_uri": "https://w3id.org/lmodel/ocsf/Agent",
      "annotations": [
        {
          "tag": "ocsf_constraints",
          "value": "{\"at_least_one\": [\"uid\", \"name\"]}",
          "@type": "Annotation"
        }
      ],
      "description": "An Agent (also known as a Sensor) is typically installed on an Operating System\n(OS) and serves as a specialized software component that can be designed to\nmonitor, detect, collect, archive, or take action. These activities and\npossible actions are defined by the upstream system controlling the Agent and\nits intended purpose. For instance, an Agent can include Endpoint Detection &\nResponse (EDR) agents, backup/disaster recovery sensors, Application\nPerformance Monitoring or profiling sensors, and similar software.",
      "notes": [
        "D3FEND\u2122 Ontology d3f:Sensor. \u2014\nhttps://d3fend.mitre.org/dao/artifact/d3f:Sensor/"
      ],
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "see_also": [
        "https://d3fend.mitre.org/dao/artifact/d3f:Sensor/"
      ],
      "aliases": [
        "Agent"
      ],
      "is_a": "Object",
      "slots": [
        "Agent_name",
        "Agent_policies",
        "Agent_type",
        "Agent_type_id",
        "Agent_uid",
        "Agent_uid_alt",
        "Agent_vendor_name",
        "Agent_version"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/Agent",
      "rules": [
        {
          "postconditions": {
            "any_of": [
              {
                "slot_conditions": [
                  {
                    "name": "uid",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "name",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "OCSF at_least_one: at least one of ['uid', 'name'] must be set.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },

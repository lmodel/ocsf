    {
      "name": "StartupItem",
      "definition_uri": "https://w3id.org/lmodel/ocsf/StartupItem",
      "annotations": [
        {
          "tag": "ocsf_constraints",
          "value": "{\"just_one\": [\"driver\", \"job\", \"process\"]}",
          "@type": "Annotation"
        }
      ],
      "description": "The startup item object describes an application component that has associated\nstartup criteria and configurations.",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "aliases": [
        "Startup Item"
      ],
      "is_a": "OcsfObject",
      "slots": [
        "StartupItem_driver",
        "StartupItem_job",
        "StartupItem_name",
        "StartupItem_process",
        "StartupItem_run_mode_ids",
        "StartupItem_run_modes",
        "StartupItem_run_state",
        "StartupItem_run_state_id",
        "StartupItem_start_type",
        "StartupItem_start_type_id",
        "StartupItem_type",
        "StartupItem_type_id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/StartupItem",
      "rules": [
        {
          "postconditions": {
            "exactly_one_of": [
              {
                "slot_conditions": [
                  {
                    "name": "driver",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "job",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "process",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "OCSF just_one: exactly one of ['driver', 'job', 'process'] must be set.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
    {
      "name": "ThreatActor",
      "definition_uri": "https://w3id.org/lmodel/ocsf/ThreatActor",

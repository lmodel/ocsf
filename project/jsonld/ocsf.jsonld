    },
    {
      "name": "PrivilegeAttackInfo",
      "definition_uri": "https://w3id.org/lmodel/ocsf/PrivilegeAttackInfo",
      "description": "The Privilege Attack Info object groups privileges by the potential attack they\ncould enable. It maps specific privileges to MITRE ATT&CK techniques, helping\nidentify security risks associated with granted permissions.",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "aliases": [
        "Privilege Attack Info"
      ],
      "is_a": "Object",
      "slots": [
        "PrivilegeAttackInfo_attack",
        "PrivilegeAttackInfo_privilege_info_list"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/PrivilegeAttackInfo",
      "@type": "ClassDefinition"
    },
    {
      "name": "PrivilegeInfo",
      "definition_uri": "https://w3id.org/lmodel/ocsf/PrivilegeInfo",
      "description": "The Privilege Info object describes information about a specific privilege,\naction, or permission. It captures the privilege name, type, usage status, and\nwhen it was last used.",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "aliases": [
        "Privilege Info"
      ],
      "is_a": "Object",
      "slots": [
        "PrivilegeInfo_is_unused",
        "PrivilegeInfo_last_used_time",
        "PrivilegeInfo_name",
        "PrivilegeInfo_type",
        "PrivilegeInfo_type_id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/PrivilegeInfo",
      "@type": "ClassDefinition"
    },
    {
      "name": "ProgrammaticCredential",
      "definition_uri": "https://w3id.org/lmodel/ocsf/ProgrammaticCredential",
      "description": "The Programmatic Credential object describes service-specific credentials used\nfor direct API access and system integration. These credentials are typically\nissued by individual services or platforms for accessing their APIs and\nresources, focusing on credential lifecycle management and usage tracking.\nExamples include API keys, service account keys, client certificates, and\nvendor-specific access tokens.",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "aliases": [
        "Programmatic Credential"
      ],
      "is_a": "Object",
      "slots": [
        "ProgrammaticCredential_last_used_time",
        "ProgrammaticCredential_type",
        "ProgrammaticCredential_uid"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/ProgrammaticCredential",
      "@type": "ClassDefinition"
    },
    {
      "name": "QueryEvidence",
      "definition_uri": "https://w3id.org/lmodel/ocsf/QueryEvidence",
      "annotations": [
        {
          "tag": "ocsf_constraints",
          "value": "{\"just_one\": [\"connection_info\", \"file\", \"folder\", \"group\", \"job\", \"kernel\",\n\"module\", \"network_interfaces\", \"peripheral_device\", \"process\", \"service\",\n\"session\", \"startup_item\", \"user\"]}",
          "@type": "Annotation"
        }
      ],
      "description": "The specific resulting evidence information that was queried or discovered.\nWhen mapping raw telemetry data users should select the appropriate child\nobject that best matches the evidence type as defined by query_type_id.",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "aliases": [
        "Query Evidence"
      ],
      "is_a": "OcsfObject",
      "slots": [
        "QueryEvidence_connection_info",
        "QueryEvidence_file",
        "QueryEvidence_folder",
        "QueryEvidence_group",
        "QueryEvidence_job",
        "QueryEvidence_kernel",
        "QueryEvidence_module",
        "QueryEvidence_network_interfaces",
        "QueryEvidence_peripheral_device",
        "QueryEvidence_process",
        "QueryEvidence_query_type",
        "QueryEvidence_query_type_id",
        "QueryEvidence_service",
        "QueryEvidence_session",
        "QueryEvidence_startup_item",
        "QueryEvidence_state",
        "QueryEvidence_tcp_state_id",
        "QueryEvidence_user",
        "QueryEvidence_users"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/QueryEvidence",
      "rules": [
        {
          "postconditions": {
            "exactly_one_of": [
              {
                "slot_conditions": [
                  {
                    "name": "connection_info",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "file",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "folder",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "group",
                    "required": true,
                    "@type": "SlotDefinition"
                  }

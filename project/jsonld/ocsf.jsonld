    },
    {
      "name": "AccessAnalysisResult_accessors",
      "definition_uri": "https://w3id.org/lmodel/ocsf/accessors",
      "description": "The identities that are granted access through the analyzed policy\nconfiguration. This identifies the specific entity that can exercise the\npermissions and helps assess the access relationship and potential security\nimplications. Examples include user accounts, service principals, roles,\naccount identifiers, or system identities.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Accessors"
      ],

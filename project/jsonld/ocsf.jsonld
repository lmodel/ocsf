        },
        {
          "text": "DELETE",
          "description": "The DELETE method deletes the specified resource.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "DELETE"
            },
            {
              "tag": "caption",
              "value": "Delete"
            }
          ]
        },
        {
          "text": "GET",
          "description": "The GET method requests a representation of the specified resource. Requests\nusing GET should only retrieve data.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "GET"
            },
            {
              "tag": "caption",
              "value": "Get"
            }
          ]
        },
        {
          "text": "HEAD",
          "description": "The HEAD method asks for a response identical to a GET request, but without the\nresponse body.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "HEAD"
            },
            {
              "tag": "caption",
              "value": "Head"
            }
          ]
        },
        {
          "text": "OPTIONS",
          "description": "The OPTIONS method describes the communication options for the target resource.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "OPTIONS"
            },
            {
              "tag": "caption",
              "value": "Options"
            }
          ]
        },
        {
          "text": "PATCH",
          "description": "The PATCH method applies partial modifications to a resource.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "PATCH"
            },
            {
              "tag": "caption",
              "value": "Patch"
            }
          ]
        },
        {
          "text": "POST",
          "description": "The POST method submits an entity to the specified resource, often causing a\nchange in state or side effects on the server.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "POST"
            },
            {
              "tag": "caption",
              "value": "Post"
            }
          ]
        },
        {
          "text": "PUT",
          "description": "The PUT method replaces all current representations of the target resource with\nthe request payload.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "PUT"
            },
            {
              "tag": "caption",
              "value": "Put"
            }
          ]
        },
        {
          "text": "TRACE",
          "description": "The TRACE method performs a message loop-back test along the path to the target\nresource.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "TRACE"
            },
            {
              "tag": "caption",
              "value": "Trace"
            }
          ]
        }
      ]
    },

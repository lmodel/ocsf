      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/Observable",
      "@type": "ClassDefinition"
    },
    {
      "name": "Observation",
      "definition_uri": "https://w3id.org/lmodel/ocsf/Observation",
      "description": "A record of an observed value or event that captures the timing and frequency\nof its occurrence. Used to track when values/events were first detected, last\ndetected, and their total occurrence count.",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "aliases": [
        "Observation"
      ],
      "exact_mappings": [
        "uco_master:Observation"
      ],
      "is_a": "Object",
      "slots": [
        "Observation_count",
        "Observation_timespan",
        "Observation_value"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/Observation",
      "@type": "ClassDefinition"
    },
    {
      "name": "OccurrenceDetails",
      "definition_uri": "https://w3id.org/lmodel/ocsf/OccurrenceDetails",
      "annotations": [
        {
          "tag": "ocsf_constraints",
          "value": "{\"at_least_one\": [\"cell_name\", \"column_name\", \"column_number\", \"end_line\",\n\"json_path\", \"page_number\", \"record_index_in_array\", \"row_number\",\n\"start_line\"]}",
          "@type": "Annotation"
        }
      ],
      "description": "Details about where in the target entity, specified information was discovered.\nOnly the attributes, relevant to the target entity type should be populated.",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "aliases": [
        "Occurrence Details"
      ],
      "is_a": "Object",
      "slots": [
        "OccurrenceDetails_cell_name",
        "OccurrenceDetails_column_name",
        "OccurrenceDetails_column_number",
        "OccurrenceDetails_end_line",
        "OccurrenceDetails_json_path",
        "OccurrenceDetails_page_number",
        "OccurrenceDetails_record_index_in_array",
        "OccurrenceDetails_row_number",
        "OccurrenceDetails_start_line"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/OccurrenceDetails",
      "rules": [
        {
          "postconditions": {
            "any_of": [
              {
                "slot_conditions": [
                  {
                    "name": "cell_name",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "column_name",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "column_number",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "end_line",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "json_path",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "page_number",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "record_index_in_array",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "row_number",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "start_line",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "OCSF at_least_one: at least one of ['cell_name', 'column_name',\n'column_number', 'end_line', 'json_path', 'page_number',\n'record_index_in_array', 'row_number', 'start_line'] must be set.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
    {
      "name": "Os",

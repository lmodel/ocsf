    {
      "name": "AutonomousSystem",
      "definition_uri": "https://w3id.org/lmodel/ocsf/AutonomousSystem",
      "annotations": [
        {
          "tag": "ocsf_constraints",
          "value": "{\"at_least_one\": [\"number\", \"name\"]}",
          "@type": "Annotation"
        }
      ],
      "description": "An autonomous system (AS) is a collection of connected Internet Protocol (IP)\nrouting prefixes under the control of one or more network operators on behalf\nof a single administrative entity or domain that presents a common, clearly\ndefined routing policy to the internet.",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "aliases": [
        "Autonomous System"
      ],
      "exact_mappings": [
        "stix:AutonomousSystem",
        "uco_master:AutonomousSystem"
      ],
      "is_a": "Object",
      "slots": [
        "AutonomousSystem_name",
        "AutonomousSystem_number"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/AutonomousSystem",
      "rules": [
        {
          "postconditions": {
            "any_of": [
              {
                "slot_conditions": [
                  {
                    "name": "number",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {

    {
      "name": "OsintTlpEnum",
      "definition_uri": "https://w3id.org/lmodel/ocsf/OsintTlpEnum",
      "description": "The <a target='_blank' href='https://www.first.org/tlp/'>Traffic Light\nProtocol</a> was created to facilitate greater sharing of potentially sensitive\ninformation and more effective collaboration. TLP provides a simple and\nintuitive schema for indicating with whom potentially sensitive information can\nbe shared.",
      "from_schema": "https://w3id.org/lmodel/ocsf/enums",
      "permissible_values": [
        {
          "text": "TLP_AMBER",
          "description": "TLP:AMBER is for limited disclosure, recipients can only spread this on a\nneed-to-know basis within their organization and its clients. Note that\nTLP:AMBER+STRICT restricts sharing to the organization only. Sources may use\nTLP:AMBER when information requires support to be effectively acted upon, yet\ncarries risk to privacy, reputation, or operations if shared outside of the\norganizations involved. Recipients may share TLP:AMBER information with members\nof their own organization and its clients, but only on a need-to-know basis to\nprotect their organization and its clients and prevent further harm. Note: if\nthe source wants to restrict sharing to the organization only, they must\nspecify TLP:AMBER+STRICT.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "AMBER"
            },
            {
              "tag": "caption",
              "value": "TLP:AMBER"
            }
          ]
        },
        {
          "text": "TLP_AMBER_STRICT",
          "description": "TLP:AMBER is for limited disclosure, recipients can only spread this on a\nneed-to-know basis within their organization and its clients. Note that\nTLP:AMBER+STRICT restricts sharing to the organization only. Sources may use\nTLP:AMBER when information requires support to be effectively acted upon, yet\ncarries risk to privacy, reputation, or operations if shared outside of the\norganizations involved. Recipients may share TLP:AMBER information with members\nof their own organization and its clients, but only on a need-to-know basis to\nprotect their organization and its clients and prevent further harm. Note: if\nthe source wants to restrict sharing to the organization only, they must\nspecify TLP:AMBER+STRICT.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "AMBER STRICT"
            },
            {
              "tag": "caption",
              "value": "TLP:AMBER+STRICT"
            }
          ]
        },
        {
          "text": "TLP_CLEAR",
          "description": "TLP:CLEAR denotes that recipients can spread this to the world, there is no\nlimit on disclosure. Sources may use TLP:CLEAR when information carries minimal\nor no foreseeable risk of misuse, in accordance with applicable rules and\nprocedures for public release. Subject to standard copyright rules, TLP:CLEAR\ninformation may be shared without restriction.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "CLEAR"
            },
            {
              "tag": "caption",
              "value": "TLP:CLEAR"
            }
          ]
        },
        {
          "text": "TLP_GREEN",
          "description": "TLP:GREEN is for limited disclosure, recipients can spread this within their\ncommunity. Sources may use TLP:GREEN when information is useful to increase\nawareness within their wider community. Recipients may share TLP:GREEN\ninformation with peers and partner organizations within their community, but\nnot via publicly accessible channels. TLP:GREEN information may not be shared\noutside of the community. Note: when \u201ccommunity\u201d is not defined, assume the\ncybersecurity/defense community.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "GREEN"
            },
            {
              "tag": "caption",
              "value": "TLP:GREEN"
            }
          ]
        },
        {
          "text": "TLP_RED",
          "description": "TLP:RED is for the eyes and ears of individual recipients only, no further\ndisclosure. Sources may use TLP:RED when information cannot be effectively\nacted upon without significant risk for the privacy, reputation, or operations\nof the organizations involved. Recipients may therefore not share TLP:RED\ninformation with anyone else. In the context of a meeting, for example, TLP:RED\ninformation is limited to those present at the meeting.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "RED"
            },
            {
              "tag": "caption",
              "value": "TLP:RED"
            }
          ]
        },
        {
          "text": "TLP_WHITE",
          "description": "TLP:WHITE and TLP:CLEAR may be used interchangeably, TLP:WHITE is the most up\nto date (as of TLP 2.0) usage.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "WHITE"
            },
            {
              "tag": "caption",
              "value": "TLP:WHITE"
            }
          ]
        }
      ]
    },

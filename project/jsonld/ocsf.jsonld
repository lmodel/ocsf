    {
      "name": "Cloud",
      "definition_uri": "https://w3id.org/lmodel/ocsf/Cloud",
      "description": "The Cloud object describes the cloud computing environment where an event or\nfinding originated. It provides comprehensive context about the cloud\ninfrastructure, including the cloud service provider, account or subscription\ndetails, organizational structure, geographic regions, availability zones, and\nlogical partitions.",

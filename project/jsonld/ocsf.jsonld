    {
      "name": "EvidenceInfo",
      "definition_uri": "https://w3id.org/lmodel/ocsf/EvidenceInfo",
      "annotations": [
        {
          "tag": "ocsf_event_uid",
          "value": 40,
          "@type": "Annotation"
        }
      ],
      "description": "Data collected directly from devices that represents forensic information\npulled, queried, or discovered from devices that may indicate malicious\nactivity. It contains a number of child objects, each representing a distinct\nevidence domain (network connections, file artifacts, registry entries, etc.).\nWhen mapping raw telemetry data users should select Query Evidence and then the\nappropriate child object that best matches the evidence type.",
      "in_subset": [
        "discovery_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/events",
      "aliases": [

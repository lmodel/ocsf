    {
      "name": "is_src_dst_assignment_known",
      "definition_uri": "https://w3id.org/lmodel/ocsf/is_src_dst_assignment_known",
      "description": "<code>true</code> denotes that <code>src_endpoint</code> and\n<code>dst_endpoint</code> correctly identify the initiator and responder\nrespectively. <code>false</code> denotes that the event source has arbitrarily\nassigned one peer to <code>src_endpoint</code> and the other to\n<code>dst_endpoint</code>, in other words that initiator and responder are not\nbeing asserted. This can occur, for example, when the event source is a network\nappliance that has not observed the initiation of a given connection. In the\nabsence of this attribute, interpretation of the initiator and responder is\nimplementation-specific.",
      "deprecated": "Use <code>initiator_id</code> instead, which provides richer semantics for\nbi-flow and asymmetric flow scenarios. (since 1.9.0)",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Source/Destination Assignment Known"
      ],
      "slot_uri": "https://w3id.org/lmodel/ocsf/is_src_dst_assignment_known",
      "owner": "NetworkActivity",
      "domain_of": [
        "NetworkActivity"
      ],
      "range": "boolean",
      "@type": "SlotDefinition"
    },

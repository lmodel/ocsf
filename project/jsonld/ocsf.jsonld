      "description": "The end timestamp of the span, essential for identifying latency and\nperformance bottlenecks. Like the start time, this timestamp is normalized\nacross the observability system to ensure consistency, even when events are\nrecorded across distributed services with unsynchronized clocks. Normalized\ntime allows for accurate duration calculations and helps observability tools\ntrack performance across services, regardless of the individual system time\nsettings.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "End Time"
      ],
      "is_a": "end_time",
      "domain": "Span",
      "slot_uri": "https://w3id.org/lmodel/ocsf/end_time",
      "alias": "end_time",
      "owner": "Span",
      "domain_of": [
        "Span"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "end_time",
      "range": "TimestampT",
      "required": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "Span_message",
      "definition_uri": "https://w3id.org/lmodel/ocsf/message",
      "description": "The message in a span (often referred to as a span event) serves as a way to\nrecord significant moments or occurrences during the span's lifecycle. This\ncontent typically manifests as log entries, annotations, or semi-structured\nevents as a string, providing additional granularity and context about what\nhappens at specific points during the execution of an operation.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Message"
      ],
      "is_a": "message",
      "domain": "Span",
      "slot_uri": "https://w3id.org/lmodel/ocsf/message",
      "alias": "message",
      "owner": "Span",
      "domain_of": [
        "Span"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "message",
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "Span_operation",
      "definition_uri": "https://w3id.org/lmodel/ocsf/operation",
      "description": "Describes an action performed in a span, such as API requests, database\nqueries, or computations.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Operation"
      ],
      "is_a": "operation",
      "domain": "Span",
      "slot_uri": "https://w3id.org/lmodel/ocsf/operation",

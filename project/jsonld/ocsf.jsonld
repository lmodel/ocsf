    },
    {
      "name": "Observable",
      "definition_uri": "https://w3id.org/lmodel/ocsf/Observable",
      "description": "The observable object is a pivot element that contains related information\nfound in many places in the event.",
      "notes": [
        "OCSF Observables FAQ \u2014\nhttps://github.com/ocsf/ocsf-docs/blob/main/Articles/Defining and Using\nObservables.md"
      ],
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "see_also": [
        "https://github.com/ocsf/ocsf-docs/blob/main/Articles/Defining%20and%20Using%20Observables.md"
      ],
      "aliases": [
        "Observable"

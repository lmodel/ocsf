    {
      "name": "ManagedEntity",
      "definition_uri": "https://w3id.org/lmodel/ocsf/ManagedEntity",
      "annotations": [
        {
          "tag": "ocsf_constraints",
          "value": "{\"at_least_one\": [\"name\", \"uid\", \"device\", \"group\", \"org\", \"policy\", \"user\"]}",
          "@type": "Annotation"
        }
      ],
      "description": "The Managed Entity object describes the type and version of an entity, such as\na user, device, or policy.  For types in the <code>type_id</code> enum list, an\nassociated attribute should be populated.  If the type of entity is not in the\n<code>type_id</code> list, information can be put into the <code>data</code>\nattribute, <code>type_id</code> should be 'Other' and the <code>type</code>\nattribute should label the entity type.",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "aliases": [
        "Managed Entity"
      ],
      "is_a": "Entity",
      "slots": [
        "ManagedEntity_data",
        "ManagedEntity_device",
        "ManagedEntity_email",
        "ManagedEntity_group",
        "location",
        "name",
        "ManagedEntity_org",
        "ManagedEntity_policy",
        "ManagedEntity_type",
        "ManagedEntity_type_id",
        "uid",
        "ManagedEntity_user",
        "ManagedEntity_version",
        "ManagedEntity_name",
        "ManagedEntity_uid"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/ManagedEntity",
      "rules": [
        {
          "postconditions": {
            "any_of": [
              {
                "slot_conditions": [
                  {
                    "name": "name",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "uid",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "device",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "group",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "org",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "policy",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "user",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "OCSF at_least_one: at least one of ['name', 'uid', 'device', 'group', 'org',\n'policy', 'user'] must be set.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
    {

        "is_exploit_available",
        "is_fix_available",
        "Vulnerability_kb_article_list",
        "kb_articles",
        "Vulnerability_last_seen_time",
        "packages",
        "Vulnerability_references",
        "related_vulnerabilities",
        "Vulnerability_remediation",
        "Vulnerability_severity",
        "Vulnerability_title",
        "Vulnerability_vendor_name"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/Vulnerability",
      "rules": [
        {
          "postconditions": {
            "exactly_one_of": [
              {
                "slot_conditions": [
                  {
                    "name": "advisory",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "cve",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "cwe",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "OCSF just_one: exactly one of ['advisory', 'cve', 'cwe'] must be set.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
    {

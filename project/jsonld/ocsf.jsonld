    {
      "name": "HttpCookie",
      "definition_uri": "https://w3id.org/lmodel/ocsf/HttpCookie",
      "description": "The HTTP Cookie object, also known as a web cookie or browser cookie, contains\ndetails and values pertaining to a small piece of data that a server sends to a\nuser's web browser. This data is then stored by the browser and sent back to\nthe server with subsequent requests, allowing the server to remember and track\ncertain information about the user's browsing session or preferences.",
      "notes": [
        "D3FEND\u2122 Ontology d3f:SessionCookie. \u2014\nhttps://d3fend.mitre.org/dao/artifact/d3f:SessionCookie/"
      ],
      "in_subset": [
        "objects_subset"
      ],

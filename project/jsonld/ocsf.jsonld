      "alias": "identity_activity_metrics",
      "owner": "IamAnalysisFinding",
      "domain_of": [
        "IamAnalysisFinding"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "identity_activity_metrics",
      "range": "IdentityActivityMetrics",
      "recommended": true,
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "IamAnalysisFinding_permission_analysis_results",
      "definition_uri": "https://w3id.org/lmodel/ocsf/permission_analysis_results",
      "annotations": [
        {
          "tag": "group",
          "value": "primary",
          "@type": "Annotation"
        }
      ],
      "description": "Describes analysis results of permissions, policies directly associated with an\nidentity (user, role, or service account). This evaluates what permissions an\nidentity has been granted through attached policies, which privileges are\nactively used versus unused, and identifies potential over-privileged access.\nUse this for identity-centric security assessments such as privilege audits,\ndormant permission discovery, and least-privilege compliance analysis.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Permission Analysis Results"
      ],
      "is_a": "permission_analysis_results",
      "domain": "IamAnalysisFinding",
      "slot_uri": "https://w3id.org/lmodel/ocsf/permission_analysis_results",
      "alias": "permission_analysis_results",
      "owner": "IamAnalysisFinding",
      "domain_of": [
        "IamAnalysisFinding"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "permission_analysis_results",
      "range": "PermissionAnalysisResult",
      "recommended": true,
      "multivalued": true,
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },

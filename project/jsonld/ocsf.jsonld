    {
      "name": "Container",
      "definition_uri": "https://w3id.org/lmodel/ocsf/Container",
      "annotations": [
        {
          "tag": "ocsf_constraints",
          "value": "{\"at_least_one\": [\"uid\", \"name\"]}",
          "@type": "Annotation"
        },
        {
          "tag": "observable_id",
          "value": 27,
          "@type": "Annotation"
        }
      ],
      "description": "The Container object describes an instance of a specific container. A container\nis a prepackaged, portable system image that runs isolated on an existing\nsystem using a container runtime like containerd.",
      "notes": [
        "D3FEND\u2122 Ontology d3f:ContainerProcess. \u2014\nhttps://d3fend.mitre.org/dao/artifact/d3f:ContainerProcess/"
      ],

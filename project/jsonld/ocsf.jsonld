              "value": "0"
            },
            {
              "tag": "caption",
              "value": "Unknown"
            }
          ]
        },
        {
          "text": "OTHER",
          "description": "The fix coverage is not mapped. See the <code>fix_coverage</code> attribute,\nwhich contains a data source specific value.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "99"
            },

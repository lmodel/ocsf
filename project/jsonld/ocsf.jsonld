    {
      "name": "Scim",
      "definition_uri": "https://w3id.org/lmodel/ocsf/Scim",
      "description": "The System for Cross-domain Identity Management (SCIM) Configuration object\nprovides a structured set of attributes related to SCIM protocols used for\nidentity provisioning and management across cloud-based platforms. It\nstandardizes user and group provisioning details, enabling identity\nsynchronization and lifecycle management with compatible Identity Providers\n(IdPs) and applications. SCIM is defined in <a target='_blank'\nhref='https://datatracker.ietf.org/doc/html/rfc7643'>RFC-7634</a>",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "aliases": [
        "SCIM"
      ],
      "is_a": "Object",
      "slots": [
        "Scim_auth_protocol",
        "Scim_auth_protocol_id",
        "Scim_created_time",

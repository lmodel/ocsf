        "NetworkProxyProfile_proxy_traffic",
        "LoadBalancerProfile_load_balancer",
        "activity_id",
        "connection_info",
        "device",
        "dst_endpoint",
        "TunnelActivity_protocol_name",
        "TunnelActivity_session",
        "src_endpoint",
        "traffic",
        "TunnelActivity_tunnel_interface",
        "TunnelActivity_tunnel_type",
        "TunnelActivity_tunnel_type_id",
        "TunnelActivity_user",
        "TunnelActivity_activity_id",
        "TunnelActivity_connection_info",
        "TunnelActivity_device",
        "TunnelActivity_dst_endpoint",
        "TunnelActivity_src_endpoint",
        "TunnelActivity_traffic"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/TunnelActivity",
      "rules": [
        {
          "postconditions": {
            "any_of": [
              {
                "slot_conditions": [
                  {
                    "name": "connection_info",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "session",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "src_endpoint",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "traffic",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "tunnel_interface",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "tunnel_type_id",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "OCSF at_least_one: at least one of ['connection_info', 'session',\n'src_endpoint', 'traffic', 'tunnel_interface', 'tunnel_type_id'] must be set.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },

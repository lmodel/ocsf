      "annotations": [
        {
          "tag": "group",
          "value": "context",
          "@type": "Annotation"
        }
      ],
      "description": "The normalized confidence refers to the accuracy of the rule that created the\nfinding. A rule with a low confidence means that the finding scope is wide and\nmay create finding reports that may not be malicious in nature.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",

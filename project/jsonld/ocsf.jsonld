      "class_uri": "https://w3id.org/lmodel/ocsf/CisBenchmark",
      "@type": "ClassDefinition"
    },
    {
      "name": "CisBenchmarkResult",
      "definition_uri": "https://w3id.org/lmodel/ocsf/CisBenchmarkResult",
      "description": "The CIS Benchmark Result object contains information as defined by the Center\nfor Internet Security (<a target='_blank'\nhref='https://www.cisecurity.org/cis-benchmarks/'>CIS</a>) benchmark result.\nCIS Benchmarks are a collection of best practices for securely configuring IT\nsystems, software, networks, and cloud infrastructure.",
      "deprecated": "Use the Compliance object with Checks object instead. (since 1.5.0)",
      "in_subset": [
        "objects_subset"
      ],

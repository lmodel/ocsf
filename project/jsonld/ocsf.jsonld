    {
      "name": "WindowsServiceErrorControlIdEnum",
      "definition_uri": "https://w3id.org/lmodel/ocsf/WindowsServiceErrorControlIdEnum",
      "description": "The normalized identifier of the service error control.",
      "from_schema": "https://w3id.org/lmodel/ocsf/enums",
      "permissible_values": [
        {
          "text": "UNKNOWN",
          "description": "The service error control is unknown.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "0"
            },
            {
              "tag": "caption",
              "value": "Unknown"
            }
          ]
        },
        {
          "text": "IGNORE",
          "description": "The startup program ignores the error and continues the startup operation.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "1"
            },
            {
              "tag": "caption",
              "value": "Ignore"
            }
          ]
        },
        {
          "text": "NORMAL",
          "description": "The startup program logs the error in the event log but continues the startup\noperation.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "2"
            },
            {
              "tag": "caption",
              "value": "Normal"
            }
          ]
        },
        {
          "text": "SEVERE",
          "description": "The startup program logs the error in the event log. If the last-known-good\nconfiguration is being started, the startup operation continues. Otherwise, the\nsystem is restarted with the last-known-good configuration.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "3"
            },
            {
              "tag": "caption",
              "value": "Severe"
            }
          ]
        },
        {
          "text": "CRITICAL",
          "description": "The startup program logs the error in the event log, if possible. If the\nlast-known-good configuration is being started, the startup operation fails.\nOtherwise, the system is restarted with the last-known good configuration.",

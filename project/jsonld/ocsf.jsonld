    {
      "name": "NetworkConnectionQueryStateIdEnum",
      "definition_uri": "https://w3id.org/lmodel/ocsf/NetworkConnectionQueryStateIdEnum",
      "description": "The state of the socket.",
      "from_schema": "https://w3id.org/lmodel/ocsf/enums",
      "permissible_values": [
        {
          "text": "UNKNOWN",
          "description": "The socket state is unknown.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "0"
            },
            {
              "tag": "caption",
              "value": "Unknown"
            }
          ]
        },
        {
          "text": "ESTABLISHED",
          "description": "The socket has an established connection between a local application and a\nremote peer.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "1"
            },
            {
              "tag": "caption",
              "value": "ESTABLISHED"
            }
          ]
        },
        {
          "text": "SYN_SENT",
          "description": "The socket is actively trying to establish a connection to a remote peer.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "2"
            },
            {
              "tag": "caption",
              "value": "SYN_SENT"
            }
          ]
        },
        {
          "text": "SYN_RECV",
          "description": "The socket has passively received a connection request from a remote peer.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "3"
            },
            {
              "tag": "caption",
              "value": "SYN_RECV"
            }
          ]
        },
        {
          "text": "FIN_WAIT1",
          "description": "The socket connection has been closed by the local application, the remote peer\nhas not yet acknowledged the close, and the system is waiting for it to close\nits half of the connection.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "4"
            },
            {
              "tag": "caption",
              "value": "FIN_WAIT1"
            }
          ]
        },
        {
          "text": "FIN_WAIT2",
          "description": "The socket connection has been closed by the local application, the remote peer\nhas acknowledged the close, and the system is waiting for it to close its half\nof the connection.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "5"
            },
            {
              "tag": "caption",
              "value": "FIN_WAIT2"
            }
          ]
        },
        {
          "text": "TIME_WAIT",
          "description": "The socket connection has been closed by the local application, the remote peer\nhas closed its half of the connection, and the system is waiting to be sure\nthat the remote peer received the last acknowledgement.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "6"
            },
            {
              "tag": "caption",
              "value": "TIME_WAIT"
            }
          ]
        },
        {
          "text": "CLOSED",
          "description": "The socket is not in use.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "7"
            },
            {
              "tag": "caption",
              "value": "CLOSED"
            }
          ]
        },
        {
          "text": "CLOSE_WAIT",
          "description": "The socket connection has been closed by the remote peer, and the system is\nwaiting for the local application to close its half of the connection.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "8"
            },
            {
              "tag": "caption",
              "value": "CLOSE_WAIT"
            }
          ]
        },
        {
          "text": "LAST_ACK",
          "description": "The socket connection has been closed by the remote peer, the local application\nhas closed its half of the connection, and the system is waiting for the remote\npeer to acknowledge the close.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "9"
            },
            {
              "tag": "caption",
              "value": "LAST_ACK"
            }
          ]
        },
        {
          "text": "LISTEN",
          "description": "The socket is listening for incoming connections.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "10"
            },
            {
              "tag": "caption",
              "value": "LISTEN"
            }
          ]
        },
        {
          "text": "CLOSING",
          "description": "The socket connection has been closed by the local application and the remote\npeer simultaneously, and the remote peer has not yet acknowledged the close\nattempt of the local application.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "11"
            },
            {
              "tag": "caption",
              "value": "CLOSING"
            }
          ]
        },

    },
    {
      "name": "Check_severity",
      "definition_uri": "https://w3id.org/lmodel/ocsf/severity",
      "description": "The severity level as defined in the source document. For example CIS\nBenchmarks, valid values are: <code>Level 1</code> (security-forward, essential\nsettings), <code>Level 2</code> (security-focused environment, more\nrestrictive), or <code>Scored/Not Scored</code> (whether compliance can be\nautomatically checked). For DISA STIG, valid values are: <code>CAT I</code>\n(maps to severity_id 5/Critical), <code>CAT II</code> (maps to severity_id\n4/High), or <code>CAT III</code> (maps to severity_id 3/Medium).",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Severity"
      ],
      "is_a": "severity",
      "domain": "Check",
      "slot_uri": "https://w3id.org/lmodel/ocsf/severity",
      "alias": "severity",
      "owner": "Check",
      "domain_of": [
        "Check"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "severity",
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "Check_severity_id",
      "definition_uri": "https://w3id.org/lmodel/ocsf/severity_id",
      "annotations": {
        "sibling": {
          "tag": "sibling",
          "value": "severity",
          "extensions": {},
          "annotations": {}
        }
      },
      "description": "The normalized severity identifier that maps severity levels to standard\nseverity levels. For example CIS Benchmark: <code>Level 2</code> maps to\n<code>4</code> (High), <code>Level 1</code> maps to <code>3</code> (Medium).\nFor DISA STIG: <code>CAT I</code> maps to <code>5</code> (Critical), <code>CAT\nII</code> maps to <code>4</code> (High), and <code>CAT III</code> maps to\n<code>3</code> (Medium).",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Severity ID"
      ],

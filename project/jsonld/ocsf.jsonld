    {
      "name": "Cve_type",
      "definition_uri": "https://w3id.org/lmodel/ocsf/type",
      "description": "<p>The vulnerability type as selected from a large dropdown menu during CVE\nrefinement.</p>Most frequently used vulnerability types are: <code>DoS</code>,\n<code>Code Execution</code>, <code>Overflow</code>, <code>Memory\nCorruption</code>, <code>Sql Injection</code>, <code>XSS</code>,\n<code>Directory Traversal</code>, <code>Http Response Splitting</code>,\n<code>Bypass something</code>, <code>Gain Information</code>, <code>Gain\nPrivileges</code>, <code>CSRF</code>, <code>File Inclusion</code>. For more\ninformation see <a target='_blank'\nhref='https://www.cvedetails.com/vulnerabilities-by-types.php'>Vulnerabilities\nBy Type</a> distributions.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Type"
      ],
      "is_a": "type",
      "domain": "Cve",
      "slot_uri": "https://w3id.org/lmodel/ocsf/type",
      "alias": "type",
      "owner": "Cve",
      "domain_of": [
        "Cve"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "type",
      "range": "string",
      "recommended": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "Cve_uid",
      "definition_uri": "https://w3id.org/lmodel/ocsf/uid",
      "description": "The Common Vulnerabilities and Exposures unique number assigned to a specific\ncomputer vulnerability. A CVE Identifier begins with 4 digits representing the\nyear followed by a sequence of digits that acts as a unique identifier. For\nexample: <code>CVE-2021-12345</code>.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Unique ID"
      ],
      "is_a": "uid",
      "domain": "Cve",
      "slot_uri": "https://w3id.org/lmodel/ocsf/uid",

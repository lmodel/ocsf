        "IncidentProfile_impact_id",
        "IncidentProfile_impact_score",
        "IncidentProfile_is_suspected_breach",
        "IncidentProfile_priority",
        "IncidentProfile_priority_id",
        "IncidentProfile_src_url",
        "IncidentProfile_ticket",
        "IncidentProfile_tickets",
        "IncidentProfile_verdict",
        "IncidentProfile_verdict_id",
        "ApplicationSecurityPostureFinding_application",
        "ApplicationSecurityPostureFinding_compliance",
        "ApplicationSecurityPostureFinding_remediation",
        "ApplicationSecurityPostureFinding_resources",
        "ApplicationSecurityPostureFinding_vulnerabilities"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/ApplicationSecurityPostureFinding",
      "rules": [
        {
          "postconditions": {
            "any_of": [
              {
                "slot_conditions": [
                  {
                    "name": "application",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "compliance",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "remediation",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "vulnerabilities",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "OCSF at_least_one: at least one of ['application', 'compliance', 'remediation',\n'vulnerabilities'] must be set.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
    {
      "name": "ComplianceFinding",
      "definition_uri": "https://w3id.org/lmodel/ocsf/ComplianceFinding",
      "annotations": [
        {
          "tag": "ocsf_event_uid",
          "value": 3,
          "@type": "Annotation"
        }
      ],
      "description": "Compliance Finding events describe results of evaluations performed against\nresources, to check compliance with various Industry Frameworks or Security\nStandards such as <code>NIST SP 800-53, CIS AWS Foundations Benchmark v1.4.0,\nISO/IEC 27001</code> etc. Note: if the event producer is a security control,\nthe <code>security_control</code> profile should be applied and its\n<code>attacks</code> information, if present, should be duplicated into the\n<code>finding_info</code> object. <br><strong>Note: </strong>If the Finding is\nan incident, i.e. requires incident workflow, also apply the\n<code>incident</code> profile or aggregate this finding into an <code>Incident\nFinding</code>.",
      "in_subset": [
        "findings_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/events",
      "aliases": [
        "Compliance Finding"
      ],

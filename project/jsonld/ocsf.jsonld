    {
      "name": "Authentication",
      "definition_uri": "https://w3id.org/lmodel/ocsf/Authentication",
      "annotations": [
        {
          "tag": "ocsf_constraints",
          "value": "{\"at_least_one\": [\"service\", \"dst_endpoint\"]}",
          "@type": "Annotation"
        },
        {
          "tag": "ocsf_event_uid",
          "value": 2,
          "@type": "Annotation"
        },
        {
          "tag": "associations",
          "value": "{\"actor.user\": [\"src_endpoint\"], \"dst_endpoint\": [\"user\"], \"src_endpoint\":\n[\"actor.user\"], \"user\": [\"dst_endpoint\"]}",
          "@type": "Annotation"
        }
      ],
      "description": "Authentication events report authentication session activities, including user\nattempts to log on or log off, regardless of success, as well as other key\nstages within the authentication process. These events are typically generated\nby authentication services, such as Kerberos, OIDC, or SAML, and may include\ninformation about the user, the authentication method used, and the status of\nthe authentication attempt.",
      "notes": [
        "D3FEND\u2122 Ontology d3f:AuthenticationEvent \u2014\nhttps://d3fend.mitre.org/event/d3f:AuthenticationEvent"
      ],

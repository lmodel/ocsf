    {
      "name": "AccessAnalysisResult",
      "definition_uri": "https://w3id.org/lmodel/ocsf/AccessAnalysisResult",
      "description": "The Access Analysis Result object describes access relationships and pathways\nbetween identities, resources, focusing on who can access what and through\nwhich mechanisms. This evaluates access levels (read/write/admin), access types\n(direct, cross-account, public, federated), and the conditions under which\naccess is granted. Use this for resource-centric security assessments such as\nexternal access discovery, public exposure analysis, etc.",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "aliases": [
        "Access Analysis Result"

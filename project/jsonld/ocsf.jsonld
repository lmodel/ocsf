    {
      "name": "ApplicationSecurityPostureFinding",
      "definition_uri": "https://w3id.org/lmodel/ocsf/ApplicationSecurityPostureFinding",
      "annotations": [
        {
          "tag": "ocsf_constraints",
          "value": "{\"at_least_one\": [\"application\", \"compliance\", \"remediation\",\n\"vulnerabilities\"]}",
          "@type": "Annotation"
        },
        {
          "tag": "ocsf_event_uid",
          "value": 7,
          "@type": "Annotation"
        }
      ],
      "description": "The Application Security Posture Finding event is a notification about any bug,\ndefect, deficiency, exploit, vulnerability, weakness or any other issue with\nsoftware and related systems. Application Security Posture Findings typically\ninvolve reporting on the greater context including compliance, impacted\nresources, remediation guidance, specific code defects, and/or vulnerability\nmetadata. Application Security Posture Findings can be reported by Threat &\nVulnerability Management (TVM) tools, Application Security Posture Management\n(ASPM) tools, or other similar tools. Note: if the event producer is a security\ncontrol, the <code>security_control</code> profile should be applied and its\n<code>attacks</code> information, if present, should be duplicated into the\n<code>finding_info</code> object. <br><strong>Note: </strong>If the Finding is\nan incident, i.e. requires incident workflow, also apply the\n<code>incident</code> profile or aggregate this finding into an <code>Incident\nFinding</code>.",
      "in_subset": [
        "findings_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/events",
      "aliases": [
        "Application Security Posture Finding"
      ],
      "is_a": "Finding",
      "mixins": [
        "IncidentProfile"
      ],
      "slots": [
        "BaseEvent_category_name",
        "BaseEvent_category_uid",
        "BaseEvent_class_name",
        "BaseEvent_class_uid",
        "BaseEvent_count",
        "BaseEvent_duration",
        "BaseEvent_enrichments",
        "BaseEvent_message",
        "BaseEvent_metadata",

      "class_uri": "https://w3id.org/lmodel/ocsf/AnomalyAnalysis",
      "@type": "ClassDefinition"
    },
    {
      "name": "Object",
      "definition_uri": "https://w3id.org/lmodel/ocsf/Object",
      "description": "An unordered collection of attributes. It defines a set of attributes available\nin all objects. It can be also used as a generic object to log objects that are\nnot otherwise defined by the schema.",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "aliases": [

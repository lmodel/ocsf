      "@type": "ClassDefinition"
    },
    {
      "name": "AnomalyAnalysis",
      "definition_uri": "https://w3id.org/lmodel/ocsf/AnomalyAnalysis",
      "description": "Describes the analysis of activity patterns and anomalies of target entities to\nidentify potential security threats, performance issues, or other deviations\nfrom established baselines. This includes monitoring and analyzing user\ninteractions, API usage, resource utilization, access patterns and other\nmeasured indicators.",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",

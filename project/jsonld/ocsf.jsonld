            {
              "tag": "ocsf_uid",
              "value": "2"
            },
            {
              "tag": "caption",
              "value": "Service Ticket"
            }
          ]
        },
        {
          "text": "IDENTITY_TOKEN",
          "description": "Identity (ID) Token for OIDC.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "3"
            },
            {
              "tag": "caption",
              "value": "Identity Token"
            }
          ]
        },
        {
          "text": "REFRESH_TOKEN",
          "description": "Refresh Token for OIDC.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "4"
            },
            {
              "tag": "caption",
              "value": "Refresh Token"
            }
          ]
        },
        {
          "text": "SAML_ASSERTION",
          "description": "Authentication Assertion for SAML.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "5"
            },
            {
              "tag": "caption",
              "value": "SAML Assertion"
            }
          ]
        },
        {
          "text": "CLIENT_TOKEN",
          "description": "Client Token issued by an Identity Provider (IdP) for application\nauthentication. Use this value for IdP-issued tokens used for\nservice-to-service authentication. Examples: Microsoft Entra ID Application\nRegistration client secrets, Okta API tokens, Auth0 Machine-to-Machine tokens.\nKey characteristic: These tokens are issued by Identity Providers, not by\nindividual services.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "6"
            },
            {
              "tag": "caption",
              "value": "Client Token"
            }
          ]
        },
        {
          "text": "API_TOKEN",
          "description": "A generic API token or API key used for authenticating API requests. Use this\nvalue for service-specific API authentication tokens that are NOT issued by\nIdentity Providers. Examples: REST API keys, GraphQL API keys, Stripe API keys,\nTwilio API keys, AWS API keys. Key characteristic: These tokens are issued by\nindividual services/platforms, not by Identity Providers.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "7"
            },
            {
              "tag": "caption",
              "value": "API Token"
            }
          ]
        },
        {
          "text": "OTHER",
          "description": "Other",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "99"
            },
            {
              "tag": "caption",
              "value": "Other"
            }
          ]
        }
      ]
    },
    {

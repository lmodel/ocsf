    {
      "name": "TokenTypeIdEnum",
      "definition_uri": "https://w3id.org/lmodel/ocsf/TokenTypeIdEnum",
      "description": "The normalized token type identifier. Valid values: 0 (Unknown), 1 (Ticket\nGranting Ticket - Kerberos), 2 (Service Ticket - Kerberos), 3 (Identity Token -\nOIDC), 4 (Refresh Token - OIDC), 5 (SAML Assertion), 6 (Client Token -\nIdP-issued), 7 (API Token - generic API keys), 99 (Other).",
      "from_schema": "https://w3id.org/lmodel/ocsf/enums",
      "permissible_values": [
        {
          "text": "UNKNOWN",
          "description": "The token type is unknown.",

    {
      "name": "Baseline",
      "definition_uri": "https://w3id.org/lmodel/ocsf/Baseline",
      "description": "Describes the baseline or expected behavior of a system, service, or component\nbased on historical observations and measurements. It establishes reference\npoints for comparison to detect anomalies, trends, and deviations from typical\npatterns.",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",

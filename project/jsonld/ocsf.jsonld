        "WindowsStartupItem_win_service"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/WindowsStartupItem",
      "rules": [
        {
          "postconditions": {
            "exactly_one_of": [
              {
                "slot_conditions": [
                  {
                    "name": "driver",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "job",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "process",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "win_service",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "OCSF just_one: exactly one of ['driver', 'job', 'process', 'win_service'] must\nbe set.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },

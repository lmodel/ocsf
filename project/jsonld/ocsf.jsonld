    {
      "name": "Span",
      "definition_uri": "https://w3id.org/lmodel/ocsf/Span",
      "description": "Represents a single unit of work or operation within a distributed trace. A\nspan typically tracks the execution of a request across a service, capturing\nimportant details such as the operation, timestamps, and status. Spans help\nbreak down the overall trace into smaller, manageable parts, enabling detailed\nanalysis of the performance and behavior of specific operations within the\nsystem. They are crucial for understanding latency, dependencies, and\nbottlenecks in complex distributed systems.",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "aliases": [
        "Span"
      ],
      "is_a": "Object",
      "slots": [
        "Span_duration",
        "Span_end_time",
        "Span_message",
        "Span_operation",
        "Span_parent_uid",
        "Span_service",
        "Span_start_time",
        "Span_status_code",
        "Span_uid"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/Span",
      "@type": "ClassDefinition"
    },

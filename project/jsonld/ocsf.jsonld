    {
      "name": "NetworkEvent_app_name",
      "definition_uri": "https://w3id.org/lmodel/ocsf/app_name",
      "annotations": [
        {
          "tag": "group",
          "value": "context",
          "@type": "Annotation"
        }
      ],
      "description": "The network application name identified by tools such as NBAR or App ID (e.g.,\nyoutube, facebook, webex). This represents a specific network application that\nuses standard protocols (such as https or quic) to deliver its service.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Application Name"
      ],
      "is_a": "app_name",
      "domain": "NetworkEvent",
      "slot_uri": "https://w3id.org/lmodel/ocsf/app_name",
      "alias": "app_name",
      "owner": "NetworkEvent",
      "domain_of": [
        "NetworkEvent"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "app_name",
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "NetworkEvent_app_protocol_name",
      "definition_uri": "https://w3id.org/lmodel/ocsf/app_protocol_name",
      "annotations": [
        {
          "tag": "group",
          "value": "context",
          "@type": "Annotation"
        }
      ],
      "description": "The application-layer (Layer 7) protocol name identified by deep packet inspection or packet parsing (e.g., <code>https</code>, <code>quic</code>, <code>ssh</code>, <code>dns</code>), expressed as an IANA-registered service name from the IANA Service Name and Transport Protocol Port Number Registry.\n\n<p><b>Note:</b> Port numbers alone are not always a reliable indicator of the actual application protocol in use.</p>",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Application Protocol Name"
      ],
      "is_a": "app_protocol_name",
      "domain": "NetworkEvent",
      "slot_uri": "https://w3id.org/lmodel/ocsf/app_protocol_name",
      "alias": "app_protocol_name",
      "owner": "NetworkEvent",
      "domain_of": [
        "NetworkEvent"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "app_protocol_name",
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "NetworkEvent_connection_info",
      "definition_uri": "https://w3id.org/lmodel/ocsf/connection_info",
      "annotations": [
        {
          "tag": "group",
          "value": "primary",
          "@type": "Annotation"
        }
      ],
      "description": "The network connection information.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",

      "from_schema": "https://w3id.org/lmodel/ocsf/enums",
      "permissible_values": [
        {
          "text": "SPDX",
          "description": "System Package Data Exchange (SPDX\u00ae) is an open standard capable of\nrepresenting systems with software components in as SBOMs (Software Bill of\nMaterials) and other AI, data and security references supporting a range of\nrisk management use cases. The SPDX specification is a freely available\ninternational open standard (ISO/IEC 5692:2021).",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "1"

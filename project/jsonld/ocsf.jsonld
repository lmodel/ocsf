    {
      "name": "Osint_confidence_id",
      "definition_uri": "https://w3id.org/lmodel/ocsf/confidence_id",
      "annotations": {
        "sibling": {
          "tag": "sibling",
          "value": "confidence",
          "extensions": {},
          "annotations": {}
        }
      },
      "description": "The normalized confidence refers to the accuracy of collected information\nrelated to the OSINT or how pertinent an indicator or analysis is to a specific\nevent or finding. A low confidence means that the information collected or\nanalysis conducted lacked detail or is not accurate enough to qualify an\nindicator as fully malicious.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Confidence ID"
      ],
      "is_a": "confidence_id",
      "domain": "Osint",

    },
    {
      "name": "Token_tenant_uid",
      "definition_uri": "https://w3id.org/lmodel/ocsf/tenant_uid",
      "description": "The unique identifier of the tenant or organization that owns the token or key,\nor the tenant context in which the token is authorized for use. This is\nparticularly relevant in multi-tenant Identity Provider scenarios where tokens\nare scoped to specific tenants.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Tenant UID"
      ],
      "is_a": "tenant_uid",
      "domain": "Token",

        "VendorAttributes_severity_id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/VendorAttributes",
      "@type": "ClassDefinition"
    },
    {
      "name": "Vulnerability",
      "definition_uri": "https://w3id.org/lmodel/ocsf/Vulnerability",
      "annotations": [
        {
          "tag": "ocsf_constraints",
          "value": "{\"just_one\": [\"advisory\", \"cve\", \"cwe\"]}",
          "@type": "Annotation"
        }
      ],
      "description": "The vulnerability is an unintended characteristic of a computing component or\nsystem configuration that multiplies the risk of an adverse event or a loss\noccurring either due to accidental exposure, deliberate attack, or conflict\nwith new system components.",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "aliases": [
        "Vulnerability Details"
      ],

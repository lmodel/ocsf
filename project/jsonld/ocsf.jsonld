              {
                "slot_conditions": [
                  {
                    "name": "user",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "OCSF just_one: exactly one of ['connection_info', 'file', 'folder', 'group',\n'job', 'kernel', 'module', 'network_interfaces', 'peripheral_device',\n'process', 'service', 'session', 'startup_item', 'user'] must be set.",
          "@type": "ClassRule"

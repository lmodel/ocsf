    {
      "name": "Cloud_account",
      "definition_uri": "https://w3id.org/lmodel/ocsf/account",
      "description": "The Account object containing details about the cloud account, subscription, or\nbilling unit where the event or finding was created. This object includes\nproperties such as the account name, unique identifier, type, labels, and\ntags.<br/><br/><strong>Examples:</strong><ul><li><strong>AWS:</strong> Account\nobject with <code>name</code>, <code>uid</code> (Account ID),\n<code>type</code>, and other account properties</li><li><strong>Azure:</strong>\nSubscription object with <code>name</code>, <code>uid</code> (Subscription ID),\n<code>type</code>, and subscription metadata</li><li><strong>GCP:</strong>\nProject object with <code>name</code>, <code>uid</code> (Project ID),\n<code>type</code>, and project attributes</li><li><strong>Oracle\nCloud:</strong> Compartment object with <code>name</code>, <code>uid</code>\n(Tenancy OCID), <code>type</code>, and compartment details</li></ul>",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Account"
      ],
      "is_a": "account",
      "domain": "Cloud",
      "slot_uri": "https://w3id.org/lmodel/ocsf/account",
      "alias": "account",
      "owner": "Cloud",
      "domain_of": [
        "Cloud"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "account",
      "range": "Account",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "Cloud_cloud_partition",
      "definition_uri": "https://w3id.org/lmodel/ocsf/cloud_partition",
      "description": "The logical grouping or isolated segment within a cloud provider's\ninfrastructure where the event or finding was created, often used for\ncompliance, governance, or regional\nseparation.<br/><br/><strong>Examples:</strong><ul><li><strong>AWS:</strong>\nPartition where the event occurred (<code>aws</code>, <code>aws-cn</code>,\n<code>aws-us-gov</code>)</li><li><strong>Azure:</strong> Cloud environment\nwhere the event occurred (<code>AzureCloud</code>,\n<code>AzureUSGovernment</code>, <code>AzureChinaCloud</code>)</li></ul>",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Cloud Partition"
      ],
      "is_a": "cloud_partition",
      "domain": "Cloud",
      "slot_uri": "https://w3id.org/lmodel/ocsf/cloud_partition",
      "alias": "cloud_partition",
      "owner": "Cloud",
      "domain_of": [
        "Cloud"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "cloud_partition",
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "Cloud_org",
      "definition_uri": "https://w3id.org/lmodel/ocsf/org",
      "description": "The Organization object containing details about the organizational unit or\nmanagement structure that governs the account, subscription, or project where\nthe event or finding was created. This object includes properties such as the\norganization name, unique identifier, type, and other organizational\nmetadata.<br/><br/><strong>Examples:</strong><ul><li><strong>AWS:</strong>\nOrganization object with <code>name</code>, <code>uid</code> (Organization ID),\n<code>type</code>, and other organizational\nproperties</li><li><strong>Azure:</strong> Management Group object with\n<code>name</code>, <code>uid</code> (Management Group ID), <code>type</code>,\nand management group metadata</li><li><strong>GCP:</strong> Organization object\nwith <code>name</code>, <code>uid</code> (Organization ID), <code>type</code>,\nand organizational attributes</li><li><strong>Oracle Cloud:</strong> Tenancy\nobject with <code>name</code>, <code>uid</code> (Tenancy OCID),\n<code>type</code>, and tenancy details</li></ul>",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Organization"
      ],
      "is_a": "org",
      "domain": "Cloud",
      "slot_uri": "https://w3id.org/lmodel/ocsf/org",
      "alias": "org",
      "owner": "Cloud",
      "domain_of": [
        "Cloud"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "org",
      "range": "Organization",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "Cloud_provider",
      "definition_uri": "https://w3id.org/lmodel/ocsf/provider",
      "description": "The unique name of the Cloud services provider where the event or finding was\ncreated. Examples include AWS, Azure, GCP (Google Cloud Platform), Oracle\nCloud, IBM Cloud, Alibaba Cloud, or other public, private, or hybrid cloud\nproviders.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Provider"
      ],
      "is_a": "provider",
      "domain": "Cloud",
      "slot_uri": "https://w3id.org/lmodel/ocsf/provider",
      "alias": "provider",
      "owner": "Cloud",
      "domain_of": [
        "Cloud"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "provider",
      "range": "string",
      "required": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "Cloud_region",
      "definition_uri": "https://w3id.org/lmodel/ocsf/region",
      "description": "The cloud region where the event or finding was created, as defined by the\ncloud\nprovider.<br/><br/><strong>Examples:</strong><ul><li><strong>AWS:</strong>\nRegion where the event occurred (<code>us-east-1</code>,\n<code>eu-west-1</code>)</li><li><strong>Azure:</strong> Region where the event\noccurred (<code>East US</code>, <code>West\nEurope</code>)</li><li><strong>GCP:</strong> Region where the event occurred\n(<code>us-central1</code>, <code>europe-west1</code>)</li><li><strong>Oracle\nCloud:</strong> Region where the event occurred (<code>us-ashburn-1</code>,\n<code>uk-london-1</code>)</li></ul>",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Region"
      ],
      "is_a": "region",
      "domain": "Cloud",
      "slot_uri": "https://w3id.org/lmodel/ocsf/region",
      "alias": "region",
      "owner": "Cloud",
      "domain_of": [
        "Cloud"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "region",
      "range": "string",
      "recommended": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "Cloud_zone",
      "definition_uri": "https://w3id.org/lmodel/ocsf/zone",
      "description": "The availability zone in the cloud region where the event or finding was\ncreated, as defined by the cloud\nprovider.<br/><br/><strong>Examples:</strong><ul><li><strong>AWS:</strong>\nAvailability zone where the event occurred (<code>us-east-1a</code>,\n<code>us-east-1b</code>)</li><li><strong>Azure:</strong> Availability zone\nwhere the event occurred (<code>1</code>, <code>2</code>, <code>3</code> within\na region)</li><li><strong>GCP:</strong> Availability zone where the event\noccurred (<code>us-central1-a</code>,\n<code>us-central1-b</code>)</li><li><strong>Oracle Cloud:</strong> Availability\nzone where the event occurred (<code>AD-1</code>, <code>AD-2</code>,\n<code>AD-3</code>)</li></ul>",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Network Zone"
      ],
      "is_a": "zone",
      "domain": "Cloud",
      "slot_uri": "https://w3id.org/lmodel/ocsf/zone",
      "alias": "zone",
      "owner": "Cloud",
      "domain_of": [
        "Cloud"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "zone",
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "Compliance_assessments",
      "definition_uri": "https://w3id.org/lmodel/ocsf/assessments",
      "description": "A list of assessments associated with the compliance requirements evaluation.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Assessments"
      ],
      "is_a": "assessments",
      "domain": "Compliance",
      "slot_uri": "https://w3id.org/lmodel/ocsf/assessments",
      "alias": "assessments",
      "owner": "Compliance",

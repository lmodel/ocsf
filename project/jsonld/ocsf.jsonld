    {
      "name": "AirborneBroadcastActivity",
      "definition_uri": "https://w3id.org/lmodel/ocsf/AirborneBroadcastActivity",
      "annotations": [
        {
          "tag": "ocsf_constraints",
          "value": "{\"at_least_one\": [\"aircraft\", \"unmanned_aerial_system\",\n\"unmanned_system_operating_area\"]}",
          "@type": "Annotation"
        },
        {
          "tag": "ocsf_event_uid",
          "value": 2,
          "@type": "Annotation"
        }
      ],
      "description": "Airborne Broadcast Activity events report the activity of any aircraft or\nunmanned system as reported and tracked by Automatic Dependent Surveillance -\nBroadcast (ADS-B) receivers. Based on the ADS-B standards described in <a\ntarget='_blank'\nhref='https://www.ecfr.gov/current/title-14/chapter-I/subchapter-F/part-91#91.225'>Code\nof Federal Regulations (CFR) Title 14 Chapter I Subchapter F Part 91</a> and in\nother general Federal Aviation Administration (FAA) supplemental orders and\nguidance described <a target='_blank'\nhref='https://www.faa.gov/about/office_org/headquarters_offices/avs/offices/afx/afs/afs400/afs410/ads-b'>here</a>.",
      "in_subset": [
        "unmanned_systems_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/events",
      "aliases": [
        "Airborne Broadcast Activity"
      ],
      "is_a": "UnmannedSystemsEvent",
      "slots": [
        "BaseEvent_activity_name",
        "BaseEvent_category_name",
        "BaseEvent_category_uid",
        "BaseEvent_class_name",
        "BaseEvent_class_uid",
        "BaseEvent_count",
        "BaseEvent_duration",
        "BaseEvent_end_time",
        "BaseEvent_enrichments",
        "BaseEvent_message",
        "BaseEvent_metadata",
        "BaseEvent_observables",
        "BaseEvent_raw_data",
        "BaseEvent_raw_data_hash",
        "BaseEvent_raw_data_size",
        "BaseEvent_severity",
        "BaseEvent_severity_id",
        "BaseEvent_start_time",
        "BaseEvent_status",
        "BaseEvent_status_code",
        "BaseEvent_status_detail",
        "BaseEvent_status_id",
        "BaseEvent_time",
        "BaseEvent_timezone_offset",
        "BaseEvent_type_name",
        "BaseEvent_type_uid",
        "BaseEvent_unmapped",
        "CloudProfile_api",
        "CloudProfile_cloud",
        "actor",
        "HostProfile_device",
        "OsintProfile_osint",
        "SecurityControlProfile_action",
        "SecurityControlProfile_action_id",
        "attacks",
        "authorizations",
        "SecurityControlProfile_confidence",
        "SecurityControlProfile_confidence_id",
        "SecurityControlProfile_confidence_score",
        "disposition",
        "SecurityControlProfile_disposition_id",
        "SecurityControlProfile_firewall_rule",
        "SecurityControlProfile_is_alert",
        "malware",
        "malware_scan_info",
        "SecurityControlProfile_policy",
        "SecurityControlProfile_risk_details",
        "SecurityControlProfile_risk_level",
        "SecurityControlProfile_risk_level_id",
        "SecurityControlProfile_risk_score",
        "UnmannedSystemsEvent_connection_info",
        "UnmannedSystemsEvent_proxy_endpoint",
        "UnmannedSystemsEvent_tls",
        "activity_id",
        "AirborneBroadcastActivity_aircraft",
        "dst_endpoint",
        "AirborneBroadcastActivity_protocol_name",
        "AirborneBroadcastActivity_rssi",
        "src_endpoint",
        "traffic",
        "AirborneBroadcastActivity_unmanned_aerial_system",
        "AirborneBroadcastActivity_unmanned_system_operating_area",
        "AirborneBroadcastActivity_unmanned_system_operator",
        "AirborneBroadcastActivity_activity_id",
        "AirborneBroadcastActivity_dst_endpoint",
        "AirborneBroadcastActivity_src_endpoint",
        "AirborneBroadcastActivity_traffic"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/AirborneBroadcastActivity",
      "rules": [
        {
          "postconditions": {
            "any_of": [
              {
                "slot_conditions": [
                  {
                    "name": "aircraft",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "unmanned_aerial_system",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "unmanned_system_operating_area",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "OCSF at_least_one: at least one of ['aircraft', 'unmanned_aerial_system',\n'unmanned_system_operating_area'] must be set.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
    {
      "name": "DroneFlightsActivity",
      "definition_uri": "https://w3id.org/lmodel/ocsf/DroneFlightsActivity",
      "annotations": [
        {
          "tag": "ocsf_constraints",
          "value": "{\"at_least_one\": [\"src_endpoint\", \"unmanned_aerial_system\",\n\"unmanned_system_operator\", \"unmanned_system_operating_area\"]}",
          "@type": "Annotation"
        },
        {
          "tag": "ocsf_event_uid",
          "value": 1,
          "@type": "Annotation"
        }
      ],
      "description": "Drone Flights Activity events report the activity of Unmanned Aerial Systems\n(UAS), their Operators, and mission-planning and authorization metadata as\nreported by the UAS platforms themselves, by Counter-UAS (CUAS) systems, or\nother remote monitoring or sensing infrastructure. Based on the Remote ID\ndefined in Standard Specification for Remote ID and Tracking (ASTM Designation:\nF3411-22a) <a target='_blank'\nhref='https://cdn.standards.iteh.ai/samples/112830/71297057ac42432880a203654f213709/ASTM-F3411-22a.pdf'>ASTM\nF3411-22a</a>",
      "in_subset": [
        "unmanned_systems_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/events",
      "aliases": [
        "Drone Flights Activity"
      ],
      "is_a": "UnmannedSystemsEvent",
      "slots": [

    {
      "name": "WindowsServiceActivityActivityIdEnum",
      "definition_uri": "https://w3id.org/lmodel/ocsf/WindowsServiceActivityActivityIdEnum",
      "description": "WindowsServiceActivity activity_id values.",
      "from_schema": "https://w3id.org/lmodel/ocsf/enums",
      "permissible_values": [
        {
          "text": "CREATE",
          "description": "A service is created, for example by calling <code>CreateService</code>. Refer\nto the <code>win_service</code> attribute for details.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "1"
            },
            {
              "tag": "caption",
              "value": "Create"
            }
          ]
        },
        {
          "text": "RECONFIGURE",
          "description": "A service is reconfigured, for example by calling\n<code>ChangeServiceConfig</code> or <code>ChangeServiceConfig2</code>. Refer to\nthe <code>win_service</code> attribute for details.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "2"
            },
            {
              "tag": "caption",
              "value": "Reconfigure"
            }
          ]
        },
        {
          "text": "START",
          "description": "A stopped service is started, for example by calling <code>StartService</code>.\nRefer to the <code>service</code> attribute for details.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "3"
            },
            {
              "tag": "caption",
              "value": "Start"
            }
          ]
        },
        {
          "text": "STOP",
          "description": "A running or paused service is stopped, for example by calling\n<code>ControlService</code> or <code>ControlServiceEx</code>. Refer to the\n<code>win_service</code> attribute for details.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "4"
            },
            {
              "tag": "caption",
              "value": "Stop"
            }
          ]
        },
        {
          "text": "PAUSE",
          "description": "A running service is paused, for example by calling <code>ControlService</code>\nor <code>ControlServiceEx</code>. Refer to the <code>win_service</code>\nattribute for details.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "5"
            },
            {
              "tag": "caption",
              "value": "Pause"
            }
          ]
        },
        {
          "text": "CONTINUE",
          "description": "A paused service is continued, for example by calling\n<code>ControlService</code> or <code>ControlServiceEx</code>. Refer to the\n<code>win_service</code> attribute for details.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "6"
            },
            {
              "tag": "caption",
              "value": "Continue"
            }
          ]
        },
        {
          "text": "DELETE",
          "description": "A service is deleted, for example by calling <code>DeleteService</code>. Refer\nto the <code>win_service</code> attribute for details.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "7"
            },
            {
              "tag": "caption",
              "value": "Delete"
            }
          ]
        },
        {
          "text": "UNKNOWN",
          "description": "The event activity is unknown.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "0"
            },
            {
              "tag": "caption",
              "value": "Unknown"
            }
          ]
        },
        {
          "text": "OTHER",
          "description": "The event activity is not mapped. See the <code>activity_name</code> attribute,\nwhich contains a data source specific value.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "99"
            },
            {
              "tag": "caption",
              "value": "Other"
            }
          ]
        }
      ]
    },
    {
      "name": "CategoryUidEnum",
      "definition_uri": "https://w3id.org/lmodel/ocsf/CategoryUidEnum",
      "description": "The normalized OCSF event category (see categories.json).",
      "from_schema": "https://w3id.org/lmodel/ocsf/categories",
      "permissible_values": [
        {
          "text": "APPLICATION_ACTIVITY",
          "description": "Application Activity events report detailed information about the behavior of\napplications and services.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": 6
            },
            {
              "tag": "category",
              "value": "application"
            }
          ]
        },
        {
          "text": "DISCOVERY",
          "description": "Discovery events report the existence and state of devices, files,\nconfigurations, processes, registry keys, and other objects.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": 5
            },
            {
              "tag": "category",
              "value": "discovery"
            }
          ]
        },
        {
          "text": "FINDINGS",
          "description": "Findings events report findings, detections, and possible resolutions of\nmalware, anomalies, or other actions performed by security products.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": 2
            },
            {
              "tag": "category",
              "value": "findings"
            }
          ]
        },
        {
          "text": "IDENTITY_ACCESS_MANAGEMENT",
          "description": "Identity & Access Management (IAM) events relate to the supervision of the\nsystem's authentication and access control model. Examples of such events are\nthe success or failure of authentication, granting of authority, password\nchange, entity change, privileged use etc.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": 3
            },
            {
              "tag": "category",
              "value": "iam"
            }
          ]
        },
        {
          "text": "NETWORK_ACTIVITY",
          "description": "Network Activity events.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": 4
            },
            {
              "tag": "category",
              "value": "network"
            }
          ]
        },
        {
          "text": "REMEDIATION",
          "description": "Remediation events report the results of remediation commands targeting files,\nprocesses, and other objects.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": 7
            },
            {
              "tag": "category",
              "value": "remediation"
            }
          ]
        },
        {
          "text": "SYSTEM_ACTIVITY",
          "description": "System Activity events.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": 1
            },
            {
              "tag": "category",
              "value": "system"
            }
          ]
        },
        {
          "text": "UNMANNED_SYSTEMS",
          "description": "Unmanned Systems events report the activity, existence, and/or state of\nunmanned systems for tracking, mission planning, and other related activities.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": 8
            },
            {
              "tag": "category",
              "value": "unmanned_systems"
            }
          ]
        }
      ]
    }
  ],
  "slots": [
    {
      "name": "access_analysis_result",
      "definition_uri": "https://w3id.org/lmodel/ocsf/access_analysis_result",
      "description": "Describes access relationships and pathways between identities, resources,\nfocusing on who can access what and through which mechanisms. This evaluates\naccess levels (read/write/admin), access types (direct, cross-account, public,\nfederated), and the conditions under which access is granted. Use this for\nresource-centric security assessments such as external access discovery, public\nexposure analysis, etc.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Access Analysis Result"
      ],
      "slot_uri": "https://w3id.org/lmodel/ocsf/access_analysis_result",
      "owner": "IamAnalysisFinding",
      "domain_of": [
        "IamAnalysisFinding"
      ],
      "range": "AccessAnalysisResult",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "access_level",
      "definition_uri": "https://w3id.org/lmodel/ocsf/access_level",

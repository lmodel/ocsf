    {
      "name": "Url_domain",
      "definition_uri": "https://w3id.org/lmodel/ocsf/domain",
      "description": "The domain portion of the URL. For example: <code>example.com</code> in\n<code>https://sub.example.com</code>.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Domain"
      ],
      "is_a": "domain",
      "domain": "Url",
      "slot_uri": "https://w3id.org/lmodel/ocsf/domain",
      "alias": "domain",
      "owner": "Url",
      "domain_of": [
        "Url"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "domain",
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "Url_hostname",

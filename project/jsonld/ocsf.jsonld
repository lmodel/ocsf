    {
      "name": "GraphQueryLanguageIdEnum",
      "definition_uri": "https://w3id.org/lmodel/ocsf/GraphQueryLanguageIdEnum",
      "description": "The normalized identifier of a graph query language that can be used to\ninteract with the graph.",
      "from_schema": "https://w3id.org/lmodel/ocsf/enums",
      "permissible_values": [
        {
          "text": "CYPHER",
          "description": "A declarative graph query language developed by Neo4j that allows for\nexpressive and efficient querying of graph databases.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "1"
            },
            {
              "tag": "caption",
              "value": "Cypher"
            }
          ]
        },
        {
          "text": "GRAPHQL",
          "description": "A query language for APIs that enables declarative data fetching and provides a\ncomplete description of the data in the API.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "2"
            },
            {
              "tag": "caption",
              "value": "GraphQL"
            }
          ]
        },
        {
          "text": "GREMLIN",
          "description": "A graph traversal language and virtual machine developed by Apache TinkerPop\nthat enables graph computing across different graph databases.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "3"
            },
            {
              "tag": "caption",
              "value": "Gremlin"
            }
          ]
        },
        {
          "text": "GQL",
          "description": "An ISO standard graph query language designed to provide a unified way to query\ngraph databases.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "4"
            },
            {
              "tag": "caption",
              "value": "GQL"
            }
          ]
        },
        {
          "text": "G_CORE",
          "description": "A graph query language that combines features from existing languages while\nadding support for paths as first-class citizens.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "5"
            },
            {
              "tag": "caption",
              "value": "G-CORE"
            }
          ]
        },
        {
          "text": "PGQL",
          "description": "Property Graph Query Language developed by Oracle that provides SQL-like syntax\nfor querying property graphs.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "6"
            },
            {
              "tag": "caption",
              "value": "PGQL"
            }
          ]
        },
        {
          "text": "SPARQL",
          "description": "A semantic query language for databases that enables querying and manipulating\ndata stored in RDF format.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "7"
            },
            {
              "tag": "caption",
              "value": "SPARQL"
            }
          ]
        },
        {
          "text": "UNKNOWN",
          "description": "The Query Language is unknown.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "0"
            },
            {
              "tag": "caption",
              "value": "Unknown"
            }
          ]
        },
        {
          "text": "OTHER",
          "description": "The Query Language is not mapped. See the <code>query_language</code>\nattribute, which contains a data source specific value.",
          "annotations": [
            {
              "tag": "ocsf_uid",
              "value": "99"
            },
            {
              "tag": "caption",
              "value": "Other"
            }
          ]
        }
      ]
    },
    {
      "name": "HttpRequestHttpMethodEnum",
      "definition_uri": "https://w3id.org/lmodel/ocsf/HttpRequestHttpMethodEnum",
      "description": "The <a target='_blank'\nhref='https://developer.mozilla.org/en-US/docs/Web/HTTP/Methods'>HTTP request\nmethod</a> indicates the desired action to be performed for a given resource.",
      "from_schema": "https://w3id.org/lmodel/ocsf/enums",
      "permissible_values": [
        {
          "text": "CONNECT",
          "description": "The CONNECT method establishes a tunnel to the server identified by the target\nresource.",

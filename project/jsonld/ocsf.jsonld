      "@type": "SlotDefinition"
    },
    {
      "name": "Span_start_time",
      "definition_uri": "https://w3id.org/lmodel/ocsf/start_time",
      "description": "The start timestamp of the span, essential for identifying latency and\nperformance bottlenecks. This timestamp is normalized across the observability\nsystem, ensuring consistency even when events occur across distributed services\nwith potentially unsynchronized clocks. By using normalized time, observability\ntools can provide accurate, uniform measurements of operation performance and\nlatency, regardless of where or when the events actually occur.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Start Time"
      ],
      "is_a": "start_time",
      "domain": "Span",
      "slot_uri": "https://w3id.org/lmodel/ocsf/start_time",
      "alias": "start_time",
      "owner": "Span",
      "domain_of": [
        "Span"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "start_time",
      "range": "TimestampT",
      "required": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "Span_status_code",
      "definition_uri": "https://w3id.org/lmodel/ocsf/status_code",
      "description": "Indicates the outcome of the operation in the span, such as success, failure,\nor error. Issues in a span typically refer to problems such as failed\noperations, timeouts, service unavailability, or errors in processing that can\nnegatively impact the performance or reliability of the system. Tracking the\n`status_code` helps pinpoint these issues, enabling quicker identification and\nresolution of system inefficiencies or faults.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Status Code"
      ],
      "is_a": "status_code",
      "domain": "Span",
      "slot_uri": "https://w3id.org/lmodel/ocsf/status_code",
      "alias": "status_code",
      "owner": "Span",
      "domain_of": [
        "Span"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "status_code",
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "Span_uid",
      "definition_uri": "https://w3id.org/lmodel/ocsf/uid",
      "description": "The unique identifier for the span, used in distributed systems and\nmicroservices architectures to track and correlate requests across different\ncomponents of an application. It enables tracing the flow of a request through\nvarious services.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Unique ID"
      ],
      "is_a": "uid",
      "domain": "Span",
      "slot_uri": "https://w3id.org/lmodel/ocsf/uid",
      "alias": "uid",
      "owner": "Span",
      "domain_of": [
        "Span"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "uid",
      "range": "string",
      "required": true,
      "@type": "SlotDefinition"
    },

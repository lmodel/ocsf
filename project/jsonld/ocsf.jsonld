      "annotations": [
        {
          "tag": "ocsf_constraints",
          "value": "{\"just_one\": [\"driver\", \"job\", \"process\", \"win_service\"]}",
          "@type": "Annotation"
        },
        {
          "tag": "ocsf_extension",
          "value": "windows",
          "@type": "Annotation"
        }
      ],
      "description": "The startup item object describes an application component that has associated\nstartup criteria and configurations.",
      "in_subset": [
        "windows_extension_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/extensions",
      "aliases": [
        "Startup Item"
      ],

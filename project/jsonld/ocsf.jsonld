      "definition_uri": "https://w3id.org/lmodel/ocsf/impact_id",
      "annotations": [
        {
          "tag": "group",
          "value": "context",
          "@type": "Annotation"
        }
      ],
      "description": "The normalized impact of the incident or finding. Per NIST, this is the\nmagnitude of harm that can be expected to result from the consequences of\nunauthorized disclosure, modification, destruction, or loss of information or\ninformation system availability.",
      "notes": [
        "NIST SP 800-172 from FIPS 199 \u2014 https://doi.org/10.6028/NIST.FIPS.199",
        "NIST Computer Security Resource Center \u2014 https://doi.org/10.6028/NIST.FIPS.199"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "see_also": [
        "https://doi.org/10.6028/NIST.FIPS.199",
        "https://doi.org/10.6028/NIST.FIPS.199"
      ],
      "aliases": [
        "Impact ID"
      ],
      "is_a": "IncidentProfile_impact_id",
      "domain": "DetectionFinding",
      "slot_uri": "https://w3id.org/lmodel/ocsf/impact_id",
      "alias": "impact_id",
      "owner": "DetectionFinding",
      "domain_of": [
        "DetectionFinding"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "impact_id",
      "range": "ImpactIdEnum",
      "recommended": true,
      "@type": "SlotDefinition"
    },

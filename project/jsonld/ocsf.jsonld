      "@type": "ClassDefinition"
    },
    {
      "name": "Check",
      "definition_uri": "https://w3id.org/lmodel/ocsf/Check",
      "description": "The check object defines a specific, testable compliance verification point\nthat evaluates a target device against a standard, framework, or custom\nrequirement. While checks are typically associated with formal standards (like\nCIS, NIST, or ISO), they can also represent custom or organizational\nrequirements. When mapped to controls, checks can evaluate specific\ncontrol_parameters to determine compliance status, but neither the control\nmapping nor control_parameters are required for a valid check.",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "aliases": [
        "Check"
      ],
      "is_a": "Object",
      "slots": [
        "Check_desc",
        "Check_name",
        "Check_resource",
        "Check_severity",
        "Check_severity_id",
        "Check_standards",
        "Check_status",
        "Check_status_id",
        "Check_uid",
        "Check_version"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/ocsf/Check",
      "@type": "ClassDefinition"
    },
    {
      "name": "CisBenchmark",
      "definition_uri": "https://w3id.org/lmodel/ocsf/CisBenchmark",
      "description": "The CIS Benchmark object describes best practices for securely configuring IT\nsystems, software, networks, and cloud infrastructure as defined by the <a\ntarget='_blank' href='https://www.cisecurity.org/cis-benchmarks/'>Center for\nInternet Security</a>. See also <a target='_blank'\nhref='https://www.cisecurity.org/insights/blog/getting-to-know-the-cis-benchmarks'>Getting\nto Know the CIS Benchmarks</a>.",
      "deprecated": "Use the Compliance object with Checks object instead. (since 1.5.0)",
      "in_subset": [
        "objects_subset"
      ],
      "from_schema": "https://w3id.org/lmodel/ocsf/objects",
      "aliases": [
        "CIS Benchmark"
      ],
      "is_a": "Object",
      "slots": [

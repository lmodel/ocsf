      "usage_slot_name": "status_id",
      "range": "FindingStatusIdEnum",
      "recommended": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "Finding_vendor_attributes",
      "definition_uri": "https://w3id.org/lmodel/ocsf/vendor_attributes",
      "annotations": [
        {
          "tag": "group",
          "value": "context",
          "@type": "Annotation"
        }
      ],
      "description": "The Vendor Attributes object can be used to represent values of attributes\npopulated by the Vendor/Finding Provider. It can help distinguish between the\nvendor-provided values and consumer-updated values, of key attributes like\n<code>severity_id</code>.<br>The original finding producer should not populate\nthis object. It should be populated by consuming systems that support data\nmutability.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Vendor Attributes"
      ],
      "is_a": "vendor_attributes",
      "domain": "Finding",
      "slot_uri": "https://w3id.org/lmodel/ocsf/vendor_attributes",
      "alias": "vendor_attributes",
      "owner": "Finding",
      "domain_of": [
        "Finding"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "vendor_attributes",
      "range": "VendorAttributes",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "IamAnalysisFinding_access_analysis_result",
      "definition_uri": "https://w3id.org/lmodel/ocsf/access_analysis_result",
      "annotations": [
        {
          "tag": "group",
          "value": "context",
          "@type": "Annotation"
        }
      ],
      "description": "Describes access relationships and pathways between identities, resources,\nfocusing on who can access what and through which mechanisms. This evaluates\naccess levels (read/write/admin), access types (direct, cross-account, public,\nfederated), and the conditions under which access is granted. Use this for\nresource-centric security assessments such as external access discovery, public\nexposure analysis, etc.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Access Analysis Result"
      ],
      "is_a": "access_analysis_result",
      "domain": "IamAnalysisFinding",
      "slot_uri": "https://w3id.org/lmodel/ocsf/access_analysis_result",
      "alias": "access_analysis_result",
      "owner": "IamAnalysisFinding",
      "domain_of": [
        "IamAnalysisFinding"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "access_analysis_result",
      "range": "AccessAnalysisResult",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "IamAnalysisFinding_applications",
      "definition_uri": "https://w3id.org/lmodel/ocsf/applications",
      "annotations": [
        {
          "tag": "group",
          "value": "primary",
          "@type": "Annotation"
        }
      ],
      "description": "Details about applications, services, or systems that are accessible based on\nthe IAM analysis. For identity-centric analysis, this represents applications\nthe identity can access. For resource-centric analysis, this represents\napplications that can access the resource.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Applications"
      ],
      "is_a": "applications",
      "domain": "IamAnalysisFinding",
      "slot_uri": "https://w3id.org/lmodel/ocsf/applications",
      "alias": "applications",
      "owner": "IamAnalysisFinding",
      "domain_of": [
        "IamAnalysisFinding"
      ],
      "is_usage_slot": true,
      "usage_slot_name": "applications",
      "range": "ApplicationObject",
      "recommended": true,
      "multivalued": true,
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "IamAnalysisFinding_identity_activity_metrics",
      "definition_uri": "https://w3id.org/lmodel/ocsf/identity_activity_metrics",
      "annotations": [
        {
          "tag": "group",
          "value": "primary",
          "@type": "Annotation"
        }
      ],
      "description": "Describes usage activity and other metrics of an Identity i.e. AWS IAM User,\nGCP IAM Principal, etc.",
      "from_schema": "https://w3id.org/lmodel/ocsf/dictionary",
      "aliases": [
        "Identity Activity Metrics"
      ],
      "is_a": "identity_activity_metrics",

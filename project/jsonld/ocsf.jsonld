              "tag": "ocsf_uid",
              "value": "5"
            },
            {
              "tag": "caption",
              "value": "Installation"
            }
          ]
        },
        {
          "text": "COMMAND_CONTROL",
          "description": "Malware opens a command channel to enable the intruders to remotely manipulate\nthe victim's system.",

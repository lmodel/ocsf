    {
      "name": "EmailActivityDirectionIdEnum",
      "definition_uri": "https://w3id.org/lmodel/ocsf/EmailActivityDirectionIdEnum",
      "description": "<p>The direction of the email relative to the scanning host or\norganization.</p>Email scanned at an internet gateway might be characterized as\ninbound to the organization from the Internet, outbound from the organization\nto the Internet, or internal within the organization. Email scanned at a\nworkstation might be characterized as inbound to, or outbound from the\nworkstation.",
      "from_schema": "https://w3id.org/lmodel/ocsf/enums",
      "permissible_values": [
        {
          "text": "UNKNOWN",
          "description": "The email direction is unknown.",
          "annotations": [

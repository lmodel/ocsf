    ocsf:ocsf_uid "2" .

<https://w3id.org/lmodel/ocsf/ProcessActivityActivityIdEnum#INJECT> a owl:Class ;
    rdfs:label "INJECT" ;
    rdfs:subClassOf ocsf:ProcessActivityActivityIdEnum ;
    skos:definition "A request by the actor to execute code within the context of a process. The target is usually a different process but this activity can also be reflexive. Refer to the <code>injection_type_id</code> attribute for details of the specific injection type." ;
    ocsf:caption "Inject" ;
    ocsf:ocsf_uid "4" .

<https://w3id.org/lmodel/ocsf/ProcessActivityActivityIdEnum#LAUNCH> a owl:Class ;
    rdfs:label "LAUNCH" ;
    rdfs:subClassOf ocsf:ProcessActivityActivityIdEnum ;
    skos:definition "A request by the actor to launch another process. Refer to the <code>launch_type_id</code> attribute for details of the specific launch type." ;
    ocsf:caption "Launch" ;
    ocsf:ocsf_uid "1" .

<https://w3id.org/lmodel/ocsf/ProcessActivityActivityIdEnum#OPEN> a owl:Class ;
    rdfs:label "OPEN" ;
    rdfs:subClassOf ocsf:ProcessActivityActivityIdEnum ;
    skos:definition "A request by the actor to obtain a handle or descriptor to a process with the aim of performing further actions upon that process. The target is usually a different process but this activity can also be reflexive." ;
    ocsf:caption "Open" ;
    ocsf:ocsf_uid "3" .

<https://w3id.org/lmodel/ocsf/ProcessActivityActivityIdEnum#OTHER> a owl:Class ;
    rdfs:label "OTHER" ;
    rdfs:subClassOf ocsf:ProcessActivityActivityIdEnum ;
    skos:definition "The event activity is not mapped. See the <code>activity_name</code> attribute, which contains a data source specific value." ;
    ocsf:caption "Other" ;
    ocsf:ocsf_uid "99" .

<https://w3id.org/lmodel/ocsf/ProcessActivityActivityIdEnum#SET_USER_ID> a owl:Class ;
    rdfs:label "SET_USER_ID" ;
    rdfs:subClassOf ocsf:ProcessActivityActivityIdEnum ;
    skos:definition "A request by the actor to change its user identity by invoking the <code>setuid()</code> system call. Common programs like <code>su</code> and <code>sudo</code> use this mechanism. Note that the <em>impersonation</em> mechanism on Windows is not directly equivalent because it acts at the thread level." ;
    ocsf:caption "Set User ID" ;
    ocsf:ocsf_uid "5" .

<https://w3id.org/lmodel/ocsf/ProcessActivityActivityIdEnum#TERMINATE> a owl:Class ;
    rdfs:label "TERMINATE" ;
    rdfs:subClassOf ocsf:ProcessActivityActivityIdEnum ;
    skos:definition "A request by the actor to terminate a process. This activity is most commonly reflexive, this being the case when a process exits at its own initiation. Note too that Windows security products cannot always identify the actor in the case of inter-process termination. In this case, <code>actor.process</code> and <code>process</code> refer to the exiting process, i.e. indistinguishable from the reflexive case." ;
    ocsf:caption "Terminate" ;
    ocsf:ocsf_uid "2" .

<https://w3id.org/lmodel/ocsf/ProcessActivityActivityIdEnum#UNKNOWN> a owl:Class ;
    rdfs:label "UNKNOWN" ;
    rdfs:subClassOf ocsf:ProcessActivityActivityIdEnum ;
    skos:definition "The event activity is unknown." ;
    ocsf:caption "Unknown" ;
    ocsf:ocsf_uid "0" .


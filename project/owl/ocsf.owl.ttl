ocsf:algorithm a owl:DatatypeProperty ;
    rdfs:label "algorithm" ;
    rdfs:range xsd:string ;
    skos:altLabel "Algorithm" ;
    skos:definition "The applicable algorithm, normalized to the caption of 'algorithm_id'. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:comment a owl:DatatypeProperty ;
    rdfs:label "comment" ;
    rdfs:range xsd:string ;
    skos:altLabel "Comment" ;
    skos:definition "The user-provided comment." ;
    skos:inScheme ocsf:dictionary .

ocsf:impact a owl:DatatypeProperty ;
    rdfs:label "impact" ;
    rdfs:range xsd:string ;
    skos:altLabel "Impact" ;
    skos:definition "The impact , normalized to the caption of the impact_id value. In the case of 'Other', it is defined by the event source." ;
    skos:inScheme ocsf:dictionary .

ocsf:impact_id a owl:ObjectProperty ;
    rdfs:label "impact_id" ;
    rdfs:range ocsf:ImpactIdEnum ;
    rdfs:seeAlso <https://doi.org/10.6028/NIST.FIPS.199> ;
    skos:altLabel "Impact ID" ;
    skos:definition "The normalized impact of the incident or finding. Per NIST, this is the magnitude of harm that can be expected to result from the consequences of unauthorized disclosure, modification, destruction, or loss of information or information system availability." ;
    skos:editorialNote "NIST Computer Security Resource Center — https://doi.org/10.6028/NIST.FIPS.199",
        "NIST SP 800-172 from FIPS 199 — https://doi.org/10.6028/NIST.FIPS.199" ;
    skos:inScheme ocsf:dictionary ;
    ocsf:ocsf_source "impact value; impact level" ;
    ocsf:sibling "impact" .

ocsf:impact_score a owl:DatatypeProperty ;
    rdfs:label "impact_score" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Impact Score" ;
    skos:definition "The impact as an integer value of the finding, valid range 0-100." ;
    skos:inScheme ocsf:dictionary .

ocsf:job a owl:ObjectProperty ;
    rdfs:label "job" ;
    rdfs:range ocsf:Job ;
    skos:altLabel "Job" ;
    skos:definition "The job object that pertains to the event." ;
    skos:inScheme ocsf:dictionary .

ocsf:org a owl:ObjectProperty ;
    rdfs:label "org" ;
    rdfs:range ocsf:Organization ;
    skos:altLabel "Organization" ;
    skos:definition "Organization and org unit relevant to the event or object. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:phone_number a owl:DatatypeProperty ;
    rdfs:label "phone_number" ;
    rdfs:range xsd:string ;
    skos:altLabel "Phone Number" ;
    skos:definition "The number associated with the phone." ;
    skos:inScheme ocsf:dictionary .

ocsf:resource a owl:ObjectProperty ;
    rdfs:label "resource" ;
    rdfs:range ocsf:ResourceDetails ;
    skos:altLabel "Resource" ;
    skos:definition "The target resource." ;
    skos:inScheme ocsf:dictionary .

ocsf:serial_number a owl:DatatypeProperty ;
    rdfs:label "serial_number" ;
    rdfs:range xsd:string ;
    skos:altLabel "Serial Number" ;
    skos:definition "The serial number that pertains to the object. See specific usage." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:observable_id 37 .

ocsf:status_detail a owl:DatatypeProperty ;
    rdfs:label "status_detail" ;
    rdfs:range xsd:string ;
    skos:altLabel "Status Detail" ;
    skos:definition "The status detail contains additional information about the event/finding outcome." ;
    skos:inScheme ocsf:dictionary .

ocsf:tls a owl:ObjectProperty ;
    rdfs:label "tls" ;
    rdfs:range ocsf:Tls ;
    skos:altLabel "TLS" ;
    skos:definition "The Transport Layer Security (TLS) attributes." ;
    skos:inScheme ocsf:dictionary .

ocsf:zone a owl:DatatypeProperty ;
    rdfs:label "zone" ;
    rdfs:range xsd:string ;
    skos:altLabel "Network Zone" ;
    skos:definition "The network zone or LAN segment. See specific usage." ;
    skos:inScheme ocsf:dictionary .


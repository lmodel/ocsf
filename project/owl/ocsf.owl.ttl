            owl:onProperty ocsf:related_analytics ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:type_id ],
        ocsf:Entity ;
    skos:altLabel "Analytic" ;
    skos:definition "The Analytic object contains details about the analytic technique used to analyze and derive insights from the data or information that led to the creation of a finding or conclusion." ;
    skos:inScheme ocsf:objects .

ocsf:ApiActivityActivityIdEnum a owl:Class ;
    rdfs:label "ApiActivityActivityIdEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/ocsf/ApiActivityActivityIdEnum#CREATE> <https://w3id.org/lmodel/ocsf/ApiActivityActivityIdEnum#READ> <https://w3id.org/lmodel/ocsf/ApiActivityActivityIdEnum#UPDATE> <https://w3id.org/lmodel/ocsf/ApiActivityActivityIdEnum#DELETE> <https://w3id.org/lmodel/ocsf/ApiActivityActivityIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/ApiActivityActivityIdEnum#OTHER> ) ;
    skos:definition "ApiActivity activity_id values." ;
    skos:inScheme ocsf:enums ;

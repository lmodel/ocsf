ocsf:HttpCookie a owl:Class ;
    rdfs:label "HttpCookie" ;
    rdfs:seeAlso <https://d3fend.mitre.org/dao/artifact/d3f:SessionCookie/> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty ocsf:is_secure ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:domain ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:path ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:domain ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty ocsf:http_only ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:domain ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:secure ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:path ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:is_http_only ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:expiration_time ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty ocsf:secure ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:long ;
            owl:onProperty ocsf:expiration_time ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:expiration_time ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:samesite ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:is_secure ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:http_only ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:http_only ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:path ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:samesite ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:is_http_only ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:samesite ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:secure ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:is_secure ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty ocsf:is_http_only ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:name ],
        ocsf:Object ;
    skos:altLabel "HTTP Cookie" ;
    skos:definition "The HTTP Cookie object, also known as a web cookie or browser cookie, contains details and values pertaining to a small piece of data that a server sends to a user's web browser. This data is then stored by the browser and sent back to the server with subsequent requests, allowing the server to remember and track certain information about the user's browsing session or preferences." ;
    skos:editorialNote "D3FEND™ Ontology d3f:SessionCookie. — https://d3fend.mitre.org/dao/artifact/d3f:SessionCookie/" ;
    skos:exactMatch uco_master:BrowserCookie ;
    skos:inScheme ocsf:objects .


    ocsf:ocsf_uid "26" .

<https://w3id.org/lmodel/ocsf/DispositionIdEnum#UNCORRECTED> a owl:Class ;
    rdfs:label "UNCORRECTED" ;
    rdfs:subClassOf ocsf:DispositionIdEnum ;
    skos:definition "A corrupt file or configuration was not corrected." ;
    ocsf:caption "Uncorrected" ;
    ocsf:ocsf_uid "13" .

<https://w3id.org/lmodel/ocsf/DispositionIdEnum#UNKNOWN> a owl:Class ;
    rdfs:label "UNKNOWN" ;
    rdfs:subClassOf ocsf:DispositionIdEnum ;
    skos:definition "The disposition is unknown." ;
    ocsf:caption "Unknown" ;
    ocsf:ocsf_uid "0" .

ocsf:Dns a owl:Class ;
    rdfs:label "Dns" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:packet_uid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:packet_uid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ocsf:packet_uid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:class_ ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:class_ ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:class_ ],
        ocsf:Object ;
    skos:altLabel "DNS" ;
    skos:closeMatch uco_master:DNSRecord ;
    skos:definition "The Domain Name System (DNS) object represents the shared information associated with the DNS query and answer objects." ;
    skos:inScheme ocsf:objects .


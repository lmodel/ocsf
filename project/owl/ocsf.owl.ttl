ocsf:access_mask a owl:DatatypeProperty ;
    rdfs:label "access_mask" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Access Mask" ;
    skos:definition "The access mask in a platform-native format." ;
    skos:inScheme ocsf:dictionary .

ocsf:activity_name a owl:DatatypeProperty ;
    rdfs:label "activity_name" ;
    rdfs:range xsd:string ;
    skos:altLabel "Activity" ;
    skos:definition "The event activity name, as defined by the activity_id." ;
    skos:inScheme ocsf:dictionary .

ocsf:attacks a owl:ObjectProperty ;
    rdfs:label "attacks" ;
    rdfs:range ocsf:Attack ;
    rdfs:seeAlso <https://atlas.mitre.org/matrices/ATLAS>,
        <https://attack.mitre.org> ;
    skos:altLabel "MITRE ATT&CK® and ATLAS™ Details" ;
    skos:definition "An array of MITRE ATT&CK® objects describing identified tactics, techniques & sub-techniques. The objects are compatible with MITRE ATLAS™ tactics, techniques & sub-techniques." ;
    skos:editorialNote "MITRE ATLAS — https://atlas.mitre.org/matrices/ATLAS",
        "MITRE ATT&CK® — https://attack.mitre.org" ;
    skos:inScheme ocsf:dictionary .

ocsf:auth_protocol a owl:DatatypeProperty ;
    rdfs:label "auth_protocol" ;
    rdfs:range xsd:string ;
    skos:altLabel "Auth Protocol" ;
    skos:definition "The authentication protocol as defined by the caption of <code>auth_protocol_id</code>. In the case of <code>Other</code>, it is defined by the event source." ;
    skos:inScheme ocsf:dictionary .

ocsf:auth_protocol_id a owl:ObjectProperty ;
    rdfs:label "auth_protocol_id" ;
    rdfs:range ocsf:AuthProtocolIdEnum ;
    skos:altLabel "Auth Protocol ID" ;
    skos:definition "The normalized identifier of the authentication protocol used to create the user session." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "auth_protocol" .

ocsf:certificate a owl:ObjectProperty ;
    rdfs:label "certificate" ;
    rdfs:range ocsf:Certificate ;
    skos:altLabel "Certificate" ;
    skos:definition "The certificate object containing information about the digital certificate." ;
    skos:inScheme ocsf:dictionary .

ocsf:classification a owl:DatatypeProperty ;
    rdfs:label "classification" ;
    rdfs:range xsd:string ;
    skos:altLabel "Classification" ;
    skos:definition "The classification as defined by the vendor." ;
    skos:inScheme ocsf:dictionary .

ocsf:code a owl:DatatypeProperty ;
    rdfs:label "code" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Response Code" ;
    skos:definition "The numeric response sent to a request." ;
    skos:inScheme ocsf:dictionary .

ocsf:command a owl:DatatypeProperty ;
    rdfs:label "command" ;
    rdfs:range xsd:string ;
    skos:altLabel "Command" ;
    skos:definition "The command name." ;
    skos:inScheme ocsf:dictionary .

ocsf:database a owl:ObjectProperty ;
    rdfs:label "database" ;
    rdfs:range ocsf:Database ;
    skos:altLabel "Database" ;
    skos:definition "The database object is used for databases which are typically datastore services that contain an organized collection of structured and unstructured data or a types of data." ;
    skos:inScheme ocsf:dictionary .

ocsf:databucket a owl:ObjectProperty ;
    rdfs:label "databucket" ;
    rdfs:range ocsf:Databucket ;
    skos:altLabel "Databucket" ;
    skos:definition "The data bucket object is a basic container that holds data, typically organized through the use of data partitions." ;
    skos:inScheme ocsf:dictionary .

ocsf:email a owl:ObjectProperty ;
    rdfs:label "email" ;
    rdfs:range ocsf:Email ;
    skos:altLabel "Email" ;
    skos:definition "The email object." ;
    skos:inScheme ocsf:dictionary .

ocsf:email_addr a owl:DatatypeProperty ;
    rdfs:label "email_addr" ;
    rdfs:range xsd:string ;
    skos:altLabel "Email Address" ;
    skos:definition "The user's primary email address." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_system a owl:DatatypeProperty ;
    rdfs:label "is_system" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "System" ;
    skos:definition "The indication of whether the object is part of the operating system." ;
    skos:inScheme ocsf:dictionary .

ocsf:model a owl:DatatypeProperty ;
    rdfs:label "model" ;
    rdfs:range xsd:string ;
    skos:altLabel "Model" ;
    skos:definition "The model name of an entity. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:module a owl:ObjectProperty ;
    rdfs:label "module" ;
    rdfs:range ocsf:Module ;
    skos:altLabel "Module" ;
    skos:definition "The module that pertains to the event." ;
    skos:inScheme ocsf:dictionary .

ocsf:port a owl:DatatypeProperty ;
    rdfs:label "port" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Port" ;
    skos:definition "The TCP/UDP port number associated with a connection. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:reg_key a owl:ObjectProperty ;
    rdfs:label "reg_key" ;
    rdfs:range ocsf:RegKey ;
    skos:altLabel "Registry Key" ;
    skos:definition "The registry key." ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_extension "windows" .

ocsf:reg_value a owl:ObjectProperty ;
    rdfs:label "reg_value" ;
    rdfs:range ocsf:RegValue ;
    skos:altLabel "Registry Value" ;
    skos:definition "The registry value." ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_extension "windows" .

ocsf:status_code a owl:DatatypeProperty ;
    rdfs:label "status_code" ;
    rdfs:range xsd:string ;
    skos:altLabel "Status Code" ;
    skos:definition "The event status code, as reported by the event source.<br /><br />For example, in a Windows Failed Authentication event, this would be the value of 'Failure Code', e.g. 0x18." ;
    skos:inScheme ocsf:dictionary .

ocsf:uuid a owl:DatatypeProperty ;
    rdfs:label "uuid" ;
    rdfs:range xsd:string ;
    skos:altLabel "UUID" ;
    skos:definition "The universally unique identifier. See specific usage." ;
    skos:inScheme ocsf:dictionary .


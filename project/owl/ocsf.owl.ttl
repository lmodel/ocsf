<https://w3id.org/lmodel/ocsf/AgentTypeIdEnum#BACKUP_RECOVERY> a owl:Class ;
    rdfs:label "BACKUP_RECOVERY" ;
    rdfs:subClassOf ocsf:AgentTypeIdEnum ;
    skos:definition "Any agent or sensor that provides backups, archival, or recovery capabilities. E.g., Azure Backup, AWS Backint Agent." ;
    ocsf:caption "Backup & Recovery" ;
    ocsf:ocsf_uid "3" .

<https://w3id.org/lmodel/ocsf/AgentTypeIdEnum#CONFIGURATION_MANAGEMENT> a owl:Class ;
    rdfs:label "CONFIGURATION_MANAGEMENT" ;
    rdfs:subClassOf ocsf:AgentTypeIdEnum ;
    skos:definition "Any agent or sensor that provides configuration management of a device, such as scanning for software, license management, or applying configurations. E.g., AWS Systems Manager Agent, Flexera, ServiceNow MID Server." ;
    ocsf:caption "Configuration Management" ;
    ocsf:ocsf_uid "8" .

<https://w3id.org/lmodel/ocsf/AgentTypeIdEnum#DATA_LOSS_PREVENTION> a owl:Class ;
    rdfs:label "DATA_LOSS_PREVENTION" ;
    rdfs:subClassOf ocsf:AgentTypeIdEnum ;
    skos:definition "Any DLP sensor or agent. Or any tool that provides similar data classification, data loss detection, and/or data loss prevention capabilities. E.g., Forcepoint DLP, Microsoft Purview, Symantec DLP." ;
    ocsf:caption "Data Loss Prevention" ;
    ocsf:ocsf_uid "2" .

<https://w3id.org/lmodel/ocsf/AgentTypeIdEnum#ENDPOINT_DETECTION_AND_RESPONSE> a owl:Class ;
    rdfs:label "ENDPOINT_DETECTION_AND_RESPONSE" ;
    rdfs:subClassOf ocsf:AgentTypeIdEnum ;
    skos:definition "Any EDR sensor or agent. Or any tool that provides similar threat detection, anti-malware, anti-ransomware, or similar capabilities. E.g., Crowdstrike Falcon, Microsoft Defender for Endpoint, Wazuh." ;
    ocsf:caption "Endpoint Detection and Response" ;
    ocsf:ocsf_uid "1" .

<https://w3id.org/lmodel/ocsf/AgentTypeIdEnum#LOG_FORWARDING> a owl:Class ;
    rdfs:label "LOG_FORWARDING" ;
    rdfs:subClassOf ocsf:AgentTypeIdEnum ;
    skos:definition "Any agent or sensor that forwards logs to a 3rd party storage system such as a data lake or SIEM. E.g., Splunk Universal Forwarder, Tenzir, FluentBit, Amazon CloudWatch Agent, Amazon Kinesis Agent." ;
    ocsf:caption "Log Forwarding" ;
    ocsf:ocsf_uid "6" .

<https://w3id.org/lmodel/ocsf/AgentTypeIdEnum#MOBILE_DEVICE_MANAGEMENT> a owl:Class ;
    rdfs:label "MOBILE_DEVICE_MANAGEMENT" ;
    rdfs:subClassOf ocsf:AgentTypeIdEnum ;
    skos:definition "Any agent or sensor responsible for providing Mobile Device Management (MDM) or Mobile Enterprise Management (MEM) capabilities. E.g., JumpCloud Agent, Esper Agent, Jamf Pro binary." ;
    ocsf:caption "Mobile Device Management" ;
    ocsf:ocsf_uid "7" .

<https://w3id.org/lmodel/ocsf/AgentTypeIdEnum#OTHER> a owl:Class ;
    rdfs:label "OTHER" ;
    rdfs:subClassOf ocsf:AgentTypeIdEnum ;
    skos:definition "The type is not mapped. See the <code>type</code> attribute, which contains a data source specific value." ;
    ocsf:caption "Other" ;
    ocsf:ocsf_uid "99" .

<https://w3id.org/lmodel/ocsf/AgentTypeIdEnum#PERFORMANCE_MONITORING_OBSERVABILITY> a owl:Class ;
    rdfs:label "PERFORMANCE_MONITORING_OBSERVABILITY" ;
    rdfs:subClassOf ocsf:AgentTypeIdEnum ;
    skos:definition "Any agent or sensor that provides Application Performance Monitoring (APM), active tracing, profiling, or other observability use cases and optionally forwards the logs. E.g., New Relic Agent, Datadog Agent, Azure Monitor Agent." ;
    ocsf:caption "Performance Monitoring & Observability" ;
    ocsf:ocsf_uid "4" .

<https://w3id.org/lmodel/ocsf/AgentTypeIdEnum#REMOTE_ACCESS> a owl:Class ;
    rdfs:label "REMOTE_ACCESS" ;
    rdfs:subClassOf ocsf:AgentTypeIdEnum ;
    skos:definition "Any agent or sensor that provides remote access capabilities to a device. E.g., BeyondTrust, Amazon Systems Manager Agent, Verkada Agent." ;
    ocsf:caption "Remote Access" ;
    ocsf:ocsf_uid "9" .

<https://w3id.org/lmodel/ocsf/AgentTypeIdEnum#UNKNOWN> a owl:Class ;
    rdfs:label "UNKNOWN" ;
    rdfs:subClassOf ocsf:AgentTypeIdEnum ;
    skos:definition "The type is unknown." ;
    ocsf:caption "Unknown" ;
    ocsf:ocsf_uid "0" .

<https://w3id.org/lmodel/ocsf/AgentTypeIdEnum#VULNERABILITY_MANAGEMENT> a owl:Class ;
    rdfs:label "VULNERABILITY_MANAGEMENT" ;
    rdfs:subClassOf ocsf:AgentTypeIdEnum ;
    skos:definition "Any agent or sensor that provides vulnerability management or scanning capabilities. E.g., Qualys VMDR, Microsoft Defender for Endpoint, Crowdstrike Spotlight, Amazon Inspector Agent." ;
    ocsf:caption "Vulnerability Management" ;
    ocsf:ocsf_uid "5" .


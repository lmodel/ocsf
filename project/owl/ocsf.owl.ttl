    ocsf:caption "Delayed" ;
    ocsf:ocsf_uid "14" .

<https://w3id.org/lmodel/ocsf/DispositionIdEnum#DELETED> a owl:Class ;
    rdfs:label "DELETED" ;
    rdfs:subClassOf ocsf:DispositionIdEnum ;
    skos:definition "A file or other content was deleted." ;
    ocsf:caption "Deleted" ;
    ocsf:ocsf_uid "5" .

<https://w3id.org/lmodel/ocsf/DispositionIdEnum#DETECTED> a owl:Class ;
    rdfs:label "DETECTED" ;
    rdfs:subClassOf ocsf:DispositionIdEnum ;
    skos:definition "Suspicious activity or a policy violation was detected without further action." ;
    ocsf:caption "Detected" ;
    ocsf:ocsf_uid "15" .

<https://w3id.org/lmodel/ocsf/DispositionIdEnum#DROPPED> a owl:Class ;
    rdfs:label "DROPPED" ;
    rdfs:subClassOf ocsf:DispositionIdEnum ;
    skos:definition "The request was detected as a threat and resulted in the connection being dropped." ;
    ocsf:caption "Dropped" ;
    ocsf:ocsf_uid "6" .

<https://w3id.org/lmodel/ocsf/DispositionIdEnum#ERROR> a owl:Class ;
    rdfs:label "ERROR" ;
    rdfs:subClassOf ocsf:DispositionIdEnum ;
    skos:definition "An error occurred during the processing of the activity or request. Use the <code>message</code> attribute of the base class for details." ;
    ocsf:caption "Error" ;
    ocsf:ocsf_uid "27" .

<https://w3id.org/lmodel/ocsf/DispositionIdEnum#EXONERATED> a owl:Class ;
    rdfs:label "EXONERATED" ;
    rdfs:subClassOf ocsf:DispositionIdEnum ;
    skos:definition "A suspicious or risky entity was deemed to no longer be suspicious (re-scored)." ;

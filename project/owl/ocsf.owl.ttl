ocsf:Actor a owl:Class ;
    rdfs:label "Actor" ;
    rdfs:seeAlso <https://next.d3fend.mitre.org/agent/d3f:Agent/> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:user ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:process ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:process ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:app_uid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:invoked_by ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:session ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:User ;
            owl:onProperty ocsf:user ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Authorization ;
            owl:onProperty ocsf:authorizations ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:invoked_by ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:app_name ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Idp ;
            owl:onProperty ocsf:idp ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:app_name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:idp ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:session ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Session ;
            owl:onProperty ocsf:session ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:app_name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:app_uid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:app_uid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:authorizations ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:invoked_by ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:idp ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:user ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Process ;
            owl:onProperty ocsf:process ],
        ocsf:Object ;
    skos:altLabel "Actor" ;
    skos:definition "The Actor object contains details about the user, role, application, service, or process that initiated or performed a specific activity. Note that Actor is not the threat actor of a campaign but may be part of a campaign." ;
    skos:editorialNote "D3FEND™ Ontology d3f:Agent. — https://next.d3fend.mitre.org/agent/d3f:Agent/" ;
    skos:inScheme ocsf:objects ;
    ocsf:ocsf_constraints "{\"at_least_one\": [\"process\", \"user\", \"invoked_by\", \"session\", \"app_name\", \"app_uid\"]}" .

ocsf:DnsActivityRcodeIdEnum a owl:Class ;
    rdfs:label "DnsActivityRcodeIdEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#NOERROR> <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#FORMERROR> <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#SERVERROR> <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#NXDOMAIN> <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#NOTIMP> <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#REFUSED> <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#YXDOMAIN> <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#YXRRSET> <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#NXRRSET> <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#NOTAUTH> <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#NOTZONE> <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#DSOTYPENI> <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#BADSIG_VERS> <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#BADKEY> <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#BADTIME> <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#BADMODE> <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#BADNAME> <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#BADALG> <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#BADTRUNC> <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#BADCOOKIE> <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#UNASSIGNED> <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#RESERVED> <https://w3id.org/lmodel/ocsf/DnsActivityRcodeIdEnum#OTHER> ) ;

        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Metric ;
            owl:onProperty ocsf:metrics ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:depth ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:version ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:metrics ],
        ocsf:Object ;
    skos:altLabel "CVSS Score" ;
    skos:closeMatch core:Impact ;
    skos:definition "The Common Vulnerability Scoring System (<a target='_blank' href='https://www.first.org/cvss/'>CVSS</a>) object provides a way to capture the principal characteristics of a vulnerability and produce a numerical score reflecting its severity." ;
    skos:exactMatch nvd:CVSSMetric ;
    skos:inScheme ocsf:objects ;
    skos:relatedMatch cve:CnaContainer .

ocsf:D3fTactic a owl:Class ;
    rdfs:label "D3fTactic" ;
    rdfs:seeAlso <https://d3fend.mitre.org> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:src_url ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty ocsf:src_url ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:src_url ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:uid ],
        ocsf:Entity ;
    skos:altLabel "MITRE D3FEND™ Tactic" ;
    skos:definition "The MITRE D3FEND™ Tactic object describes the tactic ID and/or name that is associated to an attack." ;
    skos:editorialNote "D3FEND™ Matrix — https://d3fend.mitre.org" ;
    skos:inScheme ocsf:objects .


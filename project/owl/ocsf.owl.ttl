    rdfs:subClassOf ocsf:TcpStateIdEnum ;
    skos:definition "The socket has passively received a connection request from a remote peer." ;
    ocsf:caption "SYN-RECEIVED" ;
    ocsf:ocsf_uid "3" .

<https://w3id.org/lmodel/ocsf/TcpStateIdEnum#SYN_SENT> a owl:Class ;

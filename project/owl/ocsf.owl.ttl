            owl:maxCardinality 1 ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Actor ;
            owl:onProperty ocsf:actor ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:driver ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:driver ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:KernelExtensionActivityActivityIdEnum ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:actor ],
        ocsf:SystemEvent ;
    skos:altLabel "Kernel Extension Activity" ;
    skos:definition "Kernel Extension events report when a driver/extension is loaded or unloaded into the kernel" ;
    skos:editorialNote "D3FEND™ Ontology d3f:KernelModuleEvent — https://d3fend.mitre.org/event/d3f:KernelModuleEvent/" ;
    skos:inScheme ocsf:events ;
    ocsf:ocsf_event_uid 2 .

ocsf:KernelObjectQuery a owl:Class ;
    rdfs:label "KernelObjectQuery" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:kernel ],
        [ a owl:Restriction ;

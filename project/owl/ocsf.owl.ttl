    ocsf:ocsf_uid "21" .

<https://w3id.org/lmodel/ocsf/DispositionIdEnum#RESTORED> a owl:Class ;
    rdfs:label "RESTORED" ;
    rdfs:subClassOf ocsf:DispositionIdEnum ;

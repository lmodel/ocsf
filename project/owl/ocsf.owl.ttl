ocsf:algorithm_id a owl:ObjectProperty ;
    rdfs:label "algorithm_id" ;
    rdfs:range ocsf:AlgorithmIdEnum ;
    skos:altLabel "Algorithm ID" ;
    skos:definition "The normalized identifier of the algorithm. See specific usage." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "algorithm" .

ocsf:api a owl:ObjectProperty ;
    rdfs:label "api" ;
    rdfs:range ocsf:Api ;
    skos:altLabel "API Details" ;
    skos:definition "Describes details about a typical API (Application Programming Interface) call." ;
    skos:inScheme ocsf:dictionary .

ocsf:autonomous_system a owl:ObjectProperty ;
    rdfs:label "autonomous_system" ;
    rdfs:range ocsf:AutonomousSystem ;
    skos:altLabel "Autonomous System" ;
    skos:definition "The Autonomous System details associated with an IP address." ;
    skos:inScheme ocsf:dictionary .

ocsf:class_ a owl:DatatypeProperty ;
    rdfs:label "class_" ;
    rdfs:range xsd:string ;
    skos:altLabel "Class" ;
    skos:definition "The class name of the object. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:cloud_partition a owl:DatatypeProperty ;
    rdfs:label "cloud_partition" ;
    rdfs:range xsd:string ;
    skos:altLabel "Cloud Partition" ;
    skos:definition "The logical grouping or isolated segment within a cloud provider's infrastructure. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:cmd_line a owl:DatatypeProperty ;
    rdfs:label "cmd_line" ;
    rdfs:range xsd:string ;
    skos:altLabel "Command Line" ;
    skos:definition "The full command line used to launch an application, service, process, or job. For example: <code>ssh user@10.0.0.10</code>. If the command line is unavailable or missing, the empty string <code>''</code> is to be used." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:observable_id 13 .

ocsf:compliance a owl:ObjectProperty ;
    rdfs:label "compliance" ;
    rdfs:range ocsf:Compliance ;
    skos:altLabel "Compliance" ;
    skos:definition "The compliance object provides context to compliance findings (e.g., a check against a specific regulatory or best practice framework such as CIS, NIST etc.) and contains compliance related details." ;
    skos:inScheme ocsf:dictionary .

ocsf:container a owl:ObjectProperty ;
    rdfs:label "container" ;
    rdfs:range ocsf:Container ;
    skos:altLabel "Container" ;
    skos:definition "The information describing an instance of a container. A container is a prepackaged, portable system image that runs isolated on an existing system using a container runtime like containerd." ;
    skos:inScheme ocsf:dictionary .

ocsf:cpe_name a owl:DatatypeProperty ;
    rdfs:label "cpe_name" ;
    rdfs:range xsd:string ;
    skos:altLabel "The product CPE identifier" ;
    skos:definition "The Common Platform Enumeration (CPE) name as described by (<a target='_blank' href='https://nvd.nist.gov/products/cpe'>NIST</a>) For example: <code>cpe:/a:apple:safari:16.2</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:criticality a owl:DatatypeProperty ;
    rdfs:label "criticality" ;
    rdfs:range xsd:string ;
    skos:altLabel "Criticality" ;
    skos:definition "Criticality of a resource/object in question" ;
    skos:inScheme ocsf:dictionary .

ocsf:encryption_details a owl:ObjectProperty ;
    rdfs:label "encryption_details" ;
    rdfs:range ocsf:EncryptionDetails ;
    skos:altLabel "Encryption Details" ;
    skos:definition "The encryption details of a file or other content. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:error_message a owl:DatatypeProperty ;
    rdfs:label "error_message" ;
    rdfs:range xsd:string ;
    skos:altLabel "Error Message" ;
    skos:definition "Error Message" ;
    skos:inScheme ocsf:dictionary .

ocsf:hash a owl:ObjectProperty ;
    rdfs:label "hash" ;
    rdfs:range ocsf:Fingerprint ;
    skos:altLabel "Hash" ;
    skos:definition "The hash attribute is the value of a digital fingerprint including information about its algorithm." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_alert a owl:DatatypeProperty ;
    rdfs:label "is_alert" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Alert" ;
    skos:definition "Indicates that the event is considered to be an alertable signal." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_backed_up a owl:DatatypeProperty ;
    rdfs:label "is_backed_up" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Back Ups Configured" ;
    skos:definition "Indicates whether the device or resource has a backup enabled, such as an automated snapshot or a cloud backup. For example, this is indicated by the <code>cloudBackupEnabled</code> value within JAMF Pro mobile devices or the registration of an AWS ARN with the AWS Backup service." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_truncated a owl:DatatypeProperty ;
    rdfs:label "is_truncated" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Is Truncated" ;
    skos:definition "Indicates that an attribute has been truncated. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:isp a owl:DatatypeProperty ;
    rdfs:label "isp" ;
    rdfs:range xsd:string ;
    skos:altLabel "ISP Name" ;
    skos:definition "The name of the Internet Service Provider (ISP)." ;
    skos:inScheme ocsf:dictionary .

ocsf:issuer a owl:DatatypeProperty ;
    rdfs:label "issuer" ;
    rdfs:range xsd:string ;
    skos:altLabel "Issuer Details" ;
    skos:definition "The identifier of the issuer. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:kernel a owl:ObjectProperty ;
    rdfs:label "kernel" ;
    rdfs:range ocsf:Kernel ;
    skos:altLabel "Kernel" ;
    skos:definition "The kernel resource object that pertains to the event." ;
    skos:inScheme ocsf:dictionary .

ocsf:lang a owl:DatatypeProperty ;
    rdfs:label "lang" ;
    rdfs:range xsd:string ;
    skos:altLabel "Language" ;
    skos:definition "The two letter lower case language codes, as defined by <a target='_blank' href='https://en.wikipedia.org/wiki/ISO_639-1'>ISO 639-1</a>. For example: <code>en</code> (English), <code>de</code> (German), or <code>fr</code> (French)." ;
    skos:inScheme ocsf:dictionary .

ocsf:last_run_time a owl:DatatypeProperty ;
    rdfs:label "last_run_time" ;
    rdfs:range xsd:long ;
    skos:altLabel "Last Run" ;
    skos:definition "The last run time of application or service. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:last_used_time a owl:DatatypeProperty ;
    rdfs:label "last_used_time" ;
    rdfs:range xsd:long ;
    skos:altLabel "Last Used Time" ;
    skos:definition "The most recent usage time of an entity. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:log_name a owl:DatatypeProperty ;
    rdfs:label "log_name" ;
    rdfs:range xsd:string ;
    skos:altLabel "Log Name" ;
    skos:definition "The log name. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:log_provider a owl:DatatypeProperty ;
    rdfs:label "log_provider" ;
    rdfs:range xsd:string ;
    skos:altLabel "Log Provider" ;
    skos:definition "The logging provider or logging service that logged the event. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:namespace a owl:DatatypeProperty ;
    rdfs:label "namespace" ;
    rdfs:range xsd:string ;
    skos:altLabel "Namespace" ;
    skos:definition "The namespace is useful in merger or acquisition situations. For example, when similar entities exist that you need to keep separate." ;
    skos:inScheme ocsf:dictionary .

ocsf:os a owl:ObjectProperty ;
    rdfs:label "os" ;
    rdfs:range ocsf:Os ;
    skos:altLabel "OS" ;
    skos:definition "The endpoint operating system." ;
    skos:inScheme ocsf:dictionary .

ocsf:peripheral_device a owl:ObjectProperty ;
    rdfs:label "peripheral_device" ;
    rdfs:range ocsf:PeripheralDevice ;
    skos:altLabel "Peripheral Device" ;
    skos:definition "The peripheral device that triggered the event." ;
    skos:inScheme ocsf:dictionary .

ocsf:product_uid a owl:DatatypeProperty ;
    rdfs:label "product_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "Product Identifier" ;
    skos:definition "Unique Identifier of a product." ;
    skos:inScheme ocsf:dictionary .

ocsf:protocol_ver a owl:DatatypeProperty ;
    rdfs:label "protocol_ver" ;
    rdfs:range xsd:string ;
    skos:altLabel "Protocol Version" ;
    skos:definition "The Protocol version, normalized to the caption of the protocol_ver_id value. In the case of 'Other', it is defined by the event source." ;
    skos:inScheme ocsf:dictionary .

ocsf:proxy_endpoint a owl:ObjectProperty ;
    rdfs:label "proxy_endpoint" ;
    rdfs:range ocsf:NetworkProxy ;
    skos:altLabel "Proxy Endpoint" ;
    skos:definition "The proxy (server) in a network connection." ;
    skos:inScheme ocsf:dictionary .

ocsf:reputation a owl:ObjectProperty ;
    rdfs:label "reputation" ;
    rdfs:range ocsf:Reputation ;
    skos:altLabel "Reputation Scores" ;
    skos:definition "Contains the original and normalized reputation scores." ;
    skos:inScheme ocsf:dictionary .

ocsf:resource_relationship a owl:ObjectProperty ;
    rdfs:label "resource_relationship" ;
    rdfs:range ocsf:Graph ;
    skos:altLabel "Resource Relationship" ;
    skos:definition "Describes entities related to the resource, using a graph structure. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:response a owl:ObjectProperty ;
    rdfs:label "response" ;
    rdfs:range ocsf:Response ;
    skos:altLabel "API Response Details" ;
    skos:definition "General Purpose API Response Object. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:risk_details a owl:DatatypeProperty ;
    rdfs:label "risk_details" ;
    rdfs:range xsd:string ;
    skos:altLabel "Risk Details" ;
    skos:definition "Describes the risk associated with the finding." ;
    skos:inScheme ocsf:dictionary .

ocsf:script a owl:ObjectProperty ;
    rdfs:label "script" ;
    rdfs:range ocsf:Script ;
    skos:altLabel "Script" ;
    skos:definition "The script object." ;
    skos:inScheme ocsf:dictionary .

ocsf:source a owl:DatatypeProperty ;
    rdfs:label "source" ;
    rdfs:range xsd:string ;
    skos:altLabel "Source" ;
    skos:definition "The source, when used with source_id, is normalized to the caption of the source_id value. In the case of 'Other', it is defined by the event source. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:subnet a owl:DatatypeProperty ;
    rdfs:label "subnet" ;
    rdfs:range xsd:string ;
    skos:altLabel "Subnet" ;
    skos:definition "The subnet mask." ;
    skos:inScheme ocsf:dictionary .

ocsf:table a owl:ObjectProperty ;
    rdfs:label "table" ;
    rdfs:range ocsf:Table ;
    skos:altLabel "Table" ;
    skos:definition "The table object represents a table within a structured relational database or datastore, which contains columns and rows of data that are able to be create, updated, deleted and queried." ;
    skos:inScheme ocsf:dictionary .

ocsf:tenant_uid a owl:DatatypeProperty ;
    rdfs:label "tenant_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "Tenant UID" ;
    skos:definition "The unique tenant identifier." ;
    skos:inScheme ocsf:dictionary .

ocsf:type_uid a owl:DatatypeProperty ;
    rdfs:label "type_uid" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Type ID" ;
    skos:definition "The event/finding type ID. It identifies the event's semantics and structure. The value is calculated by the logging system as: <code>class_uid * 100 + activity_id</code>." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "type_name" .

ocsf:untruncated_size a owl:DatatypeProperty ;
    rdfs:label "untruncated_size" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Untruncated Size" ;
    skos:definition "The size in bytes of an attribute before truncation. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:verdict a owl:DatatypeProperty ;
    rdfs:label "verdict" ;
    rdfs:range xsd:string ;
    skos:altLabel "Verdict" ;
    skos:definition "The verdict assigned to an Incident finding." ;
    skos:inScheme ocsf:dictionary .

ocsf:verdict_id a owl:ObjectProperty ;
    rdfs:label "verdict_id" ;
    rdfs:range ocsf:VerdictIdEnum ;
    skos:altLabel "Verdict ID" ;
    skos:definition "The normalized verdict of an Incident." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "verdict" .

ocsf:win_service a owl:ObjectProperty ;
    rdfs:label "win_service" ;
    rdfs:range ocsf:WinService ;
    skos:altLabel "Windows Service" ;
    skos:definition "The Windows service." ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_extension "windows" .


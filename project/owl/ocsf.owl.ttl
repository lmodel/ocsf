    skos:definition "The Network Interface object describes the type and associated attributes of a physical or virtual network interface." ;
    skos:editorialNote "D3FEND™ Ontology d3f:NetworkInterfaceCard. — https://d3fend.mitre.org/dao/artifact/d3f:NetworkInterfaceCard/" ;
    skos:exactMatch uco_master:NetworkInterface ;
    skos:inScheme ocsf:objects ;
    ocsf:ocsf_constraints "{\"at_least_one\": [\"ip\", \"mac\", \"name\", \"hostname\", \"uid\"]}" .


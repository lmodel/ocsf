ocsf:PermissionAnalysisResult a owl:Class ;
    rdfs:label "PermissionAnalysisResult" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:granted_privileges ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:unused_privileges_count ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:total_potential_attacks_count ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ocsf:analyzed_privileges_count ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:condition_keys ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:ServicePrivilegeAnalysis ;
            owl:onProperty ocsf:service_privilege_analysis_list ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:KeyValueObject ;
            owl:onProperty ocsf:condition_keys ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:granted_privileges ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ocsf:unused_services_count ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ocsf:unused_privileges_count ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ocsf:total_potential_attacks_count ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:unused_services_count ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:analyzed_privileges_count ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:policy ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:total_potential_attacks_count ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:analyzed_privileges_count ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:policy ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:unused_services_count ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:unused_privileges_count ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:service_privilege_analysis_list ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Policy ;
            owl:onProperty ocsf:policy ],
        ocsf:Object ;
    skos:altLabel "Permission Analysis Result" ;
    skos:definition "The Permission Analysis object describes analysis results of permissions, policies directly associated with an identity (user, role, or service account). This evaluates what permissions an identity has been granted through attached policies, which privileges are actively used versus unused, and identifies potential over-privileged access. Use this for identity-centric security assessments such as privilege audits, dormant permission discovery, and least-privilege compliance analysis." ;
    skos:inScheme ocsf:objects .


ocsf:InventoryInfo a owl:Class ;
    rdfs:label "InventoryInfo" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:actor ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:device ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:actor ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:device ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Device ;
            owl:onProperty ocsf:device ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Actor ;
            owl:onProperty ocsf:actor ],
        ocsf:DiscoveryEvent ;
    skos:altLabel "Device Inventory Info" ;
    skos:definition "Device Inventory Info events report device inventory data that is either logged or proactively collected. For example, when collecting device information from a CMDB or running a network sweep of connected devices." ;
    skos:inScheme ocsf:events ;
    ocsf:ocsf_event_uid 1 .

ocsf:JobQuery a owl:Class ;
    rdfs:label "JobQuery" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Job ;
            owl:onProperty ocsf:job ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:job ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:job ],
        ocsf:DiscoveryResult ;
    skos:altLabel "Job Query" ;
    skos:definition "Job Query events report information about scheduled jobs." ;
    skos:inScheme ocsf:events ;
    ocsf:ocsf_event_uid 10 .

ocsf:KernelActivity a owl:Class ;
    rdfs:label "KernelActivity" ;
    rdfs:seeAlso <https://d3fend.mitre.org/event/d3f:KernelEvent/> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Kernel ;
            owl:onProperty ocsf:kernel ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:KernelActivityActivityIdEnum ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:kernel ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:kernel ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:activity_id ],
        ocsf:SystemEvent ;
    skos:altLabel "Kernel Activity" ;
    skos:definition "Kernel Activity events report when an process creates, reads, or deletes a kernel resource." ;
    skos:editorialNote "D3FEND™ Ontology d3f:KernelEvent — https://d3fend.mitre.org/event/d3f:KernelEvent/" ;
    skos:inScheme ocsf:events ;
    ocsf:ocsf_event_uid 3 .

ocsf:KernelExtensionActivity a owl:Class ;
    rdfs:label "KernelExtensionActivity" ;
    rdfs:seeAlso <https://d3fend.mitre.org/event/d3f:KernelModuleEvent/> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:actor ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:KernelDriver ;
            owl:onProperty ocsf:driver ],

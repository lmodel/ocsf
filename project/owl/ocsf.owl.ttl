    skos:altLabel "OSINT" ;
    skos:definition "The OSINT (Open Source Intelligence) object contains details related to an indicator such as the indicator itself, related indicators, geolocation, registrar information, subdomains, analyst commentary, and other contextual information. This information can be used to further enrich a detection or finding by providing decisioning support to other analysts and engineers." ;
    skos:inScheme ocsf:objects .

ocsf:Packet a owl:Class ;
    rdfs:label "Packet" ;
    rdfs:seeAlso <https://d3fend.mitre.org/dao/artifact/d3f:NetworkPacket/>,
        <https://d3fend.mitre.org/dao/artifact/d3f:PacketCaptureFile/>,
        <https://d3fend.mitre.org/dao/artifact/d3f:PacketLog/> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:encoding ],
        [ a owl:Restriction ;

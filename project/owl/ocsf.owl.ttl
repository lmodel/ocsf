<https://w3id.org/lmodel/ocsf/LogonTypeIdEnum#BATCH> a owl:Class ;
    rdfs:label "BATCH" ;
    rdfs:subClassOf ocsf:LogonTypeIdEnum ;
    skos:definition "A batch server logon, where processes may be executing on behalf of a user without their direct intervention." ;
    ocsf:caption "Batch" ;
    ocsf:ocsf_uid "4" .

<https://w3id.org/lmodel/ocsf/LogonTypeIdEnum#CACHED_INTERACTIVE> a owl:Class ;
    rdfs:label "CACHED_INTERACTIVE" ;
    rdfs:subClassOf ocsf:LogonTypeIdEnum ;
    skos:definition "A user logged on to this device with network credentials that were stored locally on the device and the domain controller was not contacted to verify the credentials." ;
    ocsf:caption "Cached Interactive" ;
    ocsf:ocsf_uid "11" .

<https://w3id.org/lmodel/ocsf/LogonTypeIdEnum#CACHED_REMOTE_INTERACTIVE> a owl:Class ;
    rdfs:label "CACHED_REMOTE_INTERACTIVE" ;
    rdfs:subClassOf ocsf:LogonTypeIdEnum ;
    skos:definition "Same as Remote Interactive. This is used for internal auditing." ;
    ocsf:caption "Cached Remote Interactive" ;
    ocsf:ocsf_uid "12" .

<https://w3id.org/lmodel/ocsf/LogonTypeIdEnum#CACHED_UNLOCK> a owl:Class ;
    rdfs:label "CACHED_UNLOCK" ;
    rdfs:subClassOf ocsf:LogonTypeIdEnum ;
    skos:definition "Workstation logon." ;
    ocsf:caption "Cached Unlock" ;
    ocsf:ocsf_uid "13" .

<https://w3id.org/lmodel/ocsf/LogonTypeIdEnum#INTERACTIVE> a owl:Class ;

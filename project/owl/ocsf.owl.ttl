ocsf:extensions a owl:ObjectProperty ;
    rdfs:label "extensions" ;
    rdfs:range ocsf:Extension ;
    skos:altLabel "Schema Extensions" ;
    skos:definition "The schema extensions used to create the event." ;
    skos:inScheme ocsf:dictionary .

ocsf:user a owl:ObjectProperty ;
    rdfs:label "user" ;
    rdfs:range ocsf:User ;
    skos:altLabel "User" ;
    skos:definition "The user that pertains to the event or object." ;
    skos:inScheme ocsf:dictionary .

ocsf:device a owl:ObjectProperty ;
    rdfs:label "device" ;
    rdfs:range ocsf:Device ;
    skos:altLabel "Device" ;
    skos:definition "An addressable device, computer system or host." ;
    skos:inScheme ocsf:dictionary .

ocsf:src_endpoint a owl:ObjectProperty ;
    rdfs:label "src_endpoint" ;
    rdfs:range ocsf:NetworkEndpoint ;
    skos:altLabel "Source Endpoint" ;
    skos:definition "The network source endpoint." ;
    skos:inScheme ocsf:dictionary .

ocsf:dst_endpoint a owl:ObjectProperty ;
    rdfs:label "dst_endpoint" ;
    rdfs:range ocsf:NetworkEndpoint ;
    skos:altLabel "Destination Endpoint" ;
    skos:definition "The network destination endpoint." ;
    skos:inScheme ocsf:dictionary .

ocsf:modified_time a owl:DatatypeProperty ;
    rdfs:label "modified_time" ;
    rdfs:range xsd:long ;
    skos:altLabel "Modified Time" ;
    skos:definition "The time when the object was last modified. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:src_url a owl:DatatypeProperty ;
    rdfs:label "src_url" ;
    rdfs:range xsd:anyURI ;
    skos:altLabel "Source URL" ;
    skos:definition "The URL pointing towards the source of an entity. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:actor a owl:ObjectProperty ;
    rdfs:label "actor" ;
    rdfs:range ocsf:Actor ;
    skos:altLabel "Actor" ;
    skos:definition "The actor object describes details about the user/role/process that was the source of the activity. Note that this is not the threat actor of a campaign but may be part of a campaign." ;
    skos:inScheme ocsf:dictionary .

ocsf:file a owl:ObjectProperty ;
    rdfs:label "file" ;
    rdfs:range ocsf:File ;
    skos:altLabel "File" ;
    skos:definition "The file that pertains to the event or object. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:created_time a owl:DatatypeProperty ;
    rdfs:label "created_time" ;
    rdfs:range xsd:long ;
    skos:altLabel "Created Time" ;
    skos:definition "The time when the object was created. See specific usage." ;
    skos:inScheme ocsf:dictionary .


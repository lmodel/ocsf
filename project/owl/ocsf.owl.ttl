    linkml:permissible_values <https://w3id.org/lmodel/ocsf/DigitalSignatureAlgorithmIdEnum#AUTHENTICODE>,
        <https://w3id.org/lmodel/ocsf/DigitalSignatureAlgorithmIdEnum#DSA>,

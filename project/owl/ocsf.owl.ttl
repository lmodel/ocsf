    ocsf:ocsf_uid "10" .

<https://w3id.org/lmodel/ocsf/DispositionIdEnum#ISOLATED> a owl:Class ;
    rdfs:label "ISOLATED" ;
    rdfs:subClassOf ocsf:DispositionIdEnum ;
    skos:definition "A session was isolated on the network or within a browser." ;

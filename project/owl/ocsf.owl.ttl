            owl:maxCardinality 1 ;
            owl:onProperty ocsf:is_exploit_available ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:long ;
            owl:onProperty ocsf:last_seen_time ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:exploit_last_seen_time ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:references ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Package ;
            owl:onProperty ocsf:packages ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:severity ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:severity ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:is_fix_available ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:fix_coverage_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:title ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:kb_articles ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Cwe ;
            owl:onProperty ocsf:cwe ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:first_seen_time ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:related_vulnerabilities ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:related_vulnerabilities ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:fix_coverage ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:affected_code ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:severity ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:exploit_requirement ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:fix_coverage ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:dependency_chain ],
        ocsf:Object ;
    skos:altLabel "Vulnerability Details" ;
    skos:closeMatch cve:CVERecord,
        kev_catalog:KevEntry,
        nvd:NVDEntry ;
    skos:definition "The vulnerability is an unintended characteristic of a computing component or system configuration that multiplies the risk of an adverse event or a loss occurring either due to accidental exposure, deliberate attack, or conflict with new system components." ;
    skos:exactMatch stix:Vulnerability,
        core:Vulnerability ;
    skos:inScheme ocsf:objects ;
    skos:relatedMatch capec:AttackPattern,
        cwe:Weakness ;
    ocsf:ocsf_constraints "{\"just_one\": [\"advisory\", \"cve\", \"cwe\"]}" .


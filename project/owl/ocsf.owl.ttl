            owl:onProperty ocsf:labels ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:version ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:log_source ],
        ocsf:DataClassificationProfile,
        ocsf:Object ;
    skos:altLabel "Metadata" ;
    skos:definition "The Metadata object describes the metadata associated with the event." ;
    skos:editorialNote "D3FEND™ Ontology d3f:Metadata — https://d3fend.mitre.org/dao/artifact/d3f:Metadata/" ;
    skos:inScheme ocsf:objects .

ocsf:Mitigation a owl:Class ;
    rdfs:label "Mitigation" ;
    rdfs:seeAlso <https://atlas.mitre.org/matrices/ATLAS>,
        <https://attack.mitre.org>,
        <https://d3fend.mitre.org/mappings/attack-mitigations/> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:countermeasures ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:src_url ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty ocsf:src_url ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:src_url ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:D3fend ;
            owl:onProperty ocsf:countermeasures ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:name ],
        ocsf:Entity ;
    skos:altLabel "MITRE Mitigation" ;
    skos:definition "The MITRE Mitigation object describes the ATT&CK® or ATLAS™ Mitigation ID and/or name that is associated to an attack." ;
    skos:editorialNote "ATLAS™ Matrix — https://atlas.mitre.org/matrices/ATLAS",
        "ATT&CK® Matrix — https://attack.mitre.org",
        "ATT&CK® Mitigation to D3FEND™ Technique Mappings — https://d3fend.mitre.org/mappings/attack-mitigations/" ;
    skos:exactMatch attack:Mitigation ;
    skos:inScheme ocsf:objects ;
    skos:relatedMatch capec:AttackPattern .


ocsf:Fingerprint a owl:Class ;
    rdfs:label "Fingerprint" ;
    rdfs:seeAlso <https://d3fend.mitre.org/dao/artifact/d3f:DigitalFingerprint/> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:algorithm_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:algorithm ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:algorithm ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:value ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:FingerprintAlgorithmIdEnum ;
            owl:onProperty ocsf:algorithm_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:algorithm ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:algorithm_id ],
        ocsf:Object ;
    skos:altLabel "Fingerprint" ;
    skos:definition "The Fingerprint object provides detailed information about a fingerprint, which is a compact representation of data used to identify a longer piece of information, such as a public key, file content, or application implementation. It contains the algorithm or scheme and value of the fingerprint, enabling efficient and reliable identification of the associated data." ;
    skos:editorialNote "D3FEND™ Ontology d3f:DigitalFingerprint. — https://d3fend.mitre.org/dao/artifact/d3f:DigitalFingerprint/" ;
    skos:exactMatch uco_master:Hash ;
    skos:inScheme ocsf:objects ;
    ocsf:observable_id 30 .


ocsf:SubTechnique a owl:Class ;
    rdfs:label "SubTechnique" ;
    rdfs:seeAlso <https://atlas.mitre.org/matrices/ATLAS>,
        <https://attack.mitre.org> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:src_url ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:src_url ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty ocsf:src_url ],
        ocsf:Entity ;
    skos:altLabel "MITRE Sub-technique" ;
    skos:closeMatch capec:AttackStep ;
    skos:definition "The MITRE Sub-technique object describes the ATT&CK® or ATLAS™ Sub-technique ID and/or name associated to an attack." ;
    skos:editorialNote "ATLAS™ Matrix — https://atlas.mitre.org/matrices/ATLAS",
        "ATT&CK® Matrix — https://attack.mitre.org" ;
    skos:exactMatch attack:SubTechnique ;
    skos:inScheme ocsf:objects .

<https://w3id.org/lmodel/ocsf/TcpStateIdEnum#CLOSED> a owl:Class ;
    rdfs:label "CLOSED" ;
    rdfs:subClassOf ocsf:TcpStateIdEnum ;
    skos:definition "The socket is not in use." ;
    ocsf:caption "CLOSED" ;
    ocsf:ocsf_uid "7" .

<https://w3id.org/lmodel/ocsf/TcpStateIdEnum#CLOSE_WAIT> a owl:Class ;
    rdfs:label "CLOSE_WAIT" ;
    rdfs:subClassOf ocsf:TcpStateIdEnum ;
    skos:definition "The socket connection has been closed by the remote peer, and the system is waiting for the local application to close its half of the connection." ;
    ocsf:caption "CLOSE-WAIT" ;
    ocsf:ocsf_uid "8" .

<https://w3id.org/lmodel/ocsf/TcpStateIdEnum#CLOSING> a owl:Class ;
    rdfs:label "CLOSING" ;
    rdfs:subClassOf ocsf:TcpStateIdEnum ;
    skos:definition "The socket connection has been closed by the local application and the remote peer simultaneously, and the remote peer has not yet acknowledged the close attempt of the local application." ;
    ocsf:caption "CLOSING" ;
    ocsf:ocsf_uid "11" .

<https://w3id.org/lmodel/ocsf/TcpStateIdEnum#ESTABLISHED> a owl:Class ;
    rdfs:label "ESTABLISHED" ;
    rdfs:subClassOf ocsf:TcpStateIdEnum ;
    skos:definition "The socket has an established connection between a local application and a remote peer." ;
    ocsf:caption "ESTABLISHED" ;
    ocsf:ocsf_uid "1" .

<https://w3id.org/lmodel/ocsf/TcpStateIdEnum#FIN_WAIT_1> a owl:Class ;
    rdfs:label "FIN_WAIT_1" ;
    rdfs:subClassOf ocsf:TcpStateIdEnum ;
    skos:definition "The socket connection has been closed by the local application, the remote peer has not yet acknowledged the close, and the system is waiting for it to close its half of the connection." ;
    ocsf:caption "FIN-WAIT-1" ;
    ocsf:ocsf_uid "4" .

<https://w3id.org/lmodel/ocsf/TcpStateIdEnum#FIN_WAIT_2> a owl:Class ;
    rdfs:label "FIN_WAIT_2" ;
    rdfs:subClassOf ocsf:TcpStateIdEnum ;
    skos:definition "The socket connection has been closed by the local application, the remote peer has acknowledged the close, and the system is waiting for it to close its half of the connection." ;
    ocsf:caption "FIN-WAIT-2" ;
    ocsf:ocsf_uid "5" .

<https://w3id.org/lmodel/ocsf/TcpStateIdEnum#LAST_ACK> a owl:Class ;
    rdfs:label "LAST_ACK" ;
    rdfs:subClassOf ocsf:TcpStateIdEnum ;
    skos:definition "The socket connection has been closed by the remote peer, the local application has closed its half of the connection, and the system is waiting for the remote peer to acknowledge the close." ;
    ocsf:caption "LAST-ACK" ;
    ocsf:ocsf_uid "9" .


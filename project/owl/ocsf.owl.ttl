    skos:altLabel "Unmanned System Operating Area" ;
    skos:definition "The Unmanned System Operating Area object describes details about a precise area of operations for a UAS flight or mission." ;
    skos:inScheme ocsf:objects .

ocsf:VendorAttributes a owl:Class ;
    rdfs:label "VendorAttributes" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:severity ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:SeverityIdEnum ;
            owl:onProperty ocsf:severity_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:severity ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:severity_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:severity_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:severity ],
        ocsf:Object ;
    skos:altLabel "Vendor Attributes" ;
    skos:definition "The Vendor Attributes object can be used to represent values of attributes populated by the Vendor/Finding Provider. It can help distinguish between the vendor-provided values and consumer-updated values, of key attributes like <code>severity_id</code>.<br>The original finding producer should not populate this object. It should be populated by consuming systems that support data mutability." ;
    skos:inScheme ocsf:objects .

ocsf:access_analysis_result a owl:ObjectProperty ;
    rdfs:label "access_analysis_result" ;
    rdfs:range ocsf:AccessAnalysisResult ;
    skos:altLabel "Access Analysis Result" ;
    skos:definition "Describes access relationships and pathways between identities, resources, focusing on who can access what and through which mechanisms. This evaluates access levels (read/write/admin), access types (direct, cross-account, public, federated), and the conditions under which access is granted. Use this for resource-centric security assessments such as external access discovery, public exposure analysis, etc." ;
    skos:inScheme ocsf:dictionary .

ocsf:access_level a owl:DatatypeProperty ;
    rdfs:label "access_level" ;
    rdfs:range xsd:string ;
    skos:altLabel "Access Level" ;
    skos:definition "The access level of an entity. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:access_result a owl:DatatypeProperty ;
    rdfs:label "access_result" ;
    rdfs:range xsd:string ;
    skos:altLabel "Access Check Result" ;
    skos:definition "The list of access check results." ;
    skos:inScheme ocsf:dictionary .

ocsf:access_type a owl:DatatypeProperty ;
    rdfs:label "access_type" ;
    rdfs:range xsd:string ;
    skos:altLabel "Access Type" ;
    skos:definition "The type or category of access being granted to the identity. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:accessed_time a owl:DatatypeProperty ;
    rdfs:label "accessed_time" ;
    rdfs:range xsd:long ;
    skos:altLabel "Accessed Time" ;
    skos:definition "The time when the file was last accessed." ;
    skos:inScheme ocsf:dictionary .

ocsf:accessor a owl:ObjectProperty ;
    rdfs:label "accessor" ;
    rdfs:range ocsf:User ;
    skos:altLabel "Accessor" ;
    skos:definition "The name of the user who last accessed the object." ;
    skos:inScheme ocsf:dictionary .

ocsf:account_switch_type a owl:DatatypeProperty ;
    rdfs:label "account_switch_type" ;
    rdfs:range xsd:string ;
    skos:altLabel "Account Switch Type" ;
    skos:definition "The account switch method, normalized to the caption of the account_switch_type_id value. In the case of 'Other', it is defined by the event source." ;
    skos:inScheme ocsf:dictionary .

ocsf:account_switch_type_id a owl:ObjectProperty ;
    rdfs:label "account_switch_type_id" ;
    rdfs:range ocsf:AccountSwitchTypeIdEnum ;
    skos:altLabel "Account Switch Type ID" ;
    skos:definition "The normalized identifier of the account switch method." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "account_switch_type" .

ocsf:ack_reason a owl:DatatypeProperty ;
    rdfs:label "ack_reason" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Acknowledgement Reason" ;
    skos:definition "An integer that provides a reason code or additional information about the acknowledgment result." ;
    skos:inScheme ocsf:dictionary .

ocsf:ack_result a owl:DatatypeProperty ;
    rdfs:label "ack_result" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Acknowledgement Result" ;
    skos:definition "An integer that denotes the acknowledgment result of the DCE/RPC call." ;
    skos:inScheme ocsf:dictionary .

ocsf:action a owl:DatatypeProperty ;
    rdfs:label "action" ;
    rdfs:range xsd:string ;
    skos:altLabel "Action" ;
    skos:definition "The normalized caption of 'action_id' or the source specific action." ;
    skos:inScheme ocsf:dictionary .

ocsf:action_id a owl:ObjectProperty ;
    rdfs:label "action_id" ;
    rdfs:range ocsf:ActionIdEnum ;
    skos:altLabel "Action ID" ;
    skos:definition "The normalized action taken by a control or other policy-based system leading to an outcome or disposition." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "action" .

ocsf:advisory a owl:ObjectProperty ;
    rdfs:label "advisory" ;
    rdfs:range ocsf:Advisory ;
    skos:altLabel "Security Advisory" ;
    skos:definition "Detail about the security advisory, that is used to publicly disclose cybersecurity vulnerabilities by a vendor." ;
    skos:inScheme ocsf:dictionary .

ocsf:aerial_height a owl:DatatypeProperty ;
    rdfs:label "aerial_height" ;
    rdfs:range xsd:string ;
    skos:altLabel "Aerial Height" ;
    skos:definition "Expressed as either height above takeoff location or height above ground level (AGL) for a UAS current location. This value is provided in meters and must have a minimum resolution of 1 m. Special Values: <code>Invalid</code>, <code>No Value</code>, or <code>Unknown: -1000 m</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:ai_model a owl:ObjectProperty ;
    rdfs:label "ai_model" ;
    rdfs:range ocsf:AiModel ;
    skos:altLabel "AI Model" ;
    skos:definition "The AI Model object describes the characteristics of an AI/ML model. Examples include language models like GPT-4, embedding models like text-embedding-ada-002, and computer vision models like CLIP." ;
    skos:inScheme ocsf:dictionary .

ocsf:ai_provider a owl:DatatypeProperty ;
    rdfs:label "ai_provider" ;
    rdfs:range xsd:string ;
    skos:altLabel "AI Provider" ;
    skos:definition "AI service provider or organization name." ;
    skos:inScheme ocsf:dictionary .

ocsf:ai_role a owl:DatatypeProperty ;
    rdfs:label "ai_role" ;
    rdfs:range xsd:string ;
    skos:altLabel "AI Role" ;
    skos:definition "The normalized caption of the <code>ai_role_id</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:ai_role_id a owl:DatatypeProperty ;
    rdfs:label "ai_role_id" ;
    rdfs:range xsd:integer ;
    skos:altLabel "AI Role ID" ;
    skos:definition "The originator or target role of the message." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "ai_role" .

ocsf:aircraft a owl:ObjectProperty ;
    rdfs:label "aircraft" ;
    rdfs:range ocsf:Aircraft ;
    skos:altLabel "Aircraft" ;
    skos:definition "The Aircraft object represents any aircraft or otherwise airborne asset such as an unmanned system, airplane, balloon, spacecraft, or otherwise. The Aircraft object is intended to normalized data captured or otherwise logged from active radar, passive radar, multi-spectral systems, or the Automatic Dependant Broadcast - Surveillance (ADS-B), and/or Mode S systems." ;
    skos:inScheme ocsf:dictionary .

ocsf:alert a owl:DatatypeProperty ;
    rdfs:label "alert" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Client TLS Alert" ;
    skos:definition "The integer value of TLS alert if present. The alerts are defined in the TLS specification in <a target='_blank' href='https://datatracker.ietf.org/doc/html/rfc2246'>RFC-2246</a>." ;
    skos:inScheme ocsf:dictionary .

ocsf:all_privileges_unused a owl:DatatypeProperty ;
    rdfs:label "all_privileges_unused" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "All Privileges Unused" ;
    skos:definition "Indicates whether all privileges in a set, list, collection or group are unused. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:altitude_ceiling a owl:DatatypeProperty ;
    rdfs:label "altitude_ceiling" ;
    rdfs:range xsd:string ;
    skos:altLabel "Altitude Ceiling" ;
    skos:definition "Maximum altitude (WGS-84 HAE) for a group or an Intent-Based Network Participant. Measured in meters. Special Values: <code>Invalid</code>, <code>No Value</code>, or <code>Unknown: -1000 m</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:altitude_floor a owl:DatatypeProperty ;
    rdfs:label "altitude_floor" ;
    rdfs:range xsd:string ;
    skos:altLabel "Altitude Floor" ;
    skos:definition "Minimum altitude (WGS-84 HAE) for a group or an Intent-Based Network Participant. Measured in meters. Special Values: <code>Invalid</code>, <code>No Value</code>, or <code>Unknown: -1000 m</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:app a owl:ObjectProperty ;
    rdfs:label "app" ;
    rdfs:range ocsf:Product ;
    skos:altLabel "Application" ;
    skos:definition "The application that reported the event." ;
    skos:inScheme ocsf:dictionary .

ocsf:app_protocol_name a owl:DatatypeProperty ;
    rdfs:label "app_protocol_name" ;
    rdfs:range xsd:string ;
    skos:altLabel "Application Protocol Name" ;
    skos:definition "The application protocol name. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:app_uid a owl:DatatypeProperty ;
    rdfs:label "app_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "Application ID" ;
    skos:definition "The unique ID of the application associated with the event or object." ;
    skos:inScheme ocsf:dictionary .

ocsf:architecture a owl:DatatypeProperty ;
    rdfs:label "architecture" ;
    rdfs:range xsd:string ;
    skos:altLabel "Architecture" ;
    skos:definition "Architecture is a shorthand name describing the type of computer hardware the packaged software is meant to run on." ;
    skos:inScheme ocsf:dictionary .

ocsf:args a owl:DatatypeProperty ;
    rdfs:label "args" ;
    rdfs:range xsd:string ;
    skos:altLabel "HTTP Arguments" ;
    skos:definition "The arguments sent along with the HTTP request." ;
    skos:inScheme ocsf:dictionary .

ocsf:attack a owl:ObjectProperty ;
    rdfs:label "attack" ;
    rdfs:range ocsf:Attack ;
    skos:altLabel "MITRE ATT&CK® Details" ;
    skos:definition "The MITRE ATT&CK® object describing the tactic, technique, and sub-technique." ;
    skos:inScheme ocsf:dictionary .

ocsf:attack_graph a owl:ObjectProperty ;
    rdfs:label "attack_graph" ;
    rdfs:range ocsf:Graph ;
    rdfs:seeAlso <https://learn.microsoft.com/en-us/azure/defender-for-cloud/how-to-manage-attack-path>,
        <https://www.sentinelone.com/cybersecurity-101/cybersecurity/attack-path-analysis/> ;
    skos:altLabel "Attack Graph" ;
    skos:definition "An Attack Graph describes possible routes an attacker could take through an environment. It describes relationships between resources and their findings, such as malware detections, vulnerabilities, misconfigurations, and other security actions." ;
    skos:editorialNote "MS Defender description of Attack Path — https://learn.microsoft.com/en-us/azure/defender-for-cloud/how-to-manage-attack-path",
        "SentinelOne Attack Path documentation — https://www.sentinelone.com/cybersecurity-101/cybersecurity/attack-path-analysis/" ;
    skos:inScheme ocsf:dictionary .

ocsf:attempt a owl:DatatypeProperty ;
    rdfs:label "attempt" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Attempt" ;
    skos:definition "The delivery attempt." ;
    skos:inScheme ocsf:dictionary .

ocsf:attributes a owl:DatatypeProperty ;
    rdfs:label "attributes" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Attributes" ;
    skos:definition "The bitmask value that represents the file attributes." ;
    skos:inScheme ocsf:dictionary .

ocsf:auid a owl:DatatypeProperty ;
    rdfs:label "auid" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Audit User ID" ;
    skos:definition "The audit user assigned at login by the audit subsystem." ;
    skos:inScheme ocsf:dictionary .

ocsf:auth_type a owl:DatatypeProperty ;
    rdfs:label "auth_type" ;
    rdfs:range xsd:string ;
    skos:altLabel "Authentication Type" ;
    skos:definition "The agreed upon authentication type, normalized to the caption of 'auth_type_id'. In the case of 'Other', it is defined by the event source." ;
    skos:inScheme ocsf:dictionary .

ocsf:auth_type_id a owl:ObjectProperty ;
    rdfs:label "auth_type_id" ;
    rdfs:range ocsf:AuthTypeIdEnum ;
    skos:altLabel "Authentication Type ID" ;
    skos:definition "The normalized identifier of the agreed upon authentication type. See specific usage." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "auth_type" .

ocsf:authentication_token a owl:ObjectProperty ;
    rdfs:label "authentication_token" ;
    rdfs:range ocsf:AuthenticationToken ;
    skos:altLabel "Authentication Token" ;
    skos:definition "The authentication token, ticket, or assertion. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:author a owl:DatatypeProperty ;
    rdfs:label "author" ;
    rdfs:range xsd:string ;
    skos:altLabel "Author" ;
    skos:definition "The author(s) who published the software component." ;
    skos:inScheme ocsf:dictionary .

ocsf:autoscale_uid a owl:DatatypeProperty ;
    rdfs:label "autoscale_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "Autoscale UID" ;
    skos:definition "The unique identifier of the cloud autoscale configuration." ;
    skos:inScheme ocsf:dictionary .

ocsf:banner a owl:DatatypeProperty ;
    rdfs:label "banner" ;
    rdfs:range xsd:string ;
    skos:altLabel "Protocol Banner" ;
    skos:definition "The initial connection response that a messaging server receives after it connects to an email server." ;
    skos:inScheme ocsf:dictionary .

ocsf:bios_date a owl:DatatypeProperty ;
    rdfs:label "bios_date" ;
    rdfs:range xsd:string ;
    skos:altLabel "BIOS Date" ;
    skos:definition "The BIOS date. For example: <code>03/31/16</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:bios_manufacturer a owl:DatatypeProperty ;
    rdfs:label "bios_manufacturer" ;
    rdfs:range xsd:string ;
    skos:altLabel "BIOS Manufacturer" ;
    skos:definition "The BIOS manufacturer. For example: <code>LENOVO</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:bios_ver a owl:DatatypeProperty ;
    rdfs:label "bios_ver" ;
    rdfs:range xsd:string ;
    skos:altLabel "BIOS Version" ;
    skos:definition "The BIOS version. For example: <code>LENOVO G5ETA2WW (2.62)</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:boot_time a owl:DatatypeProperty ;
    rdfs:label "boot_time" ;
    rdfs:range xsd:long ;
    skos:altLabel "Boot Time" ;
    skos:definition "The time when the system was booted." ;
    skos:inScheme ocsf:dictionary .

ocsf:boot_uid a owl:DatatypeProperty ;
    rdfs:label "boot_uid" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://docs.kernel.org/admin-guide/sysctl/kernel.html#random> ;
    skos:altLabel "Boot UID" ;
    skos:definition "A unique identifier of the device that changes after every reboot. For example, the value of <code>/proc/sys/kernel/random/boot_id</code> from Linux's procfs." ;
    skos:editorialNote "Linux kernel's documentation — https://docs.kernel.org/admin-guide/sysctl/kernel.html#random" ;
    skos:inScheme ocsf:dictionary .

ocsf:boundary a owl:DatatypeProperty ;
    rdfs:label "boundary" ;
    rdfs:range xsd:string ;
    skos:altLabel "Boundary" ;
    skos:definition "The boundary of the connection, normalized to the caption of 'boundary_id'. In the case of 'Other', it is defined by the event source. <p> For cloud connections, this translates to the traffic-boundary(same VPC, through IGW, etc.). For traditional networks, this is described as Local, Internal, or External.</p>" ;
    skos:inScheme ocsf:dictionary .

ocsf:boundary_id a owl:ObjectProperty ;
    rdfs:label "boundary_id" ;
    rdfs:range ocsf:BoundaryIdEnum ;
    skos:altLabel "Boundary ID" ;
    skos:definition "<p>The normalized identifier of the boundary of the connection. </p><p> For cloud connections, this translates to the traffic-boundary (same VPC, through IGW, etc.). For traditional networks, this is described as Local, Internal, or External.</p>" ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "boundary" .

ocsf:build a owl:DatatypeProperty ;
    rdfs:label "build" ;
    rdfs:range xsd:string ;
    skos:altLabel "OS Build" ;
    skos:definition "The operating system build number." ;
    skos:inScheme ocsf:dictionary .

ocsf:bus_type a owl:DatatypeProperty ;
    rdfs:label "bus_type" ;
    rdfs:range xsd:string ;
    skos:altLabel "Bus Type" ;
    skos:definition "The attachment bus or interface standard, normalized to the caption of the bus_type_id value. In the case of 'Other', it is defined by the event source." ;
    skos:inScheme ocsf:dictionary .

ocsf:bus_type_id a owl:ObjectProperty ;
    rdfs:label "bus_type_id" ;
    rdfs:range ocsf:BusTypeIdEnum ;
    skos:altLabel "Bus Type ID" ;
    skos:definition "The normalized identifier of the attachment bus or interface standard." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "bus_type" .

ocsf:bytes_in a owl:DatatypeProperty ;
    rdfs:label "bytes_in" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Bytes In" ;
    skos:definition "The number of bytes sent from the destination to the source." ;
    skos:inScheme ocsf:dictionary .

ocsf:bytes_missed a owl:DatatypeProperty ;
    rdfs:label "bytes_missed" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Bytes Missed" ;
    skos:definition "Indicates the number of bytes missed, which is representative of packet loss." ;
    skos:inScheme ocsf:dictionary .

ocsf:bytes_out a owl:DatatypeProperty ;
    rdfs:label "bytes_out" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Bytes Out" ;
    skos:definition "The number of bytes sent from the source to the destination." ;
    skos:inScheme ocsf:dictionary .

ocsf:campaign a owl:ObjectProperty ;
    rdfs:label "campaign" ;
    rdfs:range ocsf:Campaign ;
    skos:altLabel "Campaign" ;
    skos:definition "The campaign object describes details about the campaign that was the source of the activity." ;
    skos:inScheme ocsf:dictionary .

ocsf:caption a owl:DatatypeProperty ;
    rdfs:label "caption" ;
    rdfs:range xsd:string ;
    skos:altLabel "Caption" ;
    skos:definition "A short description or caption of the device. For example: <code>Scanner 1</code> or <code>Database Manager</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:categories a owl:DatatypeProperty ;
    rdfs:label "categories" ;
    rdfs:range xsd:string ;
    skos:altLabel "Website Categorization" ;
    skos:definition "The Website categorization names, as defined by <code>category_ids</code> enum values." ;
    skos:inScheme ocsf:dictionary .

ocsf:category_id a owl:DatatypeProperty ;
    rdfs:label "category_id" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Category ID" ;
    skos:definition "The normalized identifier of the object category. See specific usage." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "category" .

ocsf:category_name a owl:DatatypeProperty ;
    rdfs:label "category_name" ;
    rdfs:range xsd:string ;
    skos:altLabel "Category" ;
    skos:definition "The event category name, as defined by category_uid value." ;
    skos:inScheme ocsf:dictionary .

ocsf:category_uid a owl:DatatypeProperty ;
    rdfs:label "category_uid" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Category ID" ;
    skos:definition "The category unique identifier of the event." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "category_name" .

ocsf:cell_name a owl:DatatypeProperty ;
    rdfs:label "cell_name" ;
    rdfs:range xsd:string ;
    skos:altLabel "Cell Name" ;
    skos:definition "The name of the cell. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:chassis a owl:DatatypeProperty ;
    rdfs:label "chassis" ;
    rdfs:range xsd:string ;
    skos:altLabel "Chassis" ;
    skos:definition "The chassis type describes the system enclosure or physical form factor. Such as the following examples for Windows <a target='_blank' href='https://docs.microsoft.com/en-us/windows/win32/cimwin32prov/win32-systemenclosure'>Windows Chassis Types</a>" ;
    skos:inScheme ocsf:dictionary .

ocsf:chunks a owl:DatatypeProperty ;
    rdfs:label "chunks" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Chunks" ;
    skos:definition "A unit of information within an SCTP packet, consisting of a chunk header and chunk-specific content. See RFC 4960. This field can be used for the total number of chunks (in and out)." ;
    skos:inScheme ocsf:dictionary .

ocsf:chunks_in a owl:DatatypeProperty ;
    rdfs:label "chunks_in" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Chunks In" ;
    skos:definition "A unit of information within an SCTP packet, consisting of a chunk header and chunk-specific content. See RFC 4960. This field can be used for the chunks sent from the destination to the source." ;
    skos:inScheme ocsf:dictionary .

ocsf:chunks_out a owl:DatatypeProperty ;
    rdfs:label "chunks_out" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Chunks Out" ;
    skos:definition "A unit of information within an SCTP packet, consisting of a chunk header and chunk-specific content. See RFC 4960. This field can be used for the chunks sent from the source to the destination." ;
    skos:inScheme ocsf:dictionary .

ocsf:cipher a owl:DatatypeProperty ;
    rdfs:label "cipher" ;
    rdfs:range xsd:string ;
    skos:altLabel "Cipher Suite" ;
    skos:definition "The negotiated cipher suite." ;
    skos:inScheme ocsf:dictionary .

ocsf:cis_benchmark_result a owl:ObjectProperty ;
    rdfs:label "cis_benchmark_result" ;
    rdfs:range ocsf:CisBenchmarkResult ;
    skos:altLabel "CIS Benchmark Result" ;
    skos:definition "The CIS Benchmark Result object captures results generated from benchmark evaluations as defined by the Center for Internet Security (<a target='_blank' href='https://www.cisecurity.org/cis-benchmarks/'>CIS</a>)." ;
    skos:inScheme ocsf:dictionary .

ocsf:city a owl:DatatypeProperty ;
    rdfs:label "city" ;
    rdfs:range xsd:string ;
    skos:altLabel "City" ;
    skos:definition "The name of the city." ;
    skos:inScheme ocsf:dictionary .

ocsf:class_name a owl:DatatypeProperty ;
    rdfs:label "class_name" ;
    rdfs:range xsd:string ;
    skos:altLabel "Class" ;
    skos:definition "The event class name, as defined by class_uid value." ;
    skos:inScheme ocsf:dictionary .

ocsf:class_uid a owl:DatatypeProperty ;
    rdfs:label "class_uid" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Class ID" ;
    skos:definition "The unique identifier of a class. A class describes the attributes available in an event." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "class_name" .

ocsf:classifier_details a owl:ObjectProperty ;
    rdfs:label "classifier_details" ;
    rdfs:range ocsf:ClassifierDetails ;
    skos:altLabel "Classifier Details" ;
    skos:definition "Describes details about the classifier used for data classification." ;
    skos:inScheme ocsf:dictionary .

ocsf:client_hassh a owl:ObjectProperty ;
    rdfs:label "client_hassh" ;
    rdfs:range ocsf:Hassh ;
    skos:altLabel "Client HASSH" ;
    skos:definition "The Client HASSH fingerprinting object." ;
    skos:inScheme ocsf:dictionary .

ocsf:color_depth a owl:DatatypeProperty ;
    rdfs:label "color_depth" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Color Depth" ;
    skos:definition "The numeric color depth." ;
    skos:inScheme ocsf:dictionary .

ocsf:column_name a owl:DatatypeProperty ;
    rdfs:label "column_name" ;
    rdfs:range xsd:string ;
    skos:altLabel "Column Name" ;
    skos:definition "The name of the column. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:column_number a owl:DatatypeProperty ;
    rdfs:label "column_number" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Column Number" ;
    skos:definition "The number of the column. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:command_response a owl:DatatypeProperty ;
    rdfs:label "command_response" ;
    rdfs:range xsd:string ;
    skos:altLabel "Command Response" ;
    skos:definition "The response to the command." ;
    skos:inScheme ocsf:dictionary .

ocsf:community_uid a owl:DatatypeProperty ;
    rdfs:label "community_uid" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://github.com/corelight/community-id-spec> ;
    skos:altLabel "Community ID" ;
    skos:definition "The Community ID of the network connection." ;
    skos:editorialNote "Community ID definition. — https://github.com/corelight/community-id-spec" ;
    skos:inScheme ocsf:dictionary ;
    ocsf:ocsf_source "community_id" .

ocsf:company_name a owl:DatatypeProperty ;
    rdfs:label "company_name" ;
    rdfs:range xsd:string ;
    skos:altLabel "Company Name" ;
    skos:definition "The name of the company that published the file. For example: <code>Microsoft Corporation</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:completion_tokens a owl:DatatypeProperty ;
    rdfs:label "completion_tokens" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Completion Tokens" ;
    skos:definition "Number of tokens in the model's response/completion for this message." ;
    skos:inScheme ocsf:dictionary .

ocsf:component a owl:DatatypeProperty ;
    rdfs:label "component" ;
    rdfs:range xsd:string ;
    skos:altLabel "Component" ;
    skos:definition "The component of a data object. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:condition a owl:DatatypeProperty ;
    rdfs:label "condition" ;
    rdfs:range xsd:string ;
    skos:altLabel "Condition" ;
    skos:definition "The condition that was evaluated in a rule, policy. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:connection_uid a owl:DatatypeProperty ;
    rdfs:label "connection_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "Connection Identifier" ;
    skos:definition "The network connection identifier." ;
    skos:inScheme ocsf:dictionary .

ocsf:content_type a owl:DatatypeProperty ;
    rdfs:label "content_type" ;
    rdfs:range xsd:string ;
    skos:altLabel "HTTP Content Type" ;
    skos:definition "The request header that identifies the original <a target='_blank' href='https://www.iana.org/assignments/media-types/media-types.xhtml'>media type </a> of the resource (prior to any content encoding applied for sending)." ;
    skos:inScheme ocsf:dictionary .

ocsf:continent a owl:DatatypeProperty ;
    rdfs:label "continent" ;
    rdfs:range xsd:string ;
    skos:altLabel "Continent" ;
    skos:definition "The name of the continent." ;
    skos:inScheme ocsf:dictionary .

ocsf:cores a owl:DatatypeProperty ;
    rdfs:label "cores" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Cores" ;
    skos:definition "The number of processing cores or compute units for the component." ;
    skos:inScheme ocsf:dictionary .

ocsf:correlation_uid a owl:DatatypeProperty ;
    rdfs:label "correlation_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "Correlation UID" ;
    skos:definition "A unique identifier used to correlate events. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:cost_center a owl:DatatypeProperty ;
    rdfs:label "cost_center" ;
    rdfs:range xsd:string ;
    skos:altLabel "Cost Center" ;
    skos:definition "The cost center associated with the user." ;
    skos:inScheme ocsf:dictionary .

ocsf:cpid a owl:DatatypeProperty ;
    rdfs:label "cpid" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://github.com/ocsf/common-process-id> ;
    skos:altLabel "Common Process Identifier" ;
    skos:definition "A unique process identifier that can be assigned deterministically by multiple system data producers." ;
    skos:editorialNote "OCSF Common Process Identifier (CPID) Specification — https://github.com/ocsf/common-process-id" ;
    skos:inScheme ocsf:dictionary ;
    ocsf:ocsf_source "cpid" .

ocsf:cpu_architecture a owl:DatatypeProperty ;
    rdfs:label "cpu_architecture" ;
    rdfs:range xsd:string ;
    skos:altLabel "CPU Architecture" ;
    skos:definition "The CPU architecture, normalized to the caption of the <code>cpu_architecture_id</code> value. In the case of <code>Other</code>, it is defined by the source." ;
    skos:inScheme ocsf:dictionary .

ocsf:cpu_architecture_id a owl:ObjectProperty ;
    rdfs:label "cpu_architecture_id" ;
    rdfs:range ocsf:CpuArchitectureIdEnum ;
    skos:altLabel "CPU Architecture ID" ;
    skos:definition "The normalized identifier of the CPU architecture." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "cpu_architecture" .

ocsf:cpu_cores a owl:DatatypeProperty ;
    rdfs:label "cpu_cores" ;
    rdfs:range xsd:integer ;
    skos:altLabel "CPU Cores" ;
    skos:definition "The number of processor cores in all installed processors. For Example: <code>42</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:cpu_count a owl:DatatypeProperty ;
    rdfs:label "cpu_count" ;
    rdfs:range xsd:integer ;
    skos:altLabel "CPU Count" ;
    skos:definition "The number of physical processors on a system. For example: <code>1</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:cpu_speed a owl:DatatypeProperty ;
    rdfs:label "cpu_speed" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Processor Speed" ;
    skos:definition "The speed of the processor in Mhz. For Example: <code>4200</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:cpu_type a owl:DatatypeProperty ;
    rdfs:label "cpu_type" ;
    rdfs:range xsd:string ;
    skos:altLabel "Processor Type" ;
    skos:definition "The processor type. For example: <code>x86 Family 6 Model 37 Stepping 5</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:cumulative_traffic a owl:ObjectProperty ;
    rdfs:label "cumulative_traffic" ;
    rdfs:range ocsf:NetworkTraffic ;
    skos:altLabel "Cumulative Traffic" ;
    skos:definition "The cumulative network traffic. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:cve a owl:ObjectProperty ;
    rdfs:label "cve" ;
    rdfs:range ocsf:Cve ;
    skos:altLabel "CVE" ;
    skos:definition "The Common Vulnerabilities and Exposures (<a target='_blank' href='https://cve.mitre.org/'>CVE</a>) identifiers for the vulnerability." ;
    skos:inScheme ocsf:dictionary .

ocsf:cwe_uid a owl:DatatypeProperty ;
    rdfs:label "cwe_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "CWE UID" ;
    skos:definition "The <a target='_blank' href='https://cwe.mitre.org/'>Common Weakness Enumeration (CWE)</a> unique identifier. For example: <code>CWE-787</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:cwe_url a owl:DatatypeProperty ;
    rdfs:label "cwe_url" ;
    rdfs:range xsd:anyURI ;
    skos:altLabel "CWE URL" ;
    skos:definition "Common Weakness Enumeration (CWE) definition URL. For example: <code>https://cwe.mitre.org/data/definitions/787.html</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:d3f_tactic a owl:ObjectProperty ;
    rdfs:label "d3f_tactic" ;
    rdfs:range ocsf:D3fTactic ;
    rdfs:seeAlso <https://d3fend.mitre.org> ;
    skos:altLabel "MITRE D3FEND™ Tactic" ;
    skos:definition "The D3FEND Tactic object describes the defensive tactic name associated with a countermeasure." ;
    skos:editorialNote "D3FEND™ Matrix — https://d3fend.mitre.org" ;
    skos:inScheme ocsf:dictionary .

ocsf:d3f_technique a owl:ObjectProperty ;
    rdfs:label "d3f_technique" ;
    rdfs:range ocsf:D3fTechnique ;
    rdfs:seeAlso <https://d3fend.mitre.org> ;
    skos:altLabel "MITRE D3FEND™ Technique" ;
    skos:definition "The D3FEND Technique object describes the defensive technique ID and/or name associated with a countermeasure." ;
    skos:editorialNote "D3FEND™ Matrix — https://d3fend.mitre.org" ;
    skos:inScheme ocsf:dictionary .

ocsf:data_classification a owl:ObjectProperty ;
    rdfs:label "data_classification" ;
    rdfs:range ocsf:DataClassification ;
    skos:altLabel "Data Classification" ;
    skos:definition "The Data Classification object includes information about data classification levels and data category types." ;
    skos:inScheme ocsf:dictionary .

ocsf:data_lifecycle_state a owl:DatatypeProperty ;
    rdfs:label "data_lifecycle_state" ;
    rdfs:range xsd:string ;
    skos:altLabel "Data Lifecycle State" ;
    skos:definition "The name of the stage or state that the data was in. E.g., Data-at-Rest, Data-in-Transit, etc." ;
    skos:inScheme ocsf:dictionary .

ocsf:data_lifecycle_state_id a owl:ObjectProperty ;
    rdfs:label "data_lifecycle_state_id" ;
    rdfs:range ocsf:DataLifecycleStateIdEnum ;
    skos:altLabel "Data Lifecycle State ID" ;
    skos:definition "The stage or state that the data was in when it was assessed or scanned by a data security tool." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "data_lifecycle_state" .

ocsf:data_security a owl:ObjectProperty ;
    rdfs:label "data_security" ;
    rdfs:range ocsf:DataSecurity ;
    skos:altLabel "Data Security" ;
    skos:definition "The Data Security object describes the characteristics, techniques and content of a Data Loss Prevention (DLP), Data Loss Detection (DLD), Data Classification, or similar tools' finding, alert, or detection mechanism(s)." ;
    skos:inScheme ocsf:dictionary .

ocsf:dce_rpc a owl:ObjectProperty ;
    rdfs:label "dce_rpc" ;
    rdfs:range ocsf:DceRpc ;
    skos:altLabel "Distributed Computing Environment/Remote Procedure Call (DCE/RPC)" ;
    skos:definition "The DCE/RPC object describes the remote procedure call system for distributed computing environments." ;
    skos:inScheme ocsf:dictionary .

ocsf:decision a owl:DatatypeProperty ;
    rdfs:label "decision" ;
    rdfs:range xsd:string ;
    skos:altLabel "Authorization Decision/Outcome" ;
    skos:definition "Decision/outcome of the authorization mechanism (e.g. Approved, Denied)" ;
    skos:inScheme ocsf:dictionary .

ocsf:delay a owl:DatatypeProperty ;
    rdfs:label "delay" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Root Delay" ;
    skos:definition "The total round-trip delay to the reference clock in milliseconds." ;
    skos:inScheme ocsf:dictionary .

ocsf:deleted_time a owl:DatatypeProperty ;
    rdfs:label "deleted_time" ;
    rdfs:range xsd:long ;
    skos:altLabel "Deleted Time" ;
    skos:definition "The timestamp when the user was deleted. In Active Directory (AD), when a user is deleted they are moved to a temporary container and then removed after 30 days. So, this field can be populated even after a user is deleted for the next 30 days." ;
    skos:inScheme ocsf:dictionary .

ocsf:delivered_to a owl:DatatypeProperty ;
    rdfs:label "delivered_to" ;
    rdfs:range xsd:string ;
    skos:altLabel "Delivered To" ;
    skos:definition "The machine-readable <strong>Delivered-To</strong> email header field. For example <code>example.user@usersdomain.com</code>" ;
    skos:inScheme ocsf:dictionary .

ocsf:department a owl:DatatypeProperty ;
    rdfs:label "department" ;
    rdfs:range xsd:string ;
    skos:altLabel "Department" ;
    skos:definition "The name of the department or organizational unit where the entity is assigned or belongs. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:dependency_chain a owl:DatatypeProperty ;
    rdfs:label "dependency_chain" ;
    rdfs:range xsd:string ;
    skos:altLabel "Dependency Chain" ;
    skos:definition "Information about the chain of dependencies related to the issue as reported by an Application Security or Vulnerability Management tool. E.g., <code>serverless-offline -> @serverless/utils -> memoizee -> es5-ext</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:depth a owl:ObjectProperty ;
    rdfs:label "depth" ;
    rdfs:range ocsf:DepthEnum ;
    skos:altLabel "CVSS Depth" ;
    skos:definition "The CVSS depth represents a depth of the equation used to calculate CVSS score." ;
    skos:inScheme ocsf:dictionary .

ocsf:desktop_display a owl:ObjectProperty ;
    rdfs:label "desktop_display" ;
    rdfs:range ocsf:Display ;
    skos:altLabel "Desktop Display" ;
    skos:definition "The desktop display affiliated with the event" ;
    skos:inScheme ocsf:dictionary .

ocsf:details a owl:DatatypeProperty ;
    rdfs:label "details" ;
    rdfs:range xsd:string ;
    skos:altLabel "Details" ;
    skos:definition "Details of an entity. See specific usage" ;
    skos:inScheme ocsf:dictionary .

ocsf:detection_pattern_type a owl:DatatypeProperty ;
    rdfs:label "detection_pattern_type" ;
    rdfs:range xsd:string ;
    skos:altLabel "Detection Pattern" ;
    skos:definition "The detection pattern type, normalized to the caption of the detection_pattern_type_id value. In the case of 'Other', it is defined by the event source." ;
    skos:inScheme ocsf:dictionary .

ocsf:detection_pattern_type_id a owl:ObjectProperty ;
    rdfs:label "detection_pattern_type_id" ;
    rdfs:range ocsf:DetectionPatternTypeIdEnum ;
    skos:altLabel "Detection Pattern Type ID" ;
    skos:definition "Specifies the type of detection pattern used to identify the associated threat indicator." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "detection_pattern_type" .

ocsf:detection_system a owl:DatatypeProperty ;
    rdfs:label "detection_system" ;
    rdfs:range xsd:string ;
    skos:altLabel "Detection System" ;
    skos:definition "The name of the type of data security tool or system that the finding, detection, or alert originated from. E.g., Endpoint, Secure Email Gateway, etc." ;
    skos:inScheme ocsf:dictionary .

ocsf:detection_system_id a owl:ObjectProperty ;
    rdfs:label "detection_system_id" ;
    rdfs:range ocsf:DetectionSystemIdEnum ;
    skos:altLabel "Detection System ID" ;
    skos:definition "The type of data security tool or system that the finding, detection, or alert originated from." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "detection_system" .

ocsf:developer_uid a owl:DatatypeProperty ;
    rdfs:label "developer_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "Developer UID" ;
    skos:definition "The developer ID on the certificate that signed the file." ;
    skos:inScheme ocsf:dictionary .

ocsf:dialect a owl:DatatypeProperty ;
    rdfs:label "dialect" ;
    rdfs:range xsd:string ;
    skos:altLabel "Dialect" ;
    skos:definition "The negotiated protocol dialect." ;
    skos:inScheme ocsf:dictionary .

ocsf:digest a owl:ObjectProperty ;
    rdfs:label "digest" ;
    rdfs:range ocsf:Fingerprint ;
    skos:altLabel "Message Digest" ;
    skos:definition "The message digest attribute contains the fixed length message hash representation and the corresponding hashing algorithm information." ;
    skos:inScheme ocsf:dictionary .

ocsf:dispersion a owl:DatatypeProperty ;
    rdfs:label "dispersion" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Root Dispersion" ;
    skos:definition "The dispersion in the NTP protocol is the estimated time error or uncertainty relative to the reference clock in milliseconds." ;
    skos:inScheme ocsf:dictionary .

ocsf:disposition a owl:DatatypeProperty ;
    rdfs:label "disposition" ;
    rdfs:range xsd:string ;
    skos:altLabel "Disposition" ;
    skos:definition "The disposition name, normalized to the caption of the disposition_id value. In the case of 'Other', it is defined by the event source." ;
    skos:inScheme ocsf:dictionary .

ocsf:disposition_id a owl:ObjectProperty ;
    rdfs:label "disposition_id" ;
    rdfs:range ocsf:DispositionIdEnum ;
    skos:altLabel "Disposition ID" ;
    skos:definition "Describes the outcome or action taken by a security control, such as access control checks, malware detections or various types of policy violations." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "disposition" .

ocsf:dkim a owl:DatatypeProperty ;
    rdfs:label "dkim" ;
    rdfs:range xsd:string ;
    skos:altLabel "DKIM Status" ;
    skos:definition "The DomainKeys Identified Mail (DKIM) status of the email." ;
    skos:inScheme ocsf:dictionary .

ocsf:dkim_domain a owl:DatatypeProperty ;
    rdfs:label "dkim_domain" ;
    rdfs:range xsd:string ;
    skos:altLabel "DKIM Domain" ;
    skos:definition "The DomainKeys Identified Mail (DKIM) signing domain of the email." ;
    skos:inScheme ocsf:dictionary .

ocsf:dkim_signature a owl:DatatypeProperty ;
    rdfs:label "dkim_signature" ;
    rdfs:range xsd:string ;
    skos:altLabel "DKIM Signature" ;
    skos:definition "The DomainKeys Identified Mail (DKIM) signature used by the sending/receiving system." ;
    skos:inScheme ocsf:dictionary .

ocsf:dmarc a owl:DatatypeProperty ;
    rdfs:label "dmarc" ;
    rdfs:range xsd:string ;
    skos:altLabel "DMARC Status" ;
    skos:definition "The Domain-based Message Authentication, Reporting and Conformance (DMARC) status of the email." ;
    skos:inScheme ocsf:dictionary .

ocsf:dmarc_override a owl:DatatypeProperty ;
    rdfs:label "dmarc_override" ;
    rdfs:range xsd:string ;
    skos:altLabel "DMARC Override" ;
    skos:definition "The Domain-based Message Authentication, Reporting and Conformance (DMARC) override action." ;
    skos:inScheme ocsf:dictionary .

ocsf:dmarc_policy a owl:DatatypeProperty ;
    rdfs:label "dmarc_policy" ;
    rdfs:range xsd:string ;
    skos:altLabel "DMARC Policy" ;
    skos:definition "The Domain-based Message Authentication, Reporting and Conformance (DMARC) policy status." ;
    skos:inScheme ocsf:dictionary .

ocsf:dnssec_status a owl:DatatypeProperty ;
    rdfs:label "dnssec_status" ;
    rdfs:range xsd:string ;
    skos:altLabel "DNSSEC Status" ;
    skos:definition "The normalized value of dnssec_status_id." ;
    skos:inScheme ocsf:dictionary .

ocsf:dnssec_status_id a owl:ObjectProperty ;
    rdfs:label "dnssec_status_id" ;
    rdfs:range ocsf:DnssecStatusIdEnum ;
    skos:altLabel "DNSSEC Status ID" ;
    skos:definition "Describes the normalized status of DNS Security Extensions (DNSSEC) for a domain." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "dnssec_status" .

ocsf:drive_type a owl:DatatypeProperty ;
    rdfs:label "drive_type" ;
    rdfs:range xsd:string ;
    skos:altLabel "Drive Type" ;
    skos:definition "The drive type, normalized to the caption of the <code>drive_type_id</code> value. In the case of <code>Other</code>, it is defined by the source." ;
    skos:inScheme ocsf:dictionary .

ocsf:drive_type_id a owl:ObjectProperty ;
    rdfs:label "drive_type_id" ;
    rdfs:range ocsf:DriveTypeIdEnum ;
    skos:altLabel "Drive Type ID" ;
    skos:definition "Identifies the type of a disk drive, i.e. fixed, removable, etc." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "drive_type" .

ocsf:duration_days a owl:DatatypeProperty ;
    rdfs:label "duration_days" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Duration Days" ;
    skos:definition "Represents the duration of the activity in days. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:duration_hours a owl:DatatypeProperty ;
    rdfs:label "duration_hours" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Duration Hours" ;
    skos:definition "Represents the duration of the activity in hours. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:duration_months a owl:DatatypeProperty ;
    rdfs:label "duration_months" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Duration Months" ;
    skos:definition "Represents the duration of the activity in months. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:duration_secs a owl:DatatypeProperty ;
    rdfs:label "duration_secs" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Duration Seconds" ;
    skos:definition "Represents the duration of the activity in seconds. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:duration_weeks a owl:DatatypeProperty ;
    rdfs:label "duration_weeks" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Duration Weeks" ;
    skos:definition "Represents the duration of the activity in weeks. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:duration_years a owl:DatatypeProperty ;
    rdfs:label "duration_years" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Duration Years" ;
    skos:definition "Represents the duration of the activity in years. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:edition a owl:DatatypeProperty ;
    rdfs:label "edition" ;
    rdfs:range xsd:string ;
    skos:altLabel "OS Edition" ;
    skos:definition "The operating system edition. For example: <code>Professional</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:eid a owl:DatatypeProperty ;
    rdfs:label "eid" ;
    rdfs:range xsd:string ;
    skos:altLabel "EID" ;
    skos:definition "An Embedded Identity Document, is a unique serial number that identifies an eSIM-enabled device." ;
    skos:inScheme ocsf:dictionary .

ocsf:embedding_model a owl:DatatypeProperty ;
    rdfs:label "embedding_model" ;
    rdfs:range xsd:string ;
    skos:altLabel "Embedding Model" ;
    skos:definition "Model used for creating embeddings in AI retrieval systems." ;
    skos:inScheme ocsf:dictionary .

ocsf:employee_uid a owl:DatatypeProperty ;
    rdfs:label "employee_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "Employee ID" ;
    skos:definition "The employee identifier assigned to the user by the organization." ;
    skos:inScheme ocsf:dictionary .

ocsf:encoding a owl:DatatypeProperty ;
    rdfs:label "encoding" ;
    rdfs:range xsd:string ;
    skos:altLabel "Encoding" ;
    skos:definition "The encoding method, normalized to the caption of the encoding_id value. In the case of 'Other', it is defined by the event source. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:encoding_id a owl:ObjectProperty ;
    rdfs:label "encoding_id" ;
    rdfs:range ocsf:EncodingIdEnum ;
    skos:altLabel "Encoding ID" ;
    skos:definition "The normalized identifier of the encoding method. See specific usage." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "encoding" .

ocsf:end_column a owl:DatatypeProperty ;
    rdfs:label "end_column" ;
    rdfs:range xsd:integer ;
    skos:altLabel "End Column" ;
    skos:definition "The end column number. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:end_offset a owl:DatatypeProperty ;
    rdfs:label "end_offset" ;
    rdfs:range xsd:integer ;
    skos:altLabel "End Offset" ;
    skos:definition "The ending offset. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:entity a owl:ObjectProperty ;
    rdfs:label "entity" ;
    rdfs:range ocsf:ManagedEntity ;
    skos:altLabel "Entity" ;
    skos:definition "The managed entity that is being acted upon." ;
    skos:inScheme ocsf:dictionary .

ocsf:entity_result a owl:ObjectProperty ;
    rdfs:label "entity_result" ;
    rdfs:range ocsf:ManagedEntity ;
    skos:altLabel "Entity Result" ;
    skos:definition "The updated managed entity." ;
    skos:inScheme ocsf:dictionary .

ocsf:epoch a owl:DatatypeProperty ;
    rdfs:label "epoch" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Epoch" ;
    skos:definition "The software package epoch. Epoch is a way to define weighted dependencies based on version numbers." ;
    skos:inScheme ocsf:dictionary .

ocsf:epss a owl:ObjectProperty ;
    rdfs:label "epss" ;
    rdfs:range ocsf:Epss ;
    skos:altLabel "EPSS" ;
    skos:definition "The Exploit Prediction Scoring System (EPSS) object describes the estimated probability a vulnerability will be exploited. EPSS is a community-driven effort to combine descriptive information about vulnerabilities (CVEs) with evidence of actual exploitation in-the-wild. (<a target='_blank' href='https://www.first.org/epss/'>EPSS</a>)." ;
    skos:inScheme ocsf:dictionary .

ocsf:event_code a owl:DatatypeProperty ;
    rdfs:label "event_code" ;
    rdfs:range xsd:string ;
    skos:altLabel "Event Code" ;
    skos:definition "The <code>Event ID, Code, or Name</code> that the product uses to primarily identify the event." ;
    skos:inScheme ocsf:dictionary .

ocsf:evidence a owl:DatatypeProperty ;
    rdfs:label "evidence" ;
    rdfs:range xsd:string ;
    skos:altLabel "Evidence" ;
    skos:definition "The data the finding exposes to the analyst." ;
    skos:inScheme ocsf:dictionary .

ocsf:execute_count a owl:DatatypeProperty ;
    rdfs:label "execute_count" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Execute Count" ;
    skos:definition "The execute count. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:exit_code a owl:DatatypeProperty ;
    rdfs:label "exit_code" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Exit Code" ;
    skos:definition "The exit code reported by a process when it terminates. The convention is that zero indicates success and any non-zero exit code indicates that some error occurred." ;
    skos:inScheme ocsf:dictionary .

ocsf:expiration_reason a owl:DatatypeProperty ;
    rdfs:label "expiration_reason" ;
    rdfs:range xsd:string ;
    skos:altLabel "Expiration Reason" ;
    skos:definition "The expiration reason. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:exploit_last_seen_time a owl:DatatypeProperty ;
    rdfs:label "exploit_last_seen_time" ;
    rdfs:range xsd:long ;
    skos:altLabel "Exploit Last Seen Time" ;
    skos:definition "The time when the exploit was most recently observed." ;
    skos:inScheme ocsf:dictionary .

ocsf:exploit_ref_url a owl:DatatypeProperty ;
    rdfs:label "exploit_ref_url" ;
    rdfs:range xsd:anyURI ;
    skos:altLabel "Exploit URL" ;
    skos:definition "The URL of the exploit code or Proof-of-Concept (PoC)." ;
    skos:inScheme ocsf:dictionary .

ocsf:exploit_requirement a owl:DatatypeProperty ;
    rdfs:label "exploit_requirement" ;
    rdfs:range xsd:string ;
    skos:altLabel "Exploit Requirement" ;
    skos:definition "The requirement description related to any constraints around exploit execution." ;
    skos:inScheme ocsf:dictionary .

ocsf:exploit_type a owl:DatatypeProperty ;
    rdfs:label "exploit_type" ;
    rdfs:range xsd:string ;
    skos:altLabel "Exploit Type" ;
    skos:definition "The categorization or type of Exploit. E.g., <code>Network</code> or <code>Physical</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:ext a owl:DatatypeProperty ;
    rdfs:label "ext" ;
    rdfs:range xsd:string ;
    skos:altLabel "Extension" ;
    skos:definition "The extension. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:extension a owl:ObjectProperty ;
    rdfs:label "extension" ;
    rdfs:range ocsf:Extension ;
    skos:altLabel "Schema Extension" ;
    skos:definition "The schema extension used to create the event." ;
    skos:inScheme ocsf:dictionary .

ocsf:external_uid a owl:DatatypeProperty ;
    rdfs:label "external_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "External ID" ;
    skos:definition "A unique identifier assigned by an external system for cross-referencing." ;
    skos:inScheme ocsf:dictionary .

ocsf:factor_type a owl:DatatypeProperty ;
    rdfs:label "factor_type" ;
    rdfs:range xsd:string ;
    skos:altLabel "Factor Type" ;
    skos:definition "The type of authentication factor used in an authentication attempt." ;
    skos:inScheme ocsf:dictionary .

ocsf:factor_type_id a owl:ObjectProperty ;
    rdfs:label "factor_type_id" ;
    rdfs:range ocsf:FactorTypeIdEnum ;
    skos:altLabel "Factor Type ID" ;
    skos:definition "The normalized identifier for the authentication factor." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "factor_type" .

ocsf:feature a owl:ObjectProperty ;
    rdfs:label "feature" ;
    rdfs:range ocsf:Feature ;
    skos:altLabel "Feature" ;
    skos:definition "The feature that reported the event." ;
    skos:inScheme ocsf:dictionary .

ocsf:file_diff a owl:DatatypeProperty ;
    rdfs:label "file_diff" ;
    rdfs:range xsd:string ;
    skos:altLabel "File Diff" ;
    skos:definition "File content differences used for change detection. For example, a common use case is to identify itemized changes within INI or configuration/property setting values." ;
    skos:inScheme ocsf:dictionary .

ocsf:finding a owl:ObjectProperty ;
    rdfs:label "finding" ;
    rdfs:range ocsf:FindingObject ;
    skos:altLabel "Finding" ;
    skos:definition "The Finding object provides details about a finding/detection generated by a security tool." ;
    skos:inScheme ocsf:dictionary .

ocsf:finding_info a owl:ObjectProperty ;
    rdfs:label "finding_info" ;
    rdfs:range ocsf:FindingInfo ;
    skos:altLabel "Finding Information" ;
    skos:definition "Describes the supporting information about a generated finding." ;
    skos:inScheme ocsf:dictionary .

ocsf:firewall_rule a owl:ObjectProperty ;
    rdfs:label "firewall_rule" ;
    rdfs:range ocsf:FirewallRule ;
    skos:altLabel "Firewall Rule" ;
    skos:definition "The firewall rule that triggered the event." ;
    skos:inScheme ocsf:dictionary .

ocsf:fix_available a owl:DatatypeProperty ;
    rdfs:label "fix_available" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Fix Availability" ;
    skos:definition "Indicates if a fix is available for the reported vulnerability." ;
    skos:inScheme ocsf:dictionary .

ocsf:fix_coverage a owl:DatatypeProperty ;
    rdfs:label "fix_coverage" ;
    rdfs:range xsd:string ;
    skos:altLabel "Fix Coverage" ;
    skos:definition "The fix coverage, normalized to the caption of the <code>fix_coverage_id</code> value. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:fix_coverage_id a owl:ObjectProperty ;
    rdfs:label "fix_coverage_id" ;
    rdfs:range ocsf:FixCoverageIdEnum ;
    skos:altLabel "Fix Coverage ID" ;
    skos:definition "The normalized identifier for fix coverage. See specific usage." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "fix_coverage" .

ocsf:fixed_in_version a owl:DatatypeProperty ;
    rdfs:label "fixed_in_version" ;
    rdfs:range xsd:string ;
    skos:altLabel "Fixed In Version" ;
    skos:definition "The software package version in which a reported vulnerability was patched/fixed." ;
    skos:inScheme ocsf:dictionary .

ocsf:flag_history a owl:DatatypeProperty ;
    rdfs:label "flag_history" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://docs.zeek.org/en/master/scripts/base/protocols/conn/main.zeek.html#detailed-interface:~:text=Records%20the%20state%20history%20of%20connections%20as%20a%20string%20of%20letters.%20The%20meaning%20of%20those%20letters%20is> ;
    skos:altLabel "Connection Flag History" ;
    skos:definition "The Connection Flag History summarizes events in a network connection. For example flags <code> ShAD </code> representing SYN, SYN/ACK, ACK and Data exchange." ;
    skos:editorialNote "Zeek History — https://docs.zeek.org/en/master/scripts/base/protocols/conn/main.zeek.html#detailed-interface:~:text=Records%20the%20state%20history%20of%20connections%20as%20a%20string%20of%20letters.%20The%20meaning%20of%20those%20letters%20is" ;
    skos:inScheme ocsf:dictionary .

ocsf:format a owl:DatatypeProperty ;
    rdfs:label "format" ;
    rdfs:range xsd:string ;
    skos:altLabel "Format" ;
    skos:definition "The format, normalized to the caption of the format_id value. In the case of 'Other', it is defined by the event source. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:format_id a owl:ObjectProperty ;
    rdfs:label "format_id" ;
    rdfs:range ocsf:FormatIdEnum ;
    skos:altLabel "Format ID" ;
    skos:definition "The normalized identifier of the format. See specific usage." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "format" .

ocsf:forward_addr a owl:DatatypeProperty ;
    rdfs:label "forward_addr" ;
    rdfs:range xsd:string ;
    skos:altLabel "Forwarding Address" ;
    skos:definition "The user's forwarding email address." ;
    skos:inScheme ocsf:dictionary .

ocsf:from_mailbox a owl:DatatypeProperty ;
    rdfs:label "from_mailbox" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://www.rfc-editor.org/rfc/rfc5322#section-3.4> ;
    skos:altLabel "From Mailbox" ;
    skos:definition "The human-readable email header From Mailbox value. For example <code>'Example User &lt;example.user@usersdomain.com&gt;'</code>." ;
    skos:editorialNote "RFC 5322 — https://www.rfc-editor.org/rfc/rfc5322#section-3.4" ;
    skos:inScheme ocsf:dictionary .

ocsf:full_name a owl:DatatypeProperty ;
    rdfs:label "full_name" ;
    rdfs:range xsd:string ;
    skos:altLabel "Full Name" ;
    skos:definition "The full name. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:function_invocation a owl:ObjectProperty ;
    rdfs:label "function_invocation" ;
    rdfs:range ocsf:FunctionInvocation ;
    skos:altLabel "Function Invocation" ;
    skos:definition "Details of a function invocation." ;
    skos:inScheme ocsf:dictionary .

ocsf:function_keys a owl:DatatypeProperty ;
    rdfs:label "function_keys" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Function Keys" ;
    skos:definition "The number of function keys on client keyboard." ;
    skos:inScheme ocsf:dictionary .

ocsf:function_name a owl:DatatypeProperty ;
    rdfs:label "function_name" ;
    rdfs:range xsd:string ;
    skos:altLabel "Function Name" ;
    skos:definition "The function name. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:geodetic_altitude a owl:DatatypeProperty ;
    rdfs:label "geodetic_altitude" ;
    rdfs:range xsd:string ;
    skos:altLabel "Geodetic Altitude" ;
    skos:definition "The aircraft distance above or below the ellipsoid as measured along a line that passes through the aircraft and is normal to the surface of the WGS-84 ellipsoid. This value is provided in meters and must have a minimum resolution of 1 m. Special Values: <code>Invalid</code>, <code>No Value</code>, or <code>Unknown: -1000 m</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:geodetic_vertical_accuracy a owl:DatatypeProperty ;
    rdfs:label "geodetic_vertical_accuracy" ;
    rdfs:range xsd:string ;
    skos:altLabel "Geodetic Vertical Accuracy" ;
    skos:definition "Provides quality/containment on geodetic altitude. This is based on ADS-B Geodetic Vertical Accuracy (GVA). Measured in meters." ;
    skos:inScheme ocsf:dictionary .

ocsf:geohash a owl:DatatypeProperty ;
    rdfs:label "geohash" ;
    rdfs:range xsd:string ;
    skos:altLabel "Geohash" ;
    skos:definition "<p>Geohash of the geo-coordinates (latitude and longitude).</p><a target='_blank' href='https://en.wikipedia.org/wiki/Geohash'>Geohashing</a> is a geocoding system used to encode geographic coordinates in decimal degrees, to a single string." ;
    skos:inScheme ocsf:dictionary .

ocsf:given_name a owl:DatatypeProperty ;
    rdfs:label "given_name" ;
    rdfs:range xsd:string ;
    skos:altLabel "Given Name" ;
    skos:definition "The given or first name of the user." ;
    skos:inScheme ocsf:dictionary .

ocsf:gpu_count a owl:DatatypeProperty ;
    rdfs:label "gpu_count" ;
    rdfs:range xsd:integer ;
    skos:altLabel "GPU Count" ;
    skos:definition "The number of GPU's on a system. For example: <code>1</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:handshake_dur a owl:DatatypeProperty ;
    rdfs:label "handshake_dur" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Handshake Duration" ;
    skos:definition "The amount of total time for the TLS handshake to complete after the TCP connection is established, including client-side delays, in milliseconds." ;
    skos:inScheme ocsf:dictionary .

ocsf:hire_time a owl:DatatypeProperty ;
    rdfs:label "hire_time" ;
    rdfs:range xsd:long ;
    skos:altLabel "Hire Time" ;
    skos:definition "The timestamp when the user was or will be hired by the organization." ;
    skos:inScheme ocsf:dictionary .

ocsf:horizontal_accuracy a owl:DatatypeProperty ;
    rdfs:label "horizontal_accuracy" ;
    rdfs:range xsd:string ;
    skos:altLabel "Horizontal Accuracy" ;
    skos:definition "Provides quality/containment on horizontal position. This is based on ADS-B NACp. Measured in meters." ;
    skos:inScheme ocsf:dictionary .

ocsf:hosting_process a owl:ObjectProperty ;
    rdfs:label "hosting_process" ;
    rdfs:range ocsf:ProcessEntity ;
    skos:altLabel "Hosting Process" ;
    skos:definition "The process that is hosting this service." ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_extension "windows" .

ocsf:http_method a owl:DatatypeProperty ;
    rdfs:label "http_method" ;
    rdfs:range xsd:string ;
    skos:altLabel "HTTP Method" ;
    skos:definition "The HTTP request method indicates the desired action to be performed for a given resource. Expected values: <ul> <li>TRACE</li> <li>CONNECT</li> <li>OPTIONS</li> <li>HEAD</li> <li>DELETE</li> <li>POST</li> <li>PUT</li> <li>GET</li></ul>" ;
    skos:inScheme ocsf:dictionary .

ocsf:http_only a owl:DatatypeProperty ;
    rdfs:label "http_only" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "HTTP Only" ;
    skos:definition "A cookie attribute to make it inaccessible via JavaScript" ;
    skos:inScheme ocsf:dictionary .

ocsf:http_status a owl:DatatypeProperty ;
    rdfs:label "http_status" ;
    rdfs:range xsd:integer ;
    skos:altLabel "HTTP Status" ;
    skos:definition "The Hypertext Transfer Protocol (HTTP) <a target='_blank' href='https://www.iana.org/assignments/http-status-codes/http-status-codes.xhtml'>status code</a> returned to the client." ;
    skos:inScheme ocsf:dictionary .

ocsf:hypervisor a owl:DatatypeProperty ;
    rdfs:label "hypervisor" ;
    rdfs:range xsd:string ;
    skos:altLabel "Hypervisor" ;
    skos:definition "The name of the hypervisor running on the device. For example, <code>Xen</code>, <code>VMware</code>, <code>Hyper-V</code>, <code>VirtualBox</code>, etc." ;
    skos:inScheme ocsf:dictionary .

ocsf:iccid a owl:DatatypeProperty ;
    rdfs:label "iccid" ;
    rdfs:range xsd:string ;
    skos:altLabel "ICCID" ;
    skos:definition "The Integrated Circuit Card Identification of a mobile device. Typically it is a unique 18 to 22 digit number that identifies a SIM card." ;
    skos:inScheme ocsf:dictionary .

ocsf:identifier_cookie a owl:DatatypeProperty ;
    rdfs:label "identifier_cookie" ;
    rdfs:range xsd:string ;
    skos:altLabel "Identifier Cookie" ;
    skos:definition "The client identifier cookie during client/server exchange." ;
    skos:inScheme ocsf:dictionary .

ocsf:identity_activity_metrics a owl:ObjectProperty ;
    rdfs:label "identity_activity_metrics" ;
    rdfs:range ocsf:IdentityActivityMetrics ;
    skos:altLabel "Identity Activity Metrics" ;
    skos:definition "Describes usage activity and other metrics of an Identity i.e. AWS IAM User, GCP IAM Principal, etc." ;
    skos:inScheme ocsf:dictionary .

ocsf:idle_timeout a owl:DatatypeProperty ;
    rdfs:label "idle_timeout" ;
    rdfs:range xsd:integer ;
    skos:altLabel "SSO Idle Timeout" ;
    skos:definition "Duration (in minutes) of allowed inactivity before a timeout See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:ime a owl:DatatypeProperty ;
    rdfs:label "ime" ;
    rdfs:range xsd:string ;
    skos:altLabel "IME" ;
    skos:definition "The Input Method Editor (IME) file name." ;
    skos:inScheme ocsf:dictionary .

ocsf:imei a owl:DatatypeProperty ;
    rdfs:label "imei" ;
    rdfs:range xsd:string ;
    skos:altLabel "IMEI" ;
    skos:definition "The International Mobile Equipment Identity that is associated with the device." ;
    skos:inScheme ocsf:dictionary .

ocsf:initiator a owl:DatatypeProperty ;
    rdfs:label "initiator" ;
    rdfs:range xsd:string ;
    skos:altLabel "Initiator" ;
    skos:definition "The initiator of an activity or operation. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:initiator_id a owl:ObjectProperty ;
    rdfs:label "initiator_id" ;
    rdfs:range ocsf:InitiatorIdEnum ;
    skos:altLabel "Initiator ID" ;
    skos:definition "The normalized identifier of the <code>initiator</code>. See specific usage." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "initiator" .

ocsf:injection_type a owl:DatatypeProperty ;
    rdfs:label "injection_type" ;
    rdfs:range xsd:string ;
    skos:altLabel "Injection Type" ;
    skos:definition "The process injection method, normalized to the caption of the injection_type_id value. In the case of 'Other', it is defined by the event source." ;
    skos:inScheme ocsf:dictionary .

ocsf:injection_type_id a owl:ObjectProperty ;
    rdfs:label "injection_type_id" ;
    rdfs:range ocsf:InjectionTypeIdEnum ;
    skos:altLabel "Injection Type ID" ;
    skos:definition "The normalized identifier of the process injection method." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "injection_type" .

ocsf:instance_uid a owl:DatatypeProperty ;
    rdfs:label "instance_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "Instance ID" ;
    skos:definition "The unique identifier of a VM instance." ;
    skos:inScheme ocsf:dictionary .

ocsf:integrity a owl:DatatypeProperty ;
    rdfs:label "integrity" ;
    rdfs:range xsd:string ;
    skos:altLabel "Integrity" ;
    skos:definition "The process integrity level, normalized to the caption of the integrity_id value. In the case of 'Other', it is defined by the event source (Windows only)." ;
    skos:inScheme ocsf:dictionary .

ocsf:integrity_id a owl:ObjectProperty ;
    rdfs:label "integrity_id" ;
    rdfs:range ocsf:IntegrityIdEnum ;
    skos:altLabel "Integrity Level" ;
    skos:definition "The normalized identifier of the process integrity level (Windows only)." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "integrity" .

ocsf:interface_name a owl:DatatypeProperty ;
    rdfs:label "interface_name" ;
    rdfs:range xsd:string ;
    skos:altLabel "Network Interface Name" ;
    skos:definition "The name of the network interface (e.g. eth2)." ;
    skos:inScheme ocsf:dictionary .

ocsf:interface_uid a owl:DatatypeProperty ;
    rdfs:label "interface_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "Network Interface ID" ;
    skos:definition "The unique identifier of the network interface." ;
    skos:inScheme ocsf:dictionary .

ocsf:internal_name a owl:DatatypeProperty ;
    rdfs:label "internal_name" ;
    rdfs:range xsd:string ;
    skos:altLabel "Internal Name" ;
    skos:definition "The name by which a resource identifies itself internally. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:invoked_by a owl:DatatypeProperty ;
    rdfs:label "invoked_by" ;
    rdfs:range xsd:string ;
    skos:altLabel "Invoked by" ;
    skos:definition "The name of the service that invoked the activity as described in the event." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_applied a owl:DatatypeProperty ;
    rdfs:label "is_applied" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Applied" ;
    skos:definition "A determination if a policy, rule, or enforcement action was applied." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_cleartext a owl:DatatypeProperty ;
    rdfs:label "is_cleartext" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Cleartext Credentials" ;
    skos:definition "Indicates whether the credentials were passed in clear text.<p><b>Note:</b> True if the credentials were passed in a clear text protocol such as FTP or TELNET, or if Windows detected that a user's logon password was passed to the authentication package in clear text.</p>" ;
    skos:inScheme ocsf:dictionary .

ocsf:is_compliant a owl:DatatypeProperty ;
    rdfs:label "is_compliant" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Compliant Device" ;
    skos:definition "The event occurred on a compliant device." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_default a owl:DatatypeProperty ;
    rdfs:label "is_default" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Default Value" ;
    skos:definition "The indication of whether the value is from a default value name. For example, the value name could be missing." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_deleted a owl:DatatypeProperty ;
    rdfs:label "is_deleted" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Deleted" ;
    skos:definition "Indicates if the entity was deleted. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_disabled a owl:DatatypeProperty ;
    rdfs:label "is_disabled" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Disabled" ;
    skos:definition "Indicates if the entity is disabled. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_exploit_available a owl:DatatypeProperty ;
    rdfs:label "is_exploit_available" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Exploit Availability" ;
    skos:definition "Indicates if an exploit or a PoC (proof-of-concept) is available for the reported vulnerability." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_fix_available a owl:DatatypeProperty ;
    rdfs:label "is_fix_available" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Fix Availability" ;
    skos:definition "Indicates if a fix is available for the reported vulnerability." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_group_provisioning_enabled a owl:DatatypeProperty ;
    rdfs:label "is_group_provisioning_enabled" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Group Provisioning Enabled" ;
    skos:definition "Indicates whether group provisioning is automated (e.g., for a SCIM resource). See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_hotp a owl:DatatypeProperty ;
    rdfs:label "is_hotp" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "HMAC-based One-time Password (HOTP)" ;
    skos:definition "Whether the authentication factor is an HMAC-based One-time Password (HOTP)." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_http_only a owl:DatatypeProperty ;
    rdfs:label "is_http_only" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "HTTP Only" ;
    skos:definition "This attribute prevents the cookie from being accessed via JavaScript." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_locked a owl:DatatypeProperty ;
    rdfs:label "is_locked" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Locked" ;
    skos:definition "Indicates if the entity is locked. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_managed a owl:DatatypeProperty ;
    rdfs:label "is_managed" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Managed Device" ;
    skos:definition "The event occurred on a managed device." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_mobile_account_active a owl:DatatypeProperty ;
    rdfs:label "is_mobile_account_active" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Mobile Account Active" ;
    skos:definition "Indicates whether the device has an active mobile account. For example, this is indicated by the <code>itunesStoreAccountActive</code> value within JAMF Pro mobile devices." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_new_logon a owl:DatatypeProperty ;
    rdfs:label "is_new_logon" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "New Logon" ;
    skos:definition "Indicates logon is from a device not seen before or a first time account logon." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_on_premises a owl:DatatypeProperty ;
    rdfs:label "is_on_premises" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "On-Premises" ;
    skos:definition "Indicates whether the location is on-premises." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_on_premises_sync_enabled a owl:DatatypeProperty ;
    rdfs:label "is_on_premises_sync_enabled" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "On-Premises Sync Enabled" ;
    skos:definition "Indicates whether synchronization with an on-premises directory service is enabled. For example, Microsoft Entra Connect." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_personal a owl:DatatypeProperty ;
    rdfs:label "is_personal" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Personal Device" ;
    skos:definition "The event occurred on a personal device." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_read a owl:DatatypeProperty ;
    rdfs:label "is_read" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Read" ;
    skos:definition "The indication of whether the email has been read." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_readonly a owl:DatatypeProperty ;
    rdfs:label "is_readonly" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Read-Only" ;
    skos:definition "Indicates that an object cannot be modified. See specific usage" ;
    skos:inScheme ocsf:dictionary .

ocsf:is_renewal a owl:DatatypeProperty ;
    rdfs:label "is_renewal" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Renewal" ;
    skos:definition "The indication of whether the event or object represents a renewal. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_secure a owl:DatatypeProperty ;
    rdfs:label "is_secure" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Secure" ;
    skos:definition "The cookie attribute indicates that cookies are sent to the server only when the request is encrypted using the HTTPS protocol." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_self_signed a owl:DatatypeProperty ;
    rdfs:label "is_self_signed" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Certificate Self-Signed" ;
    skos:definition "Denotes whether a digital certificate is self-signed or signed by a known certificate authority (CA)." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_shared a owl:DatatypeProperty ;
    rdfs:label "is_shared" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Shared Device" ;
    skos:definition "The event occurred on a shared device." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_src_dst_assignment_known a owl:DatatypeProperty ;
    rdfs:label "is_src_dst_assignment_known" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Source/Destination Assignment Known" ;
    skos:definition "<code>true</code> denotes that <code>src_endpoint</code> and <code>dst_endpoint</code> correctly identify the initiator and responder respectively. <code>false</code> denotes that the event source has arbitrarily assigned one peer to <code>src_endpoint</code> and the other to <code>dst_endpoint</code>, in other words that initiator and responder are not being asserted. This can occur, for example, when the event source is a network appliance that has not observed the initiation of a given connection. In the absence of this attribute, interpretation of the initiator and responder is implementation-specific." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_supervised a owl:DatatypeProperty ;
    rdfs:label "is_supervised" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Supervised Device" ;
    skos:definition "The event occurred on a supervised device. Devices that are supervised are typically mobile devices managed by a Mobile Device Management solution and are restricted from specific behaviors such as Apple AirDrop." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_totp a owl:DatatypeProperty ;
    rdfs:label "is_totp" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Time-based One-time Password (TOTP)" ;
    skos:definition "Whether the authentication factor is a Time-based One-time Password (TOTP)." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_trusted a owl:DatatypeProperty ;
    rdfs:label "is_trusted" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Trusted Device" ;
    skos:definition "The event occurred on a trusted device." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_unused a owl:DatatypeProperty ;
    rdfs:label "is_unused" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Is Unused" ;
    skos:definition "Indicates whether an item is unused. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_user_provisioning_enabled a owl:DatatypeProperty ;
    rdfs:label "is_user_provisioning_enabled" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "User Provisioning Enabled" ;
    skos:definition "Indicates whether user provisioning is automated (e.g., for a SCIM resource). See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_vpn a owl:DatatypeProperty ;
    rdfs:label "is_vpn" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "VPN Session" ;
    skos:definition "The indication of whether the session is a VPN session." ;
    skos:inScheme ocsf:dictionary .

ocsf:ja3_hash a owl:ObjectProperty ;
    rdfs:label "ja3_hash" ;
    rdfs:range ocsf:Fingerprint ;
    skos:altLabel "JA3 Hash" ;
    skos:definition "The MD5 hash of a JA3 string." ;
    skos:inScheme ocsf:dictionary .

ocsf:ja3s_hash a owl:ObjectProperty ;
    rdfs:label "ja3s_hash" ;
    rdfs:range ocsf:Fingerprint ;
    skos:altLabel "JA3S Hash" ;
    skos:definition "The MD5 hash of a JA3S string." ;
    skos:inScheme ocsf:dictionary .

ocsf:job_title a owl:DatatypeProperty ;
    rdfs:label "job_title" ;
    rdfs:range xsd:string ;
    skos:altLabel "Job Title" ;
    skos:definition "The user's job title." ;
    skos:inScheme ocsf:dictionary .

ocsf:json_path a owl:DatatypeProperty ;
    rdfs:label "json_path" ;
    rdfs:range xsd:string ;
    skos:altLabel "JSON Path" ;
    skos:definition "The JSON path of the attribute. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:kerberos_flags a owl:DatatypeProperty ;
    rdfs:label "kerberos_flags" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://learn.microsoft.com/en-us/previous-versions/windows/it-pro/windows-10/security/threat-protection/auditing/event-4769>,
        <https://www.rfc-editor.org/rfc/rfc4120#section-5.2.8> ;
    skos:altLabel "Kerberos Flags" ;
    skos:definition "A bitmask, either in hexadecimal or decimal form, which encodes various attributes or permissions associated with a Kerberos ticket. These flags delineate specific characteristics of the ticket, such as its renewability or forwardability." ;
    skos:editorialNote "Microsoft Windows Security 4769 (see 'Ticket Options') — https://learn.microsoft.com/en-us/previous-versions/windows/it-pro/windows-10/security/threat-protection/auditing/event-4769",
        "RFC 4120: 5.2.8.  KerberosFlags — https://www.rfc-editor.org/rfc/rfc4120#section-5.2.8" ;
    skos:inScheme ocsf:dictionary .

ocsf:kernel_release a owl:DatatypeProperty ;
    rdfs:label "kernel_release" ;
    rdfs:range xsd:string ;
    skos:altLabel "Kernel Release" ;
    skos:definition "The kernel release of the operating system. On Unix-based systems, this is determined from the <code>uname -r</code> command output, for example \"5.15.0-122-generic\"." ;
    skos:inScheme ocsf:dictionary .

ocsf:key_uid a owl:DatatypeProperty ;
    rdfs:label "key_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "Key UID" ;
    skos:definition "The unique identifier of the key. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:keyboard_layout a owl:DatatypeProperty ;
    rdfs:label "keyboard_layout" ;
    rdfs:range xsd:string ;
    skos:altLabel "Keyboard Layout" ;
    skos:definition "The keyboard locale identifier name (e.g., en-US)." ;
    skos:inScheme ocsf:dictionary .

ocsf:keyboard_subtype a owl:DatatypeProperty ;
    rdfs:label "keyboard_subtype" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Keyboard Subtype" ;
    skos:definition "The keyboard numeric code." ;
    skos:inScheme ocsf:dictionary .

ocsf:keyboard_type a owl:DatatypeProperty ;
    rdfs:label "keyboard_type" ;
    rdfs:range xsd:string ;
    skos:altLabel "Keyboard Type" ;
    skos:definition "The keyboard type (e.g., xt, ico)." ;
    skos:inScheme ocsf:dictionary .

ocsf:last_authentication_time a owl:DatatypeProperty ;
    rdfs:label "last_authentication_time" ;
    rdfs:range xsd:long ;
    skos:altLabel "Last Authentication Time" ;
    skos:definition "The timestamp when this identity last successfully authenticated to any system or service. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:last_login_time a owl:DatatypeProperty ;
    rdfs:label "last_login_time" ;
    rdfs:range xsd:long ;
    skos:altLabel "Last Login" ;
    skos:definition "The last time when the user logged in." ;
    skos:inScheme ocsf:dictionary .

ocsf:lat a owl:DatatypeProperty ;
    rdfs:label "lat" ;
    rdfs:range xsd:float ;
    skos:altLabel "Latitude" ;
    skos:definition "The geographical Latitude coordinate represented in Decimal Degrees (DD). For example: <code>42.361145</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:latency a owl:DatatypeProperty ;
    rdfs:label "latency" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Latency" ;
    skos:definition "The HTTP response latency measured in milliseconds." ;
    skos:inScheme ocsf:dictionary .

ocsf:launch_type a owl:DatatypeProperty ;
    rdfs:label "launch_type" ;
    rdfs:range xsd:string ;
    skos:altLabel "Launch Type" ;
    skos:definition "The specific type of <code>Launch</code> activity, normalized to the caption of the <code>launch_type_id</code> value. In the case of <code>Other</code> it is defined by the event source." ;
    skos:inScheme ocsf:dictionary .

ocsf:launch_type_id a owl:ObjectProperty ;
    rdfs:label "launch_type_id" ;
    rdfs:range ocsf:LaunchTypeIdEnum ;
    rdfs:seeAlso <https://www.man7.org/linux/man-pages/man2/execve.2.html>,
        <https://www.man7.org/linux/man-pages/man2/fork.2.html> ;
    skos:altLabel "Launch Type ID" ;
    skos:definition "The normalized identifier for the specific type of <code>Launch</code> activity." ;
    skos:editorialNote "execve() man page — https://www.man7.org/linux/man-pages/man2/execve.2.html",
        "fork() man page — https://www.man7.org/linux/man-pages/man2/fork.2.html" ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "launch_type" .

ocsf:ldap_cn a owl:DatatypeProperty ;
    rdfs:label "ldap_cn" ;
    rdfs:range xsd:string ;
    skos:altLabel "LDAP Common Name" ;
    skos:definition "The LDAP and X.500 <code>commonName</code> attribute, typically the full name of the person. For example, <code>John Doe</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:ldap_dn a owl:DatatypeProperty ;
    rdfs:label "ldap_dn" ;
    rdfs:range xsd:string ;
    skos:altLabel "LDAP Distinguished Name" ;
    skos:definition "The X.500 Distinguished Name (DN) is a structured string that uniquely identifies an entry, such as a user, in an X.500 directory service For example, <code>cn=John Doe,ou=People,dc=example,dc=com</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:ldap_person a owl:ObjectProperty ;
    rdfs:label "ldap_person" ;
    rdfs:range ocsf:LdapPerson ;
    skos:altLabel "LDAP Person" ;
    skos:definition "The additional LDAP attributes that describe a person." ;
    skos:inScheme ocsf:dictionary .

ocsf:lease_dur a owl:DatatypeProperty ;
    rdfs:label "lease_dur" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Lease Duration" ;
    skos:definition "This represents the length of the DHCP lease in seconds. This is present in DHCP Ack events." ;
    skos:inScheme ocsf:dictionary .

ocsf:leave_time a owl:DatatypeProperty ;
    rdfs:label "leave_time" ;
    rdfs:range xsd:long ;
    skos:altLabel "Leave Time" ;
    skos:definition "The timestamp when the user left or will be leaving the organization." ;
    skos:inScheme ocsf:dictionary .

ocsf:license_url a owl:DatatypeProperty ;
    rdfs:label "license_url" ;
    rdfs:range xsd:anyURI ;
    skos:altLabel "Software License URL" ;
    skos:definition "The URL pointing to the license applied on package or software. This is typically a <code>LICENSE.md</code> file within a repository." ;
    skos:inScheme ocsf:dictionary .

ocsf:load_balancer a owl:ObjectProperty ;
    rdfs:label "load_balancer" ;
    rdfs:range ocsf:LoadBalancer ;
    skos:altLabel "Load Balancer" ;
    skos:definition "The Load Balancer object contains information related to the device that is distributing incoming traffic to specified destinations." ;
    skos:inScheme ocsf:dictionary .

ocsf:load_order_group a owl:DatatypeProperty ;
    rdfs:label "load_order_group" ;
    rdfs:range xsd:string ;
    skos:altLabel "Load Order Group" ;
    skos:definition "The name of the load ordering group of which this service is a member." ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_extension "windows" .

ocsf:load_type a owl:DatatypeProperty ;
    rdfs:label "load_type" ;
    rdfs:range xsd:string ;
    skos:altLabel "Load Type" ;
    skos:definition "The load type, normalized to the caption of the load_type_id value. In the case of 'Other', it is defined by the event source." ;
    skos:inScheme ocsf:dictionary .

ocsf:load_type_id a owl:ObjectProperty ;
    rdfs:label "load_type_id" ;
    rdfs:range ocsf:LoadTypeIdEnum ;
    skos:altLabel "Load Type ID" ;
    skos:definition "The normalized identifier of the load type. See specific usage." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "load_type" .

ocsf:log_source a owl:DatatypeProperty ;
    rdfs:label "log_source" ;
    rdfs:range xsd:string ;
    skos:altLabel "Log Source" ;
    skos:definition "The log where the data originated. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:log_type a owl:DatatypeProperty ;
    rdfs:label "log_type" ;
    rdfs:range xsd:string ;
    skos:altLabel "Log Type" ;
    skos:definition "The log type, normalized to the caption of the <code>log_type_id</code> value. In the case of 'Other', it is defined by the event source." ;
    skos:inScheme ocsf:dictionary .

ocsf:log_type_id a owl:ObjectProperty ;
    rdfs:label "log_type_id" ;
    rdfs:range ocsf:LogTypeIdEnum ;
    skos:altLabel "Log Type ID" ;
    skos:definition "The normalized log type identifier." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "log_type" .

ocsf:login_endpoint a owl:DatatypeProperty ;
    rdfs:label "login_endpoint" ;
    rdfs:range xsd:anyURI ;
    skos:altLabel "Login Endpoint" ;
    skos:definition "URL for initiating a login request. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:logon_process a owl:ObjectProperty ;
    rdfs:label "logon_process" ;
    rdfs:range ocsf:Process ;
    skos:altLabel "Logon Process" ;
    skos:definition "The trusted process that validated the authentication credentials." ;
    skos:inScheme ocsf:dictionary .

ocsf:logon_type a owl:DatatypeProperty ;
    rdfs:label "logon_type" ;
    rdfs:range xsd:string ;
    skos:altLabel "Logon Type" ;
    skos:definition "The logon type, normalized to the caption of the logon_type_id value. In the case of 'Other', it is defined by the event source." ;
    skos:inScheme ocsf:dictionary .

ocsf:logon_type_id a owl:ObjectProperty ;
    rdfs:label "logon_type_id" ;
    rdfs:range ocsf:LogonTypeIdEnum ;
    skos:altLabel "Logon Type ID" ;
    skos:definition "The normalized logon type identifier." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "logon_type" .

ocsf:logout_endpoint a owl:DatatypeProperty ;
    rdfs:label "logout_endpoint" ;
    rdfs:range xsd:anyURI ;
    skos:altLabel "Logout Endpoint" ;
    skos:definition "URL for initiating a logout request. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:long a owl:DatatypeProperty ;
    rdfs:label "long" ;
    rdfs:range xsd:float ;
    skos:altLabel "Longitude" ;
    skos:definition "The geographical Longitude coordinate represented in Decimal Degrees (DD). For example: <code>-71.057083</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:mac_vendor a owl:DatatypeProperty ;
    rdfs:label "mac_vendor" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://standards.ieee.org/products-programs/regauth/> ;
    skos:altLabel "MAC Vendor" ;
    skos:definition "The vendor or manufacturer of the network interface controller (NIC) identified from the MAC address. For example: <code>Apple, Inc.</code>, <code>Intel Corporate</code>." ;
    skos:editorialNote "IEEE Registration Authority — https://standards.ieee.org/products-programs/regauth/" ;
    skos:inScheme ocsf:dictionary .

ocsf:manager a owl:ObjectProperty ;
    rdfs:label "manager" ;
    rdfs:range ocsf:User ;
    skos:altLabel "Manager" ;
    skos:definition "The user's manager. This helps in understanding an org hierarchy. This should only ever be populated once in an event. I.e. there should not be a manager's manager in an event." ;
    skos:inScheme ocsf:dictionary .

ocsf:match_location a owl:DatatypeProperty ;
    rdfs:label "match_location" ;
    rdfs:range xsd:string ;
    skos:altLabel "Match Location" ;
    skos:definition "The location of the matched data in the source which resulted in the triggered firewall rule. For example: HEADER." ;
    skos:inScheme ocsf:dictionary .

ocsf:meets_criteria a owl:DatatypeProperty ;
    rdfs:label "meets_criteria" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Meets Criteria" ;
    skos:definition "Determines if an assessment, control, policy, or otherwise meets its assessment criteria. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:meid a owl:DatatypeProperty ;
    rdfs:label "meid" ;
    rdfs:range xsd:string ;
    skos:altLabel "MEID" ;
    skos:definition "The Mobile Equipment Identifier. It's a unique number that identifies a Code Division Multiple Access (CDMA) mobile device." ;
    skos:inScheme ocsf:dictionary .

ocsf:message_context a owl:ObjectProperty ;
    rdfs:label "message_context" ;
    rdfs:range ocsf:MessageContext ;
    skos:altLabel "Message Context" ;
    skos:definition "Communication context for AI system interactions including protocols, roles, clients, and session information for MCP and other AI communication systems." ;
    skos:inScheme ocsf:dictionary .

ocsf:message_trace_uid a owl:DatatypeProperty ;
    rdfs:label "message_trace_uid" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://learn.microsoft.com/en-us/previous-versions/office/developer/o365-enterprise-developers/jj984335(v=office.15)> ;
    skos:altLabel "Message Trace UID" ;
    skos:definition "The identifier that tracks a message that travels through multiple points of a messaging service." ;
    skos:editorialNote "For example Office 365 Message Trace Report. — https://learn.microsoft.com/en-us/previous-versions/office/developer/o365-enterprise-developers/jj984335(v=office.15)" ;
    skos:inScheme ocsf:dictionary .

ocsf:message_uid a owl:DatatypeProperty ;
    rdfs:label "message_uid" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://www.rfc-editor.org/rfc/rfc5322> ;
    skos:altLabel "Message UID" ;
    skos:definition "The email header Message-ID value, as defined by RFC 5322." ;
    skos:editorialNote "RFC 5322 — https://www.rfc-editor.org/rfc/rfc5322" ;
    skos:inScheme ocsf:dictionary ;
    ocsf:observable_id 42 ;
    ocsf:ocsf_source "Message-ID" .

ocsf:metadata a owl:ObjectProperty ;
    rdfs:label "metadata" ;
    rdfs:range ocsf:Metadata ;
    skos:altLabel "Metadata" ;
    skos:definition "The metadata associated with the event or a finding." ;
    skos:inScheme ocsf:dictionary .

ocsf:metadata_endpoint a owl:DatatypeProperty ;
    rdfs:label "metadata_endpoint" ;
    rdfs:range xsd:anyURI ;
    skos:altLabel "Metadata Endpoint" ;
    skos:definition "URL where metadata about a configuration or resource is available (e.g., for SAML configurations). See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:mime_type a owl:DatatypeProperty ;
    rdfs:label "mime_type" ;
    rdfs:range xsd:string ;
    skos:altLabel "MIME type" ;
    skos:definition "The Multipurpose Internet Mail Extensions (MIME) type of the file, if applicable." ;
    skos:inScheme ocsf:dictionary .

ocsf:mitigation a owl:ObjectProperty ;
    rdfs:label "mitigation" ;
    rdfs:range ocsf:Mitigation ;
    rdfs:seeAlso <https://atlas.mitre.org/matrices/ATLAS>,
        <https://attack.mitre.org> ;
    skos:altLabel "MITRE Mitigation" ;
    skos:definition "The Mitigation object describes the MITRE ATT&CK® or ATLAS™ Mitigation ID and/or name that is associated to an attack." ;
    skos:editorialNote "ATLAS™ Matrix — https://atlas.mitre.org/matrices/ATLAS",
        "ATT&CK® Matrix — https://attack.mitre.org" ;
    skos:inScheme ocsf:dictionary .

ocsf:modifier a owl:ObjectProperty ;
    rdfs:label "modifier" ;
    rdfs:range ocsf:User ;
    skos:altLabel "Modifier" ;
    skos:definition "The user that last modified the object associated with the event. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:namespace_pid a owl:DatatypeProperty ;
    rdfs:label "namespace_pid" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Namespace PID" ;
    skos:definition "If running under a process namespace (such as in a container), the process identifier within that process namespace." ;
    skos:inScheme ocsf:dictionary .

ocsf:network_driver a owl:DatatypeProperty ;
    rdfs:label "network_driver" ;
    rdfs:range xsd:string ;
    skos:altLabel "Network Driver" ;
    skos:definition "The network driver used by the container. For example, bridge, overlay, host, none, etc." ;
    skos:inScheme ocsf:dictionary .

ocsf:network_endpoint a owl:ObjectProperty ;
    rdfs:label "network_endpoint" ;
    rdfs:range ocsf:NetworkEndpoint ;
    skos:altLabel "Network Endpoint" ;
    skos:definition "The Network Endpoint object describes characteristics of a network endpoint. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:network_observation_point a owl:ObjectProperty ;
    rdfs:label "network_observation_point" ;
    rdfs:range ocsf:NetworkEndpoint ;
    skos:altLabel "Network Observation Point" ;
    skos:definition "The network endpoint that observes or inspects network traffic as a third-party system, used when the observer is neither the source nor the destination of the communication. Examples include network taps, span ports, inline security devices, or packet capture systems." ;
    skos:inScheme ocsf:dictionary .

ocsf:network_scope a owl:DatatypeProperty ;
    rdfs:label "network_scope" ;
    rdfs:range xsd:string ;
    skos:altLabel "Network Scope" ;
    skos:definition "Indicates whether the endpoint resides inside the customer’s network, outside on the Internet, or if its location relative to the customer’s network cannot be determined. The value is normalized to the caption of the <code>network_scope_id</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:network_scope_id a owl:ObjectProperty ;
    rdfs:label "network_scope_id" ;
    rdfs:range ocsf:NetworkScopeIdEnum ;
    skos:altLabel "Network Scope ID" ;
    skos:definition "The normalized identifier of the endpoint’s network scope. The normalized network scope identifier indicates whether the endpoint resides inside the customer’s network, outside on the Internet, or if its location relative to the customer’s network cannot be determined." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "network_scope" .

ocsf:next_run_time a owl:DatatypeProperty ;
    rdfs:label "next_run_time" ;
    rdfs:range xsd:long ;
    skos:altLabel "Next Run" ;
    skos:definition "The next run time. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:num_detections a owl:DatatypeProperty ;
    rdfs:label "num_detections" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Detections" ;
    skos:definition "The number of detections." ;
    skos:inScheme ocsf:dictionary .

ocsf:num_folders a owl:DatatypeProperty ;
    rdfs:label "num_folders" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Scanned Folders" ;
    skos:definition "The number of folders scanned." ;
    skos:inScheme ocsf:dictionary .

ocsf:num_network_items a owl:DatatypeProperty ;
    rdfs:label "num_network_items" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Scanned Network Items" ;
    skos:definition "The number of network items scanned." ;
    skos:inScheme ocsf:dictionary .

ocsf:num_processes a owl:DatatypeProperty ;
    rdfs:label "num_processes" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Scanned Processes" ;
    skos:definition "The number of processes scanned." ;
    skos:inScheme ocsf:dictionary .

ocsf:num_registry_items a owl:DatatypeProperty ;
    rdfs:label "num_registry_items" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Scanned Registry Items" ;
    skos:definition "The number of registry items scanned." ;
    skos:inScheme ocsf:dictionary .

ocsf:num_resolutions a owl:DatatypeProperty ;
    rdfs:label "num_resolutions" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Resolutions" ;
    skos:definition "The number of items that were resolved." ;
    skos:inScheme ocsf:dictionary .

ocsf:num_skipped_items a owl:DatatypeProperty ;
    rdfs:label "num_skipped_items" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Skipped" ;
    skos:definition "The number of skipped items." ;
    skos:inScheme ocsf:dictionary .

ocsf:num_trusted_items a owl:DatatypeProperty ;
    rdfs:label "num_trusted_items" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Trusted" ;
    skos:definition "The number of trusted items." ;
    skos:inScheme ocsf:dictionary .

ocsf:num_volumes a owl:DatatypeProperty ;
    rdfs:label "num_volumes" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Number of Volumes" ;
    skos:definition "The number of volumes in the storage device. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:number a owl:DatatypeProperty ;
    rdfs:label "number" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Number" ;
    skos:definition "The number of the entity. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:observation_point a owl:DatatypeProperty ;
    rdfs:label "observation_point" ;
    rdfs:range xsd:string ;
    skos:altLabel "Observation Point" ;
    skos:definition "The normalized observation point value. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:observation_point_id a owl:ObjectProperty ;
    rdfs:label "observation_point_id" ;
    rdfs:range ocsf:ObservationPointIdEnum ;
    skos:altLabel "Observation Point ID" ;
    skos:definition "The normalized identifier of the observation point. See specific usage." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "observation_point" .

ocsf:occurrence_details a owl:ObjectProperty ;
    rdfs:label "occurrence_details" ;
    rdfs:range ocsf:OccurrenceDetails ;
    skos:altLabel "Occurrence Details" ;
    skos:definition "Details about where in the target entity the specified information was discovered. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:office_location a owl:DatatypeProperty ;
    rdfs:label "office_location" ;
    rdfs:range xsd:string ;
    skos:altLabel "Office Location" ;
    skos:definition "The primary office location associated with the user. This could be any string and isn't a specific address. For example, <code>South East Virtual</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:opcode a owl:DatatypeProperty ;
    rdfs:label "opcode" ;
    rdfs:range xsd:string ;
    skos:altLabel "DNS Opcode" ;
    skos:definition "The DNS opcode specifies the type of the query message." ;
    skos:inScheme ocsf:dictionary .

ocsf:opcode_id a owl:ObjectProperty ;
    rdfs:label "opcode_id" ;
    rdfs:range ocsf:OpcodeIdEnum ;
    skos:altLabel "DNS Opcode ID" ;
    skos:definition "The DNS opcode ID specifies the normalized query message type as defined in <a target='_blank' href='https://www.rfc-editor.org/rfc/rfc5395.html'>RFC-5395</a>." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:suppress_checks "enum_convention" .

ocsf:open_mask a owl:DatatypeProperty ;
    rdfs:label "open_mask" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Open Mask" ;
    skos:definition "The Windows options needed to open a registry key." ;
    skos:inScheme ocsf:dictionary .

ocsf:open_type a owl:DatatypeProperty ;
    rdfs:label "open_type" ;
    rdfs:range xsd:string ;
    skos:altLabel "Open Type" ;
    skos:definition "The file open type." ;
    skos:inScheme ocsf:dictionary .

ocsf:opnum a owl:DatatypeProperty ;
    rdfs:label "opnum" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Opnum" ;
    skos:definition "An operation number used to identify a specific remote procedure call (RPC) method or a method in an interface." ;
    skos:inScheme ocsf:dictionary .

ocsf:orchestrator a owl:DatatypeProperty ;
    rdfs:label "orchestrator" ;
    rdfs:range xsd:string ;
    skos:altLabel "Orchestrator" ;
    skos:definition "The orchestrator managing the container, such as ECS, EKS, K8s, or OpenShift." ;
    skos:inScheme ocsf:dictionary .

ocsf:original_event_uid a owl:DatatypeProperty ;
    rdfs:label "original_event_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "Original Event ID" ;
    skos:definition "The unique identifier assigned to the event in its original logging system before transformation to OCSF format. This field preserves the source system's native event identifier, enabling traceability back to the raw log entry. For example, a Windows Event Record ID, a syslog message ID, a Splunk _cd value, or a database transaction log sequence number." ;
    skos:inScheme ocsf:dictionary .

ocsf:original_time a owl:DatatypeProperty ;
    rdfs:label "original_time" ;
    rdfs:range xsd:string ;
    skos:altLabel "Original Time" ;
    skos:definition "The original event time as reported by the event source. For example, the time in the original format from system event log such as Syslog on Unix/Linux and the System event file on Windows. Omit if event is generated instead of collected via logs." ;
    skos:inScheme ocsf:dictionary .

ocsf:os_machine_uuid a owl:DatatypeProperty ;
    rdfs:label "os_machine_uuid" ;
    rdfs:range xsd:string ;
    skos:altLabel "OS Machine UUID" ;
    skos:definition "The operating system assigned Machine ID. In Windows, this is the value stored at the registry path: <code>HKEY_LOCAL_MACHINE\\SOFTWARE\\Microsoft\\Cryptography\\MachineGuid</code>. In Linux, this is stored in the file: <code>/etc/machine-id</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:ou_name a owl:DatatypeProperty ;
    rdfs:label "ou_name" ;
    rdfs:range xsd:string ;
    skos:altLabel "Org Unit Name" ;
    skos:definition "The name of the organizational unit, within an organization.  For example, Finance, IT, R&D" ;
    skos:inScheme ocsf:dictionary .

ocsf:ou_uid a owl:DatatypeProperty ;
    rdfs:label "ou_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "Org Unit ID" ;
    skos:definition "The alternate identifier for an entity's unique identifier. For example, its Active Directory OU DN or AWS OU ID." ;
    skos:inScheme ocsf:dictionary .

ocsf:overall_score a owl:DatatypeProperty ;
    rdfs:label "overall_score" ;
    rdfs:range xsd:float ;
    skos:altLabel "Overall Score" ;
    skos:definition "The overall score as reported by the event source. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:package_manager a owl:DatatypeProperty ;
    rdfs:label "package_manager" ;
    rdfs:range xsd:string ;
    skos:altLabel "Package Manager" ;
    skos:definition "The software packager manager utilized to manage a package on a system, e.g. npm, yum, dpkg etc." ;
    skos:inScheme ocsf:dictionary .

ocsf:package_manager_url a owl:DatatypeProperty ;
    rdfs:label "package_manager_url" ;
    rdfs:range xsd:anyURI ;
    skos:altLabel "Package Manager URL" ;
    skos:definition "The URL of the package or library at the package manager, or the specific URL or URI of an internal package manager link such as <code>AWS CodeArtifact</code> or <code>Artifactory</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:packet_uid a owl:DatatypeProperty ;
    rdfs:label "packet_uid" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Packet UID" ;
    skos:definition "The packet identifier assigned by the protocol." ;
    skos:inScheme ocsf:dictionary .

ocsf:packets a owl:DatatypeProperty ;
    rdfs:label "packets" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Total Packets" ;
    skos:definition "The total number of packets (in and out)." ;
    skos:inScheme ocsf:dictionary .

ocsf:packets_in a owl:DatatypeProperty ;
    rdfs:label "packets_in" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Packets In" ;
    skos:definition "The number of packets sent from the destination to the source." ;
    skos:inScheme ocsf:dictionary .

ocsf:packets_out a owl:DatatypeProperty ;
    rdfs:label "packets_out" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Packets Out" ;
    skos:definition "The number of packets sent from the source to the destination." ;
    skos:inScheme ocsf:dictionary .

ocsf:page_number a owl:DatatypeProperty ;
    rdfs:label "page_number" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Page Number" ;
    skos:definition "The page number of the document. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:parent_folder a owl:DatatypeProperty ;
    rdfs:label "parent_folder" ;
    rdfs:range xsd:string ;
    skos:altLabel "Parent Folder" ;
    skos:definition "The parent folder in which the file resides. For example: <code>c:\\windows\\system32</code>" ;
    skos:inScheme ocsf:dictionary .

ocsf:parent_process a owl:ObjectProperty ;
    rdfs:label "parent_process" ;
    rdfs:range ocsf:Process ;
    rdfs:seeAlso <https://github.com/ocsf/ocsf-docs/blob/main/articles/representing-process-parentage.md> ;
    skos:altLabel "Parent Process" ;
    skos:definition "The parent process of this process object. It is recommended to only populate this field for the top-level process object, to prevent deep nesting. Additional ancestry information can be supplied in the <code>ancestry</code> attribute." ;
    skos:editorialNote "Guidance on Representing Process Parentage — https://github.com/ocsf/ocsf-docs/blob/main/articles/representing-process-parentage.md" ;
    skos:inScheme ocsf:dictionary .

ocsf:password_last_used_time a owl:DatatypeProperty ;
    rdfs:label "password_last_used_time" ;
    rdfs:range xsd:long ;
    skos:altLabel "Password Last Used Time" ;
    skos:definition "The time when a user's password was last used. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:pattern_match a owl:DatatypeProperty ;
    rdfs:label "pattern_match" ;
    rdfs:range xsd:string ;
    skos:altLabel "Pattern Match" ;
    skos:definition "A text, binary, file name, or datastore that matched against a detection rule." ;
    skos:inScheme ocsf:dictionary .

ocsf:percentile a owl:DatatypeProperty ;
    rdfs:label "percentile" ;
    rdfs:range xsd:float ;
    skos:altLabel "EPSS Percentile" ;
    skos:definition "The EPSS score's percentile representing relative importance and ranking of the score in the larger EPSS dataset." ;
    skos:inScheme ocsf:dictionary .

ocsf:phase a owl:DatatypeProperty ;
    rdfs:label "phase" ;
    rdfs:range xsd:string ;
    skos:altLabel "Kill Chain Phase" ;
    skos:definition "The cyber kill chain phase." ;
    skos:inScheme ocsf:dictionary .

ocsf:phase_id a owl:ObjectProperty ;
    rdfs:label "phase_id" ;
    rdfs:range ocsf:PhaseIdEnum ;
    skos:altLabel "Kill Chain Phase ID" ;
    skos:definition "The cyber kill chain phase identifier." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "phase" .

ocsf:physical_height a owl:DatatypeProperty ;
    rdfs:label "physical_height" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Physical Height" ;
    skos:definition "The numeric physical height of display." ;
    skos:inScheme ocsf:dictionary .

ocsf:physical_orientation a owl:DatatypeProperty ;
    rdfs:label "physical_orientation" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Physical Orientation" ;
    skos:definition "The numeric physical orientation of display." ;
    skos:inScheme ocsf:dictionary .

ocsf:physical_width a owl:DatatypeProperty ;
    rdfs:label "physical_width" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Physical Width" ;
    skos:definition "The numeric physical width of display." ;
    skos:inScheme ocsf:dictionary .

ocsf:pid a owl:DatatypeProperty ;
    rdfs:label "pid" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Process ID" ;
    skos:definition "The process identifier, as reported by the operating system. Process ID (PID) is a number used by the operating system to uniquely identify an active process." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:observable_id 15 .

ocsf:pod_uuid a owl:DatatypeProperty ;
    rdfs:label "pod_uuid" ;
    rdfs:range xsd:string ;
    skos:altLabel "Pod UUID" ;
    skos:definition "The unique identifier of the pod (or equivalent) that the container is executing on." ;
    skos:inScheme ocsf:dictionary .

ocsf:pool a owl:ObjectProperty ;
    rdfs:label "pool" ;
    rdfs:range ocsf:Group ;
    skos:altLabel "Pool" ;
    skos:definition "An unordered collection of resources. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:post_value a owl:DatatypeProperty ;
    rdfs:label "post_value" ;
    rdfs:range xsd:string ;
    skos:altLabel "Post-Value" ;
    skos:definition "The value after. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:postal_code a owl:DatatypeProperty ;
    rdfs:label "postal_code" ;
    rdfs:range xsd:string ;
    skos:altLabel "Postal Code" ;
    skos:definition "The postal code of the location." ;
    skos:inScheme ocsf:dictionary .

ocsf:pre_value a owl:DatatypeProperty ;
    rdfs:label "pre_value" ;
    rdfs:range xsd:string ;
    skos:altLabel "Pre-Value" ;
    skos:definition "The value before. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:precision a owl:DatatypeProperty ;
    rdfs:label "precision" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Precision" ;
    skos:definition "The numeric precision. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:pressure_altitude a owl:DatatypeProperty ;
    rdfs:label "pressure_altitude" ;
    rdfs:range xsd:string ;
    skos:altLabel "Pressure Altitude" ;
    skos:definition "The uncorrected barometric pressure altitude (based on reference standard 29.92 inHg, 1013.25 mb) provides a reference for algorithms that utilize 'altitude deltas' between aircraft. This value is provided in meters and must have a minimum resolution of 1 m.. Special Values: <code>Invalid</code>, <code>No Value</code>, or <code>Unknown: -1000 m</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:prev_reg_key a owl:ObjectProperty ;
    rdfs:label "prev_reg_key" ;
    rdfs:range ocsf:RegKey ;
    skos:altLabel "Previous Registry Key" ;
    skos:definition "The registry key before the mutation" ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_extension "windows" .

ocsf:prev_reg_value a owl:ObjectProperty ;
    rdfs:label "prev_reg_value" ;
    rdfs:range ocsf:RegValue ;
    skos:altLabel "Previous Registry Value" ;
    skos:definition "The registry value before the mutation" ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_extension "windows" .

ocsf:prev_security_level a owl:DatatypeProperty ;
    rdfs:label "prev_security_level" ;
    rdfs:range xsd:string ;
    skos:altLabel "Previous Security Level" ;
    skos:definition "The previous security level of the entity" ;
    skos:inScheme ocsf:dictionary .

ocsf:prev_security_level_id a owl:ObjectProperty ;
    rdfs:label "prev_security_level_id" ;
    rdfs:range ocsf:PrevSecurityLevelIdEnum ;
    skos:altLabel "Previous Security Level ID" ;
    skos:definition "The previous security level of the entity" ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "prev_security_level" .

ocsf:processed_time a owl:DatatypeProperty ;
    rdfs:label "processed_time" ;
    rdfs:range xsd:long ;
    skos:altLabel "Processed Time" ;
    skos:definition "The event processed time, such as an ETL operation." ;
    skos:inScheme ocsf:dictionary .

ocsf:project_uid a owl:DatatypeProperty ;
    rdfs:label "project_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "Project ID" ;
    skos:definition "The unique identifier of a Cloud project." ;
    skos:inScheme ocsf:dictionary .

ocsf:prompt_tokens a owl:DatatypeProperty ;
    rdfs:label "prompt_tokens" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Prompt Tokens" ;
    skos:definition "Number of tokens in the input prompt for this message." ;
    skos:inScheme ocsf:dictionary .

ocsf:protocol_ver_id a owl:ObjectProperty ;
    rdfs:label "protocol_ver_id" ;
    rdfs:range ocsf:ProtocolVerIdEnum ;
    skos:altLabel "Protocol Version ID" ;
    skos:definition "The normalized identifier of the Protocol version. See specific usage." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "protocol_ver" .

ocsf:proxy_connection_info a owl:ObjectProperty ;
    rdfs:label "proxy_connection_info" ;
    rdfs:range ocsf:NetworkConnectionInfo ;
    skos:altLabel "Proxy Connection Info" ;
    skos:definition "The connection information from the proxy server to the remote server." ;
    skos:inScheme ocsf:dictionary .

ocsf:proxy_http_request a owl:ObjectProperty ;
    rdfs:label "proxy_http_request" ;
    rdfs:range ocsf:HttpRequest ;
    skos:altLabel "Proxy HTTP Request" ;
    skos:definition "The HTTP Request from the proxy server to the remote server." ;
    skos:inScheme ocsf:dictionary .

ocsf:proxy_http_response a owl:ObjectProperty ;
    rdfs:label "proxy_http_response" ;
    rdfs:range ocsf:HttpResponse ;
    skos:altLabel "Proxy HTTP Response" ;
    skos:definition "The HTTP Response from the remote server to the proxy server." ;
    skos:inScheme ocsf:dictionary .

ocsf:proxy_tls a owl:ObjectProperty ;
    rdfs:label "proxy_tls" ;
    rdfs:range ocsf:Tls ;
    skos:altLabel "Proxy TLS" ;
    skos:definition "The TLS protocol negotiated between the proxy server and the remote server." ;
    skos:inScheme ocsf:dictionary .

ocsf:proxy_traffic a owl:ObjectProperty ;
    rdfs:label "proxy_traffic" ;
    rdfs:range ocsf:NetworkTraffic ;
    skos:altLabel "Proxy Traffic" ;
    skos:definition "The network traffic refers to the amount of data moving across a network, from proxy to remote server at a given point of time." ;
    skos:inScheme ocsf:dictionary .

ocsf:ptid a owl:DatatypeProperty ;
    rdfs:label "ptid" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Process Thread ID" ;
    skos:definition "The identifier of the process thread associated with the event, as returned by the operating system." ;
    skos:inScheme ocsf:dictionary .

ocsf:query_evidence a owl:ObjectProperty ;
    rdfs:label "query_evidence" ;
    rdfs:range ocsf:QueryEvidence ;
    skos:altLabel "Query Evidence" ;
    skos:definition "The resulting evidence discovered from the evidence search request." ;
    skos:inScheme ocsf:dictionary .

ocsf:query_language a owl:DatatypeProperty ;
    rdfs:label "query_language" ;
    rdfs:range xsd:string ;
    skos:altLabel "Query Language" ;
    skos:definition "The query language, normalized to the caption of the <code>query_language_id</code> value. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:query_language_id a owl:ObjectProperty ;
    rdfs:label "query_language_id" ;
    rdfs:range ocsf:QueryLanguageIdEnum ;
    skos:altLabel "Query Language ID" ;
    skos:definition "The normalized identifier of the query language. See specific usage." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "query_language" .

ocsf:query_result a owl:DatatypeProperty ;
    rdfs:label "query_result" ;
    rdfs:range xsd:string ;
    skos:altLabel "Query Result" ;
    skos:definition "The result of the query." ;
    skos:inScheme ocsf:dictionary .

ocsf:query_result_id a owl:ObjectProperty ;
    rdfs:label "query_result_id" ;
    rdfs:range ocsf:QueryResultIdEnum ;
    skos:altLabel "Query Result ID" ;
    skos:definition "The normalized identifier of the query result." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "query_result" .

ocsf:query_type a owl:DatatypeProperty ;
    rdfs:label "query_type" ;
    rdfs:range xsd:string ;
    skos:altLabel "Query Type" ;
    skos:definition "The normalized caption of query_type_id or the source-specific query type." ;
    skos:inScheme ocsf:dictionary .

ocsf:query_type_id a owl:ObjectProperty ;
    rdfs:label "query_type_id" ;
    rdfs:range ocsf:QueryTypeIdEnum ;
    skos:altLabel "Query Type ID" ;
    skos:definition "The normalized type of system query performed against a device or system component." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "query_type" .

ocsf:radius a owl:DatatypeProperty ;
    rdfs:label "radius" ;
    rdfs:range xsd:string ;
    skos:altLabel "Radius" ;
    skos:definition "Farthest horizontal distance from the reported location at which any UA in a group may be located (meters). Also allows defining the area where an Intent-Based Network Participant operation is taking place. Default: 0 m." ;
    skos:inScheme ocsf:dictionary .

ocsf:ram_size a owl:DatatypeProperty ;
    rdfs:label "ram_size" ;
    rdfs:range xsd:integer ;
    skos:altLabel "RAM Size" ;
    skos:definition "The total amount of installed RAM, in Megabytes. For example: <code>2048</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:raw_data a owl:DatatypeProperty ;
    rdfs:label "raw_data" ;
    rdfs:range xsd:string ;
    skos:altLabel "Raw Data" ;
    skos:definition "The raw event/finding data as received from the source." ;
    skos:inScheme ocsf:dictionary .

ocsf:raw_data_hash a owl:ObjectProperty ;
    rdfs:label "raw_data_hash" ;
    rdfs:range ocsf:Fingerprint ;
    skos:altLabel "Raw Data Hash" ;
    skos:definition "The hash, which describes the content of the raw_data field." ;
    skos:inScheme ocsf:dictionary .

ocsf:raw_data_size a owl:DatatypeProperty ;
    rdfs:label "raw_data_size" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Raw Data Size" ;
    skos:definition "The size of the raw data which was transformed into an OCSF event, in bytes." ;
    skos:inScheme ocsf:dictionary .

ocsf:raw_header a owl:DatatypeProperty ;
    rdfs:label "raw_header" ;
    rdfs:range xsd:string ;
    skos:altLabel "Raw Header" ;
    skos:definition "The email authentication header." ;
    skos:inScheme ocsf:dictionary .

ocsf:rcode a owl:DatatypeProperty ;
    rdfs:label "rcode" ;
    rdfs:range xsd:string ;
    skos:altLabel "Response Code" ;
    skos:definition "The server response code, normalized to the caption of the rcode_id value. In the case of 'Other', it is defined by the event source." ;
    skos:inScheme ocsf:dictionary .

ocsf:rcode_id a owl:ObjectProperty ;
    rdfs:label "rcode_id" ;
    rdfs:range ocsf:RcodeIdEnum ;
    skos:altLabel "Response Code ID" ;
    skos:definition "The normalized identifier of the server response code. See specific usage." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "rcode" .

ocsf:rdata a owl:DatatypeProperty ;
    rdfs:label "rdata" ;
    rdfs:range xsd:string ;
    skos:altLabel "DNS RData" ;
    skos:definition "The data describing the DNS resource. The meaning of this data depends on the type and class of the resource record." ;
    skos:inScheme ocsf:dictionary .

ocsf:read_count a owl:DatatypeProperty ;
    rdfs:label "read_count" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Read Count" ;
    skos:definition "The read count. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:record_index_in_array a owl:DatatypeProperty ;
    rdfs:label "record_index_in_array" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Record Index in Array" ;
    skos:definition "The index of the record in the array of records." ;
    skos:inScheme ocsf:dictionary .

ocsf:referrer a owl:DatatypeProperty ;
    rdfs:label "referrer" ;
    rdfs:range xsd:string ;
    skos:altLabel "HTTP Referrer" ;
    skos:definition "The request header that identifies the address of the previous web page, which is linked to the current web page or resource being requested." ;
    skos:inScheme ocsf:dictionary .

ocsf:reg_binary_data a owl:DatatypeProperty ;
    rdfs:label "reg_binary_data" ;
    rdfs:range xsd:string ;
    skos:altLabel "Registry Binary Data" ;
    skos:definition "The data of the registry value when <code>type_id</code> is <code>REG_BINARY</code> or <code>REG_NONE</code>." ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_extension "windows" .

ocsf:reg_integer_data a owl:DatatypeProperty ;
    rdfs:label "reg_integer_data" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Registry Integer Data" ;
    skos:definition "The data of the registry value when <code>type_id</code> is <code>REG_DWORD</code>, <code>REG_DWORD_BIG_ENDIAN</code>, or <code>REG_QWORD</code>." ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_extension "windows" .

ocsf:reg_string_data a owl:DatatypeProperty ;
    rdfs:label "reg_string_data" ;
    rdfs:range xsd:string ;
    skos:altLabel "Registry String Data" ;
    skos:definition "The data of the registry value when <code>type_id</code> is <code>REG_SZ</code>, <code>REG_EXPAND_SZ</code>, or <code>REG_LINK</code>." ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_extension "windows" .

ocsf:registrar a owl:DatatypeProperty ;
    rdfs:label "registrar" ;
    rdfs:range xsd:string ;
    skos:altLabel "Domain Registrar" ;
    skos:definition "The domain registrar." ;
    skos:inScheme ocsf:dictionary .

ocsf:related_component a owl:DatatypeProperty ;
    rdfs:label "related_component" ;
    rdfs:range xsd:string ;
    skos:altLabel "Related Component" ;
    skos:definition "The package URL (PURL) of the component that this software component has a relationship with." ;
    skos:inScheme ocsf:dictionary .

ocsf:related_events_count a owl:DatatypeProperty ;
    rdfs:label "related_events_count" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Related Events/Findings Count" ;
    skos:definition "Number of related events or findings." ;
    skos:inScheme ocsf:dictionary .

ocsf:relation a owl:DatatypeProperty ;
    rdfs:label "relation" ;
    rdfs:range xsd:string ;
    skos:altLabel "Relation" ;
    skos:definition "The relationship between two entities. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:relationship a owl:DatatypeProperty ;
    rdfs:label "relationship" ;
    rdfs:range xsd:string ;
    skos:altLabel "Relationship" ;
    skos:definition "The relationship between two software components, normalized to the caption of the <code>relationship_id</code> value. In the case of 'Other', it is defined by the source." ;
    skos:inScheme ocsf:dictionary .

ocsf:relationship_id a owl:ObjectProperty ;
    rdfs:label "relationship_id" ;
    rdfs:range ocsf:RelationshipIdEnum ;
    skos:altLabel "Relationship ID" ;
    skos:definition "The normalized identifier of the relationship between two software components." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "relationship" .

ocsf:relay a owl:ObjectProperty ;
    rdfs:label "relay" ;
    rdfs:range ocsf:NetworkInterface ;
    skos:altLabel "Relay" ;
    skos:definition "The network relay that is associated with the event." ;
    skos:inScheme ocsf:dictionary .

ocsf:release a owl:DatatypeProperty ;
    rdfs:label "release" ;
    rdfs:range xsd:string ;
    skos:altLabel "Software Release Details" ;
    skos:definition "Release is the number of times a version of the software has been packaged." ;
    skos:inScheme ocsf:dictionary .

ocsf:remote_display a owl:ObjectProperty ;
    rdfs:label "remote_display" ;
    rdfs:range ocsf:Display ;
    skos:altLabel "Remote Display" ;
    skos:definition "The remote display affiliated with the event" ;
    skos:inScheme ocsf:dictionary .

ocsf:reply_to a owl:DatatypeProperty ;
    rdfs:label "reply_to" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://www.rfc-editor.org/rfc/rfc5322> ;
    skos:altLabel "Reply To" ;
    skos:definition "The machine-readable email header Reply-To value, as defined by RFC 5322. For example <code>example.user@usersdomain.com</code>" ;
    skos:editorialNote "RFC 5322 — https://www.rfc-editor.org/rfc/rfc5322" ;
    skos:inScheme ocsf:dictionary .

ocsf:reporter a owl:ObjectProperty ;
    rdfs:label "reporter" ;
    rdfs:range ocsf:Reporter ;
    skos:altLabel "Reporter" ;
    skos:definition "The entity from which an event or finding was first reported. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:resource_type a owl:DatatypeProperty ;
    rdfs:label "resource_type" ;
    rdfs:range xsd:string ;
    skos:altLabel "Resource Type" ;
    skos:definition "The resource type as defined by the event source." ;
    skos:inScheme ocsf:dictionary .

ocsf:response_time a owl:DatatypeProperty ;
    rdfs:label "response_time" ;
    rdfs:range xsd:long ;
    skos:altLabel "Response Time" ;
    skos:definition "The Domain Name System (DNS) response time." ;
    skos:inScheme ocsf:dictionary .

ocsf:return_path a owl:DatatypeProperty ;
    rdfs:label "return_path" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://datatracker.ietf.org/doc/html/rfc5321#section-4.4>,
        <https://www.rfc-editor.org/rfc/rfc5322> ;
    skos:altLabel "Return Path" ;
    skos:definition "The address found in the 'Return-Path' header, which indicates where bounce messages (non-delivery reports) should be sent. This address is often set by the sending system and may differ from the 'From' or 'Sender' addresses. For example, <code>mailer-daemon@senderserver.com</code>." ;
    skos:editorialNote "RFC 5321 - Simple Mail Transfer Protocol — https://datatracker.ietf.org/doc/html/rfc5321#section-4.4",
        "RFC 5322 — https://www.rfc-editor.org/rfc/rfc5322" ;
    skos:inScheme ocsf:dictionary .

ocsf:return_value a owl:DatatypeProperty ;
    rdfs:label "return_value" ;
    rdfs:range xsd:string ;
    skos:altLabel "Return Value" ;
    skos:definition "The value returned from a function." ;
    skos:inScheme ocsf:dictionary .

ocsf:role a owl:DatatypeProperty ;
    rdfs:label "role" ;
    rdfs:range xsd:string ;
    skos:altLabel "Role" ;
    skos:definition "The role of an entity in the context of the event or finding, normalized to the caption of the role_id value. In the case of 'Other', it is defined by the event source. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:role_id a owl:ObjectProperty ;
    rdfs:label "role_id" ;
    rdfs:range ocsf:RoleIdEnum ;
    skos:altLabel "Role ID" ;
    skos:definition "The normalized identifier of an entity's role in the context of the event or finding. See specific usage." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "role" .

ocsf:row_number a owl:DatatypeProperty ;
    rdfs:label "row_number" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Row Number" ;
    skos:definition "The row number. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:rpc_interface a owl:ObjectProperty ;
    rdfs:label "rpc_interface" ;
    rdfs:range ocsf:RpcInterface ;
    skos:altLabel "Remote Procedure Call Interface" ;
    skos:definition "The RPC Interface object describes the details pertaining to the remote procedure call interface." ;
    skos:inScheme ocsf:dictionary .

ocsf:rssi a owl:DatatypeProperty ;
    rdfs:label "rssi" ;
    rdfs:range xsd:integer ;
    skos:altLabel "RSSI" ;
    skos:definition "Received Signal Strength Indicator (RSSI) is a measurement of the power of a radio signal. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:run_count a owl:DatatypeProperty ;
    rdfs:label "run_count" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Run Count" ;
    skos:definition "The prefetch file run count." ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_extension "windows" .

ocsf:runtime a owl:DatatypeProperty ;
    rdfs:label "runtime" ;
    rdfs:range xsd:string ;
    skos:altLabel "Runtime" ;
    skos:definition "The backend running the container, such as containerd or cri-o." ;
    skos:inScheme ocsf:dictionary .

ocsf:samesite a owl:DatatypeProperty ;
    rdfs:label "samesite" ;
    rdfs:range xsd:string ;
    skos:altLabel "SameSite" ;
    skos:definition "The cookie attribute that lets servers specify whether/when cookies are sent with cross-site requests. Values are: Strict, Lax or None" ;
    skos:inScheme ocsf:dictionary .

ocsf:sandbox a owl:DatatypeProperty ;
    rdfs:label "sandbox" ;
    rdfs:range xsd:string ;
    skos:altLabel "Sandbox" ;
    skos:definition "The name of the containment jail (i.e., sandbox). For example, hardened_ps, high_security_ps, oracle_ps, netsvcs_ps, or default_ps." ;
    skos:inScheme ocsf:dictionary .

ocsf:scale_factor a owl:DatatypeProperty ;
    rdfs:label "scale_factor" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Scale Factor" ;
    skos:definition "The numeric scale factor of display." ;
    skos:inScheme ocsf:dictionary .

ocsf:schedule_uid a owl:DatatypeProperty ;
    rdfs:label "schedule_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "Schedule UID" ;
    skos:definition "The unique identifier of the schedule associated with a scan job." ;
    skos:inScheme ocsf:dictionary .

ocsf:scheme a owl:DatatypeProperty ;
    rdfs:label "scheme" ;
    rdfs:range xsd:string ;
    skos:altLabel "Scheme" ;
    skos:definition "The scheme portion of the URL. For example: <code>http</code>, <code>https</code>, <code>ftp</code>, or <code>sftp</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:scim a owl:ObjectProperty ;
    rdfs:label "scim" ;
    rdfs:range ocsf:Scim ;
    rdfs:seeAlso <https://datatracker.ietf.org/doc/html/rfc7643> ;
    skos:altLabel "SCIM" ;
    skos:definition "The System for Cross-domain Identity Management (SCIM) resource object provides a structured set of attributes related to SCIM protocols used for identity provisioning and management across cloud-based platforms. It standardizes user and group provisioning details, enabling identity synchronization and lifecycle management with compatible Identity Providers (IdPs) and applications. SCIM is defined in <a target='_blank' href='https://datatracker.ietf.org/doc/html/rfc7643'>RFC-7634</a>" ;
    skos:editorialNote "System for Cross-domain Identity Management (SCIM) RFC. — https://datatracker.ietf.org/doc/html/rfc7643" ;
    skos:inScheme ocsf:dictionary .

ocsf:scim_group_schema a owl:DatatypeProperty ;
    rdfs:label "scim_group_schema" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://datatracker.ietf.org/doc/html/rfc7643> ;
    skos:altLabel "SCIM Group Schema" ;
    skos:definition "SCIM provides a schema for representing groups, identified using the following schema URI: <code>urn:ietf:params:scim:schemas:core:2.0:Group</code> as defined in <a target='_blank' href='https://datatracker.ietf.org/doc/html/rfc7643'>RFC-7634</a>. This attribute will capture key-value pairs for the scheme implemented in a SCIM resource." ;
    skos:editorialNote "System for Cross-domain Identity Management (SCIM) RFC spec. — https://datatracker.ietf.org/doc/html/rfc7643" ;
    skos:inScheme ocsf:dictionary .

ocsf:scim_user_schema a owl:DatatypeProperty ;
    rdfs:label "scim_user_schema" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://datatracker.ietf.org/doc/html/rfc7643> ;
    skos:altLabel "SCIM User Schema" ;
    skos:definition "SCIM provides a resource type for user resources. The core schema for user is identified using the following schema URI: <code>urn:ietf:params:scim:schemas:core:2.0:User</code> as defined in <a target='_blank' href='https://datatracker.ietf.org/doc/html/rfc7643'>RFC-7634</a>. his attribute will capture key-value pairs for the scheme implemented in a SCIM resource. This object is inclusive of both the basic and Enterprise User Schema Extension." ;
    skos:editorialNote "System for Cross-domain Identity Management (SCIM) RFC spec. — https://datatracker.ietf.org/doc/html/rfc7643" ;
    skos:inScheme ocsf:dictionary .

ocsf:score_id a owl:ObjectProperty ;
    rdfs:label "score_id" ;
    rdfs:range ocsf:ScoreIdEnum ;
    skos:altLabel "Reputation Score ID" ;
    skos:definition "The normalized reputation score identifier." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "score" .

ocsf:script_content a owl:ObjectProperty ;
    rdfs:label "script_content" ;
    rdfs:range ocsf:LongString ;
    skos:altLabel "Script Content" ;
    skos:definition "The script content, normalized to UTF-8 encoding irrespective of its original encoding. When emitting this attribute, it may be appropriate to truncate large scripts. When consuming this attribute, large scripts should be anticipated." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:observable_id 36 .

ocsf:section_a a owl:DatatypeProperty ;
    rdfs:label "section_a" ;
    rdfs:range xsd:string ;
    skos:altLabel "JA4 Section A" ;
    skos:definition "The 'a' section of the JA4 fingerprint." ;
    skos:inScheme ocsf:dictionary .

ocsf:section_b a owl:DatatypeProperty ;
    rdfs:label "section_b" ;
    rdfs:range xsd:string ;
    skos:altLabel "JA4 Section B" ;
    skos:definition "The 'b' section of the JA4 fingerprint." ;
    skos:inScheme ocsf:dictionary .

ocsf:section_c a owl:DatatypeProperty ;
    rdfs:label "section_c" ;
    rdfs:range xsd:string ;
    skos:altLabel "JA4 Section C" ;
    skos:definition "The 'c' section of the JA4 fingerprint." ;
    skos:inScheme ocsf:dictionary .

ocsf:section_d a owl:DatatypeProperty ;
    rdfs:label "section_d" ;
    rdfs:range xsd:string ;
    skos:altLabel "JA4 Section D" ;
    skos:definition "The 'd' section of the JA4 fingerprint." ;
    skos:inScheme ocsf:dictionary .

ocsf:secure a owl:DatatypeProperty ;
    rdfs:label "secure" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Secure" ;
    skos:definition "The cookie attribute to only send cookies to the server with an encrypted request over the HTTPS protocol." ;
    skos:inScheme ocsf:dictionary .

ocsf:security_level a owl:DatatypeProperty ;
    rdfs:label "security_level" ;
    rdfs:range xsd:string ;
    skos:altLabel "Security Level" ;
    skos:definition "The current security level of the entity" ;
    skos:inScheme ocsf:dictionary .

ocsf:security_level_id a owl:ObjectProperty ;
    rdfs:label "security_level_id" ;
    rdfs:range ocsf:SecurityLevelIdEnum ;
    skos:altLabel "Security Level ID" ;
    skos:definition "The current security level of the entity" ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "security_level" .

ocsf:sender a owl:DatatypeProperty ;
    rdfs:label "sender" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://www.rfc-editor.org/rfc/rfc5322> ;
    skos:altLabel "Sender" ;
    skos:definition "The machine readable email address of the system or server that actually transmitted the email message, extracted from the email headers per RFC 5322. This differs from the <code>from</code> field, which shows the message author. The sender field is most commonly used when multiple addresses appear in the <code> from_list </code> field, or when the transmitting system is different from the message author (such as when sending on behalf of someone else)." ;
    skos:editorialNote "RFC 5322 — https://www.rfc-editor.org/rfc/rfc5322" ;
    skos:inScheme ocsf:dictionary .

ocsf:sender_mailbox a owl:DatatypeProperty ;
    rdfs:label "sender_mailbox" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://www.rfc-editor.org/rfc/rfc5322> ;
    skos:altLabel "Sender Mailbox" ;
    skos:definition "The human readable email address of the system or server that actually transmitted the email message, extracted from the email headers per RFC 5322. This differs from the <code>from_mailbox</code> field, which shows the message author. The sender mailbox field is most commonly used when multiple addresses appear in the <code> from_mailboxes </code> field, or when the transmitting system is different from the message author (such as when sending on behalf of someone else)." ;
    skos:editorialNote "RFC 5322 — https://www.rfc-editor.org/rfc/rfc5322" ;
    skos:inScheme ocsf:dictionary .

ocsf:sensitivity a owl:DatatypeProperty ;
    rdfs:label "sensitivity" ;
    rdfs:range xsd:string ;
    skos:altLabel "Sensitivity" ;
    skos:definition "The sensitivity of the firewall rule in the matched event. For example: HIGH." ;
    skos:inScheme ocsf:dictionary .

ocsf:sequence a owl:DatatypeProperty ;
    rdfs:label "sequence" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Sequence Number" ;
    skos:definition "Sequence number of the event. The sequence number is a value available in some events, to make the exact ordering of events unambiguous, regardless of the event time precision." ;
    skos:inScheme ocsf:dictionary .

ocsf:sequence_number a owl:DatatypeProperty ;
    rdfs:label "sequence_number" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Sequence Number" ;
    skos:definition "The sequence number. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:server_hassh a owl:ObjectProperty ;
    rdfs:label "server_hassh" ;
    rdfs:range ocsf:Hassh ;
    skos:altLabel "Server HASSH" ;
    skos:definition "The Server HASSH fingerprinting object." ;
    skos:inScheme ocsf:dictionary .

ocsf:service_category a owl:DatatypeProperty ;
    rdfs:label "service_category" ;
    rdfs:range xsd:string ;
    skos:altLabel "Service Category" ;
    skos:definition "The service category, normalized to the caption of the service_category_id value. In the case of 'Other', it is defined by the event source." ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_extension "windows" .

ocsf:service_category_id a owl:ObjectProperty ;
    rdfs:label "service_category_id" ;
    rdfs:range ocsf:WindowsServiceCategoryIdEnum ;
    skos:altLabel "Service Category ID" ;
    skos:definition "The normalized identifier of the service category." ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_extension "windows" .

ocsf:service_dll_file a owl:ObjectProperty ;
    rdfs:label "service_dll_file" ;
    rdfs:range ocsf:File ;
    skos:altLabel "Service DLL" ;
    skos:definition "For a shared user mode service (<code>service_type_id</code> is 4) this is the DLL that gets loaded by the generic service host process (e.g. <code>svchost.exe</code>) to implement the service." ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_extension "windows" .

ocsf:service_error_control a owl:DatatypeProperty ;
    rdfs:label "service_error_control" ;
    rdfs:range xsd:string ;
    skos:altLabel "Service Error Control" ;
    skos:definition "The service error control, normalized to the caption of the <code>service_error_control_id</code> value. In the case of 'Other', it is defined by the event source." ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_extension "windows" .

ocsf:service_error_control_id a owl:ObjectProperty ;
    rdfs:label "service_error_control_id" ;
    rdfs:range ocsf:WindowsServiceErrorControlIdEnum ;
    skos:altLabel "Service Error Control ID" ;
    skos:definition "The normalized identifier of the service error control." ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_extension "windows" .

ocsf:service_file a owl:ObjectProperty ;
    rdfs:label "service_file" ;
    rdfs:range ocsf:File ;
    skos:altLabel "Service File" ;
    skos:definition "For a user mode service (<code>service_type_id</code> 3 or 4) this is the executable program that the SCM launches as the service process.<br>For a kernel mode driver (<code>service_type_id</code> 1 or 2) this is the driver file loaded into the kernel at the request of the SCM. " ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_extension "windows" .

ocsf:service_start_name a owl:DatatypeProperty ;
    rdfs:label "service_start_name" ;
    rdfs:range xsd:string ;
    skos:altLabel "Service Start Name" ;
    skos:definition "For a user mode service, this attribute represents the name of the account under which the service is run. For a kernel mode driver, this attribute represents the object name used to load the driver." ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_extension "windows" .

ocsf:service_start_type a owl:DatatypeProperty ;
    rdfs:label "service_start_type" ;
    rdfs:range xsd:string ;
    skos:altLabel "Service Start Type" ;
    skos:definition "The service start type, normalized to the caption of the <code>service_start_type_id</code> value. In the case of 'Other', it is defined by the event source." ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_extension "windows" .

ocsf:service_start_type_id a owl:ObjectProperty ;
    rdfs:label "service_start_type_id" ;
    rdfs:range ocsf:WindowsServiceStartTypeIdEnum ;
    skos:altLabel "Service Start Type ID" ;
    skos:definition "The normalized identifier of the service start type." ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_extension "windows" .

ocsf:service_type a owl:DatatypeProperty ;
    rdfs:label "service_type" ;
    rdfs:range xsd:string ;
    skos:altLabel "Service Type" ;
    skos:definition "The service type, normalized to the caption of the service_type_id value. In the case of 'Other', it is defined by the event source." ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_extension "windows" .

ocsf:service_type_id a owl:ObjectProperty ;
    rdfs:label "service_type_id" ;
    rdfs:range ocsf:WindowsServiceTypeIdEnum ;
    skos:altLabel "Service Type ID" ;
    skos:definition "The normalized identifier of the service type." ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_extension "windows" .

ocsf:short_desc a owl:DatatypeProperty ;
    rdfs:label "short_desc" ;
    rdfs:range xsd:string ;
    skos:altLabel "Short Description" ;
    skos:definition "The short description that pertains to the object or event. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:signature a owl:ObjectProperty ;
    rdfs:label "signature" ;
    rdfs:range ocsf:DigitalSignature ;
    skos:altLabel "Digital Signature" ;
    skos:definition "The digital signature of the file." ;
    skos:inScheme ocsf:dictionary .

ocsf:smtp_from a owl:DatatypeProperty ;
    rdfs:label "smtp_from" ;
    rdfs:range xsd:string ;
    skos:altLabel "SMTP From" ;
    skos:definition "The value of the SMTP MAIL FROM command." ;
    skos:inScheme ocsf:dictionary .

ocsf:smtp_hello a owl:DatatypeProperty ;
    rdfs:label "smtp_hello" ;
    rdfs:range xsd:string ;
    skos:altLabel "SMTP Hello" ;
    skos:definition "The value of the SMTP HELO or EHLO command." ;
    skos:inScheme ocsf:dictionary .

ocsf:sni a owl:DatatypeProperty ;
    rdfs:label "sni" ;
    rdfs:range xsd:string ;
    skos:altLabel "Server Name Indication" ;
    skos:definition " The Server Name Indication (SNI) extension sent by the client." ;
    skos:inScheme ocsf:dictionary .

ocsf:source_id a owl:ObjectProperty ;
    rdfs:label "source_id" ;
    rdfs:range ocsf:SourceIdEnum ;
    skos:altLabel "Source ID" ;
    skos:definition "The normalized identifier of the source. See specific usage." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "source" .

ocsf:sp_name a owl:DatatypeProperty ;
    rdfs:label "sp_name" ;
    rdfs:range xsd:string ;
    skos:altLabel "OS Service Pack" ;
    skos:definition "The name of the latest Service Pack." ;
    skos:inScheme ocsf:dictionary .

ocsf:sp_ver a owl:DatatypeProperty ;
    rdfs:label "sp_ver" ;
    rdfs:range xsd:integer ;
    skos:altLabel "OS Service Pack Version" ;
    skos:definition "The version number of the latest Service Pack." ;
    skos:inScheme ocsf:dictionary .

ocsf:span a owl:ObjectProperty ;
    rdfs:label "span" ;
    rdfs:range ocsf:Span ;
    skos:altLabel "Span" ;
    skos:definition "The information about the span. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:speed a owl:DatatypeProperty ;
    rdfs:label "speed" ;
    rdfs:range xsd:string ;
    skos:altLabel "Speed" ;
    skos:definition "Ground speed of flight. This value is provided in meters per second with a minimum resolution of 0.25 m/s. Special Values: <code>Invalid</code>, <code>No Value</code>, or <code>Unknown: 255 m/s</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:speed_accuracy a owl:DatatypeProperty ;
    rdfs:label "speed_accuracy" ;
    rdfs:range xsd:string ;
    skos:altLabel "Speed Accuracy" ;
    skos:definition "Provides quality/containment on horizontal ground speed. Measured in meters/second." ;
    skos:inScheme ocsf:dictionary .

ocsf:spf a owl:DatatypeProperty ;
    rdfs:label "spf" ;
    rdfs:range xsd:string ;
    skos:altLabel "SPF Status" ;
    skos:definition "The Sender Policy Framework (SPF) status of the email." ;
    skos:inScheme ocsf:dictionary .

ocsf:sso a owl:ObjectProperty ;
    rdfs:label "sso" ;
    rdfs:range ocsf:Sso ;
    skos:altLabel "SSO" ;
    skos:definition "The Single Sign-On (SSO) object provides a structure for normalizing SSO attributes, configuration, and/or settings from Identity Providers." ;
    skos:inScheme ocsf:dictionary .

ocsf:start_address a owl:DatatypeProperty ;
    rdfs:label "start_address" ;
    rdfs:range xsd:string ;
    skos:altLabel "Start Address" ;
    skos:definition "The start address of the execution." ;
    skos:inScheme ocsf:dictionary .

ocsf:start_column a owl:DatatypeProperty ;
    rdfs:label "start_column" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Start Column" ;
    skos:definition "The start column number. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:start_offset a owl:DatatypeProperty ;
    rdfs:label "start_offset" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Start Offset" ;
    skos:definition "The starting offset. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:start_type a owl:DatatypeProperty ;
    rdfs:label "start_type" ;
    rdfs:range xsd:string ;
    skos:altLabel "Start Type" ;
    skos:definition "The start type of a service, driver, or application." ;
    skos:inScheme ocsf:dictionary .

ocsf:start_type_id a owl:ObjectProperty ;
    rdfs:label "start_type_id" ;
    rdfs:range ocsf:StartTypeIdEnum ;
    skos:altLabel "Start Type ID" ;
    skos:definition "The start type ID of a service or application." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "start_type" .

ocsf:storage_class a owl:DatatypeProperty ;
    rdfs:label "storage_class" ;
    rdfs:range xsd:string ;
    skos:altLabel "Storage Class" ;
    skos:definition "The storage class of the entity. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:stratum a owl:DatatypeProperty ;
    rdfs:label "stratum" ;
    rdfs:range xsd:string ;
    skos:altLabel "Stratum" ;
    skos:definition "The stratum level of the NTP server's time source, normalized to the caption of the stratum_id value." ;
    skos:inScheme ocsf:dictionary .

ocsf:stratum_id a owl:ObjectProperty ;
    rdfs:label "stratum_id" ;
    rdfs:range ocsf:StratumIdEnum ;
    skos:altLabel "Stratum ID" ;
    skos:definition "The normalized identifier of the stratum level, as defined in <a target='_blank' href='https://www.rfc-editor.org/rfc/rfc5905.html'>RFC-5905</a>." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "stratum" .

ocsf:sub_technique a owl:ObjectProperty ;
    rdfs:label "sub_technique" ;
    rdfs:range ocsf:SubTechnique ;
    rdfs:seeAlso <https://atlas.mitre.org/matrices/ATLAS>,
        <https://attack.mitre.org> ;
    skos:altLabel "MITRE Sub-technique" ;
    skos:definition "The Sub-technique object describes the MITRE ATT&CK® or ATLAS™ Sub-technique ID and/or name associated to an attack." ;
    skos:editorialNote "ATLAS™ Matrix — https://atlas.mitre.org/matrices/ATLAS",
        "ATT&CK® Matrix — https://attack.mitre.org" ;
    skos:inScheme ocsf:dictionary .

ocsf:subdomain a owl:DatatypeProperty ;
    rdfs:label "subdomain" ;
    rdfs:range xsd:string ;
    skos:altLabel "Subdomain" ;
    skos:definition "The subdomain portion of the URL. For example: <code>sub</code> in <code>https://sub.example.com</code> or <code>sub2.sub1</code> in <code>https://sub2.sub1.example.com</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:subgroup a owl:ObjectProperty ;
    rdfs:label "subgroup" ;
    rdfs:range ocsf:Group ;
    skos:altLabel "Subgroup" ;
    skos:definition "A subgroup that was added to or removed from the group." ;
    skos:inScheme ocsf:dictionary .

ocsf:subnet_prefix a owl:DatatypeProperty ;
    rdfs:label "subnet_prefix" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Subnet Prefix Length" ;
    skos:definition "The subnet prefix length determines the number of bits used to represent the network part of the IP address. The remaining bits are reserved for identifying individual hosts within that subnet." ;
    skos:inScheme ocsf:dictionary .

ocsf:subnet_uid a owl:DatatypeProperty ;
    rdfs:label "subnet_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "Subnet UID" ;
    skos:definition "The unique identifier of a virtual subnet." ;
    skos:inScheme ocsf:dictionary .

ocsf:supporting_data a owl:DatatypeProperty ;
    rdfs:label "supporting_data" ;
    rdfs:range xsd:string ;
    skos:altLabel "Supporting Data" ;
    skos:definition "Additional data supporting a finding as provided by security tool" ;
    skos:inScheme ocsf:dictionary .

ocsf:surname a owl:DatatypeProperty ;
    rdfs:label "surname" ;
    rdfs:range xsd:string ;
    skos:altLabel "Surname" ;
    skos:definition "The last or family name for the user." ;
    skos:inScheme ocsf:dictionary .

ocsf:system_call a owl:DatatypeProperty ;
    rdfs:label "system_call" ;
    rdfs:range xsd:string ;
    skos:altLabel "System Call" ;
    skos:definition "The system call that was invoked." ;
    skos:inScheme ocsf:dictionary .

ocsf:tactic a owl:ObjectProperty ;
    rdfs:label "tactic" ;
    rdfs:range ocsf:Tactic ;
    rdfs:seeAlso <https://atlas.mitre.org/matrices/ATLAS>,
        <https://attack.mitre.org> ;
    skos:altLabel "MITRE Tactic" ;
    skos:definition "The Tactic object describes the MITRE ATT&CK® or ATLAS™ Tactic ID and/or name that is associated to an attack." ;
    skos:editorialNote "ATLAS™ Matrix — https://atlas.mitre.org/matrices/ATLAS",
        "ATT&CK® Matrix — https://attack.mitre.org" ;
    skos:inScheme ocsf:dictionary .

ocsf:target a owl:DatatypeProperty ;
    rdfs:label "target" ;
    rdfs:range xsd:string ;
    skos:altLabel "Target" ;
    skos:definition "The target of the event or object. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:tcp_flags a owl:DatatypeProperty ;
    rdfs:label "tcp_flags" ;
    rdfs:range xsd:integer ;
    skos:altLabel "TCP Flags" ;
    skos:definition "The network connection TCP header flags (i.e., control bits)." ;
    skos:inScheme ocsf:dictionary .

ocsf:tcp_state_id a owl:ObjectProperty ;
    rdfs:label "tcp_state_id" ;
    rdfs:range ocsf:TcpStateIdEnum ;
    rdfs:seeAlso <https://datatracker.ietf.org/doc/html/rfc9293> ;
    skos:altLabel "TCP State ID" ;
    skos:definition "The state of the TCP socket for the network connection." ;
    skos:editorialNote "RFC 9293 — https://datatracker.ietf.org/doc/html/rfc9293" ;
    skos:inScheme ocsf:dictionary .

ocsf:technique a owl:ObjectProperty ;
    rdfs:label "technique" ;
    rdfs:range ocsf:Technique ;
    rdfs:seeAlso <https://atlas.mitre.org/matrices/ATLAS>,
        <https://attack.mitre.org> ;
    skos:altLabel "MITRE Technique" ;
    skos:definition "The Technique object describes the MITRE ATT&CK® or ATLAS™ Technique ID and/or name associated to an attack." ;
    skos:editorialNote "ATLAS™ Matrix — https://atlas.mitre.org/matrices/ATLAS",
        "ATT&CK® Matrix — https://attack.mitre.org" ;
    skos:inScheme ocsf:dictionary .

ocsf:terminal a owl:DatatypeProperty ;
    rdfs:label "terminal" ;
    rdfs:range xsd:string ;
    skos:altLabel "Terminal" ;
    skos:definition "The Pseudo Terminal. Ex: the tty or pts value." ;
    skos:inScheme ocsf:dictionary .

ocsf:terminated_time a owl:DatatypeProperty ;
    rdfs:label "terminated_time" ;
    rdfs:range xsd:long ;
    skos:altLabel "Terminated Time" ;
    skos:definition "The time when the entity was terminated. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:threat_actor a owl:ObjectProperty ;
    rdfs:label "threat_actor" ;
    rdfs:range ocsf:ThreatActor ;
    rdfs:seeAlso <https://stixproject.github.io/data-model/1.2/ta/ThreatActorType/> ;
    skos:altLabel "Threat Actor" ;
    skos:definition "A threat actor is an individual or group that conducts malicious cyber activities, often with financial, political, or ideological motives." ;
    skos:editorialNote "STIX Threat Actor definition — https://stixproject.github.io/data-model/1.2/ta/ThreatActorType/" ;
    skos:inScheme ocsf:dictionary .

ocsf:tid a owl:DatatypeProperty ;
    rdfs:label "tid" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Thread ID" ;
    skos:definition "The identifier of the thread associated with the event, as returned by the operating system." ;
    skos:inScheme ocsf:dictionary .

ocsf:timezone_offset a owl:DatatypeProperty ;
    rdfs:label "timezone_offset" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Timezone Offset" ;
    skos:definition "The number of minutes that the reported event <code>time</code> is ahead or behind UTC, in the range -1,080 to +1,080." ;
    skos:inScheme ocsf:dictionary .

ocsf:tlp a owl:DatatypeProperty ;
    rdfs:label "tlp" ;
    rdfs:range xsd:string ;
    skos:altLabel "Traffic Light Protocol" ;
    skos:definition "The <a target='_blank' href='https://www.first.org/tlp/'>Traffic Light Protocol</a> was created to facilitate greater sharing of potentially sensitive information and more effective collaboration. TLP provides a simple and intuitive schema for indicating with whom potentially sensitive information can be shared." ;
    skos:inScheme ocsf:dictionary .

ocsf:token a owl:ObjectProperty ;
    rdfs:label "token" ;
    rdfs:range ocsf:Token ;
    skos:altLabel "Token" ;
    skos:definition "The Token object is the base object for representing tokens, API keys, and authentication credentials. This object provides common attributes for all token types and can be used directly in API activity events to represent API tokens (type_id: 7) or client tokens (type_id: 6) such as Okta API tokens or Microsoft Entra ID Application Registration client secrets. The base <code>token</code> object is also extended by <code>authentication_token</code> for protocol-specific authentication tokens in authentication events. Note: Use <code>authentication_token</code> (which extends <code>token</code>) for protocol-specific authentication tokens (Kerberos, OIDC, SAML) in authentication events, and <code>programmatic_credential</code> for tracking credential lifecycle and usage patterns." ;
    skos:inScheme ocsf:dictionary .

ocsf:total_potential_attacks_count a owl:DatatypeProperty ;
    rdfs:label "total_potential_attacks_count" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Total Potential Attacks Count" ;
    skos:definition "The total count of privilege-to-attack technique mappings identified across all analyzed privileges." ;
    skos:inScheme ocsf:dictionary .

ocsf:total_queued_duration a owl:ObjectProperty ;
    rdfs:label "total_queued_duration" ;
    rdfs:range ocsf:Timespan ;
    skos:altLabel "Total Queued Duration" ;
    skos:definition "The amount of time an event spent in a queue awaiting processing." ;
    skos:inScheme ocsf:dictionary .

ocsf:total_tokens a owl:DatatypeProperty ;
    rdfs:label "total_tokens" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Total Tokens" ;
    skos:definition "Total number of tokens used for this message (prompt + completion)." ;
    skos:inScheme ocsf:dictionary .

ocsf:trace a owl:ObjectProperty ;
    rdfs:label "trace" ;
    rdfs:range ocsf:Trace ;
    skos:altLabel "Trace" ;
    skos:definition "The information about the trace. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:track_direction a owl:DatatypeProperty ;
    rdfs:label "track_direction" ;
    rdfs:range xsd:string ;
    skos:altLabel "Track Direction" ;
    skos:definition "Direction of flight expressed as a “True North-based” ground track angle. This value is provided in clockwise degrees with a minimum resolution of 1 degree. If aircraft is not moving horizontally, use the “Unknown” value" ;
    skos:inScheme ocsf:dictionary .

ocsf:transaction_uid a owl:DatatypeProperty ;
    rdfs:label "transaction_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "Transaction UID" ;
    skos:definition "The unique identifier of the transaction." ;
    skos:inScheme ocsf:dictionary .

ocsf:tree_uid a owl:DatatypeProperty ;
    rdfs:label "tree_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "Tree UID" ;
    skos:definition "The tree id is a unique SMB identifier which represents an open connection to a share." ;
    skos:inScheme ocsf:dictionary .

ocsf:ttl a owl:DatatypeProperty ;
    rdfs:label "ttl" ;
    rdfs:range xsd:integer ;
    skos:altLabel "TTL" ;
    skos:definition "The time interval that the resource record may be cached. Zero value means that the resource record can only be used for the transaction in progress, and should not be cached." ;
    skos:inScheme ocsf:dictionary .

ocsf:tunnel_interface a owl:ObjectProperty ;
    rdfs:label "tunnel_interface" ;
    rdfs:range ocsf:NetworkInterface ;
    skos:altLabel "Interface" ;
    skos:definition "The information about the tunnel interface. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:tunnel_type a owl:DatatypeProperty ;
    rdfs:label "tunnel_type" ;
    rdfs:range xsd:string ;
    skos:altLabel "Tunnel Type" ;
    skos:definition "The type of tunnel configuration, normalized to the caption of the <code>tunnel_type_id</code> value, indicating the scope of traffic routed through the connection. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:tunnel_type_id a owl:ObjectProperty ;
    rdfs:label "tunnel_type_id" ;
    rdfs:range ocsf:TunnelTypeIdEnum ;
    skos:altLabel "Tunnel Type ID" ;
    skos:definition "The normalized identifier for the type of tunnel configuration, indicating the scope of traffic routed through the connection. See specific usage." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "tunnel_type" .

ocsf:udid a owl:DatatypeProperty ;
    rdfs:label "udid" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://theapplewiki.com/wiki/UDID> ;
    skos:altLabel "Unique Device Identifier" ;
    skos:definition "The Apple assigned Unique Device Identifier (UDID). For iOS, iPadOS, tvOS, watchOS and visionOS devices, this is the UDID. For macOS devices, it is the Provisioning UDID. For example: <code>00008020-008D4548007B4F26</code>" ;
    skos:editorialNote "Apple Wiki — https://theapplewiki.com/wiki/UDID" ;
    skos:inScheme ocsf:dictionary .

ocsf:unique_malware_count a owl:DatatypeProperty ;
    rdfs:label "unique_malware_count" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Unique Malware Count" ;
    skos:definition "The number of unique malware detected during a scan. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:unmapped a owl:ObjectProperty ;
    rdfs:label "unmapped" ;
    rdfs:range ocsf:Object ;
    skos:altLabel "Unmapped Data" ;
    skos:definition "The attributes that are not mapped to the event schema. The names and values of those attributes are specific to the event source." ;
    skos:inScheme ocsf:dictionary .

ocsf:unused_services_count a owl:DatatypeProperty ;
    rdfs:label "unused_services_count" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Unused Services Count" ;
    skos:definition "The number of unused services. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:uploaded_time a owl:DatatypeProperty ;
    rdfs:label "uploaded_time" ;
    rdfs:range xsd:long ;
    skos:altLabel "Uploaded Time" ;
    skos:definition "The timestamp at which an entity was uploaded. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:uri a owl:DatatypeProperty ;
    rdfs:label "uri" ;
    rdfs:range xsd:anyURI ;
    rdfs:seeAlso <https://datatracker.ietf.org/doc/html/rfc3986> ;
    skos:altLabel "URI" ;
    skos:definition "A Uniform Resource Identifier (URI) is a string of characters that identifies a resource on the Internet. URIs can identify physical resources, like webpages and documents. See specific usage." ;
    skos:editorialNote "RFC 3986 — https://datatracker.ietf.org/doc/html/rfc3986" ;
    skos:inScheme ocsf:dictionary .

ocsf:user_agent a owl:DatatypeProperty ;
    rdfs:label "user_agent" ;
    rdfs:range xsd:string ;
    skos:altLabel "HTTP User-Agent" ;
    skos:definition "The request header that identifies the operating system and web browser." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:observable_id 16 .

ocsf:user_result a owl:ObjectProperty ;
    rdfs:label "user_result" ;
    rdfs:range ocsf:User ;
    skos:altLabel "User Result" ;
    skos:definition "The result of the user account change. It should contain the new values of the changed attributes." ;
    skos:inScheme ocsf:dictionary .

ocsf:vector_string a owl:DatatypeProperty ;
    rdfs:label "vector_string" ;
    rdfs:range xsd:string ;
    skos:altLabel "Vector String" ;
    skos:definition "The CVSS vector string is a text representation of a set of CVSS metrics. It is commonly used to record or transfer CVSS metric information in a concise form. For example: <code>3.1/AV:L/AC:L/PR:L/UI:N/S:U/C:H/I:N/A:H</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:vertical_speed a owl:DatatypeProperty ;
    rdfs:label "vertical_speed" ;
    rdfs:range xsd:string ;
    skos:altLabel "Vertical Speed" ;
    skos:definition "Vertical speed upward relative to the WGS-84 datum, measured in meters per second. Special Values: <code>Invalid</code>, <code>No Value</code>, or <code>Unknown: 63 m/s</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:vlan_uid a owl:DatatypeProperty ;
    rdfs:label "vlan_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "VLAN" ;
    skos:definition "The Virtual LAN identifier." ;
    skos:inScheme ocsf:dictionary .

ocsf:volume a owl:DatatypeProperty ;
    rdfs:label "volume" ;
    rdfs:range xsd:string ;
    skos:altLabel "Volume" ;
    skos:definition "The volume on the storage device where the file is located. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:vpc_uid a owl:DatatypeProperty ;
    rdfs:label "vpc_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "VPC UID" ;
    skos:definition "The unique identifier of the Virtual Private Cloud (VPC)." ;
    skos:inScheme ocsf:dictionary .

ocsf:vram_mode a owl:DatatypeProperty ;
    rdfs:label "vram_mode" ;
    rdfs:range xsd:string ;
    skos:altLabel "VRAM Mode" ;
    skos:definition "The video memory attachment mode, indicating how the VRAM hardware is integrated with the system (e.g., shared or dedicated), normalized to the caption of the vram_mode_id value. For 'Other', the exact attachment mode is defined by the event source." ;
    skos:inScheme ocsf:dictionary .

ocsf:vram_mode_id a owl:ObjectProperty ;
    rdfs:label "vram_mode_id" ;
    rdfs:range ocsf:VramModeIdEnum ;
    skos:altLabel "VRAM Mode ID" ;
    skos:definition "The normalized identifier of the video memory attachment mode." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "vram_mode" .

ocsf:vram_size a owl:DatatypeProperty ;
    rdfs:label "vram_size" ;
    rdfs:range xsd:integer ;
    skos:altLabel "VRAM Size" ;
    skos:definition "The total amount of installed video RAM." ;
    skos:inScheme ocsf:dictionary .

ocsf:whois a owl:ObjectProperty ;
    rdfs:label "whois" ;
    rdfs:range ocsf:Whois ;
    skos:altLabel "WHOIS" ;
    skos:definition "The resources of a WHOIS record for a given domain. This can include domain names, IP address blocks, autonomous system information, and/or contact and registration information for a domain." ;
    skos:inScheme ocsf:dictionary .

ocsf:win_resource a owl:ObjectProperty ;
    rdfs:label "win_resource" ;
    rdfs:range ocsf:WinResource ;
    skos:altLabel "Windows Resource" ;
    skos:definition "The Windows resource object that was accessed, such as a mutant or timer." ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_extension "windows" .

ocsf:working_directory a owl:DatatypeProperty ;
    rdfs:label "working_directory" ;
    rdfs:range xsd:string ;
    skos:altLabel "Working Directory" ;
    skos:definition "The working directory of a process." ;
    skos:inScheme ocsf:dictionary .

ocsf:write_count a owl:DatatypeProperty ;
    rdfs:label "write_count" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Write Count" ;
    skos:definition "The write count. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:Api a owl:Class ;
    rdfs:label "Api" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:group ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:version ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:operation ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:operation ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Request ;
            owl:onProperty ocsf:request ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Service ;
            owl:onProperty ocsf:service ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:token ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Group ;
            owl:onProperty ocsf:group ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:service ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Token ;
            owl:onProperty ocsf:token ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:version ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:response ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:operation ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:version ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Response ;
            owl:onProperty ocsf:response ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:token ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:service ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:group ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:response ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:request ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:request ],
        ocsf:Object ;
    skos:altLabel "API" ;
    skos:definition "The API, or Application Programming Interface, object represents  information pertaining to an API request and response." ;
    skos:inScheme ocsf:objects .

ocsf:Assessment a owl:Class ;
    rdfs:label "Assessment" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:meets_criteria ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty ocsf:meets_criteria ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:category ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:policy ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:category ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:category ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:desc ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Policy ;
            owl:onProperty ocsf:policy ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:meets_criteria ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:desc ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:desc ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:policy ],
        ocsf:Entity ;
    skos:altLabel "Assessment" ;
    skos:definition "The Assessment object describes a point-in-time assessment, check, or evaluation of a specific configuration or signal against an asset, entity, person, or otherwise. For example, this can encapsulate <code>os_signals</code> from CrowdStrike Falcon Zero Trust Assessments, or account for <code>Datastore</code> configurations from Cyera, or capture details of Microsoft Intune configuration policies." ;
    skos:inScheme ocsf:objects .

ocsf:AuthFactor a owl:Class ;
    rdfs:label "AuthFactor" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:is_hotp ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:is_hotp ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:factor_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty ocsf:is_totp ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:phone_number ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:provider ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:provider ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:factor_type_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:is_totp ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:security_questions ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:email_addr ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:factor_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:email_addr ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:factor_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:email_addr ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty ocsf:is_hotp ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:is_totp ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:provider ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:factor_type_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:device ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:phone_number ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:phone_number ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:FactorTypeIdEnum ;
            owl:onProperty ocsf:factor_type_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:security_questions ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:device ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Device ;
            owl:onProperty ocsf:device ],
        ocsf:Object ;
    skos:altLabel "Authentication Factor" ;
    skos:definition "An Authentication Factor object describes a category of methods used for identity verification in an authentication attempt." ;
    skos:inScheme ocsf:objects .

ocsf:AutonomousSystem a owl:Class ;
    rdfs:label "AutonomousSystem" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ocsf:number ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:number ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:number ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:name ],
        ocsf:Object ;
    skos:altLabel "Autonomous System" ;
    skos:definition "An autonomous system (AS) is a collection of connected Internet Protocol (IP) routing prefixes under the control of one or more network operators on behalf of a single administrative entity or domain that presents a common, clearly defined routing policy to the internet." ;
    skos:exactMatch stix:AutonomousSystem,
        uco_master:AutonomousSystem ;
    skos:inScheme ocsf:objects ;
    ocsf:ocsf_constraints "{\"at_least_one\": [\"number\", \"name\"]}" .

ocsf:CloudProfile a owl:Class ;
    rdfs:label "CloudProfile" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:api ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:cloud ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Api ;
            owl:onProperty ocsf:api ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Cloud ;
            owl:onProperty ocsf:cloud ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:cloud ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:api ] ;
    skos:altLabel "Cloud" ;
    skos:definition "The attributes that describe information specific to Cloud services/applications." ;
    skos:inScheme ocsf:profiles ;
    ocsf:ocsf_profile "cloud" .

ocsf:Compliance a owl:Class ;
    rdfs:label "Compliance" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:desc ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:status_details ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:requirements ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Assessment ;
            owl:onProperty ocsf:assessments ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:desc ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:requirements ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:status_code ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:control ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:status_detail ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:KbArticle ;
            owl:onProperty ocsf:compliance_standards ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:status_code ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:category ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:category ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:status_detail ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:status ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:category ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:status ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:status_code ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:standards ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:compliance_standards ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Check ;
            owl:onProperty ocsf:checks ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:assessments ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:ComplianceStatusIdEnum ;
            owl:onProperty ocsf:status_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:checks ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:control ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:status_details ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:status_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:control ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:status ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:control_parameters ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:status_detail ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:KbArticle ;
            owl:onProperty ocsf:compliance_references ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:KeyValueObject ;
            owl:onProperty ocsf:control_parameters ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:compliance_references ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:standards ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:desc ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:status_id ],
        ocsf:Object ;
    skos:altLabel "Compliance" ;
    skos:closeMatch iso27001:SecurityControl ;
    skos:definition "The Compliance object contains information about Industry and Regulatory Framework standards, controls and requirements or details about custom assessments utilized in a compliance evaluation. Standards define broad security frameworks, controls represent specific security requirements within those frameworks, and checks are the testable verification points used to determine if controls are properly implemented." ;
    skos:inScheme ocsf:objects .

ocsf:DiscoveryResultActivityIdEnum a owl:Class ;
    rdfs:label "DiscoveryResultActivityIdEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/ocsf/DiscoveryResultActivityIdEnum#QUERY> <https://w3id.org/lmodel/ocsf/DiscoveryResultActivityIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/DiscoveryResultActivityIdEnum#OTHER> ) ;
    skos:definition "DiscoveryResult activity_id values." ;

    ocsf:ocsf_uid "7" .

<https://w3id.org/lmodel/ocsf/DispositionIdEnum#DELAYED> a owl:Class ;
    rdfs:label "DELAYED" ;
    rdfs:subClassOf ocsf:DispositionIdEnum ;

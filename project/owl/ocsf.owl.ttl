ocsf:Script a owl:Class ;
    rdfs:label "Script" ;
    rdfs:seeAlso <https://d3fend.mitre.org/dao/artifact/d3f:ExecutableScript/> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Fingerprint ;
            owl:onProperty ocsf:hashes ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:parent_uid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:parent_uid ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:ScriptTypeIdEnum ;
            owl:onProperty ocsf:type_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:parent_uid ],

        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:interface_name ],
        ocsf:ContainerProfile,
        ocsf:Entity ;
    skos:altLabel "Endpoint" ;
    skos:broadMatch stix:Host,
        uco_master:Device ;
    skos:definition "The Endpoint object describes a physical or virtual device that connects to and exchanges information with a computer network. Some examples of endpoints are mobile devices, desktop computers, virtual machines, embedded devices, and servers. Internet-of-Things devices—like cameras, lighting, refrigerators, security systems, smart speakers, and thermostats—are also endpoints." ;
    skos:editorialNote "D3FEND™ Ontology d3f:Host. — https://d3fend.mitre.org/dao/artifact/d3f:ComputerNetworkNode/" ;
    skos:inScheme ocsf:objects ;
    ocsf:observable_id 20 ;
    ocsf:ocsf_constraints "{\"at_least_one\": [\"ip\", \"uid\", \"name\", \"hostname\", \"instance_uid\", \"interface_uid\", \"interface_name\"]}" .

ocsf:EndpointConnection a owl:Class ;
    rdfs:label "EndpointConnection" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ocsf:NetworkEndpoint ;
            owl:onProperty ocsf:network_endpoint ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:code ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:network_endpoint ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:code ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ocsf:code ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:network_endpoint ],
        ocsf:Object ;
    skos:altLabel "Endpoint Connection" ;
    skos:definition "The Endpoint Connection object contains information detailing a connection attempt to an endpoint." ;
    skos:inScheme ocsf:objects ;
    ocsf:ocsf_constraints "{\"at_least_one\": [\"network_endpoint\", \"code\"]}" .


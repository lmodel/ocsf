ocsf:DceRpc a owl:Class ;
    rdfs:label "DceRpc" ;
    rdfs:seeAlso <https://d3fend.mitre.org/dao/artifact/d3f:RemoteProcedureCall/> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:command ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:rpc_interface ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:RpcInterface ;
            owl:onProperty ocsf:rpc_interface ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:opnum ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:command ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:command ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:flags ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:flags ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:rpc_interface ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:command_response ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:command_response ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ocsf:opnum ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:opnum ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:command_response ],
        ocsf:Object ;
    skos:altLabel "DCE/RPC" ;
    skos:definition "The DCE/RPC, or Distributed Computing Environment/Remote Procedure Call, object describes the remote procedure call system for distributed computing environments." ;
    skos:editorialNote "D3FEND™ Ontology d3f:RemoteProcedureCall. — https://d3fend.mitre.org/dao/artifact/d3f:RemoteProcedureCall/" ;
    skos:inScheme ocsf:objects .


    ocsf:ocsf_uid "9" .

<https://w3id.org/lmodel/ocsf/DispositionIdEnum#TAGGED> a owl:Class ;
    rdfs:label "TAGGED" ;
    rdfs:subClassOf ocsf:DispositionIdEnum ;

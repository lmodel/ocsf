ocsf:DiscoveryDetails a owl:Class ;
    rdfs:label "DiscoveryDetails" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:count ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:OccurrenceDetails ;
            owl:onProperty ocsf:occurrence_details ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ocsf:count ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:OccurrenceDetails ;
            owl:onProperty ocsf:occurrences ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:count ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:occurrences ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:occurrence_details ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:occurrence_details ],
        ocsf:Object ;
    skos:altLabel "Discovery Details" ;
    skos:definition "The Discovery Details object describes results of a discovery task/job." ;
    skos:inScheme ocsf:objects .


ocsf:accessors a owl:ObjectProperty ;
    rdfs:label "accessors" ;
    rdfs:range ocsf:User ;
    skos:altLabel "Accessors" ;
    skos:definition "A list of users who have access to an entity. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:additional_restrictions a owl:ObjectProperty ;
    rdfs:label "additional_restrictions" ;
    rdfs:range ocsf:AdditionalRestriction ;
    skos:altLabel "Additional Restrictions" ;
    skos:definition "The supplementary restrictions that may apply to an entity, by the virtue of a policy. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:affected_code a owl:ObjectProperty ;
    rdfs:label "affected_code" ;
    rdfs:range ocsf:AffectedCode ;
    skos:altLabel "Affected Code" ;
    skos:definition "List of Affected Code objects that describe details about code blocks identified as vulnerable." ;
    skos:inScheme ocsf:dictionary .

ocsf:affected_packages a owl:ObjectProperty ;
    rdfs:label "affected_packages" ;
    rdfs:range ocsf:AffectedPackage ;
    skos:altLabel "Affected Software Packages" ;
    skos:definition "List of software packages identified as affected by a vulnerability/vulnerabilities." ;
    skos:inScheme ocsf:dictionary .

ocsf:analysis_targets a owl:ObjectProperty ;
    rdfs:label "analysis_targets" ;
    rdfs:range ocsf:AnalysisTarget ;
    skos:altLabel "Analysis Targets" ;
    skos:definition "The specific dimensions, components, or aspects of the system that are the targets of the analysis. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:ancestry a owl:ObjectProperty ;
    rdfs:label "ancestry" ;
    rdfs:range ocsf:ProcessEntity ;
    rdfs:seeAlso <https://github.com/ocsf/ocsf-docs/blob/main/articles/representing-process-parentage.md> ;
    skos:altLabel "Ancestry" ;
    skos:definition "An array of Process Entities describing the extended parentage of this process object. Direct parent information should be expressed through the <code>parent_process</code> attribute. The first array element is the direct parent of this process object. Subsequent list elements go up the process parentage hierarchy. That is, the array is sorted from newest to oldest process. It is recommended to only populate this field for the top-level process object." ;
    skos:editorialNote "Guidance on Representing Process Parentage — https://github.com/ocsf/ocsf-docs/blob/main/articles/representing-process-parentage.md" ;
    skos:inScheme ocsf:dictionary .

ocsf:anomalies a owl:ObjectProperty ;
    rdfs:label "anomalies" ;
    rdfs:range ocsf:Anomaly ;
    skos:altLabel "Anomalies" ;
    skos:definition "A list of detected anomalies or deviations from expected behavior patterns. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:anomaly_analyses a owl:ObjectProperty ;
    rdfs:label "anomaly_analyses" ;
    rdfs:range ocsf:AnomalyAnalysis ;
    skos:altLabel "Anomaly Analyses" ;
    skos:definition "A list of anomaly analysis results that examine and characterize patterns of activity or usage over time to identify normal vs abnormal activities. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:applications a owl:ObjectProperty ;
    rdfs:label "applications" ;
    rdfs:range ocsf:ApplicationObject ;
    skos:altLabel "Applications" ;
    skos:definition "A list of application objects. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:baselines a owl:ObjectProperty ;
    rdfs:label "baselines" ;
    rdfs:range ocsf:Baseline ;
    skos:altLabel "Baselines" ;
    skos:definition "A list of baseline measurements or normal behavior patterns used as reference points for comparison and anomaly detection. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:capabilities a owl:DatatypeProperty ;
    rdfs:label "capabilities" ;
    rdfs:range xsd:string ;
    skos:altLabel "Capabilities" ;
    skos:definition "A list of RDP capabilities." ;
    skos:inScheme ocsf:dictionary .

ocsf:category_ids a owl:ObjectProperty ;
    rdfs:label "category_ids" ;
    rdfs:range ocsf:CategoryIdsEnum ;
    skos:altLabel "Website Categorization IDs" ;
    skos:definition "The Website categorization identifiers." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "categories" .

ocsf:cc a owl:DatatypeProperty ;
    rdfs:label "cc" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://www.rfc-editor.org/rfc/rfc5322> ;
    skos:altLabel "Cc" ;
    skos:definition "The machine-readable email header Cc values, as defined by RFC 5322. For example <code>example.user@usersdomain.com</code>." ;
    skos:editorialNote "RFC 5322 — https://www.rfc-editor.org/rfc/rfc5322" ;
    skos:inScheme ocsf:dictionary .

ocsf:cc_mailboxes a owl:DatatypeProperty ;
    rdfs:label "cc_mailboxes" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://www.rfc-editor.org/rfc/rfc5322#section-3.4> ;
    skos:altLabel "Cc Mailboxes" ;
    skos:definition "The human-readable email header Cc Mailbox values. For example <code>'Example User &lt;example.user@usersdomain.com&gt;'</code>." ;
    skos:editorialNote "RFC 5322 — https://www.rfc-editor.org/rfc/rfc5322#section-3.4" ;
    skos:inScheme ocsf:dictionary .

ocsf:checks a owl:ObjectProperty ;
    rdfs:label "checks" ;
    rdfs:range ocsf:Check ;
    skos:altLabel "Compliance Checks" ;
    skos:definition "A list of specific, individual compliance verification checks derived from standard or non-standard benchmark rules or requirements." ;
    skos:inScheme ocsf:dictionary .

ocsf:cis_csc a owl:ObjectProperty ;
    rdfs:label "cis_csc" ;
    rdfs:range ocsf:CisCsc ;
    skos:altLabel "CIS CSC" ;
    skos:definition "The CIS Critical Security Controls is a list of top 20 actions and practices an organization’s security team can take on such that cyber attacks or malware, are minimized and prevented." ;
    skos:inScheme ocsf:dictionary .

ocsf:classification_ids a owl:ObjectProperty ;
    rdfs:label "classification_ids" ;
    rdfs:range ocsf:ClassificationIdsEnum ;
    skos:altLabel "Classification IDs" ;
    skos:definition "The list of normalized classification identifiers. See specific usage." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "classifications" .

ocsf:classifications a owl:DatatypeProperty ;
    rdfs:label "classifications" ;
    rdfs:range xsd:string ;
    skos:altLabel "Classifications" ;
    skos:definition "The list of malware classifications, normalized to the captions of the classification_id values. In the case of 'Other', they are defined by the event source." ;
    skos:inScheme ocsf:dictionary .

ocsf:client_ciphers a owl:DatatypeProperty ;
    rdfs:label "client_ciphers" ;
    rdfs:range xsd:string ;
    skos:altLabel "Client Cipher Suites" ;
    skos:definition "The client cipher suites that were exchanged during the TLS handshake negotiation." ;
    skos:inScheme ocsf:dictionary .

ocsf:client_dialects a owl:DatatypeProperty ;
    rdfs:label "client_dialects" ;
    rdfs:range xsd:string ;
    skos:altLabel "Client Dialects" ;
    skos:definition "The list of SMB dialects that the client speaks." ;
    skos:inScheme ocsf:dictionary .

ocsf:codes a owl:DatatypeProperty ;
    rdfs:label "codes" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Response Codes" ;
    skos:definition "The list of numeric responses sent to a request." ;
    skos:inScheme ocsf:dictionary .

ocsf:command_responses a owl:DatatypeProperty ;
    rdfs:label "command_responses" ;
    rdfs:range xsd:string ;
    skos:altLabel "Command Responses" ;
    skos:definition "The responses to the command." ;
    skos:inScheme ocsf:dictionary .

ocsf:compliance_references a owl:ObjectProperty ;
    rdfs:label "compliance_references" ;
    rdfs:range ocsf:KbArticle ;
    skos:altLabel "Compliance Standard References" ;
    skos:definition "A list of reference KB articles that provide information to help organizations understand, interpret, and implement compliance standards. They provide guidance, best practices, and examples." ;
    skos:inScheme ocsf:dictionary .

ocsf:compliance_standards a owl:ObjectProperty ;
    rdfs:label "compliance_standards" ;
    rdfs:range ocsf:KbArticle ;
    skos:altLabel "Compliance Standards: Details" ;
    skos:definition "A list of established guidelines or criteria that define specific requirements an organization must follow." ;
    skos:inScheme ocsf:dictionary .

ocsf:control_parameters a owl:ObjectProperty ;
    rdfs:label "control_parameters" ;
    rdfs:range ocsf:KeyValueObject ;
    skos:altLabel "Control Parameters" ;
    skos:definition "The list of control parameters evaluated in a Compliance check." ;
    skos:inScheme ocsf:dictionary .

ocsf:coordinates a owl:DatatypeProperty ;
    rdfs:label "coordinates" ;
    rdfs:range xsd:float ;
    skos:altLabel "Coordinates" ;
    skos:definition "A two-element array, containing a longitude/latitude pair. The format conforms with <a target='_blank' href='https://geojson.org'>GeoJSON</a>. For example: <code>[-73.983, 40.719]</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:cves a owl:ObjectProperty ;
    rdfs:label "cves" ;
    rdfs:range ocsf:Cve ;
    skos:altLabel "CVE List" ;
    skos:definition "List of Common Vulnerabilities and Exposures (<a target='_blank' href='https://cve.mitre.org/'>CVE</a>)." ;
    skos:inScheme ocsf:dictionary .

ocsf:cvss a owl:ObjectProperty ;
    rdfs:label "cvss" ;
    rdfs:range ocsf:Cvss ;
    skos:altLabel "CVSS Score" ;
    skos:definition "The CVSS object details Common Vulnerability Scoring System (<a target='_blank' href='https://www.first.org/cvss/'>CVSS</a>) scores from the advisory that are related to the vulnerability." ;
    skos:inScheme ocsf:dictionary .

ocsf:data_classifications a owl:ObjectProperty ;
    rdfs:label "data_classifications" ;
    rdfs:range ocsf:DataClassification ;
    skos:altLabel "Data Classification" ;
    skos:definition "A list of Data Classification objects, that include information about data classification levels and data category types, identified by a classifier." ;
    skos:inScheme ocsf:dictionary .

ocsf:debug a owl:DatatypeProperty ;
    rdfs:label "debug" ;
    rdfs:range xsd:string ;
    skos:altLabel "Debug Information" ;
    skos:definition "Debug information about non-fatal issues with this OCSF event. Each issue is a line in this string array." ;
    skos:inScheme ocsf:dictionary .

ocsf:delivered_to_list a owl:DatatypeProperty ;
    rdfs:label "delivered_to_list" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://www.rfc-editor.org/rfc/rfc9228> ;
    skos:altLabel "Delivered To List" ;
    skos:definition "The machine-readable <strong>Delivered-To</strong> email header values. For example <code>example.user@usersdomain.com</code>" ;
    skos:editorialNote "RFC 9228 — https://www.rfc-editor.org/rfc/rfc9228" ;
    skos:inScheme ocsf:dictionary .

ocsf:discovery_details a owl:ObjectProperty ;
    rdfs:label "discovery_details" ;
    rdfs:range ocsf:DiscoveryDetails ;
    skos:altLabel "Discovery Details" ;
    skos:definition "A collection of <code>Discovery Details</code> objects. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:domain_contacts a owl:ObjectProperty ;
    rdfs:label "domain_contacts" ;
    rdfs:range ocsf:DomainContact ;
    skos:altLabel "Domain Contacts" ;
    skos:definition "An array of <code>Domain Contact</code> objects." ;
    skos:inScheme ocsf:dictionary .

ocsf:edges a owl:ObjectProperty ;
    rdfs:label "edges" ;
    rdfs:range ocsf:Edge ;
    skos:altLabel "Edges" ;
    skos:definition "The list of edge objects that are part of the graph." ;
    skos:inScheme ocsf:dictionary .

ocsf:email_addrs a owl:DatatypeProperty ;
    rdfs:label "email_addrs" ;
    rdfs:range xsd:string ;
    skos:altLabel "Email Addresses" ;
    skos:definition "A list of additional email addresses for the user." ;
    skos:inScheme ocsf:dictionary .

ocsf:endpoint_connections a owl:ObjectProperty ;
    rdfs:label "endpoint_connections" ;
    rdfs:range ocsf:EndpointConnection ;
    skos:altLabel "Endpoint Connections" ;
    skos:definition "Contains information about network connection attempts. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:enrichments a owl:ObjectProperty ;
    rdfs:label "enrichments" ;
    rdfs:range ocsf:Enrichment ;
    skos:altLabel "Enrichments" ;
    skos:definition "The additional information from an external data source, which is associated with the event or a finding. For example add location information for the IP address in the DNS answers:</p><code>[{\"name\": \"answers.ip\", \"value\": \"92.24.47.250\", \"type\": \"location\", \"data\": {\"city\": \"Socotra\", \"continent\": \"Asia\", \"coordinates\": [-25.4153, 17.0743], \"country\": \"YE\", \"desc\": \"Yemen\"}}]</code>" ;
    skos:inScheme ocsf:dictionary .

ocsf:environment_variables a owl:ObjectProperty ;
    rdfs:label "environment_variables" ;
    rdfs:range ocsf:EnvironmentVariable ;
    skos:altLabel "Environment Variables" ;
    skos:definition "An array of environment variables." ;
    skos:inScheme ocsf:dictionary .

ocsf:extension_list a owl:ObjectProperty ;
    rdfs:label "extension_list" ;
    rdfs:range ocsf:TlsExtension ;
    skos:altLabel "Extension List" ;
    skos:definition "The list of TLS extensions." ;
    skos:inScheme ocsf:dictionary .

ocsf:finding_info_list a owl:ObjectProperty ;
    rdfs:label "finding_info_list" ;
    rdfs:range ocsf:FindingInfo ;
    skos:altLabel "Finding Information List" ;
    skos:definition "A list of <code>finding_info</code> objects associated to an incident." ;
    skos:inScheme ocsf:dictionary .

ocsf:flag_ids a owl:ObjectProperty ;
    rdfs:label "flag_ids" ;
    rdfs:range ocsf:FlagIdsEnum ;
    skos:altLabel "Communication Flag IDs" ;
    skos:definition "The list of normalized identifiers of the communication flag IDs. See specific usage." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "flags" .

ocsf:from_list a owl:DatatypeProperty ;
    rdfs:label "from_list" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://www.rfc-editor.org/rfc/rfc5322#section-3.4> ;
    skos:altLabel "From List" ;
    skos:definition "The machine-readable email header From values. This array should contain the value in <code>from</code>. For example <code>example.user@usersdomain.com</code>." ;
    skos:editorialNote "RFC 5322 — https://www.rfc-editor.org/rfc/rfc5322#section-3.4" ;
    skos:inScheme ocsf:dictionary .

ocsf:from_mailboxes a owl:DatatypeProperty ;
    rdfs:label "from_mailboxes" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://www.rfc-editor.org/rfc/rfc5322#section-3.4> ;
    skos:altLabel "From Mailboxes" ;
    skos:definition "The human-readable email header From Mailbox values. This array should contain the value in <code>from_mailbox</code>. For example <code>'Example User &lt;example.user@usersdomain.com&gt;'</code>." ;
    skos:editorialNote "RFC 5322 — https://www.rfc-editor.org/rfc/rfc5322#section-3.4" ;
    skos:inScheme ocsf:dictionary .

ocsf:gpu_info_list a owl:ObjectProperty ;
    rdfs:label "gpu_info_list" ;
    rdfs:range ocsf:GpuInfo ;
    skos:altLabel "GPU information" ;
    skos:definition "An array of objects describing describing Graphical Processing Unit hardware." ;
    skos:inScheme ocsf:dictionary .

ocsf:hosted_services a owl:ObjectProperty ;
    rdfs:label "hosted_services" ;
    rdfs:range ocsf:WinService ;
    skos:altLabel "Hosted Services" ;
    skos:definition "The Windows services that this process is hosting." ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_extension "windows" .

ocsf:http_cookies a owl:ObjectProperty ;
    rdfs:label "http_cookies" ;
    rdfs:range ocsf:HttpCookie ;
    skos:altLabel "HTTP Cookies" ;
    skos:definition "The cookies object describes details about HTTP cookies" ;
    skos:inScheme ocsf:dictionary .

ocsf:imei_list a owl:DatatypeProperty ;
    rdfs:label "imei_list" ;
    rdfs:range xsd:string ;
    skos:altLabel "IMEI List" ;
    skos:definition "The International Mobile Equipment Identity values that are associated with the device." ;
    skos:inScheme ocsf:dictionary .

ocsf:imported_symbols a owl:DatatypeProperty ;
    rdfs:label "imported_symbols" ;
    rdfs:range xsd:string ;
    skos:altLabel "Imported Symbols" ;
    skos:definition "A list of symbols imported by the executable file." ;
    skos:inScheme ocsf:dictionary .

ocsf:intermediate_ips a owl:DatatypeProperty ;
    rdfs:label "intermediate_ips" ;
    rdfs:range xsd:string ;
    skos:altLabel "Intermediate IP Addresses" ;
    skos:definition "The intermediate IP Addresses. For example, the IP addresses in the HTTP X-Forwarded-For header." ;
    skos:inScheme ocsf:dictionary .

ocsf:intrusion_sets a owl:DatatypeProperty ;
    rdfs:label "intrusion_sets" ;
    rdfs:range xsd:string ;
    skos:altLabel "Intrusion Sets" ;
    skos:definition "A grouping of adversarial behaviors and resources believed to be associated with specific threat actors or campaigns. Intrusion sets often encompass multiple campaigns and are used to organize related activities under a common label." ;
    skos:inScheme ocsf:dictionary .

ocsf:lineage a owl:DatatypeProperty ;
    rdfs:label "lineage" ;
    rdfs:range xsd:string ;
    skos:altLabel "Lineage" ;
    skos:definition "The lineage of the process, represented by a list of paths for each ancestor process. For example: <code>['/usr/sbin/sshd', '/usr/bin/bash', '/usr/bin/whoami']</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:loaded_modules a owl:DatatypeProperty ;
    rdfs:label "loaded_modules" ;
    rdfs:range xsd:string ;
    skos:altLabel "Loaded Modules" ;
    skos:definition "The list of loaded module names." ;
    skos:inScheme ocsf:dictionary .

ocsf:locations a owl:ObjectProperty ;
    rdfs:label "locations" ;
    rdfs:range ocsf:Location ;
    skos:altLabel "Geo Locations" ;
    skos:definition "A list of detailed geographical locations." ;
    skos:inScheme ocsf:dictionary .

ocsf:loggers a owl:ObjectProperty ;
    rdfs:label "loggers" ;
    rdfs:range ocsf:Logger ;
    skos:altLabel "Loggers" ;
    skos:definition "An array of Logger objects that describe the pipeline of devices and logging products between the event source and its eventual destination. Note, this attribute can be used when there is a complex end-to-end path of event flow and/or to track the chain of custody of the data." ;
    skos:inScheme ocsf:dictionary .

ocsf:match_details a owl:DatatypeProperty ;
    rdfs:label "match_details" ;
    rdfs:range xsd:string ;
    skos:altLabel "Match Details" ;
    skos:definition "The data in a request that rule matched. For example: '[\"10\",\"and\",\"1\"]'." ;
    skos:inScheme ocsf:dictionary .

ocsf:name_servers a owl:DatatypeProperty ;
    rdfs:label "name_servers" ;
    rdfs:range xsd:string ;
    skos:altLabel "Name Servers" ;
    skos:definition "A collection of name servers related to a domain registration or other record." ;
    skos:inScheme ocsf:dictionary .

ocsf:nist a owl:DatatypeProperty ;
    rdfs:label "nist" ;
    rdfs:range xsd:string ;
    skos:altLabel "NIST List" ;
    skos:definition "The NIST Cybersecurity Framework recommendations for managing the cybersecurity risk." ;
    skos:inScheme ocsf:dictionary .

ocsf:nodes a owl:ObjectProperty ;
    rdfs:label "nodes" ;
    rdfs:range ocsf:Node ;
    skos:altLabel "Nodes" ;
    skos:definition "The list of node objects that are part of the graph." ;
    skos:inScheme ocsf:dictionary .

ocsf:occurrences a owl:ObjectProperty ;
    rdfs:label "occurrences" ;
    rdfs:range ocsf:OccurrenceDetails ;
    skos:altLabel "Occurrences" ;
    skos:definition "A list of <code>occurrence_details</code> objects, each describing where in the target entity the specified information was discovered. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:open_ports a owl:ObjectProperty ;
    rdfs:label "open_ports" ;
    rdfs:range ocsf:PortInfo ;
    skos:altLabel "Open Ports" ;
    skos:definition "The list of open ports on a network interface, including port numbers and associated protocol information." ;
    skos:inScheme ocsf:dictionary .

ocsf:packages a owl:ObjectProperty ;
    rdfs:label "packages" ;
    rdfs:range ocsf:Package ;
    skos:altLabel "Software Packages" ;
    skos:definition "List of vulnerable packages as identified by the security product" ;
    skos:inScheme ocsf:dictionary .

ocsf:packet_list a owl:ObjectProperty ;
    rdfs:label "packet_list" ;
    rdfs:range ocsf:Packet ;
    skos:altLabel "Packets" ;
    skos:definition "The list of packet objects describing captured network packets." ;
    skos:inScheme ocsf:dictionary .

ocsf:parameters a owl:ObjectProperty ;
    rdfs:label "parameters" ;
    rdfs:range ocsf:Parameter ;
    skos:altLabel "Parameters" ;
    skos:definition "The parameters passed into a function invocation." ;
    skos:inScheme ocsf:dictionary .

ocsf:permission_analysis_results a owl:ObjectProperty ;
    rdfs:label "permission_analysis_results" ;
    rdfs:range ocsf:PermissionAnalysisResult ;
    skos:altLabel "Permission Analysis Results" ;
    skos:definition "Describes analysis results of permissions, policies directly associated with an identity (user, role, or service account). This evaluates what permissions an identity has been granted through attached policies, which privileges are actively used versus unused, and identifies potential over-privileged access. Use this for identity-centric security assessments such as privilege audits, dormant permission discovery, and least-privilege compliance analysis." ;
    skos:inScheme ocsf:dictionary .

ocsf:prev_security_states a owl:ObjectProperty ;
    rdfs:label "prev_security_states" ;
    rdfs:range ocsf:SecurityState ;
    skos:altLabel "Previous Security States" ;
    skos:definition "The previous security states. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:privilege_attack_info_list a owl:ObjectProperty ;
    rdfs:label "privilege_attack_info_list" ;
    rdfs:range ocsf:PrivilegeAttackInfo ;
    skos:altLabel "Privilege Attack Info List" ;
    skos:definition "A list of privilege-to-attack mappings." ;
    skos:inScheme ocsf:dictionary .

ocsf:privilege_info_list a owl:ObjectProperty ;
    rdfs:label "privilege_info_list" ;
    rdfs:range ocsf:PrivilegeInfo ;
    skos:altLabel "Privilege Info List" ;
    skos:definition "A list of privilege information objects, where each element describes a specific privilege, action, or permission with its usage status." ;
    skos:inScheme ocsf:dictionary .

ocsf:reg_string_list_data a owl:DatatypeProperty ;
    rdfs:label "reg_string_list_data" ;
    rdfs:range xsd:string ;
    skos:altLabel "Registry String List Data" ;
    skos:definition "The data of the registry value when <code>type_id</code> is <code>REG_MULTI_SZ</code>." ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_extension "windows" .

ocsf:related_cves a owl:ObjectProperty ;
    rdfs:label "related_cves" ;
    rdfs:range ocsf:Cve ;
    skos:altLabel "Related CVEs" ;
    skos:definition "Describes Common Vulnerabilities and Exposures <a target='_blank' href='https://cve.mitre.org/'>(CVE)</a> entries that are related to an entity. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:related_vulnerabilities a owl:DatatypeProperty ;
    rdfs:label "related_vulnerabilities" ;
    rdfs:range xsd:string ;
    skos:altLabel "Related Vulnerability IDs" ;
    skos:definition "List of vulnerability IDs (e.g. CVE ID) that are related to this vulnerability." ;
    skos:inScheme ocsf:dictionary .

ocsf:reply_to_list a owl:DatatypeProperty ;
    rdfs:label "reply_to_list" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://www.rfc-editor.org/rfc/rfc5322> ;
    skos:altLabel "Reply To List" ;
    skos:definition "The machine-readable email header Reply-To values, as defined by RFC 5322. For example <code>example.user@usersdomain.com</code>" ;
    skos:editorialNote "RFC 5322 — https://www.rfc-editor.org/rfc/rfc5322" ;
    skos:inScheme ocsf:dictionary .

ocsf:reply_to_mailboxes a owl:DatatypeProperty ;
    rdfs:label "reply_to_mailboxes" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://www.rfc-editor.org/rfc/rfc5322#section-3.4> ;
    skos:altLabel "Reply To Mailboxes" ;
    skos:definition "The human-readable email header Reply To Mailbox values. For example <code>'Example User &lt;example.user@usersdomain.com&gt;'</code>." ;
    skos:editorialNote "RFC 5322 — https://www.rfc-editor.org/rfc/rfc5322#section-3.4" ;
    skos:inScheme ocsf:dictionary .

ocsf:requirements a owl:DatatypeProperty ;
    rdfs:label "requirements" ;
    rdfs:range xsd:string ;
    skos:altLabel "Compliance Requirements" ;
    skos:definition "A list of requirements associated to a specific control in an industry or regulatory framework. e.g. <code>NIST.800-53.r5 AU-10</code>" ;
    skos:inScheme ocsf:dictionary .

ocsf:run_mode_ids a owl:ObjectProperty ;
    rdfs:label "run_mode_ids" ;
    rdfs:range ocsf:RunModeIdsEnum ;
    skos:altLabel "Run Mode IDs" ;
    skos:definition "The list of normalized identifiers that describe application attributes when it is running. See specific usage." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "run_modes" .

ocsf:run_modes a owl:DatatypeProperty ;
    rdfs:label "run_modes" ;
    rdfs:range xsd:string ;
    skos:altLabel "Run Modes" ;
    skos:definition "The list of run_modes, normalized to the captions of the run_mode_ids values.  In the case of 'Other', they are defined by the event source. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:scopes a owl:DatatypeProperty ;
    rdfs:label "scopes" ;
    rdfs:range xsd:string ;
    skos:altLabel "Scopes" ;
    skos:definition "Scopes define the specific permissions or actions that the client is allowed to perform on behalf of the user. Each scope represents a different set of permissions, and the user can selectively grant or deny access to specific scopes during the authorization process." ;
    skos:inScheme ocsf:dictionary .

ocsf:security_questions a owl:DatatypeProperty ;
    rdfs:label "security_questions" ;
    rdfs:range xsd:string ;
    skos:altLabel "Security Questions" ;
    skos:definition "The question(s) provided to user for a question-based authentication factor." ;
    skos:inScheme ocsf:dictionary .

ocsf:security_states a owl:ObjectProperty ;
    rdfs:label "security_states" ;
    rdfs:range ocsf:SecurityState ;
    skos:altLabel "Security States" ;
    skos:definition "The current security states. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:server_ciphers a owl:DatatypeProperty ;
    rdfs:label "server_ciphers" ;
    rdfs:range xsd:string ;
    skos:altLabel "Server Cipher Suites" ;
    skos:definition "The server cipher suites that were exchanged during the TLS handshake negotiation." ;
    skos:inScheme ocsf:dictionary .

ocsf:service_dependencies a owl:DatatypeProperty ;
    rdfs:label "service_dependencies" ;
    rdfs:range xsd:string ;
    skos:altLabel "Service Dependencies" ;
    skos:definition "The names of other services upon which this service has a dependency." ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_extension "windows" .

ocsf:service_privilege_analysis_list a owl:ObjectProperty ;
    rdfs:label "service_privilege_analysis_list" ;
    rdfs:range ocsf:ServicePrivilegeAnalysis ;
    skos:altLabel "Service Privilege Analysis List" ;
    skos:definition "A list of privilege analysis results grouped by cloud service or namespace." ;
    skos:inScheme ocsf:dictionary .

ocsf:smtp_to a owl:DatatypeProperty ;
    rdfs:label "smtp_to" ;
    rdfs:range xsd:string ;
    skos:altLabel "SMTP To" ;
    skos:definition "The value of the SMTP envelope RCPT TO command." ;
    skos:inScheme ocsf:dictionary .

ocsf:software_components a owl:ObjectProperty ;
    rdfs:label "software_components" ;
    rdfs:range ocsf:SoftwareComponent ;
    skos:altLabel "Software Components" ;
    skos:definition "The list of software components used in the software package." ;
    skos:inScheme ocsf:dictionary .

ocsf:tactics a owl:ObjectProperty ;
    rdfs:label "tactics" ;
    rdfs:range ocsf:Tactic ;
    skos:altLabel "Tactics" ;
    skos:definition "The Tactic object describes the tactic ID and/or tactic name that are associated with the attack technique, as defined by <a target='_blank' href='https://attack.mitre.org/wiki/ATT&CK_Matrix'>ATT&CK® Matrix</a>." ;
    skos:inScheme ocsf:dictionary .

ocsf:tls_extension_list a owl:ObjectProperty ;
    rdfs:label "tls_extension_list" ;
    rdfs:range ocsf:TlsExtension ;
    skos:altLabel "TLS Extension List" ;
    skos:definition "The list of TLS extensions." ;
    skos:inScheme ocsf:dictionary .

ocsf:to_mailboxes a owl:DatatypeProperty ;
    rdfs:label "to_mailboxes" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://www.rfc-editor.org/rfc/rfc5322#section-3.4> ;
    skos:altLabel "To Mailboxes" ;
    skos:definition "The human-readable email header To Mailbox values. For example <code>'Example User &lt;example.user@usersdomain.com&gt;'</code>." ;
    skos:editorialNote "RFC 5322 — https://www.rfc-editor.org/rfc/rfc5322#section-3.4" ;
    skos:inScheme ocsf:dictionary .

ocsf:transformation_info_list a owl:ObjectProperty ;
    rdfs:label "transformation_info_list" ;
    rdfs:range ocsf:TransformationInfo ;
    skos:altLabel "Transformation Info" ;
    skos:definition "An array of transformation info that describes the mappings or transforms applied to the data." ;
    skos:inScheme ocsf:dictionary .

ocsf:urls a owl:ObjectProperty ;
    rdfs:label "urls" ;
    rdfs:range ocsf:Url ;
    skos:altLabel "URLs" ;
    skos:definition "The URLs that pertain to the event or object." ;
    skos:inScheme ocsf:dictionary .

ocsf:vendor_id_list a owl:DatatypeProperty ;
    rdfs:label "vendor_id_list" ;
    rdfs:range xsd:string ;
    skos:altLabel "Vendor ID List" ;
    skos:definition "The list of vendor IDs. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:web_resources_result a owl:ObjectProperty ;
    rdfs:label "web_resources_result" ;
    rdfs:range ocsf:WebResource ;
    skos:altLabel "Web Resources Result" ;
    skos:definition "The results of the activity on web resources. It should contain the new values of the changed attributes of the web resources." ;
    skos:inScheme ocsf:dictionary .

ocsf:x_forwarded_for a owl:DatatypeProperty ;
    rdfs:label "x_forwarded_for" ;
    rdfs:range xsd:string ;
    skos:altLabel "X-Forwarded-For" ;
    skos:definition "The X-Forwarded-For header identifying the originating IP address(es) of a client connecting to a web server through an HTTP proxy or a load balancer." ;
    skos:inScheme ocsf:dictionary .

ocsf:x_originating_ip a owl:DatatypeProperty ;
    rdfs:label "x_originating_ip" ;
    rdfs:range xsd:string ;
    skos:altLabel "X-Originating-IP" ;
    skos:definition "The X-Originating-IP header identifying the emails originating IP address(es)." ;
    skos:inScheme ocsf:dictionary .

ocsf:Account a owl:Class ;
    rdfs:label "Account" ;
    rdfs:seeAlso <https://d3fend.mitre.org/dao/artifact/d3f:CloudUserAccount/>,
        <https://d3fend.mitre.org/dao/artifact/d3f:UserAccount/> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:KeyValueObject ;
            owl:onProperty ocsf:tags ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:is_locked ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty ocsf:is_on_premises_sync_enabled ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:is_on_premises_sync_enabled ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty ocsf:is_locked ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty ocsf:is_disabled ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:type_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:labels ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:is_on_premises_sync_enabled ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:tags ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:is_locked ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:labels ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:is_disabled ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:is_disabled ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:type_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:AccountTypeIdEnum ;
            owl:onProperty ocsf:type_id ],
        ocsf:Entity ;
    skos:altLabel "Account" ;
    skos:closeMatch stix:UserAccount,
        uco_master:Account ;
    skos:definition "The Account object contains details about the account that initiated or performed a specific activity within a system or application. Additionally, the Account object refers to logical Cloud and Software-as-a-Service (SaaS) based containers such as AWS Accounts, Azure Subscriptions, Oracle Cloud Compartments, Google Cloud Projects, and otherwise." ;
    skos:editorialNote "D3FEND™ Ontology d3f:CloudUserAccount. — https://d3fend.mitre.org/dao/artifact/d3f:CloudUserAccount/",
        "D3FEND™ Ontology d3f:UserAccount. — https://d3fend.mitre.org/dao/artifact/d3f:UserAccount/" ;
    skos:inScheme ocsf:objects .

ocsf:ActivityIdEnum a owl:Class ;
    rdfs:label "ActivityIdEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/ocsf/ActivityIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/ActivityIdEnum#OTHER> ) ;
    skos:definition "The normalized identifier of the activity that triggered the event." ;
    skos:inScheme ocsf:enums ;
    linkml:permissible_values <https://w3id.org/lmodel/ocsf/ActivityIdEnum#OTHER>,
        <https://w3id.org/lmodel/ocsf/ActivityIdEnum#UNKNOWN> .

ocsf:AiOperationProfile a owl:Class ;
    rdfs:label "AiOperationProfile" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:ai_model ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:MessageContext ;
            owl:onProperty ocsf:message_context ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:ai_model ],
        [ a owl:Restriction ;

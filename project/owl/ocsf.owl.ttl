<https://w3id.org/lmodel/ocsf/AnalyticStateIdEnum#SUPPRESSED> a owl:Class ;
    rdfs:label "SUPPRESSED" ;
    rdfs:subClassOf ocsf:AnalyticStateIdEnum ;
    skos:definition "The Analytic is suppressed. For example, a user/customer has suppressed a particular detection signature in a security product." ;
    ocsf:caption "Suppressed" ;
    ocsf:ocsf_uid "2" .

<https://w3id.org/lmodel/ocsf/AnalyticStateIdEnum#UNKNOWN> a owl:Class ;
    rdfs:label "UNKNOWN" ;
    rdfs:subClassOf ocsf:AnalyticStateIdEnum ;
    skos:definition "The state is unknown." ;
    ocsf:caption "Unknown" ;
    ocsf:ocsf_uid "0" .

<https://w3id.org/lmodel/ocsf/AnalyticTypeIdEnum#BEHAVIORAL> a owl:Class ;
    rdfs:label "BEHAVIORAL" ;
    rdfs:subClassOf ocsf:AnalyticTypeIdEnum ;
    skos:definition "Behavioral analytics focus on monitoring and analyzing user or system actions to identify deviations from established patterns, aiding in the detection of insider threats, fraud, and advanced persistent threats (APTs)." ;
    ocsf:caption "Behavioral" ;
    ocsf:ocsf_uid "2" .

<https://w3id.org/lmodel/ocsf/AnalyticTypeIdEnum#EXACT_DATA_MATCH> a owl:Class ;
    rdfs:label "EXACT_DATA_MATCH" ;
    rdfs:subClassOf ocsf:AnalyticTypeIdEnum ;
    skos:definition "Exact Data Match is a precise comparison technique used to detect the unauthorized use or exposure of specific, sensitive information, crucial for enforcing DLP policies and protecting against data breaches." ;
    ocsf:caption "Exact Data Match" ;
    ocsf:ocsf_uid "9" .

<https://w3id.org/lmodel/ocsf/AnalyticTypeIdEnum#FINGERPRINTING> a owl:Class ;
    rdfs:label "FINGERPRINTING" ;
    rdfs:subClassOf ocsf:AnalyticTypeIdEnum ;
    skos:definition "Fingerprinting is the technique of collecting detailed system data, including software versions and configurations, to enhance threat detection, data loss prevention (DLP), and endpoint detection and response (EDR) capabilities." ;
    ocsf:caption "Fingerprinting" ;
    ocsf:ocsf_uid "5" .

<https://w3id.org/lmodel/ocsf/AnalyticTypeIdEnum#INDEXED_DATA_MATCH> a owl:Class ;
    rdfs:label "INDEXED_DATA_MATCH" ;
    rdfs:subClassOf ocsf:AnalyticTypeIdEnum ;
    skos:definition "Indexed Data Match refers to comparing content against a pre-compiled index of sensitive information to efficiently detect and prevent unauthorized access or breaches, streamlining DLP and compliance efforts." ;
    ocsf:caption "Indexed Data Match" ;
    ocsf:ocsf_uid "11" .

<https://w3id.org/lmodel/ocsf/AnalyticTypeIdEnum#KEYWORD_MATCH> a owl:Class ;
    rdfs:label "KEYWORD_MATCH" ;
    rdfs:subClassOf ocsf:AnalyticTypeIdEnum ;
    skos:definition "Keyword Match involves scanning content for specific terms to identify sensitive information, potential threats, or policy violations, aiding in DLP and compliance monitoring." ;
    ocsf:caption "Keyword Match" ;
    ocsf:ocsf_uid "7" .

<https://w3id.org/lmodel/ocsf/AnalyticTypeIdEnum#LEARNING_ML_DL> a owl:Class ;
    rdfs:label "LEARNING_ML_DL" ;
    rdfs:subClassOf ocsf:AnalyticTypeIdEnum ;
    skos:definition "Learning (ML/DL) encompasses techniques that can \"learn\" from known data to create analytics that generalize to new data. There may be a statistical component to these techniques, but it is not a requirement." ;
    ocsf:caption "Learning (ML/DL)" ;
    ocsf:ocsf_uid "4" .

<https://w3id.org/lmodel/ocsf/AnalyticTypeIdEnum#OTHER> a owl:Class ;
    rdfs:label "OTHER" ;
    rdfs:subClassOf ocsf:AnalyticTypeIdEnum ;
    skos:definition "Other" ;
    ocsf:caption "Other" ;
    ocsf:ocsf_uid "99" .

<https://w3id.org/lmodel/ocsf/AnalyticTypeIdEnum#PARTIAL_DATA_MATCH> a owl:Class ;
    rdfs:label "PARTIAL_DATA_MATCH" ;
    rdfs:subClassOf ocsf:AnalyticTypeIdEnum ;
    skos:definition "Partial Data Match involves identifying instances where segments of sensitive information or patterns match, facilitating nuanced DLP and threat detection without requiring complete data conformity." ;
    ocsf:caption "Partial Data Match" ;
    ocsf:ocsf_uid "10" .

<https://w3id.org/lmodel/ocsf/AnalyticTypeIdEnum#REGULAR_EXPRESSIONS> a owl:Class ;
    rdfs:label "REGULAR_EXPRESSIONS" ;
    rdfs:subClassOf ocsf:AnalyticTypeIdEnum ;
    skos:definition "Regular Expressions are used to define complex search patterns for identifying, validating, and extracting specific data sets or threats within digital content, enhancing DLP, EDR, and threat detection mechanisms." ;
    ocsf:caption "Regular Expressions" ;
    ocsf:ocsf_uid "8" .

<https://w3id.org/lmodel/ocsf/AnalyticTypeIdEnum#RULE> a owl:Class ;
    rdfs:label "RULE" ;
    rdfs:subClassOf ocsf:AnalyticTypeIdEnum ;
    skos:definition "A Rule in security analytics refers to predefined criteria or conditions set to monitor, alert, or enforce policies, playing a crucial role in access control, threat detection, and regulatory compliance across security systems." ;
    ocsf:caption "Rule" ;
    ocsf:ocsf_uid "1" .

<https://w3id.org/lmodel/ocsf/AnalyticTypeIdEnum#STATISTICAL> a owl:Class ;
    rdfs:label "STATISTICAL" ;
    rdfs:subClassOf ocsf:AnalyticTypeIdEnum ;
    skos:definition "Statistical analytics pertains to analyzing data patterns and anomalies using statistical models to predict, detect, and respond to potential threats, enhancing overall security posture through informed decision-making." ;
    ocsf:caption "Statistical" ;
    ocsf:ocsf_uid "3" .

<https://w3id.org/lmodel/ocsf/AnalyticTypeIdEnum#TAGGING> a owl:Class ;
    rdfs:label "TAGGING" ;
    rdfs:subClassOf ocsf:AnalyticTypeIdEnum ;
    skos:definition "Tagging refers to the practice of assigning labels or identifiers to data, users, assets, or activities to monitor, control access, and facilitate incident response across various security domains such as DLP and EDR." ;
    ocsf:caption "Tagging" ;
    ocsf:ocsf_uid "6" .

<https://w3id.org/lmodel/ocsf/AnalyticTypeIdEnum#UNKNOWN> a owl:Class ;
    rdfs:label "UNKNOWN" ;
    rdfs:subClassOf ocsf:AnalyticTypeIdEnum ;
    skos:definition "Unknown" ;
    ocsf:caption "Unknown" ;
    ocsf:ocsf_uid "0" .

ocsf:Anomaly a owl:Class ;
    rdfs:label "Anomaly" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:observed_pattern ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:observation_parameter ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:observed_pattern ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:observation_parameter ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:observed_pattern ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:observation_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:observation_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:observation_type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:observation_parameter ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Observation ;
            owl:onProperty ocsf:observations ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:observations ],
        ocsf:Object ;
    skos:altLabel "Anomaly" ;
    skos:definition "Describes an anomaly or deviation detected in a system. Anomalies are unexpected activity patterns that could indicate potential issues needing attention." ;
    skos:inScheme ocsf:objects .

ocsf:AnomalyAnalysis a owl:Class ;
    rdfs:label "AnomalyAnalysis" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:anomalies ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Anomaly ;
            owl:onProperty ocsf:anomalies ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:baselines ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:AnalysisTarget ;
            owl:onProperty ocsf:analysis_targets ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:analysis_targets ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Baseline ;
            owl:onProperty ocsf:baselines ],
        ocsf:OcsfObject ;
    skos:altLabel "Anomaly Analysis" ;
    skos:definition "Describes the analysis of activity patterns and anomalies of target entities to identify potential security threats, performance issues, or other deviations from established baselines. This includes monitoring and analyzing user interactions, API usage, resource utilization, access patterns and other measured indicators." ;
    skos:inScheme ocsf:objects .


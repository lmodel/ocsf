    rdfs:label "LISTEN" ;
    rdfs:subClassOf ocsf:TcpStateIdEnum ;
    skos:definition "The socket is listening for incoming connections." ;
    ocsf:caption "LISTEN" ;
    ocsf:ocsf_uid "10" .


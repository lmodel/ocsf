            owl:maxCardinality 1 ;
            owl:onProperty ocsf:user ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:user ],
        ocsf:DiscoveryEvent ;
    skos:altLabel "User Inventory Info" ;
    skos:definition "User Inventory Info events report user inventory data that is either logged or proactively collected. For example, when collecting user information from Active Directory entries." ;
    skos:inScheme ocsf:events ;
    ocsf:ocsf_event_uid 3 .

ocsf:UserQuery a owl:Class ;
    rdfs:label "UserQuery" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ocsf:User ;
            owl:onProperty ocsf:user ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:user ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:user ],
        ocsf:DiscoveryResult ;
    skos:altLabel "User Query" ;
    skos:definition "User Query events report user data that have been discovered, queried, polled or searched. This event differs from User Inventory as it describes the result of a targeted search by filtering a subset of user attributes." ;
    skos:inScheme ocsf:events ;
    ocsf:ocsf_event_uid 18 .

ocsf:VulnerabilityFinding a owl:Class ;
    rdfs:label "VulnerabilityFinding" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:resources ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:resource ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:vulnerabilities ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:ResourceDetails ;
            owl:onProperty ocsf:resources ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:resource ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:ResourceDetails ;
            owl:onProperty ocsf:resource ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Vulnerability ;
            owl:onProperty ocsf:vulnerabilities ],
        ocsf:Finding ;
    skos:altLabel "Vulnerability Finding" ;
    skos:closeMatch cve:CVERecord,
        iso27001:Risk,
        kev_catalog:KevEntry,
        nvd:NVDEntry,
        core:Vulnerability ;
    skos:definition "The Vulnerability Finding event is a notification about weakness in an information system, system security procedures, internal controls, or implementation that could be exploited or triggered by a threat source. Note: if the event producer is a security control, the <code>security_control</code> profile should be applied and its <code>attacks</code> information, if present, should be duplicated into the <code>finding_info</code> object. <br><strong>Note: </strong>If the Finding is an incident, i.e. requires incident workflow, also apply the <code>incident</code> profile  or aggregate this finding into an <code>Incident Finding</code>." ;
    skos:inScheme ocsf:events ;
    skos:relatedMatch capec:AttackPattern,
        cwe:Weakness ;
    ocsf:ocsf_event_uid 2 .

ocsf:WebResourceAccessActivity a owl:Class ;
    rdfs:label "WebResourceAccessActivity" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ocsf:HttpRequest ;
            owl:onProperty ocsf:http_request ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:web_resources ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:HttpResponse ;
            owl:onProperty ocsf:http_response ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:http_request ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:proxy ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:WebResourceAccessActivityActivityIdEnum ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:NetworkEndpoint ;
            owl:onProperty ocsf:src_endpoint ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:WebResource ;
            owl:onProperty ocsf:web_resources ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:tls ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:proxy ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:http_response ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:http_response ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:src_endpoint ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:tls ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:http_request ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Tls ;
            owl:onProperty ocsf:tls ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:NetworkProxy ;
            owl:onProperty ocsf:proxy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:src_endpoint ],
        ocsf:ApplicationEvent,
        ocsf:NetworkProxyProfile ;
    skos:altLabel "Web Resource Access Activity" ;
    skos:definition "Web Resource Access Activity events describe successful/failed attempts to access a web resource over HTTP." ;
    skos:inScheme ocsf:events ;
    ocsf:ocsf_event_uid 4 .

ocsf:WebResourcesActivity a owl:Class ;
    rdfs:label "WebResourcesActivity" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ocsf:WebResource ;
            owl:onProperty ocsf:web_resources_result ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:NetworkEndpoint ;
            owl:onProperty ocsf:src_endpoint ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Tls ;
            owl:onProperty ocsf:tls ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:dst_endpoint ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:NetworkEndpoint ;
            owl:onProperty ocsf:dst_endpoint ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:WebResource ;
            owl:onProperty ocsf:web_resources ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:WebResourcesActivityActivityIdEnum ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:http_request ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:HttpRequest ;
            owl:onProperty ocsf:http_request ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:src_endpoint ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:HttpResponse ;
            owl:onProperty ocsf:http_response ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:tls ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:src_endpoint ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:web_resources_result ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:tls ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:dst_endpoint ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:web_resources ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:http_response ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:http_request ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:http_response ],
        ocsf:ApplicationEvent,
        ocsf:NetworkProxyProfile ;
    skos:altLabel "Web Resources Activity" ;
    skos:definition "Web Resources Activity events describe actions executed on a set of Web Resources." ;
    skos:inScheme ocsf:events ;
    ocsf:ocsf_event_uid 1 .

ocsf:WindowsEvidences a owl:Class ;
    rdfs:label "WindowsEvidences" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:reg_key ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:reg_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:reg_key ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:win_service ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:WinService ;
            owl:onProperty ocsf:win_service ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:RegKey ;
            owl:onProperty ocsf:reg_key ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:RegValue ;
            owl:onProperty ocsf:reg_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:win_service ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:reg_value ],
        ocsf:Evidences ;
    skos:altLabel "Windows Evidence Artifacts" ;
    skos:definition "Extends the evidences object to add Windows specific fields" ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_constraints "{\"at_least_one\": [\"actor\", \"api\", \"connection_info\", \"data\", \"database\", \"databucket\", \"device\", \"dst_endpoint\", \"email\", \"file\", \"process\", \"query\", \"src_endpoint\", \"url\", \"user\", \"job\", \"script\", \"reg_key\", \"reg_value\", \"win_service\"]}" ;
    ocsf:ocsf_extension "windows" .

ocsf:WindowsProcess a owl:Class ;
    rdfs:label "WindowsProcess" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ocsf:WinService ;
            owl:onProperty ocsf:hosted_services ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:hosted_services ],
        ocsf:Process ;
    skos:altLabel "Process" ;
    skos:definition "Extends the process object to add Windows specific fields." ;
    skos:exactMatch uco_master:WindowsProcess ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_constraints "{\"at_least_one\": [\"pid\", \"uid\", \"cpid\"]}" ;
    ocsf:ocsf_extension "windows" .

ocsf:WindowsQueryEvidence a owl:Class ;
    rdfs:label "WindowsQueryEvidence" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:reg_key ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:RegKey ;
            owl:onProperty ocsf:reg_key ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:reg_key ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:RegValue ;
            owl:onProperty ocsf:reg_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:reg_value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:reg_value ],
        ocsf:QueryEvidence ;
    skos:altLabel "Query Evidence" ;
    skos:definition "The resulting evidence information that was queried." ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_constraints "{\"just_one\": [\"connection_info\", \"file\", \"folder\", \"group\", \"job\", \"kernel\", \"module\", \"network_interfaces\", \"peripheral_device\", \"process\", \"reg_key\", \"reg_value\", \"service\", \"session\", \"startup_item\", \"user\"]}" ;
    ocsf:ocsf_extension "windows" .

ocsf:WindowsResourceActivity a owl:Class ;
    rdfs:label "WindowsResourceActivity" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ocsf:WindowsResourceActivityActivityIdEnum ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:WinResource ;
            owl:onProperty ocsf:win_resource ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:win_resource ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:win_resource ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:activity_id ],
        ocsf:SystemEvent ;
    skos:altLabel "Windows Resource Activity" ;
    skos:definition "Windows Resource Activity events report when a process accesses a Windows managed resource object, successful or otherwise." ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_event_uid 3 ;
    ocsf:ocsf_extension "windows" .

ocsf:WindowsServiceActivity a owl:Class ;
    rdfs:label "WindowsServiceActivity" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:win_service ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:win_service ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:WinService ;
            owl:onProperty ocsf:win_service ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:WindowsServiceActivityActivityIdEnum ;
            owl:onProperty ocsf:activity_id ],
        ocsf:SystemEvent ;
    skos:altLabel "Windows Service Activity" ;
    skos:definition "Windows Service Activity events report when a process interacts with the Service Control Manager." ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_event_uid 4 ;
    ocsf:ocsf_extension "windows" .

ocsf:WindowsStartupItem a owl:Class ;
    rdfs:label "WindowsStartupItem" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:win_service ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:WinService ;
            owl:onProperty ocsf:win_service ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:win_service ],
        ocsf:StartupItem ;
    skos:altLabel "Startup Item" ;
    skos:definition "The startup item object describes an application component that has associated startup criteria and configurations." ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_constraints "{\"just_one\": [\"driver\", \"job\", \"process\", \"win_service\"]}" ;
    ocsf:ocsf_extension "windows" .

ocsf:agent a owl:ObjectProperty ;
    rdfs:label "agent" ;
    rdfs:range ocsf:Agent ;
    skos:altLabel "Agent" ;
    skos:definition "An Agent (also known as a Sensor) is typically installed on an Operating System (OS) and serves as a specialized software component that can be designed to monitor, detect, collect, archive, or take action. These activities and possible actions are defined by the upstream system controlling the Agent and its intended purpose. For instance, an Agent can include Endpoint Detection & Response (EDR) agents, backup/disaster recovery sensors, Application Performance Monitoring or profiling sensors, and similar software." ;
    skos:inScheme ocsf:dictionary .

ocsf:assessment a owl:ObjectProperty ;
    rdfs:label "assessment" ;
    rdfs:range ocsf:Assessment ;
    skos:altLabel "Assessment" ;
    skos:definition "The Assessment object describes a point-in-time assessment, check, or evaluation of a specific configuration or signal against an asset, entity, person, or otherwise. For example, this can encapsulate <code>os_signals</code> from CrowdStrike Falcon Zero Trust Assessments, or account for <code>Datastore</code> configurations from Cyera." ;
    skos:inScheme ocsf:dictionary .

ocsf:cis_benchmark a owl:ObjectProperty ;
    rdfs:label "cis_benchmark" ;
    rdfs:range ocsf:CisBenchmark ;
    skos:altLabel "CIS Benchmark" ;
    skos:definition "The CIS Benchmark describes best practices for securely configuring IT systems, software, networks, and cloud infrastructure as defined by the Center for Internet Security (<a target='_blank' href='https://www.cisecurity.org/cis-benchmarks/'>CIS</a>)." ;
    skos:inScheme ocsf:dictionary .

ocsf:customer_uid a owl:DatatypeProperty ;
    rdfs:label "customer_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "Customer UID" ;
    skos:definition "The unique customer identifier." ;
    skos:inScheme ocsf:dictionary .

ocsf:detection_uid a owl:DatatypeProperty ;
    rdfs:label "detection_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "Detection UID" ;
    skos:definition "The associated unique detection event identifier. For example: detection response events include the <b>Detection ID</b> of the original event." ;
    skos:inScheme ocsf:dictionary .

ocsf:devices a owl:ObjectProperty ;
    rdfs:label "devices" ;
    rdfs:range ocsf:Device ;
    skos:altLabel "Devices" ;
    skos:definition "The object describes details related to the list of devices." ;
    skos:inScheme ocsf:dictionary .

ocsf:domain_contact a owl:ObjectProperty ;
    rdfs:label "domain_contact" ;
    rdfs:range ocsf:DomainContact ;
    skos:altLabel "Domain Contact" ;
    skos:definition "The contact information related to a domain registration, e.g., registrant, administrator, abuse, billing, or technical contact." ;
    skos:inScheme ocsf:dictionary .

ocsf:graph a owl:ObjectProperty ;
    rdfs:label "graph" ;
    rdfs:range ocsf:Graph ;
    skos:altLabel "Graph" ;
    skos:definition "A graph data structure representation with nodes and edges." ;
    skos:inScheme ocsf:dictionary .

ocsf:group_name a owl:DatatypeProperty ;
    rdfs:label "group_name" ;
    rdfs:range xsd:string ;
    skos:altLabel "Group Name" ;
    skos:definition "The name of the group that the resource belongs to." ;
    skos:inScheme ocsf:dictionary .

ocsf:num_violations a owl:DatatypeProperty ;
    rdfs:label "num_violations" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Violations" ;
    skos:definition "The number of times the policy or rule was violated." ;
    skos:inScheme ocsf:dictionary .

ocsf:packet a owl:ObjectProperty ;
    rdfs:label "packet" ;
    rdfs:range ocsf:Packet ;
    skos:altLabel "Packet" ;
    skos:definition "The packet object describes a single captured network packet and its associated metadata." ;
    skos:inScheme ocsf:dictionary .

ocsf:permission a owl:DatatypeProperty ;
    rdfs:label "permission" ;
    rdfs:range xsd:string ;
    skos:altLabel "Permission" ;
    skos:definition "The IAM permission related to an event" ;
    skos:inScheme ocsf:dictionary .

ocsf:phones a owl:DatatypeProperty ;
    rdfs:label "phones" ;
    rdfs:range xsd:string ;
    skos:altLabel "Phones" ;
    skos:definition "The phone numbers associated with the user" ;
    skos:inScheme ocsf:dictionary .

ocsf:privilege_attack_info a owl:ObjectProperty ;
    rdfs:label "privilege_attack_info" ;
    rdfs:range ocsf:PrivilegeAttackInfo ;
    skos:altLabel "Privilege Attack Info" ;
    skos:definition "Information about privileges grouped by the potential attack they could enable." ;
    skos:inScheme ocsf:dictionary .

ocsf:privilege_info a owl:ObjectProperty ;
    rdfs:label "privilege_info" ;
    rdfs:range ocsf:PrivilegeInfo ;
    skos:altLabel "Privilege Info" ;
    skos:definition "Information about a specific privilege, action, or permission." ;
    skos:inScheme ocsf:dictionary .

ocsf:resources_result a owl:ObjectProperty ;
    rdfs:label "resources_result" ;
    rdfs:range ocsf:ResourceDetails ;
    skos:altLabel "Resource Results Array" ;
    skos:definition "Updated resources after an activity/event." ;
    skos:inScheme ocsf:dictionary .

ocsf:service_privilege_analysis a owl:ObjectProperty ;
    rdfs:label "service_privilege_analysis" ;
    rdfs:range ocsf:ServicePrivilegeAnalysis ;
    skos:altLabel "Service Privilege Analysis" ;
    skos:definition "Privilege analysis results for a single cloud service or resource namespace." ;
    skos:inScheme ocsf:dictionary .

ocsf:vulnerability a owl:ObjectProperty ;
    rdfs:label "vulnerability" ;
    rdfs:range ocsf:Vulnerability ;
    skos:altLabel "Vulnerability" ;
    skos:definition "The vulnerability object describes details related to the observed vulnerability" ;
    skos:inScheme ocsf:dictionary .

<https://w3id.org/lmodel/ocsf/BaseEventCategoryUidEnum#UNCATEGORIZED> a owl:Class ;
    rdfs:label "UNCATEGORIZED" ;
    rdfs:subClassOf ocsf:BaseEventCategoryUidEnum ;
    skos:definition "Uncategorized" ;
    ocsf:caption "Uncategorized" ;
    ocsf:ocsf_uid "0" .

<https://w3id.org/lmodel/ocsf/BaseEventClassUidEnum#BASE_EVENT> a owl:Class ;
    rdfs:label "BASE_EVENT" ;
    rdfs:subClassOf ocsf:BaseEventClassUidEnum ;
    skos:definition "Base Event" ;
    ocsf:caption "Base Event" ;
    ocsf:ocsf_uid "0" .

ocsf:CisBenchmark a owl:Class ;
    rdfs:label "CisBenchmark" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:desc ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:desc ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:desc ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:cis_controls ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:CisControl ;
            owl:onProperty ocsf:cis_controls ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:name ],
        ocsf:Object ;
    skos:altLabel "CIS Benchmark" ;
    skos:definition "The CIS Benchmark object describes best practices for securely configuring IT systems, software, networks, and cloud infrastructure as defined by the <a target='_blank' href='https://www.cisecurity.org/cis-benchmarks/'>Center for Internet Security</a>. See also <a target='_blank' href='https://www.cisecurity.org/insights/blog/getting-to-know-the-cis-benchmarks'>Getting to Know the CIS Benchmarks</a>." ;
    skos:inScheme ocsf:objects .

ocsf:DatetimeProfile a owl:Class ;
    rdfs:label "DatetimeProfile" ;
    skos:altLabel "Date/Time" ;
    skos:definition "This profile defines date/time attributes as defined in RFC-3339. For example 1985-04-12T23:20:50.52Z." ;
    skos:inScheme ocsf:profiles ;
    ocsf:ocsf_profile "datetime" .

ocsf:HostProfile a owl:Class ;
    rdfs:label "HostProfile" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:actor ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:device ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:actor ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Device ;
            owl:onProperty ocsf:device ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:device ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Actor ;
            owl:onProperty ocsf:actor ] ;
    skos:altLabel "Host" ;
    skos:definition "The attributes that identify host/device attributes." ;
    skos:inScheme ocsf:profiles ;
    ocsf:group "primary" ;
    ocsf:ocsf_profile "host" .

ocsf:LinuxUsersProfile a owl:Class ;
    rdfs:label "LinuxUsersProfile" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ocsf:egid ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Group ;
            owl:onProperty ocsf:group ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:group ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:euid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:auid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:egid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ocsf:euid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:auid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:group ],

        <https://w3id.org/lmodel/ocsf/DigitalSignatureAlgorithmIdEnum#RSA>,
        <https://w3id.org/lmodel/ocsf/DigitalSignatureAlgorithmIdEnum#UNKNOWN> .

ocsf:EmailActivityDirectionIdEnum a owl:Class ;
    rdfs:label "EmailActivityDirectionIdEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/ocsf/EmailActivityDirectionIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/EmailActivityDirectionIdEnum#INBOUND> <https://w3id.org/lmodel/ocsf/EmailActivityDirectionIdEnum#OUTBOUND> <https://w3id.org/lmodel/ocsf/EmailActivityDirectionIdEnum#INTERNAL> <https://w3id.org/lmodel/ocsf/EmailActivityDirectionIdEnum#OTHER> <https://w3id.org/lmodel/ocsf/EmailActivityDirectionIdEnum#LOCAL> ) ;
    skos:definition "<p>The direction of the email relative to the scanning host or organization.</p>Email scanned at an internet gateway might be characterized as inbound to the organization from the Internet, outbound from the organization to the Internet, or internal within the organization. Email scanned at a workstation might be characterized as inbound to, or outbound from the workstation." ;
    skos:inScheme ocsf:enums ;
    linkml:permissible_values <https://w3id.org/lmodel/ocsf/EmailActivityDirectionIdEnum#INBOUND>,
        <https://w3id.org/lmodel/ocsf/EmailActivityDirectionIdEnum#INTERNAL>,
        <https://w3id.org/lmodel/ocsf/EmailActivityDirectionIdEnum#LOCAL>,
        <https://w3id.org/lmodel/ocsf/EmailActivityDirectionIdEnum#OTHER>,
        <https://w3id.org/lmodel/ocsf/EmailActivityDirectionIdEnum#OUTBOUND>,
        <https://w3id.org/lmodel/ocsf/EmailActivityDirectionIdEnum#UNKNOWN> .

ocsf:Graph a owl:Class ;
    rdfs:label "Graph" ;
    rdfs:seeAlso <https://github.com/jsongraph/json-graph-specification/> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Edge ;
            owl:onProperty ocsf:edges ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:GraphQueryLanguageIdEnum ;
            owl:onProperty ocsf:query_language_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:query_language_id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:nodes ],
        [ a owl:Restriction ;

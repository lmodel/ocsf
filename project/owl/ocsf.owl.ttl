    skos:altLabel "Cloud" ;
    skos:definition "The Cloud object describes the cloud computing environment where an event or finding originated. It provides comprehensive context about the cloud infrastructure, including the cloud service provider, account or subscription details, organizational structure, geographic regions, availability zones, and logical partitions." ;
    skos:inScheme ocsf:objects .

ocsf:D3fend a owl:Class ;
    rdfs:label "D3fend" ;
    rdfs:seeAlso <https://d3fend.mitre.org> ;
    rdfs:subClassOf [ a owl:Restriction ;

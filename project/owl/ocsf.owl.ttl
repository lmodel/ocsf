@prefix attack: <https://lmodel.github.io/attack/> .
@prefix capec: <https://w3id.org/lmodel/capec/> .
@prefix core: <https://w3id.org/lmodel/vulnerability-core/> .
@prefix cve: <https://w3id.org/lmodel/cve/> .
@prefix cwe: <https://w3id.org/lmodel/cwe/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix iso27001: <https://w3id.org/lmodel/iso27001/> .
@prefix kev_catalog: <https://w3id.org/lmodel/kev-catalog/> .
@prefix linkml: <https://w3id.org/linkml/> .
@prefix nvd: <https://w3id.org/lmodel/nist-nvd/> .
@prefix ocsf: <https://w3id.org/lmodel/ocsf/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pav: <http://purl.org/pav/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix stix: <https://lmodel.github.io/stix/> .
@prefix uco_master: <https://lmodel.github.io/uco-master/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/lmodel/ocsf.owl.ttl> a owl:Ontology ;
    rdfs:label "ocsf" ;
    dcterms:license "Apache-2.0" ;
    dcterms:source <https://github.com/ocsf/ocsf-schema/tree/main> ;
    dcterms:title "Open Cybersecurity Schema Framework (OCSF) — LinkML Schema" ;
    pav:version "1.9.0-dev" ;
    rdfs:seeAlso <https://github.com/ocsf/ocsf-schema>,
        <https://lmodel.github.io/ocsf>,
        <https://schema.ocsf.io/> ;
    skos:definition "Open Cybersecurity Schema Framework (OCSF) — LinkML schema. Generated from upstream OCSF JSON at version 1.9.0-dev. Each top-level concern is one module: types, dictionary (slots), enums, categories, objects, profiles, events, extensions." ;
    ocsf:copyright "© OCSF a Series of LF Projects, LLC" .

ocsf:AccountChange a owl:Class ;
    rdfs:label "AccountChange" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:policy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:policy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:auth_factors ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:User ;
            owl:onProperty ocsf:user ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:policies ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:AccountChangeActivityIdEnum ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:user_result ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:AuthFactor ;
            owl:onProperty ocsf:auth_factors ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:user ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:User ;
            owl:onProperty ocsf:user_result ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Policy ;
            owl:onProperty ocsf:policies ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Policy ;
            owl:onProperty ocsf:policy ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:user ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:user_result ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:activity_id ],
        ocsf:IamEvent ;
    skos:altLabel "Account Change" ;
    skos:definition "Account Change events report when specific user account management tasks are performed, such as a user/role being created, changed, deleted, renamed, disabled, enabled, locked out or unlocked." ;
    skos:inScheme ocsf:events ;
    ocsf:ocsf_event_uid 1 .

ocsf:AdminGroupQuery a owl:Class ;
    rdfs:label "AdminGroupQuery" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:group ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:users ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:group ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Group ;
            owl:onProperty ocsf:group ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:User ;
            owl:onProperty ocsf:users ],
        ocsf:DiscoveryResult ;
    skos:altLabel "Admin Group Query" ;
    skos:definition "Admin Group Query events report information about administrative groups." ;
    skos:inScheme ocsf:events ;
    ocsf:ocsf_event_uid 9 .

ocsf:AirborneBroadcastActivity a owl:Class ;
    rdfs:label "AirborneBroadcastActivity" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:unmanned_aerial_system ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:unmanned_system_operating_area ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:dst_endpoint ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:dst_endpoint ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:unmanned_system_operating_area ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:aircraft ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:unmanned_system_operator ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:unmanned_aerial_system ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ocsf:rssi ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:rssi ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:AirborneBroadcastActivityActivityIdEnum ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:rssi ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:NetworkEndpoint ;
            owl:onProperty ocsf:dst_endpoint ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:unmanned_system_operator ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:traffic ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:UnmannedAerialSystem ;
            owl:onProperty ocsf:unmanned_aerial_system ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:aircraft ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Aircraft ;
            owl:onProperty ocsf:aircraft ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:src_endpoint ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:User ;
            owl:onProperty ocsf:unmanned_system_operator ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:protocol_name ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:NetworkEndpoint ;
            owl:onProperty ocsf:src_endpoint ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:src_endpoint ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:protocol_name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:traffic ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:protocol_name ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:UnmannedSystemOperatingArea ;
            owl:onProperty ocsf:unmanned_system_operating_area ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:NetworkTraffic ;
            owl:onProperty ocsf:traffic ],
        ocsf:UnmannedSystemsEvent ;
    skos:altLabel "Airborne Broadcast Activity" ;
    skos:definition "Airborne Broadcast Activity events report the activity of any aircraft or unmanned system as reported and tracked by Automatic Dependent Surveillance - Broadcast (ADS-B) receivers. Based on the ADS-B standards described in <a target='_blank' href='https://www.ecfr.gov/current/title-14/chapter-I/subchapter-F/part-91#91.225'>Code of Federal Regulations (CFR) Title 14 Chapter I Subchapter F Part 91</a> and in other general Federal Aviation Administration (FAA) supplemental orders and guidance described <a target='_blank' href='https://www.faa.gov/about/office_org/headquarters_offices/avs/offices/afx/afs/afs400/afs410/ads-b'>here</a>." ;
    skos:inScheme ocsf:events ;
    ocsf:ocsf_constraints "{\"at_least_one\": [\"aircraft\", \"unmanned_aerial_system\", \"unmanned_system_operating_area\"]}" ;
    ocsf:ocsf_event_uid 2 .

ocsf:ApiActivity a owl:Class ;
    rdfs:label "ApiActivity" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:actor ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:HttpResponse ;
            owl:onProperty ocsf:http_response ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:api ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:ResourceDetails ;
            owl:onProperty ocsf:resources ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:NetworkEndpoint ;
            owl:onProperty ocsf:dst_endpoint ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:NetworkEndpoint ;
            owl:onProperty ocsf:src_endpoint ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Api ;
            owl:onProperty ocsf:api ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Actor ;
            owl:onProperty ocsf:actor ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:src_endpoint ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:ApiActivityActivityIdEnum ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:http_response ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:http_response ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:http_request ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:dst_endpoint ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:src_endpoint ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:http_request ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:dst_endpoint ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:actor ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:api ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:HttpRequest ;
            owl:onProperty ocsf:http_request ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:resources ],
        ocsf:AiOperationProfile,
        ocsf:ApplicationEvent,
        ocsf:TraceProfile ;
    skos:altLabel "API Activity" ;
    skos:definition "API events describe general CRUD (Create, Read, Update, Delete) API activities, e.g. (AWS Cloudtrail)" ;
    skos:inScheme ocsf:events ;
    ocsf:ocsf_event_uid 3 .

ocsf:ApplicationError a owl:Class ;
    rdfs:label "ApplicationError" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ocsf:ApplicationErrorActivityIdEnum ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:message ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:message ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:message ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:activity_id ],
        ocsf:ApplicationEvent ;
    skos:altLabel "Application Error" ;
    skos:definition "Application Error events describe issues with an applications. The error message should be put in the event's <code>message</code> attribute. The <code>metadata.product</code> attribute can be used to capture the originating application information. The <code>host</code> profile can used to include the generating device information. This class is helpful for applications that generate or handle OCSF events and can also be used for errors in upstream products and services." ;
    skos:inScheme ocsf:events ;
    ocsf:ocsf_event_uid 8 .

ocsf:ApplicationLifecycle a owl:Class ;
    rdfs:label "ApplicationLifecycle" ;
    rdfs:seeAlso <https://d3fend.mitre.org/event/d3f:ApplicationEvent/> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:app ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Product ;
            owl:onProperty ocsf:app ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:app ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:ApplicationLifecycleActivityIdEnum ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:activity_id ],
        ocsf:ApplicationEvent ;
    skos:altLabel "Application Lifecycle" ;
    skos:definition "Application Lifecycle events report installation, removal, start, stop of an application or service." ;
    skos:editorialNote "D3FEND™ Ontology d3f:ApplicationEvent — https://d3fend.mitre.org/event/d3f:ApplicationEvent/" ;
    skos:inScheme ocsf:events ;
    ocsf:ocsf_event_uid 2 .

ocsf:ApplicationSecurityPostureFinding a owl:Class ;
    rdfs:label "ApplicationSecurityPostureFinding" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:application ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:compliance ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:resources ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Compliance ;
            owl:onProperty ocsf:compliance ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Remediation ;
            owl:onProperty ocsf:remediation ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:vulnerabilities ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:ApplicationObject ;
            owl:onProperty ocsf:application ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:compliance ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Vulnerability ;
            owl:onProperty ocsf:vulnerabilities ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:remediation ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:application ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:remediation ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:ResourceDetails ;
            owl:onProperty ocsf:resources ],
        ocsf:Finding,
        ocsf:IncidentProfile ;
    skos:altLabel "Application Security Posture Finding" ;
    skos:definition "The Application Security Posture Finding event is a notification about any bug, defect, deficiency, exploit, vulnerability, weakness or any other issue with software and related systems. Application Security Posture Findings typically involve reporting on the greater context including compliance, impacted resources, remediation guidance, specific code defects, and/or vulnerability metadata. Application Security Posture Findings can be reported by Threat & Vulnerability Management (TVM) tools, Application Security Posture Management (ASPM) tools, or other similar tools. Note: if the event producer is a security control, the <code>security_control</code> profile should be applied and its <code>attacks</code> information, if present, should be duplicated into the <code>finding_info</code> object. <br><strong>Note: </strong>If the Finding is an incident, i.e. requires incident workflow, also apply the <code>incident</code> profile or aggregate this finding into an <code>Incident Finding</code>." ;
    skos:inScheme ocsf:events ;
    ocsf:ocsf_constraints "{\"at_least_one\": [\"application\", \"compliance\", \"remediation\", \"vulnerabilities\"]}" ;
    ocsf:ocsf_event_uid 7 .

ocsf:Authentication a owl:Class ;
    rdfs:label "Authentication" ;
    rdfs:seeAlso <https://d3fend.mitre.org/event/d3f:AuthenticationEvent> ;

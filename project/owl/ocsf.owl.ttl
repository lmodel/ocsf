            owl:onProperty ocsf:format ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:encoding ],
        ocsf:Object ;
    skos:altLabel "Packet" ;
    skos:definition "The Packet object represents a single captured network packet and its associated metadata. It describes where the packet came from, how it is stored or encoded, and how it can be located within a capture file or stream. This object does not interpret protocol content; it only represents the captured packet data and its positioning information." ;
    skos:editorialNote "D3FEND™ Ontology d3f:NetworkPacket. — https://d3fend.mitre.org/dao/artifact/d3f:NetworkPacket/",
        "D3FEND™ Ontology d3f:PacketCaptureFile. — https://d3fend.mitre.org/dao/artifact/d3f:PacketCaptureFile/",
        "D3FEND™ Ontology d3f:PacketLog. — https://d3fend.mitre.org/dao/artifact/d3f:PacketLog/" ;
    skos:inScheme ocsf:objects .

ocsf:PrivilegeAttackInfo a owl:Class ;
    rdfs:label "PrivilegeAttackInfo" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:attack ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Attack ;
            owl:onProperty ocsf:attack ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:PrivilegeInfo ;
            owl:onProperty ocsf:privilege_info_list ],
        [ a owl:Restriction ;

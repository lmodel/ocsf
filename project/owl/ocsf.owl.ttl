            owl:onProperty ocsf:location ],
        ocsf:Entity ;
    skos:altLabel "Aircraft" ;
    skos:definition "The Aircraft object represents any aircraft or otherwise airborne asset such as an unmanned system, airplane, balloon, spacecraft, or otherwise. The Aircraft object is intended to normalized data captured or otherwise logged from active radar, passive radar, multi-spectral systems, or the Automatic Dependant Broadcast - Surveillance (ADS-B), and/or Mode S systems." ;
    skos:inScheme ocsf:objects ;
    ocsf:ocsf_constraints "{\"at_least_one\": [\"name\", \"serial_number\", \"uid\", \"uid_alt\"]}" .

ocsf:AlgorithmIdEnum a owl:Class ;
    rdfs:label "AlgorithmIdEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/ocsf/AlgorithmIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/AlgorithmIdEnum#OTHER> ) ;
    skos:definition "The normalized identifier of the algorithm. See specific usage." ;
    skos:inScheme ocsf:enums ;
    linkml:permissible_values <https://w3id.org/lmodel/ocsf/AlgorithmIdEnum#OTHER>,
        <https://w3id.org/lmodel/ocsf/AlgorithmIdEnum#UNKNOWN> .

ocsf:AuthTypeIdEnum a owl:Class ;
    rdfs:label "AuthTypeIdEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/ocsf/AuthTypeIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/AuthTypeIdEnum#OTHER> ) ;
    skos:definition "The normalized identifier of the agreed upon authentication type. See specific usage." ;
    skos:inScheme ocsf:enums ;
    linkml:permissible_values <https://w3id.org/lmodel/ocsf/AuthTypeIdEnum#OTHER>,
        <https://w3id.org/lmodel/ocsf/AuthTypeIdEnum#UNKNOWN> .

ocsf:Authorization a owl:Class ;
    rdfs:label "Authorization" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:decision ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:policy ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Policy ;
            owl:onProperty ocsf:policy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:decision ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:policy ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:decision ],
        ocsf:Object ;
    skos:altLabel "Authorization Result" ;
    skos:definition "The Authorization Result object provides details about the authorization outcome and associated policies related to activity." ;
    skos:inScheme ocsf:objects .

ocsf:BaseEventActivityIdEnum a owl:Class ;
    rdfs:label "BaseEventActivityIdEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/ocsf/BaseEventActivityIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/BaseEventActivityIdEnum#OTHER> ) ;
    skos:definition "BaseEvent activity_id values." ;
    skos:inScheme ocsf:enums ;
    linkml:permissible_values <https://w3id.org/lmodel/ocsf/BaseEventActivityIdEnum#OTHER>,
        <https://w3id.org/lmodel/ocsf/BaseEventActivityIdEnum#UNKNOWN> .

ocsf:CisControl a owl:Class ;
    rdfs:label "CisControl" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:desc ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:version ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:desc ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:version ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:version ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:desc ],
        ocsf:Object ;
    skos:altLabel "CIS Control" ;
    skos:closeMatch iso27001:SecurityControl ;
    skos:definition "The CIS Control (aka Critical Security Control) object describes a prioritized set of actions to protect your organization and data from cyber-attack vectors. The <a target='_blank' href='https://www.cisecurity.org/controls'>CIS Controls</a> are defined by the Center for Internet Security." ;
    skos:inScheme ocsf:objects .

ocsf:ClassificationIdsEnum a owl:Class ;
    rdfs:label "ClassificationIdsEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/ocsf/ClassificationIdsEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/ClassificationIdsEnum#OTHER> ) ;
    skos:definition "The list of normalized classification identifiers. See specific usage." ;

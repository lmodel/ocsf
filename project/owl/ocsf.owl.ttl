<https://w3id.org/lmodel/ocsf/DataLifecycleStateIdEnum#DATA_AT_REST> a owl:Class ;
    rdfs:label "DATA_AT_REST" ;
    rdfs:subClassOf ocsf:DataLifecycleStateIdEnum ;
    skos:definition "The data was stored on physical or logical media and was not actively moving through the network nor was being processed. E.g., data stored in a database, PDF files in a file share, or EHR records in object storage." ;
    ocsf:caption "Data at-Rest" ;
    ocsf:ocsf_uid "1" .

<https://w3id.org/lmodel/ocsf/DataLifecycleStateIdEnum#DATA_IN_TRANSIT> a owl:Class ;
    rdfs:label "DATA_IN_TRANSIT" ;
    rdfs:subClassOf ocsf:DataLifecycleStateIdEnum ;
    skos:definition "The data was actively moving through the network or from one physical or logical location to another. E.g., emails being send, data replication or Change Data Capture (CDC) streams, or sensitive data processed on an API." ;
    ocsf:caption "Data in-Transit" ;
    ocsf:ocsf_uid "2" .

<https://w3id.org/lmodel/ocsf/DataLifecycleStateIdEnum#DATA_IN_USE> a owl:Class ;
    rdfs:label "DATA_IN_USE" ;
    rdfs:subClassOf ocsf:DataLifecycleStateIdEnum ;
    skos:definition "The data was being processed, accessed, or read by a system, making it active in memory or CPU. E.g., sensitive data in a Business Intelligence tool, ePHI being processed in an EHR application or a user viewing data stored in a spreadsheet or PDF." ;
    ocsf:caption "Data in-Use" ;
    ocsf:ocsf_uid "3" .

<https://w3id.org/lmodel/ocsf/DataLifecycleStateIdEnum#OTHER> a owl:Class ;
    rdfs:label "OTHER" ;
    rdfs:subClassOf ocsf:DataLifecycleStateIdEnum ;
    skos:definition "The data lifecycle state is not mapped. See the <code>data_lifecycle_state</code> attribute, which contains a data source specific value." ;
    ocsf:caption "Other" ;
    ocsf:ocsf_uid "99" .

<https://w3id.org/lmodel/ocsf/DataLifecycleStateIdEnum#UNKNOWN> a owl:Class ;
    rdfs:label "UNKNOWN" ;
    rdfs:subClassOf ocsf:DataLifecycleStateIdEnum ;
    skos:definition "The data lifecycle state is unknown." ;
    ocsf:caption "Unknown" ;
    ocsf:ocsf_uid "0" .

ocsf:DataSecurity a owl:Class ;
    rdfs:label "DataSecurity" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:data_lifecycle_state ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:detection_system ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:pattern_match ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:policy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:data_lifecycle_state ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:detection_pattern ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:detection_pattern ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:policy ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:pattern_match ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:DataLifecycleStateIdEnum ;
            owl:onProperty ocsf:data_lifecycle_state_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Policy ;
            owl:onProperty ocsf:policy ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:data_lifecycle_state_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:detection_system_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:DetectionSystemIdEnum ;
            owl:onProperty ocsf:detection_system_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:data_lifecycle_state_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:detection_system ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:data_lifecycle_state ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:detection_pattern ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:detection_system_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:detection_system ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:pattern_match ],
        ocsf:DataClassification ;
    skos:altLabel "Data Security" ;
    skos:definition "The Data Security object describes the characteristics, techniques and content of a Data Loss Prevention (DLP), Data Loss Detection (DLD), Data Classification, or similar tools' finding, alert, or detection mechanism(s)." ;
    skos:inScheme ocsf:objects ;
    ocsf:ocsf_constraints "{\"at_least_one\": [\"data_lifecycle_state_id\", \"detection_pattern\", \"detection_system_id\", \"policy\"]}" .


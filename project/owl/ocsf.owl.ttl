    ocsf:ocsf_uid "3" .

<https://w3id.org/lmodel/ocsf/DispositionIdEnum#REJECTED> a owl:Class ;
    rdfs:label "REJECTED" ;
    rdfs:subClassOf ocsf:DispositionIdEnum ;

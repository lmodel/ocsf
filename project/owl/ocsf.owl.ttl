<https://w3id.org/lmodel/ocsf/DetectionSystemIdEnum#APPLICATION_LEVEL_DLP> a owl:Class ;
    rdfs:label "APPLICATION_LEVEL_DLP" ;
    rdfs:subClassOf ocsf:DetectionSystemIdEnum ;
    skos:definition "A built in Data Loss Prevention (DLP) or other data security capability within a tool or platform such as an Enterprise Resource Planning (ERP) or Customer Relations Management (CRM) tool that can detect sensitive data and/or enforce data security policies." ;
    ocsf:caption "Application-Level DLP" ;
    ocsf:ocsf_uid "10" .

<https://w3id.org/lmodel/ocsf/DetectionSystemIdEnum#CLOUD_ACCESS_SECURITY_BROKER> a owl:Class ;
    rdfs:label "CLOUD_ACCESS_SECURITY_BROKER" ;
    rdfs:subClassOf ocsf:DetectionSystemIdEnum ;
    skos:definition "A Cloud Access Security Broker (CASB) that can detect sensitive data and/or enforce data security policies in-line to cloud systems such as the public cloud or Software-as-a-Service (SaaS) tool. E.g., Forcepoint CASB, SkyHigh Security." ;
    ocsf:caption "Cloud Access Security Broker" ;
    ocsf:ocsf_uid "8" .

<https://w3id.org/lmodel/ocsf/DetectionSystemIdEnum#DATABASE_ACTIVITY_MONITORING> a owl:Class ;
    rdfs:label "DATABASE_ACTIVITY_MONITORING" ;
    rdfs:subClassOf ocsf:DetectionSystemIdEnum ;
    skos:definition "A Database Activity Monitoring (DAM) tool that can detect sensitive data and/or enforce data security policies as part of a dedicated database or warehouse monitoring solution." ;
    ocsf:caption "Database Activity Monitoring" ;
    ocsf:ocsf_uid "9" .

<https://w3id.org/lmodel/ocsf/DetectionSystemIdEnum#DATA_DISCOVERY_CLASSIFICATION> a owl:Class ;
    rdfs:label "DATA_DISCOVERY_CLASSIFICATION" ;
    rdfs:subClassOf ocsf:DetectionSystemIdEnum ;
    skos:definition "A tool that actively identifies and classifies sensitive data in digital media and information stores in accordance with a policy or automated functionality. E.g, Amazon Macie, Microsoft Purview." ;
    ocsf:caption "Data Discovery & Classification" ;
    ocsf:ocsf_uid "4" .

<https://w3id.org/lmodel/ocsf/DetectionSystemIdEnum#DATA_SECURITY_POSTURE_MANAGEMENT> a owl:Class ;
    rdfs:label "DATA_SECURITY_POSTURE_MANAGEMENT" ;
    rdfs:subClassOf ocsf:DetectionSystemIdEnum ;
    skos:definition "A Data Security Posture Management (DSPM) tool is a continuous monitoring and data discovery solution that can detect sensitive data and/or enforce data security policies for local and cloud environments. E.g., Cyera, Sentra, IBM Polar Security." ;
    ocsf:caption "Data Security Posture Management" ;
    ocsf:ocsf_uid "12" .

<https://w3id.org/lmodel/ocsf/DetectionSystemIdEnum#DEVELOPER_SECURITY> a owl:Class ;
    rdfs:label "DEVELOPER_SECURITY" ;
    rdfs:subClassOf ocsf:DetectionSystemIdEnum ;
    skos:definition "Any Developer Security tool such as an Infrastructure-as-Code (IAC) security scanner, Secrets Detection, or Secure Software Development Lifecycle (SSDLC) tool that can detect sensitive data and/or enforce data security policies. E.g., TruffleHog, GitGuardian, Git-Secrets." ;
    ocsf:caption "Developer Security" ;
    ocsf:ocsf_uid "11" .

<https://w3id.org/lmodel/ocsf/DetectionSystemIdEnum#DIGITAL_RIGHTS_MANAGEMENT> a owl:Class ;
    rdfs:label "DIGITAL_RIGHTS_MANAGEMENT" ;
    rdfs:subClassOf ocsf:DetectionSystemIdEnum ;
    skos:definition "A Digital Rights Management (DRM) or a dedicated Information Rights Management (IRM) are tools which can detect sensitive data and/or enforce data security policies on digital media via policy or user access rights." ;
    ocsf:caption "Digital Rights Management" ;
    ocsf:ocsf_uid "7" .

<https://w3id.org/lmodel/ocsf/DetectionSystemIdEnum#DLP_GATEWAY> a owl:Class ;
    rdfs:label "DLP_GATEWAY" ;
    rdfs:subClassOf ocsf:DetectionSystemIdEnum ;
    skos:definition "A Data Loss Prevention (DLP) gateway that is positioned in-line of an information store such as a network share, a database, or otherwise that can detect sensitive data and/or enforce data security policies." ;
    ocsf:caption "DLP Gateway" ;
    ocsf:ocsf_uid "2" .

<https://w3id.org/lmodel/ocsf/DetectionSystemIdEnum#ENDPOINT> a owl:Class ;
    rdfs:label "ENDPOINT" ;
    rdfs:subClassOf ocsf:DetectionSystemIdEnum ;
    skos:definition "A dedicated agent or sensor installed on a device, either a dedicated data security tool or an Endpoint Detection & Response (EDR) tool that can detect sensitive data and/or enforce data security policies. E.g., Forcepoint DLP, Symantec DLP, Microsoft Defender for Endpoint (MDE)." ;
    ocsf:caption "Endpoint" ;
    ocsf:ocsf_uid "1" .

<https://w3id.org/lmodel/ocsf/DetectionSystemIdEnum#MOBILE_DEVICE_MANAGEMENT> a owl:Class ;
    rdfs:label "MOBILE_DEVICE_MANAGEMENT" ;
    rdfs:subClassOf ocsf:DetectionSystemIdEnum ;
    skos:definition "A Mobile Device Management (MDM) or Enterprise Mobility Management (EMM) tool that can detect sensitive data and/or enforce data security policies on mobile devices (e.g., cellphones, tablets, End User Devices [EUDs])." ;
    ocsf:caption "Mobile Device Management" ;
    ocsf:ocsf_uid "3" .

<https://w3id.org/lmodel/ocsf/DetectionSystemIdEnum#OTHER> a owl:Class ;
    rdfs:label "OTHER" ;
    rdfs:subClassOf ocsf:DetectionSystemIdEnum ;
    skos:definition "Any other type of detection system or a multi-variate system made up of several other systems." ;
    ocsf:caption "Other" ;
    ocsf:ocsf_uid "99" .

<https://w3id.org/lmodel/ocsf/DetectionSystemIdEnum#SECURE_EMAIL_GATEWAY> a owl:Class ;
    rdfs:label "SECURE_EMAIL_GATEWAY" ;
    rdfs:subClassOf ocsf:DetectionSystemIdEnum ;
    skos:definition "A Secure Email Gateway (SEG) is any tool that can detect sensitive data and/or enforce data security policies within email systems. E.g., Microsoft Defender for Office, Google Workspaces." ;
    ocsf:caption "Secure Email Gateway" ;
    ocsf:ocsf_uid "6" .

<https://w3id.org/lmodel/ocsf/DetectionSystemIdEnum#SECURE_WEB_GATEWAY> a owl:Class ;
    rdfs:label "SECURE_WEB_GATEWAY" ;
    rdfs:subClassOf ocsf:DetectionSystemIdEnum ;
    skos:definition "A Secure Web Gateway (SWG) is any tool that can detect sensitive data and/or enforce data security policies at a network-edge such as within a proxy or firewall service." ;
    ocsf:caption "Secure Web Gateway" ;
    ocsf:ocsf_uid "5" .

<https://w3id.org/lmodel/ocsf/DetectionSystemIdEnum#UNKNOWN> a owl:Class ;
    rdfs:label "UNKNOWN" ;
    rdfs:subClassOf ocsf:DetectionSystemIdEnum ;
    skos:definition "The type is not mapped. See the <code>detection_system</code> attribute, which contains a data source specific value." ;
    ocsf:caption "Unknown" ;
    ocsf:ocsf_uid "0" .


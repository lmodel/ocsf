<https://w3id.org/lmodel/ocsf/LaunchTypeIdEnum#SPAWN> a owl:Class ;
    rdfs:label "SPAWN" ;
    rdfs:subClassOf ocsf:LaunchTypeIdEnum ;
    skos:definition "Denotes that the <code>Launch</code> event represents atomic creation of a new process on Windows. This launch type ID may also be used to represent both steps of Unix process creation in a single <code>Launch</code> event." ;
    ocsf:caption "Spawn" ;
    ocsf:ocsf_uid "1" .

<https://w3id.org/lmodel/ocsf/LaunchTypeIdEnum#UNKNOWN> a owl:Class ;

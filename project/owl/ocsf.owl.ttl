ocsf:DiscoveryEvent a owl:Class ;
    rdfs:label "DiscoveryEvent" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:DiscoveryEventActivityIdEnum ;
            owl:onProperty ocsf:activity_id ],
        ocsf:BaseEvent ;
    skos:altLabel "Discovery" ;
    skos:definition "The Discovery event is a generic event that defines a set of attributes available in Discovery category events. As a generic event, it could be used to log events that are not otherwise defined by the Discovery specific event classes." ;
    skos:inScheme ocsf:events ;
    ocsf:category "discovery" .


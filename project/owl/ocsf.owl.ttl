        <https://w3id.org/lmodel/ocsf/ModuleLoadTypeIdEnum#STANDARD>,
        <https://w3id.org/lmodel/ocsf/ModuleLoadTypeIdEnum#UNKNOWN> .

ocsf:NetworkInterface a owl:Class ;
    rdfs:label "NetworkInterface" ;

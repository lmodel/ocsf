ocsf:KillChainPhase a owl:Class ;
    rdfs:label "KillChainPhase" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ocsf:PhaseIdEnum ;
            owl:onProperty ocsf:phase_id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:phase_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:phase_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:phase ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:phase ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:phase ],
        ocsf:Object ;
    skos:altLabel "Kill Chain Phase" ;
    skos:closeMatch attack:KillChainPhase ;
    skos:definition "The Kill Chain Phase object represents a single phase of a cyber attack, including the initial reconnaissance and planning stages up to the final objective of the attacker. It provides a detailed description of each phase and its associated activities within the broader context of a cyber attack. See <a target='_blank' href='https://www.lockheedmartin.com/en-us/capabilities/cyber/cyber-kill-chain.html'>Cyber Kill Chain®</a>." ;
    skos:inScheme ocsf:objects .


ocsf:IamAnalysisFinding a owl:Class ;
    rdfs:label "IamAnalysisFinding" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ocsf:ApplicationObject ;
            owl:onProperty ocsf:applications ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:IdentityActivityMetrics ;
            owl:onProperty ocsf:identity_activity_metrics ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:identity_activity_metrics ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:AccessAnalysisResult ;
            owl:onProperty ocsf:access_analysis_result ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:user ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:access_analysis_result ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Remediation ;
            owl:onProperty ocsf:remediation ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:identity_activity_metrics ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:resources ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:PermissionAnalysisResult ;
            owl:onProperty ocsf:permission_analysis_results ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:permission_analysis_results ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:user ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:User ;
            owl:onProperty ocsf:user ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:ResourceDetails ;
            owl:onProperty ocsf:resources ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:remediation ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:applications ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:access_analysis_result ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:remediation ],
        ocsf:Finding ;
    skos:altLabel "IAM Analysis Finding" ;
    skos:definition "This finding represents an IAM analysis result, which evaluates IAM policies, access patterns, and IAM configurations for potential security risks. The analysis can focus on either an identity (user, role, service account) or a resource to assess permissions, access patterns, and security posture within the IAM domain. <br><strong>Note:</strong> Use <code>permission_analysis_results</code> for identity-centric analysis (evaluating what an identity can do) and <code>access_analysis_result</code> for resource-centric analysis (evaluating who can access a resource). These complement each other for comprehensive IAM security assessment.<br><strong>Note:</strong> If the Finding is an incident, i.e. requires incident workflow, also apply the <code>incident</code> profile or aggregate this finding into an <code>Incident Finding</code>." ;
    skos:inScheme ocsf:events ;
    ocsf:ocsf_constraints "{\"at_least_one\": [\"access_analysis_result\", \"applications\", \"identity_activity_metrics\", \"permission_analysis_results\"]}" ;
    ocsf:ocsf_event_uid 8 .


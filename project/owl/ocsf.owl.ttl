ocsf:KeyValueObject a owl:Class ;
    rdfs:label "KeyValueObject" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:values ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:value ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:values ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:value ],
        ocsf:Object ;
    skos:altLabel "Key:Value object" ;
    skos:definition "A generic object allowing to define a <code>{key:value}</code> pair." ;
    skos:inScheme ocsf:objects ;
    ocsf:ocsf_constraints "{\"at_least_one\": [\"value\", \"values\"]}" .


            owl:onProperty ocsf:authentication_token ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:session ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Certificate ;
            owl:onProperty ocsf:certificate ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:certificate ],
        [ a owl:Restriction ;

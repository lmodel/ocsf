ocsf:AuthProtocolIdEnum a owl:Class ;
    rdfs:label "AuthProtocolIdEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#NTLM> <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#KERBEROS> <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#DIGEST> <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#OPENID> <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#SAML> <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#OAUTH_2_0> <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#PAP> <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#CHAP> <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#EAP> <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#RADIUS> <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#BASIC_AUTHENTICATION> <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#LDAP> <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#OTHER> ) ;
    skos:definition "The normalized identifier of the authentication protocol used to create the user session." ;
    skos:inScheme ocsf:enums ;
    linkml:permissible_values <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#BASIC_AUTHENTICATION>,
        <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#CHAP>,
        <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#DIGEST>,
        <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#EAP>,
        <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#KERBEROS>,
        <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#LDAP>,
        <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#NTLM>,
        <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#OAUTH_2_0>,
        <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#OPENID>,
        <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#OTHER>,
        <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#PAP>,
        <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#RADIUS>,
        <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#SAML>,
        <https://w3id.org/lmodel/ocsf/AuthProtocolIdEnum#UNKNOWN> .

ocsf:DiscoveryResult a owl:Class ;
    rdfs:label "DiscoveryResult" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ocsf:DiscoveryResultActivityIdEnum ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:QueryInfo ;
            owl:onProperty ocsf:query_info ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:query_result ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:query_info ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:query_info ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:query_result_id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:query_result_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:query_result ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:QueryResultIdEnum ;
            owl:onProperty ocsf:query_result_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:activity_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:query_result ],
        ocsf:BaseEvent ;
    skos:altLabel "Discovery Result" ;
    skos:definition "Discovery Result events report the results of a discovery request." ;
    skos:inScheme ocsf:events ;
    ocsf:category "discovery" .

ocsf:EndpointTypeIdEnum a owl:Class ;
    rdfs:label "EndpointTypeIdEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/ocsf/EndpointTypeIdEnum#SERVER> <https://w3id.org/lmodel/ocsf/EndpointTypeIdEnum#DESKTOP> <https://w3id.org/lmodel/ocsf/EndpointTypeIdEnum#LAPTOP> <https://w3id.org/lmodel/ocsf/EndpointTypeIdEnum#TABLET> <https://w3id.org/lmodel/ocsf/EndpointTypeIdEnum#MOBILE> <https://w3id.org/lmodel/ocsf/EndpointTypeIdEnum#VIRTUAL> <https://w3id.org/lmodel/ocsf/EndpointTypeIdEnum#IOT> <https://w3id.org/lmodel/ocsf/EndpointTypeIdEnum#BROWSER> <https://w3id.org/lmodel/ocsf/EndpointTypeIdEnum#FIREWALL> <https://w3id.org/lmodel/ocsf/EndpointTypeIdEnum#SWITCH> <https://w3id.org/lmodel/ocsf/EndpointTypeIdEnum#HUB> <https://w3id.org/lmodel/ocsf/EndpointTypeIdEnum#ROUTER> <https://w3id.org/lmodel/ocsf/EndpointTypeIdEnum#IDS> <https://w3id.org/lmodel/ocsf/EndpointTypeIdEnum#IPS> <https://w3id.org/lmodel/ocsf/EndpointTypeIdEnum#LOAD_BALANCER> <https://w3id.org/lmodel/ocsf/EndpointTypeIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/EndpointTypeIdEnum#OTHER> ) ;

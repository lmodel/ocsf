    ocsf:caption "Partially Corrected" ;
    ocsf:ocsf_uid "12" .

<https://w3id.org/lmodel/ocsf/DispositionIdEnum#QUARANTINED> a owl:Class ;
    rdfs:label "QUARANTINED" ;
    rdfs:subClassOf ocsf:DispositionIdEnum ;
    skos:definition "A suspicious file or other content was moved to a benign location." ;

ocsf:Trace a owl:Class ;
    rdfs:label "Trace" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:duration ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Span ;
            owl:onProperty ocsf:span ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:flags ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:start_time ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:end_time ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:start_time ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:long ;
            owl:onProperty ocsf:end_time ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ocsf:duration ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:flags ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:duration ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:span ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:service ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:long ;
            owl:onProperty ocsf:start_time ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:span ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Service ;
            owl:onProperty ocsf:service ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:service ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:end_time ],
        ocsf:Object ;
    skos:altLabel "Trace" ;
    skos:definition "The trace object contains information about a distributed trace,  which is crucial for observability. Traces are made up of one or more spans, which are individual units of work in application activity. Traces track the journey of a request as it moves through various services in a system, capturing key details like timing, status, and dependencies at each step. Traces provide insights into system performance, helping to identify latency, bottlenecks, and issues in complex, distributed environments." ;
    skos:inScheme ocsf:objects .

ocsf:TraceProfile a owl:Class ;
    rdfs:label "TraceProfile" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:trace ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:trace ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Trace ;
            owl:onProperty ocsf:trace ] ;
    skos:altLabel "Trace" ;
    skos:definition "The Trace Profile extends the OCSF framework to capture and standardize observability events, specifically targeting trace-level data. This profile enables integration and normalization of distributed tracing information, allowing OCSF events to retain essential trace context such as trace IDs, span relationships, and service dependencies." ;
    skos:inScheme ocsf:profiles ;
    ocsf:group "primary" ;
    ocsf:ocsf_profile "trace" .


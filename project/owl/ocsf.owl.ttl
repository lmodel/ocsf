ocsf:desc a owl:DatatypeProperty ;
    rdfs:label "desc" ;
    rdfs:range xsd:string ;
    skos:altLabel "Description" ;
    skos:definition "The description that pertains to the object or event. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:version a owl:DatatypeProperty ;
    rdfs:label "version" ;
    rdfs:range xsd:string ;
    skos:altLabel "Version" ;
    skos:definition "The version that pertains to the event or object. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:type_id a owl:ObjectProperty ;
    rdfs:label "type_id" ;
    rdfs:range ocsf:TypeIdEnum ;
    skos:altLabel "Type ID" ;
    skos:definition "The normalized type identifier of an object. See specific usage." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "type" .

ocsf:Object a owl:Class ;
    rdfs:label "Object" ;
    rdfs:subClassOf ocsf:OcsfObject ;
    skos:altLabel "Object" ;
    skos:definition "An unordered collection of attributes. It defines a set of attributes available in all objects. It can be also used as a generic object to log objects that are not otherwise defined by the schema." ;
    skos:inScheme ocsf:objects .

xsd:long a rdfs:Datatype ;
    owl:equivalentClass xsd:integer .

ocsf:activity_id a owl:ObjectProperty ;
    rdfs:label "activity_id" ;
    rdfs:range ocsf:ActivityIdEnum ;
    skos:altLabel "Activity ID" ;
    skos:definition "The normalized identifier of the activity that triggered the event." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "activity_name" ;
    ocsf:suppress_checks "sibling_convention" .

ocsf:type a owl:DatatypeProperty ;
    rdfs:label "type" ;
    rdfs:range xsd:string ;
    skos:altLabel "Type" ;
    skos:definition "The type of an object or value, normalized to the caption of the type_id value. In the case of 'Other', it is defined by the event source. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:uid a owl:DatatypeProperty ;
    rdfs:label "uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "Unique ID" ;
    skos:definition "The unique identifier. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:name a owl:DatatypeProperty ;
    rdfs:label "name" ;
    rdfs:range xsd:string ;
    skos:altLabel "Name" ;
    skos:definition "The name of the entity. See specific usage." ;
    skos:inScheme ocsf:dictionary .

xsd:integer a rdfs:Datatype ;
    owl:equivalentClass [ owl:intersectionOf ( [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:maxInclusive 65535 ] ) ] ) ] .

xsd:string a rdfs:Datatype ;
    owl:equivalentClass [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "^[\\w.+\\-]+@[\\w\\-]+(\\.[\\w\\-]+)+$" ] ) ],
        [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" ] ) ],
        [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "^((\\d{1,3}\\.){3}\\d{1,3}|[0-9a-fA-F:]{2,39})/(\\d|[1-9]\\d|1[0-1]\\d|12[0-8])$" ] ) ],
        [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "^((\\d{1,3}\\.){3}\\d{1,3}|[0-9a-fA-F:]{2,39})$" ] ) ],
        [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "^([0-9a-fA-F]{2}[:\\-]){5}[0-9a-fA-F]{2}$" ] ) ] .



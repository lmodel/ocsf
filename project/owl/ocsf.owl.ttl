            owl:onProperty ocsf:data ],
        ocsf:Object ;
    skos:altLabel "TLS Extension" ;
    skos:definition "The TLS Extension object describes additional attributes that extend the base Transport Layer Security (TLS) object." ;
    skos:inScheme ocsf:objects .

ocsf:WindowsResourceActivityActivityIdEnum a owl:Class ;
    rdfs:label "WindowsResourceActivityActivityIdEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/ocsf/WindowsResourceActivityActivityIdEnum#ACCESS> <https://w3id.org/lmodel/ocsf/WindowsResourceActivityActivityIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/WindowsResourceActivityActivityIdEnum#OTHER> ) ;
    skos:definition "WindowsResourceActivity activity_id values." ;
    skos:inScheme ocsf:enums ;
    linkml:permissible_values <https://w3id.org/lmodel/ocsf/WindowsResourceActivityActivityIdEnum#ACCESS>,
        <https://w3id.org/lmodel/ocsf/WindowsResourceActivityActivityIdEnum#OTHER>,
        <https://w3id.org/lmodel/ocsf/WindowsResourceActivityActivityIdEnum#UNKNOWN> .

ocsf:access_list a owl:DatatypeProperty ;
    rdfs:label "access_list" ;
    rdfs:range xsd:string ;
    skos:altLabel "Access List" ;
    skos:definition "The list of requested access rights." ;
    skos:inScheme ocsf:dictionary .

ocsf:answers a owl:ObjectProperty ;
    rdfs:label "answers" ;
    rdfs:range ocsf:DnsAnswer ;
    skos:altLabel "DNS Answer" ;
    skos:definition "The Domain Name System (DNS) answers." ;
    skos:inScheme ocsf:dictionary .

ocsf:assessments a owl:ObjectProperty ;
    rdfs:label "assessments" ;
    rdfs:range ocsf:Assessment ;
    skos:altLabel "Assessments" ;
    skos:definition "A list of <code>assessment</code> objects. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:authorizations a owl:ObjectProperty ;
    rdfs:label "authorizations" ;
    rdfs:range ocsf:Authorization ;
    skos:altLabel "Authorization Information" ;
    skos:definition "Provides details about an authorization, such as authorization outcome, and any associated policies related to the activity/event." ;
    skos:inScheme ocsf:dictionary .

ocsf:certificate_chain a owl:DatatypeProperty ;
    rdfs:label "certificate_chain" ;
    rdfs:range xsd:string ;
    skos:altLabel "Certificate Chain" ;
    skos:definition "The Chain of Certificate Serial Numbers field provides a chain of Certificate Issuer Serial Numbers leading to the Root Certificate Issuer." ;
    skos:inScheme ocsf:dictionary .

ocsf:cis_controls a owl:ObjectProperty ;
    rdfs:label "cis_controls" ;
    rdfs:range ocsf:CisControl ;
    skos:altLabel "CIS Controls" ;
    skos:definition "The CIS Critical Security Controls is a prioritized set of actions to protect your organization and data from cyber-attack vectors." ;
    skos:inScheme ocsf:dictionary .

ocsf:condition_keys a owl:ObjectProperty ;
    rdfs:label "condition_keys" ;
    rdfs:range ocsf:KeyValueObject ;
    skos:altLabel "Condition Keys" ;
    skos:definition "The list of condition keys and their values that were evaluated as part of a rule or policy. Condition keys are used to define circumstances under which the rule/policy is in effect. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:containers a owl:ObjectProperty ;
    rdfs:label "containers" ;
    rdfs:range ocsf:Container ;
    skos:altLabel "Containers" ;
    skos:definition "When working with containerized applications, the set of containers which write to the standard the output of a particular logging driver. For example, this may be the set of containers involved in handling api requests and responses for a containerized application." ;
    skos:inScheme ocsf:dictionary .

ocsf:countermeasures a owl:ObjectProperty ;
    rdfs:label "countermeasures" ;
    rdfs:range ocsf:D3fend ;
    skos:altLabel "Countermeasures" ;
    skos:definition "The MITRE D3FEND™ Matrix Countermeasures associated with a remediation." ;
    skos:inScheme ocsf:dictionary .

ocsf:data_sources a owl:DatatypeProperty ;
    rdfs:label "data_sources" ;
    rdfs:range xsd:string ;
    skos:altLabel "Data Sources" ;
    skos:definition "A list of data sources utilized in generation of the finding." ;
    skos:inScheme ocsf:dictionary .

ocsf:evidences a owl:ObjectProperty ;
    rdfs:label "evidences" ;
    rdfs:range ocsf:Evidences ;
    skos:altLabel "Evidence Artifacts" ;
    skos:definition "A collection of evidence artifacts associated to the activity/activities that triggered a finding. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:files a owl:ObjectProperty ;
    rdfs:label "files" ;
    rdfs:range ocsf:File ;
    skos:altLabel "Files" ;
    skos:definition "The files that are part of the event or object." ;
    skos:inScheme ocsf:dictionary .

ocsf:fingerprints a owl:ObjectProperty ;
    rdfs:label "fingerprints" ;
    rdfs:range ocsf:Fingerprint ;
    skos:altLabel "Fingerprints" ;
    skos:definition "An array of digital fingerprint objects." ;
    skos:inScheme ocsf:dictionary .

ocsf:granted_privileges a owl:DatatypeProperty ;
    rdfs:label "granted_privileges" ;
    rdfs:range xsd:string ;
    skos:altLabel "Granted Privileges" ;
    skos:definition "The Privileges that were granted to the user via an IAM policy or otherwise. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:hashes a owl:ObjectProperty ;
    rdfs:label "hashes" ;
    rdfs:range ocsf:Fingerprint ;
    skos:altLabel "Hashes" ;
    skos:definition "An array of hash attributes." ;
    skos:inScheme ocsf:dictionary .

ocsf:ja4_fingerprint_list a owl:ObjectProperty ;
    rdfs:label "ja4_fingerprint_list" ;
    rdfs:range ocsf:Ja4Fingerprint ;
    skos:altLabel "JA4+ Fingerprints" ;
    skos:definition "A list of the JA4+ network fingerprints." ;
    skos:inScheme ocsf:dictionary .

ocsf:kb_articles a owl:DatatypeProperty ;
    rdfs:label "kb_articles" ;
    rdfs:range xsd:string ;
    skos:altLabel "Knowledgebase Articles" ;
    skos:definition "The KB article/s related to the entity. A KB Article contains metadata that describes the patch or an update." ;
    skos:inScheme ocsf:dictionary .

ocsf:metrics a owl:ObjectProperty ;
    rdfs:label "metrics" ;
    rdfs:range ocsf:Metric ;
    skos:altLabel "Metrics" ;
    skos:definition "The general purpose metrics associated with the event. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:observables a owl:ObjectProperty ;
    rdfs:label "observables" ;
    rdfs:range ocsf:Observable ;
    rdfs:seeAlso <https://github.com/ocsf/ocsf-docs/blob/main/articles/defining-and-using-observables.md> ;
    skos:altLabel "Observables" ;
    skos:definition "The observables associated with the event or a finding." ;
    skos:editorialNote "OCSF Observables FAQ — https://github.com/ocsf/ocsf-docs/blob/main/articles/defining-and-using-observables.md" ;
    skos:inScheme ocsf:dictionary .

ocsf:observations a owl:ObjectProperty ;
    rdfs:label "observations" ;
    rdfs:range ocsf:Observation ;
    skos:altLabel "Observations" ;
    skos:definition "A list of individual observations or measurements collected during analysis. Each observation captures a specific data point. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:osint a owl:ObjectProperty ;
    rdfs:label "osint" ;
    rdfs:range ocsf:Osint ;
    skos:altLabel "OSINT" ;
    skos:definition "The OSINT (Open Source Intelligence) object contains details related to an indicator such as the indicator itself, related indicators, geolocation, registrar information, subdomains, analyst commentary, and other contextual information. This information can be used to further enrich a detection or finding by providing decisioning support to other analysts and engineers." ;
    skos:inScheme ocsf:dictionary .

ocsf:policies a owl:ObjectProperty ;
    rdfs:label "policies" ;
    rdfs:range ocsf:Policy ;
    skos:altLabel "Policies" ;
    skos:definition "An array of <code>Policy</code> objects." ;
    skos:inScheme ocsf:dictionary .

ocsf:programmatic_credentials a owl:ObjectProperty ;
    rdfs:label "programmatic_credentials" ;
    rdfs:range ocsf:ProgrammaticCredential ;
    skos:altLabel "Programmatic Credentials" ;
    skos:definition "Details about the programmatic credential (API key, service account key, access token, certificate). See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:related_cwes a owl:ObjectProperty ;
    rdfs:label "related_cwes" ;
    rdfs:range ocsf:Cwe ;
    skos:altLabel "Related CWEs" ;
    skos:definition "Describes Common Weakness Enumeration <a target='_blank' href='https://cwe.mitre.org/'>(CWE)</a> entries that are related to an entity. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:related_events a owl:ObjectProperty ;
    rdfs:label "related_events" ;
    rdfs:range ocsf:RelatedEvent ;
    skos:altLabel "Related Events/Findings" ;
    skos:definition "Describes events and/or other findings related to the finding as identified by the security product. Note that these events may or may not be in OCSF." ;
    skos:inScheme ocsf:dictionary .

ocsf:sans a owl:ObjectProperty ;
    rdfs:label "sans" ;
    rdfs:range ocsf:San ;
    skos:altLabel "Subject Alternative Names" ;
    skos:definition "The list of subject alternative names that are secured by a specific certificate." ;
    skos:inScheme ocsf:dictionary .

ocsf:signatures a owl:ObjectProperty ;
    rdfs:label "signatures" ;
    rdfs:range ocsf:DigitalSignature ;
    skos:altLabel "Digital Signatures" ;
    skos:definition "A collection of <code>Digital Signature</code> objects." ;
    skos:inScheme ocsf:dictionary .

ocsf:standards a owl:DatatypeProperty ;
    rdfs:label "standards" ;
    rdfs:range xsd:string ;
    skos:altLabel "Compliance Standards: List" ;
    skos:definition "Compliance standards are a set of criteria organizations can follow to protect sensitive and confidential information. e.g. <code>NIST SP 800-53, CIS AWS Foundations Benchmark v1.4.0, ISO/IEC 27001</code>" ;
    skos:inScheme ocsf:dictionary .

ocsf:subdomains a owl:DatatypeProperty ;
    rdfs:label "subdomains" ;
    rdfs:range xsd:string ;
    skos:altLabel "Subdomains" ;
    skos:definition "An array of subdomain strings. Can be used to collect several subdomains such as those from Domain Generation Algorithms (DGAs)." ;
    skos:inScheme ocsf:dictionary .

ocsf:tickets a owl:ObjectProperty ;
    rdfs:label "tickets" ;
    rdfs:range ocsf:Ticket ;
    skos:altLabel "Tickets" ;
    skos:definition "The associated ticket(s) in the ticketing system. Each ticket contains details like ticket ID, status, etc." ;
    skos:inScheme ocsf:dictionary .

ocsf:to a owl:DatatypeProperty ;
    rdfs:label "to" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://www.rfc-editor.org/rfc/rfc5322> ;
    skos:altLabel "To" ;
    skos:definition "The machine-readable email header To values, as defined by RFC 5322. For example <code>example.user@usersdomain.com</code>" ;
    skos:editorialNote "RFC 5322 — https://www.rfc-editor.org/rfc/rfc5322" ;
    skos:inScheme ocsf:dictionary .

ocsf:traits a owl:ObjectProperty ;
    rdfs:label "traits" ;
    rdfs:range ocsf:Trait ;
    skos:altLabel "Traits" ;
    skos:definition "The traits that describe characteristics, features of an entity. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:types a owl:DatatypeProperty ;
    rdfs:label "types" ;
    rdfs:range xsd:string ;
    skos:altLabel "Types" ;
    skos:definition "The type/s of an entity. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:users a owl:ObjectProperty ;
    rdfs:label "users" ;
    rdfs:range ocsf:User ;
    skos:altLabel "Users" ;
    skos:definition "The users that pertain to the event or object." ;
    skos:inScheme ocsf:dictionary .

ocsf:values a owl:DatatypeProperty ;
    rdfs:label "values" ;
    rdfs:range xsd:string ;
    skos:altLabel "Values" ;
    skos:definition "An array of values associated to an attribute. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:web_resources a owl:ObjectProperty ;
    rdfs:label "web_resources" ;
    rdfs:range ocsf:WebResource ;
    skos:altLabel "Web Resources" ;
    skos:definition "Describes details about web resources that were affected by an activity/event." ;
    skos:inScheme ocsf:dictionary .

ocsf:Agent a owl:Class ;
    rdfs:label "Agent" ;
    rdfs:seeAlso <https://d3fend.mitre.org/dao/artifact/d3f:Sensor/> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:policies ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:uid_alt ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:vendor_name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:version ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:version ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:uid_alt ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:vendor_name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:uid_alt ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:type_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:type_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:AgentTypeIdEnum ;
            owl:onProperty ocsf:type_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:version ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Policy ;
            owl:onProperty ocsf:policies ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:vendor_name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:uid ],
        ocsf:Object ;
    skos:altLabel "Agent" ;
    skos:definition "An Agent (also known as a Sensor) is typically installed on an Operating System (OS) and serves as a specialized software component that can be designed to monitor, detect, collect, archive, or take action. These activities and possible actions are defined by the upstream system controlling the Agent and its intended purpose. For instance, an Agent can include Endpoint Detection & Response (EDR) agents, backup/disaster recovery sensors, Application Performance Monitoring or profiling sensors, and similar software." ;
    skos:editorialNote "D3FEND™ Ontology d3f:Sensor. — https://d3fend.mitre.org/dao/artifact/d3f:Sensor/" ;
    skos:inScheme ocsf:objects ;
    ocsf:ocsf_constraints "{\"at_least_one\": [\"uid\", \"name\"]}" .

ocsf:AirborneBroadcastActivityActivityIdEnum a owl:Class ;
    rdfs:label "AirborneBroadcastActivityActivityIdEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/ocsf/AirborneBroadcastActivityActivityIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/AirborneBroadcastActivityActivityIdEnum#CAPTURE> <https://w3id.org/lmodel/ocsf/AirborneBroadcastActivityActivityIdEnum#RECORD> <https://w3id.org/lmodel/ocsf/AirborneBroadcastActivityActivityIdEnum#OTHER> ) ;
    skos:definition "AirborneBroadcastActivity activity_id values." ;
    skos:inScheme ocsf:enums ;
    linkml:permissible_values <https://w3id.org/lmodel/ocsf/AirborneBroadcastActivityActivityIdEnum#CAPTURE>,
        <https://w3id.org/lmodel/ocsf/AirborneBroadcastActivityActivityIdEnum#OTHER>,
        <https://w3id.org/lmodel/ocsf/AirborneBroadcastActivityActivityIdEnum#RECORD>,
        <https://w3id.org/lmodel/ocsf/AirborneBroadcastActivityActivityIdEnum#UNKNOWN> .

ocsf:ApplicationErrorActivityIdEnum a owl:Class ;
    rdfs:label "ApplicationErrorActivityIdEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/ocsf/ApplicationErrorActivityIdEnum#GENERAL_ERROR> <https://w3id.org/lmodel/ocsf/ApplicationErrorActivityIdEnum#TRANSLATION_ERROR> <https://w3id.org/lmodel/ocsf/ApplicationErrorActivityIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/ApplicationErrorActivityIdEnum#OTHER> ) ;

ocsf:Attack a owl:Class ;
    rdfs:label "Attack" ;
    rdfs:seeAlso <https://atlas.mitre.org/matrices/ATLAS>,
        <https://attack.mitre.org> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:technique ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:version ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:version ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:mitigation ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:SubTechnique ;
            owl:onProperty ocsf:sub_technique ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:tactic ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:version ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:sub_technique ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:tactic ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Tactic ;
            owl:onProperty ocsf:tactics ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Tactic ;
            owl:onProperty ocsf:tactic ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Technique ;
            owl:onProperty ocsf:technique ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:sub_technique ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Mitigation ;
            owl:onProperty ocsf:mitigation ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:technique ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:mitigation ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:tactics ],
        ocsf:Object ;
    skos:altLabel "MITRE ATT&CK® & ATLAS™" ;
    skos:definition "The MITRE ATT&CK® & ATLAS™ object describes the tactic, technique, sub-technique & mitigation associated to an attack." ;
    skos:editorialNote "ATLAS™ Matrix — https://atlas.mitre.org/matrices/ATLAS",
        "ATT&CK® Matrix — https://attack.mitre.org" ;
    skos:exactMatch attack:AttackPattern,
        stix:AttackPattern,
        capec:AttackPattern ;
    skos:inScheme ocsf:objects ;
    ocsf:ocsf_constraints "{\"at_least_one\": [\"tactic\", \"technique\", \"sub_technique\"]}" .

ocsf:CheckSeverityIdEnum a owl:Class ;
    rdfs:label "CheckSeverityIdEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/ocsf/CheckSeverityIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/CheckSeverityIdEnum#INFORMATIONAL> <https://w3id.org/lmodel/ocsf/CheckSeverityIdEnum#LOW> <https://w3id.org/lmodel/ocsf/CheckSeverityIdEnum#MEDIUM> <https://w3id.org/lmodel/ocsf/CheckSeverityIdEnum#HIGH> <https://w3id.org/lmodel/ocsf/CheckSeverityIdEnum#CRITICAL> <https://w3id.org/lmodel/ocsf/CheckSeverityIdEnum#FATAL> <https://w3id.org/lmodel/ocsf/CheckSeverityIdEnum#OTHER> ) ;
    skos:definition "The normalized severity identifier that maps severity levels to standard severity levels. For example CIS Benchmark: <code>Level 2</code> maps to <code>4</code> (High), <code>Level 1</code> maps to <code>3</code> (Medium). For DISA STIG: <code>CAT I</code> maps to <code>5</code> (Critical), <code>CAT II</code> maps to <code>4</code> (High), and <code>CAT III</code> maps to <code>3</code> (Medium)." ;
    skos:inScheme ocsf:enums ;
    linkml:permissible_values <https://w3id.org/lmodel/ocsf/CheckSeverityIdEnum#CRITICAL>,
        <https://w3id.org/lmodel/ocsf/CheckSeverityIdEnum#FATAL>,
        <https://w3id.org/lmodel/ocsf/CheckSeverityIdEnum#HIGH>,
        <https://w3id.org/lmodel/ocsf/CheckSeverityIdEnum#INFORMATIONAL>,
        <https://w3id.org/lmodel/ocsf/CheckSeverityIdEnum#LOW>,
        <https://w3id.org/lmodel/ocsf/CheckSeverityIdEnum#MEDIUM>,
        <https://w3id.org/lmodel/ocsf/CheckSeverityIdEnum#OTHER>,
        <https://w3id.org/lmodel/ocsf/CheckSeverityIdEnum#UNKNOWN> .


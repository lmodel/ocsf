    owl:unionOf ( <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#KERNEL> <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#FILE> <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#FOLDER> <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#ADMIN_GROUP> <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#JOB> <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#MODULE> <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#NETWORK_CONNECTION> <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#NETWORK_INTERFACES> <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#PERIPHERAL_DEVICE> <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#PROCESS> <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#SERVICE> <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#SESSION> <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#USER> <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#USERS> <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#STARTUP_ITEM> <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#REGISTRY_KEY> <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#REGISTRY_VALUE> <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#PREFETCH> <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#OTHER> ) ;
    skos:definition "The normalized type of system query performed against a device or system component." ;
    skos:inScheme ocsf:enums ;
    linkml:permissible_values <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#ADMIN_GROUP>,
        <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#FILE>,
        <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#FOLDER>,
        <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#JOB>,
        <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#KERNEL>,
        <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#MODULE>,
        <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#NETWORK_CONNECTION>,
        <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#NETWORK_INTERFACES>,
        <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#OTHER>,
        <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#PERIPHERAL_DEVICE>,
        <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#PREFETCH>,
        <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#PROCESS>,
        <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#REGISTRY_KEY>,
        <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#REGISTRY_VALUE>,
        <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#SERVICE>,
        <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#SESSION>,
        <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#STARTUP_ITEM>,
        <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#UNKNOWN>,
        <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#USER>,
        <https://w3id.org/lmodel/ocsf/QueryTypeIdEnum#USERS> .

ocsf:confidence a owl:DatatypeProperty ;
    rdfs:label "confidence" ;
    rdfs:range xsd:string ;
    skos:altLabel "Confidence" ;
    skos:definition "The confidence, normalized to the caption of the confidence_id value. In the case of 'Other', it is defined by the event source." ;
    skos:inScheme ocsf:dictionary .

ocsf:confidence_id a owl:ObjectProperty ;
    rdfs:label "confidence_id" ;
    rdfs:range ocsf:ConfidenceIdEnum ;
    skos:altLabel "Confidence ID" ;
    skos:definition "The normalized confidence refers to the accuracy of the rule that created the finding. A rule with a low confidence means that the finding scope is wide and may create finding reports that may not be malicious in nature." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "confidence" .

ocsf:ip a owl:DatatypeProperty ;
    rdfs:label "ip" ;
    rdfs:range xsd:string ;
    skos:altLabel "IP Address" ;
    skos:definition "The IP address, in either IPv4 or IPv6 format." ;
    skos:inScheme ocsf:dictionary .

ocsf:last_seen_time a owl:DatatypeProperty ;
    rdfs:label "last_seen_time" ;
    rdfs:range xsd:long ;
    skos:altLabel "Last Seen" ;
    skos:definition "The most recent detection time of the activity or object. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:provider a owl:DatatypeProperty ;
    rdfs:label "provider" ;
    rdfs:range xsd:string ;
    skos:altLabel "Provider" ;
    skos:definition "The origin of information associated with the event. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:region a owl:DatatypeProperty ;
    rdfs:label "region" ;
    rdfs:range xsd:string ;
    skos:altLabel "Region" ;
    skos:definition "The name or the code of a region. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:risk_level a owl:DatatypeProperty ;
    rdfs:label "risk_level" ;
    rdfs:range xsd:string ;
    skos:altLabel "Risk Level" ;
    skos:definition "The risk level, normalized to the caption of the risk_level_id value." ;
    skos:inScheme ocsf:dictionary .

ocsf:risk_level_id a owl:ObjectProperty ;
    rdfs:label "risk_level_id" ;
    rdfs:range ocsf:RiskLevelIdEnum ;
    skos:altLabel "Risk Level ID" ;
    skos:definition "The normalized risk level id." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "risk_level" ;
    ocsf:suppress_checks "enum_convention" .

ocsf:service a owl:ObjectProperty ;
    rdfs:label "service" ;
    rdfs:range ocsf:Service ;
    skos:altLabel "Service" ;
    skos:definition "The service that pertains to the event." ;
    skos:inScheme ocsf:dictionary .

ocsf:AccountTypeIdEnum a owl:Class ;
    rdfs:label "AccountTypeIdEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#LDAP_ACCOUNT> <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#WINDOWS_ACCOUNT> <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#AWS_IAM_USER> <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#AWS_IAM_ROLE> <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#GCP_ACCOUNT> <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#AZURE_AD_ACCOUNT> <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#MAC_OS_ACCOUNT> <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#APPLE_ACCOUNT> <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#LINUX_ACCOUNT> <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#AWS_ACCOUNT> <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#GCP_PROJECT> <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#OCI_COMPARTMENT> <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#AZURE_SUBSCRIPTION> <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#SALESFORCE_ACCOUNT> <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#GOOGLE_WORKSPACE> <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#SERVICENOW_INSTANCE> <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#M365_TENANT> <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#EMAIL_ACCOUNT> <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#ACTIVEDIRECTORY_ACCOUNT> <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#OTHER> ) ;
    skos:definition "The normalized account type identifier." ;
    skos:inScheme ocsf:enums ;
    linkml:permissible_values <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#ACTIVEDIRECTORY_ACCOUNT>,
        <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#APPLE_ACCOUNT>,
        <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#AWS_ACCOUNT>,
        <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#AWS_IAM_ROLE>,
        <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#AWS_IAM_USER>,
        <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#AZURE_AD_ACCOUNT>,
        <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#AZURE_SUBSCRIPTION>,
        <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#EMAIL_ACCOUNT>,
        <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#GCP_ACCOUNT>,
        <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#GCP_PROJECT>,
        <https://w3id.org/lmodel/ocsf/AccountTypeIdEnum#GOOGLE_WORKSPACE>,

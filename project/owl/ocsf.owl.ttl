<https://w3id.org/lmodel/ocsf/NetworkConnectionQueryStateIdEnum#CLOSED> a owl:Class ;
    rdfs:label "CLOSED" ;
    rdfs:subClassOf ocsf:NetworkConnectionQueryStateIdEnum ;
    skos:definition "The socket is not in use." ;
    ocsf:caption "CLOSED" ;
    ocsf:ocsf_uid "7" .

<https://w3id.org/lmodel/ocsf/NetworkConnectionQueryStateIdEnum#CLOSE_WAIT> a owl:Class ;
    rdfs:label "CLOSE_WAIT" ;
    rdfs:subClassOf ocsf:NetworkConnectionQueryStateIdEnum ;
    skos:definition "The socket connection has been closed by the remote peer, and the system is waiting for the local application to close its half of the connection." ;
    ocsf:caption "CLOSE_WAIT" ;
    ocsf:ocsf_uid "8" .

<https://w3id.org/lmodel/ocsf/NetworkConnectionQueryStateIdEnum#CLOSING> a owl:Class ;
    rdfs:label "CLOSING" ;
    rdfs:subClassOf ocsf:NetworkConnectionQueryStateIdEnum ;
    skos:definition "The socket connection has been closed by the local application and the remote peer simultaneously, and the remote peer has not yet acknowledged the close attempt of the local application." ;
    ocsf:caption "CLOSING" ;
    ocsf:ocsf_uid "11" .

<https://w3id.org/lmodel/ocsf/NetworkConnectionQueryStateIdEnum#ESTABLISHED> a owl:Class ;
    rdfs:label "ESTABLISHED" ;
    rdfs:subClassOf ocsf:NetworkConnectionQueryStateIdEnum ;
    skos:definition "The socket has an established connection between a local application and a remote peer." ;
    ocsf:caption "ESTABLISHED" ;
    ocsf:ocsf_uid "1" .

<https://w3id.org/lmodel/ocsf/NetworkConnectionQueryStateIdEnum#FIN_WAIT1> a owl:Class ;
    rdfs:label "FIN_WAIT1" ;
    rdfs:subClassOf ocsf:NetworkConnectionQueryStateIdEnum ;
    skos:definition "The socket connection has been closed by the local application, the remote peer has not yet acknowledged the close, and the system is waiting for it to close its half of the connection." ;
    ocsf:caption "FIN_WAIT1" ;
    ocsf:ocsf_uid "4" .

<https://w3id.org/lmodel/ocsf/NetworkConnectionQueryStateIdEnum#FIN_WAIT2> a owl:Class ;
    rdfs:label "FIN_WAIT2" ;
    rdfs:subClassOf ocsf:NetworkConnectionQueryStateIdEnum ;
    skos:definition "The socket connection has been closed by the local application, the remote peer has acknowledged the close, and the system is waiting for it to close its half of the connection." ;
    ocsf:caption "FIN_WAIT2" ;
    ocsf:ocsf_uid "5" .

<https://w3id.org/lmodel/ocsf/NetworkConnectionQueryStateIdEnum#LAST_ACK> a owl:Class ;
    rdfs:label "LAST_ACK" ;
    rdfs:subClassOf ocsf:NetworkConnectionQueryStateIdEnum ;
    skos:definition "The socket connection has been closed by the remote peer, the local application has closed its half of the connection, and the system is waiting for the remote peer to acknowledge the close." ;
    ocsf:caption "LAST_ACK" ;
    ocsf:ocsf_uid "9" .

<https://w3id.org/lmodel/ocsf/NetworkConnectionQueryStateIdEnum#LISTEN> a owl:Class ;
    rdfs:label "LISTEN" ;
    rdfs:subClassOf ocsf:NetworkConnectionQueryStateIdEnum ;
    skos:definition "The socket is listening for incoming connections." ;
    ocsf:caption "LISTEN" ;
    ocsf:ocsf_uid "10" .

<https://w3id.org/lmodel/ocsf/NetworkConnectionQueryStateIdEnum#OTHER> a owl:Class ;
    rdfs:label "OTHER" ;
    rdfs:subClassOf ocsf:NetworkConnectionQueryStateIdEnum ;
    skos:definition "The state is not mapped. See the <code>state</code> attribute, which contains a data source specific value." ;
    ocsf:caption "Other" ;
    ocsf:ocsf_uid "99" .

<https://w3id.org/lmodel/ocsf/NetworkConnectionQueryStateIdEnum#SYN_RECV> a owl:Class ;
    rdfs:label "SYN_RECV" ;
    rdfs:subClassOf ocsf:NetworkConnectionQueryStateIdEnum ;
    skos:definition "The socket has passively received a connection request from a remote peer." ;
    ocsf:caption "SYN_RECV" ;
    ocsf:ocsf_uid "3" .

<https://w3id.org/lmodel/ocsf/NetworkConnectionQueryStateIdEnum#SYN_SENT> a owl:Class ;
    rdfs:label "SYN_SENT" ;
    rdfs:subClassOf ocsf:NetworkConnectionQueryStateIdEnum ;
    skos:definition "The socket is actively trying to establish a connection to a remote peer." ;
    ocsf:caption "SYN_SENT" ;
    ocsf:ocsf_uid "2" .

<https://w3id.org/lmodel/ocsf/NetworkConnectionQueryStateIdEnum#TIME_WAIT> a owl:Class ;
    rdfs:label "TIME_WAIT" ;
    rdfs:subClassOf ocsf:NetworkConnectionQueryStateIdEnum ;
    skos:definition "The socket connection has been closed by the local application, the remote peer has closed its half of the connection, and the system is waiting to be sure that the remote peer received the last acknowledgement." ;
    ocsf:caption "TIME_WAIT" ;
    ocsf:ocsf_uid "6" .

<https://w3id.org/lmodel/ocsf/NetworkConnectionQueryStateIdEnum#UNKNOWN> a owl:Class ;
    rdfs:label "UNKNOWN" ;
    rdfs:subClassOf ocsf:NetworkConnectionQueryStateIdEnum ;
    skos:definition "The socket state is unknown." ;
    ocsf:caption "Unknown" ;
    ocsf:ocsf_uid "0" .

<https://w3id.org/lmodel/ocsf/NetworkEventObservationPointIdEnum#BOTH> a owl:Class ;
    rdfs:label "BOTH" ;
    rdfs:subClassOf ocsf:NetworkEventObservationPointIdEnum ;
    skos:definition "Both the source and destination network endpoint are the observation point. This typically occurs in localhost or internal communications where the source and destination are the same endpoint, often resulting in a <code>connection_info.direction</code> of <code>Local</code>." ;

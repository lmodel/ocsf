ocsf:WindowsServiceCategoryIdEnum a owl:Class ;
    rdfs:label "WindowsServiceCategoryIdEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/ocsf/WindowsServiceCategoryIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/WindowsServiceCategoryIdEnum#KERNEL_MODE> <https://w3id.org/lmodel/ocsf/WindowsServiceCategoryIdEnum#USER_MODE> <https://w3id.org/lmodel/ocsf/WindowsServiceCategoryIdEnum#OTHER> ) ;
    skos:definition "The normalized identifier of the service category." ;
    skos:inScheme ocsf:enums ;
    linkml:permissible_values <https://w3id.org/lmodel/ocsf/WindowsServiceCategoryIdEnum#KERNEL_MODE>,
        <https://w3id.org/lmodel/ocsf/WindowsServiceCategoryIdEnum#OTHER>,
        <https://w3id.org/lmodel/ocsf/WindowsServiceCategoryIdEnum#UNKNOWN>,
        <https://w3id.org/lmodel/ocsf/WindowsServiceCategoryIdEnum#USER_MODE> .

ocsf:account a owl:ObjectProperty ;
    rdfs:label "account" ;
    rdfs:range ocsf:Account ;
    skos:altLabel "Account" ;
    skos:definition "The account object describes details about the account that was the source or target of the activity. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:actual_permissions a owl:DatatypeProperty ;
    rdfs:label "actual_permissions" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Actual Permissions" ;
    skos:definition "The permissions that were granted in a platform-native format. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:agent_list a owl:ObjectProperty ;
    rdfs:label "agent_list" ;
    rdfs:range ocsf:Agent ;
    skos:altLabel "Agent List" ;
    skos:definition "A list of <code>agent</code> objects associated with a device, endpoint, or resource." ;
    skos:inScheme ocsf:dictionary .

ocsf:analytic a owl:ObjectProperty ;
    rdfs:label "analytic" ;
    rdfs:range ocsf:Analytic ;
    skos:altLabel "Analytic" ;
    skos:definition "The analytic technique used to analyze and derive insights from the data or information that led to the finding or conclusion." ;
    skos:inScheme ocsf:dictionary .

ocsf:analyzed_privileges_count a owl:DatatypeProperty ;
    rdfs:label "analyzed_privileges_count" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Analyzed Privileges Count" ;
    skos:definition "The total count of privileges that were analyzed. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:app_name a owl:DatatypeProperty ;
    rdfs:label "app_name" ;
    rdfs:range xsd:string ;
    skos:altLabel "Application Name" ;
    skos:definition "The name of the application associated with the event or object." ;
    skos:inScheme ocsf:dictionary .

ocsf:application a owl:ObjectProperty ;
    rdfs:label "application" ;
    rdfs:range ocsf:ApplicationObject ;
    skos:altLabel "Application" ;
    skos:definition "An Application describes the details for an inventoried application as reported by an Application Security tool or other Developer-centric tooling. Applications can be defined as Kubernetes resources, Containerized resources, or application hosting-specific cloud sources such as AWS Elastic BeanStalk, AWS Lightsail, or Azure Logic Apps." ;
    skos:inScheme ocsf:dictionary .

ocsf:assignee a owl:ObjectProperty ;
    rdfs:label "assignee" ;
    rdfs:range ocsf:User ;
    skos:altLabel "Assignee" ;
    skos:definition "The details of the user assigned to an Incident." ;
    skos:inScheme ocsf:dictionary .

ocsf:assignee_group a owl:ObjectProperty ;
    rdfs:label "assignee_group" ;
    rdfs:range ocsf:Group ;
    skos:altLabel "Assignee Group" ;
    skos:definition "The details of the group assigned to an Incident." ;
    skos:inScheme ocsf:dictionary .

ocsf:auth_factors a owl:ObjectProperty ;
    rdfs:label "auth_factors" ;
    rdfs:range ocsf:AuthFactor ;
    skos:altLabel "Authentication Factors" ;
    skos:definition "Describes a category of methods used for identity verification. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:avg_timespan a owl:ObjectProperty ;
    rdfs:label "avg_timespan" ;
    rdfs:range ocsf:Timespan ;
    skos:altLabel "Average Timespan" ;
    skos:definition "The average time span of an activity." ;
    skos:inScheme ocsf:dictionary .

ocsf:base_address a owl:DatatypeProperty ;
    rdfs:label "base_address" ;
    rdfs:range xsd:string ;
    skos:altLabel "Base Address" ;
    skos:definition "The memory address where the module was loaded." ;
    skos:inScheme ocsf:dictionary .

ocsf:base_score a owl:DatatypeProperty ;
    rdfs:label "base_score" ;
    rdfs:range xsd:float ;
    skos:altLabel "Base Score" ;
    skos:definition "The base score as reported by the event source. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:body_length a owl:DatatypeProperty ;
    rdfs:label "body_length" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Body Length not including header" ;
    skos:definition "The actual length of the HTTP response/request body, in number of bytes, independent of a potentially existing Content-Length header." ;
    skos:inScheme ocsf:dictionary .

ocsf:bulletin a owl:DatatypeProperty ;
    rdfs:label "bulletin" ;
    rdfs:range xsd:string ;
    skos:altLabel "Patch Bulletin" ;
    skos:definition "The vendor bulletin identifier." ;
    skos:inScheme ocsf:dictionary .

ocsf:bytes a owl:DatatypeProperty ;
    rdfs:label "bytes" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Total Bytes" ;
    skos:definition "The total number of bytes (in and out)." ;
    skos:inScheme ocsf:dictionary .

ocsf:cloud a owl:ObjectProperty ;
    rdfs:label "cloud" ;
    rdfs:range ocsf:Cloud ;
    skos:altLabel "Cloud" ;
    skos:definition "Describes details about the Cloud environment where the event or finding was created." ;
    skos:inScheme ocsf:dictionary .

ocsf:command_uid a owl:DatatypeProperty ;
    rdfs:label "command_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "Command UID" ;
    skos:definition "The unique command identifier." ;
    skos:inScheme ocsf:dictionary .

ocsf:confidentiality a owl:DatatypeProperty ;
    rdfs:label "confidentiality" ;
    rdfs:range xsd:string ;
    skos:altLabel "Confidentiality" ;
    skos:definition "The file content confidentiality, normalized to the confidentiality_id value. In the case of 'Other', it is defined by the event source." ;
    skos:inScheme ocsf:dictionary .

ocsf:confidentiality_id a owl:ObjectProperty ;
    rdfs:label "confidentiality_id" ;
    rdfs:range ocsf:ConfidentialityIdEnum ;
    skos:altLabel "Confidentiality ID" ;
    skos:definition "The normalized identifier of the file content confidentiality indicator." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "confidentiality" .

ocsf:control a owl:DatatypeProperty ;
    rdfs:label "control" ;
    rdfs:range xsd:string ;
    skos:altLabel "Security Control" ;
    skos:definition "A Control is prescriptive, prioritized, and simplified set of best practices that one can use to strengthen their cybersecurity posture. e.g. AWS SecurityHub Controls, CIS Controls." ;
    skos:inScheme ocsf:dictionary .

ocsf:country a owl:DatatypeProperty ;
    rdfs:label "country" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://www.iso.org/obp/ui/#iso:pub:PUB500001:en> ;
    skos:altLabel "Country" ;
    skos:definition "The ISO 3166-1 Alpha-2 country code.<p><b>Note:</b> The two letter country code should be capitalized. For example: <code>US</code> or <code>CA</code>.</p>" ;
    skos:editorialNote "ISO 3166-1 alpha-2 codes — https://www.iso.org/obp/ui/#iso:pub:PUB500001:en" ;
    skos:inScheme ocsf:dictionary ;
    ocsf:observable_id 14 .

ocsf:cpu_bits a owl:DatatypeProperty ;
    rdfs:label "cpu_bits" ;
    rdfs:range xsd:integer ;
    skos:altLabel "CPU Bits" ;
    skos:definition "The cpu architecture, the number of bits used for addressing in memory. For example: <code>32</code> or <code>64</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:create_mask a owl:DatatypeProperty ;
    rdfs:label "create_mask" ;
    rdfs:range xsd:string ;
    skos:altLabel "Create Mask" ;
    skos:definition "The original Windows mask that is required to create the object." ;
    skos:inScheme ocsf:dictionary .

ocsf:creator a owl:ObjectProperty ;
    rdfs:label "creator" ;
    rdfs:range ocsf:User ;
    skos:altLabel "Creator" ;
    skos:definition "The user that created the object associated with event. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:credential_uid a owl:DatatypeProperty ;
    rdfs:label "credential_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "User Credential ID" ;
    skos:definition "The unique identifier of the user's credential. For example, AWS Access Key ID." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:observable_id 19 .

ocsf:cwe a owl:ObjectProperty ;
    rdfs:label "cwe" ;
    rdfs:range ocsf:Cwe ;
    skos:altLabel "CWE" ;
    skos:definition "The CWE object represents a weakness in a software system that can be exploited by a threat actor to perform an attack. The CWE object is based on the <a target='_blank' href='https://cwe.mitre.org/'>Common Weakness Enumeration (CWE)</a> catalog." ;
    skos:inScheme ocsf:dictionary .

ocsf:detection_pattern a owl:DatatypeProperty ;
    rdfs:label "detection_pattern" ;
    rdfs:range xsd:string ;
    skos:altLabel "Detection Pattern" ;
    skos:definition "Specific pattern, algorithm, fingerprint, or model used for detection." ;
    skos:inScheme ocsf:dictionary .

ocsf:direction a owl:DatatypeProperty ;
    rdfs:label "direction" ;
    rdfs:range xsd:string ;
    skos:altLabel "Direction" ;
    skos:definition "The direction of the initiated connection, traffic, or email, normalized to the caption of the direction_id value. In the case of 'Other', it is defined by the event source." ;
    skos:inScheme ocsf:dictionary .

ocsf:direction_id a owl:ObjectProperty ;
    rdfs:label "direction_id" ;
    rdfs:range ocsf:DirectionIdEnum ;
    skos:altLabel "Direction ID" ;
    skos:definition "The normalized identifier of the direction of the initiated connection, traffic, or email." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "direction" .

ocsf:display_name a owl:DatatypeProperty ;
    rdfs:label "display_name" ;
    rdfs:range xsd:string ;
    skos:altLabel "Display Name" ;
    skos:definition "The display name. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:driver a owl:ObjectProperty ;
    rdfs:label "driver" ;
    rdfs:range ocsf:KernelDriver ;
    skos:altLabel "Kernel Driver" ;
    skos:definition "The driver that was loaded/unloaded into the kernel" ;
    skos:inScheme ocsf:dictionary .

ocsf:duration_mins a owl:DatatypeProperty ;
    rdfs:label "duration_mins" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Duration Minutes" ;
    skos:definition "Represents the duration of the activity in minutes. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:egid a owl:DatatypeProperty ;
    rdfs:label "egid" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Effective Group ID" ;
    skos:definition "The effective group under which this process is running." ;
    skos:inScheme ocsf:dictionary .

ocsf:email_auth a owl:ObjectProperty ;
    rdfs:label "email_auth" ;
    rdfs:range ocsf:EmailAuth ;
    skos:altLabel "Email Authentication" ;
    skos:definition "The SPF, DKIM and DMARC attributes of an email." ;
    skos:inScheme ocsf:dictionary .

ocsf:email_uid a owl:DatatypeProperty ;
    rdfs:label "email_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "Email UID" ;
    skos:definition "The unique identifier of the email, used to correlate related email alert and activity events." ;
    skos:inScheme ocsf:dictionary .

ocsf:end_line a owl:DatatypeProperty ;
    rdfs:label "end_line" ;
    rdfs:range xsd:integer ;
    skos:altLabel "End Line" ;
    skos:definition "The line number of the last line of code block identified as vulnerable." ;
    skos:inScheme ocsf:dictionary .

ocsf:error a owl:DatatypeProperty ;
    rdfs:label "error" ;
    rdfs:range xsd:string ;
    skos:altLabel "Error Code" ;
    skos:definition "Error Code" ;
    skos:inScheme ocsf:dictionary .

ocsf:euid a owl:DatatypeProperty ;
    rdfs:label "euid" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Effective User ID" ;
    skos:definition "The effective user under which this process is running." ;
    skos:inScheme ocsf:dictionary .

ocsf:event_uid a owl:DatatypeProperty ;
    rdfs:label "event_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "Event UID" ;
    skos:definition "The unique identifier of an event. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:file_result a owl:ObjectProperty ;
    rdfs:label "file_result" ;
    rdfs:range ocsf:File ;
    skos:altLabel "File Result" ;
    skos:definition "The result of the file change. It should contain the new values of the changed attributes." ;
    skos:inScheme ocsf:dictionary .

ocsf:fingerprint a owl:ObjectProperty ;
    rdfs:label "fingerprint" ;
    rdfs:range ocsf:Fingerprint ;
    skos:altLabel "Fingerprint" ;
    skos:definition "The digital fingerprint associated with an object." ;
    skos:inScheme ocsf:dictionary .

ocsf:folder a owl:ObjectProperty ;
    rdfs:label "folder" ;
    rdfs:range ocsf:File ;
    skos:altLabel "Folder" ;
    skos:definition "The folder that pertains to the event." ;
    skos:inScheme ocsf:dictionary .

ocsf:from_ a owl:DatatypeProperty ;
    rdfs:label "from_" ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <https://www.rfc-editor.org/rfc/rfc5322> ;
    skos:altLabel "From" ;
    skos:definition "The machine-readable email header From value, as defined by RFC 5322. For example <code>example.user@usersdomain.com</code>." ;
    skos:editorialNote "RFC 5322 — https://www.rfc-editor.org/rfc/rfc5322" ;
    skos:inScheme ocsf:dictionary .

ocsf:has_mfa a owl:DatatypeProperty ;
    rdfs:label "has_mfa" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "MFA Assigned" ;
    skos:definition "The user has a multi-factor or secondary-factor device assigned." ;
    skos:inScheme ocsf:dictionary .

ocsf:http_headers a owl:ObjectProperty ;
    rdfs:label "http_headers" ;
    rdfs:range ocsf:HttpHeader ;
    skos:altLabel "HTTP Headers" ;
    skos:definition "Additional HTTP headers of an HTTP request or response." ;
    skos:inScheme ocsf:dictionary .

ocsf:hw_info a owl:ObjectProperty ;
    rdfs:label "hw_info" ;
    rdfs:range ocsf:DeviceHwInfo ;
    skos:altLabel "Hardware Info" ;
    skos:definition "The endpoint hardware information." ;
    skos:inScheme ocsf:dictionary .

ocsf:idp a owl:ObjectProperty ;
    rdfs:label "idp" ;
    rdfs:range ocsf:Idp ;
    skos:altLabel "Identity Provider" ;
    skos:definition "This object describes details about the Identity Provider used." ;
    skos:inScheme ocsf:dictionary .

ocsf:image a owl:ObjectProperty ;
    rdfs:label "image" ;
    rdfs:range ocsf:Image ;
    skos:altLabel "Image" ;
    skos:definition "The image used as a template to run a container or virtual machine." ;
    skos:inScheme ocsf:dictionary .

ocsf:install_state a owl:DatatypeProperty ;
    rdfs:label "install_state" ;
    rdfs:range xsd:string ;
    skos:altLabel "Install State" ;
    skos:definition "The install state, normalized to the caption of install_state_id. In the case of 'Other', it is defined by the event source." ;
    skos:inScheme ocsf:dictionary .

ocsf:install_state_id a owl:ObjectProperty ;
    rdfs:label "install_state_id" ;
    rdfs:range ocsf:InstallStateIdEnum ;
    skos:altLabel "Install State ID" ;
    skos:definition "The normalized state of the install." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "install_state" .

ocsf:is_directed a owl:DatatypeProperty ;
    rdfs:label "is_directed" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Directed" ;
    skos:definition "Indicates if the entity has directionality. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_encrypted a owl:DatatypeProperty ;
    rdfs:label "is_encrypted" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Encrypted" ;
    skos:definition "Indicates if the entity was encrypted. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_mfa a owl:DatatypeProperty ;
    rdfs:label "is_mfa" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Multi Factor Authentication" ;
    skos:definition "Indicates whether Multi Factor Authentication was used during authentication." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_public a owl:DatatypeProperty ;
    rdfs:label "is_public" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Public" ;
    skos:definition "Determination of the public accessibility. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_remote a owl:DatatypeProperty ;
    rdfs:label "is_remote" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Remote" ;
    skos:definition "The indication of whether the session is remote." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_renewable a owl:DatatypeProperty ;
    rdfs:label "is_renewable" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Renewable" ;
    skos:definition "The indication of whether something is renewable. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_superseded a owl:DatatypeProperty ;
    rdfs:label "is_superseded" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "The patch is superseded." ;
    skos:definition "The vendor patch has been replaced by another." ;
    skos:inScheme ocsf:dictionary .

ocsf:is_suspected_breach a owl:DatatypeProperty ;
    rdfs:label "is_suspected_breach" ;
    rdfs:range xsd:boolean ;
    skos:altLabel "Suspected Breach" ;
    skos:definition "A determination based on analytics as to whether a potential breach was found." ;
    skos:inScheme ocsf:dictionary .

ocsf:isp_org a owl:DatatypeProperty ;
    rdfs:label "isp_org" ;
    rdfs:range xsd:string ;
    skos:altLabel "ISP Org" ;
    skos:definition "The organization name of the Internet Service Provider (ISP). This represents the parent organization or company that owns/operates the ISP. For example, Comcast Corporation would be the ISP org for Xfinity internet service. This attribute helps identify the ultimate provider when ISPs operate under different brand names." ;
    skos:inScheme ocsf:dictionary .

ocsf:kb_article_list a owl:ObjectProperty ;
    rdfs:label "kb_article_list" ;
    rdfs:range ocsf:KbArticle ;
    skos:altLabel "Knowledgebase Articles" ;
    skos:definition "A list of KB articles or patches related to an endpoint. A KB Article contains metadata that describes the patch or an update." ;
    skos:inScheme ocsf:dictionary .

ocsf:key_length a owl:DatatypeProperty ;
    rdfs:label "key_length" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Key Length" ;
    skos:definition "The length of the encryption key." ;
    skos:inScheme ocsf:dictionary .

ocsf:keyboard_info a owl:ObjectProperty ;
    rdfs:label "keyboard_info" ;
    rdfs:range ocsf:KeyboardInfo ;
    skos:altLabel "Keyboard Information" ;
    skos:definition "The keyboard detailed information." ;
    skos:inScheme ocsf:dictionary .

ocsf:length a owl:DatatypeProperty ;
    rdfs:label "length" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Response Length" ;
    skos:definition "The HTTP response length, in number of bytes." ;
    skos:inScheme ocsf:dictionary .

ocsf:license a owl:DatatypeProperty ;
    rdfs:label "license" ;
    rdfs:range xsd:string ;
    skos:altLabel "Software License" ;
    skos:definition "The name or identifier of the license applied on package or software. See <a target='_blank' href='https://spdx.org/licenses/'>SPDX License List</a>." ;
    skos:inScheme ocsf:dictionary .

ocsf:log_format a owl:DatatypeProperty ;
    rdfs:label "log_format" ;
    rdfs:range xsd:string ;
    skos:altLabel "Log Format" ;
    skos:definition "The format of data in the log. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:log_level a owl:DatatypeProperty ;
    rdfs:label "log_level" ;
    rdfs:range xsd:string ;
    skos:altLabel "Log Level" ;
    skos:definition "The log specific level at which an event was generated. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:log_version a owl:DatatypeProperty ;
    rdfs:label "log_version" ;
    rdfs:range xsd:string ;
    skos:altLabel "Log Version" ;
    skos:definition "The log version. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:logged_time a owl:DatatypeProperty ;
    rdfs:label "logged_time" ;
    rdfs:range xsd:long ;
    skos:altLabel "Logged Time" ;
    skos:definition "<p>The time when the logging system collected and logged the event.</p>This attribute is distinct from the event time in that event time typically contain the time extracted from the original event. Most of the time, these two times will be different." ;
    skos:inScheme ocsf:dictionary .

ocsf:mac a owl:DatatypeProperty ;
    rdfs:label "mac" ;
    rdfs:range xsd:string ;
    skos:altLabel "MAC Address" ;
    skos:definition "The Media Access Control (MAC) address that is associated with the network interface." ;
    skos:inScheme ocsf:dictionary .

ocsf:malware_scan_info a owl:ObjectProperty ;
    rdfs:label "malware_scan_info" ;
    rdfs:range ocsf:MalwareScanInfo ;
    skos:altLabel "Malware Scan Info" ;
    skos:definition "Describes details about the scan job that identified malware on the target system." ;
    skos:inScheme ocsf:dictionary .

ocsf:network_interfaces a owl:ObjectProperty ;
    rdfs:label "network_interfaces" ;
    rdfs:range ocsf:NetworkInterface ;
    skos:altLabel "Network Interfaces" ;
    skos:definition "The physical or virtual network interfaces that are associated with the device, one for each unique MAC address/IP address/hostname/name combination.<p><b>Note:</b> The first element of the array is the network information that pertains to the event.</p>" ;
    skos:inScheme ocsf:dictionary .

ocsf:num_files a owl:DatatypeProperty ;
    rdfs:label "num_files" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Scanned Files" ;
    skos:definition "The number of files scanned." ;
    skos:inScheme ocsf:dictionary .

ocsf:num_infected a owl:DatatypeProperty ;
    rdfs:label "num_infected" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Number of Infected Entities" ;
    skos:definition "The number of infected entities. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:observation_parameter a owl:DatatypeProperty ;
    rdfs:label "observation_parameter" ;
    rdfs:range xsd:string ;
    skos:altLabel "Observation Parameter" ;
    skos:definition "The name of the parameter being analyzed or monitored. This generally identifies the specific characteristic or property being measured. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:observation_type a owl:DatatypeProperty ;
    rdfs:label "observation_type" ;
    rdfs:range xsd:string ;
    skos:altLabel "Observation Type" ;
    skos:definition "The classification or category of the observation, indicating what kind of measurement or finding it represents. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:observed_pattern a owl:DatatypeProperty ;
    rdfs:label "observed_pattern" ;
    rdfs:range xsd:string ;
    skos:altLabel "Observed Pattern" ;
    skos:definition "A detected pattern or trend identified in the analyzed data, describing recurring activities or characteristics." ;
    skos:inScheme ocsf:dictionary .

ocsf:operation a owl:DatatypeProperty ;
    rdfs:label "operation" ;
    rdfs:range xsd:string ;
    skos:altLabel "Operation" ;
    skos:definition "Verb/Operation associated with the request" ;
    skos:inScheme ocsf:dictionary .

ocsf:package a owl:ObjectProperty ;
    rdfs:label "package" ;
    rdfs:range ocsf:Package ;
    rdfs:seeAlso <https://d3fend.mitre.org/dao/artifact/d3f:SoftwarePackage/> ;
    skos:altLabel "Software Package" ;
    skos:definition "The Software Package object describes details about a software package." ;
    skos:editorialNote "D3FEND™ Ontology d3f:SoftwarePackage. — https://d3fend.mitre.org/dao/artifact/d3f:SoftwarePackage/" ;
    skos:inScheme ocsf:dictionary .

ocsf:parent_uid a owl:DatatypeProperty ;
    rdfs:label "parent_uid" ;
    rdfs:range xsd:string ;
    skos:altLabel "Parent Unique ID" ;
    skos:definition "The unique identifier of an object's parent object. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:priority a owl:DatatypeProperty ;
    rdfs:label "priority" ;
    rdfs:range xsd:string ;
    skos:altLabel "Priority" ;
    skos:definition "The priority, normalized to the caption of the priority_id value. In the case of 'Other', it is defined by the event source." ;
    skos:inScheme ocsf:dictionary .

ocsf:priority_id a owl:ObjectProperty ;
    rdfs:label "priority_id" ;
    rdfs:range ocsf:PriorityIdEnum ;
    skos:altLabel "Priority ID" ;
    skos:definition "The normalized priority. Priority identifies the relative importance of the incident or finding. It is a measurement of urgency." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "priority" .

ocsf:protocol_num a owl:DatatypeProperty ;
    rdfs:label "protocol_num" ;
    rdfs:range xsd:integer ;
    rdfs:seeAlso <https://www.iana.org/assignments/protocol-numbers/protocol-numbers.xhtml> ;
    skos:altLabel "Protocol Number" ;
    skos:definition "The IP protocol number, as defined by the Internet Assigned Numbers Authority (IANA). For example: <code>6</code> for TCP and <code>17</code> for UDP." ;
    skos:editorialNote "IANA Protocol Numbers — https://www.iana.org/assignments/protocol-numbers/protocol-numbers.xhtml" ;
    skos:inScheme ocsf:dictionary .

ocsf:proxy a owl:ObjectProperty ;
    rdfs:label "proxy" ;
    rdfs:range ocsf:NetworkProxy ;
    skos:altLabel "Proxy" ;
    skos:definition "The proxy (server) in a network connection." ;
    skos:inScheme ocsf:dictionary .

ocsf:purl a owl:DatatypeProperty ;
    rdfs:label "purl" ;
    rdfs:range xsd:string ;
    skos:altLabel "Package URL" ;
    skos:definition "A purl is a URL string used to identify and locate a software package in a mostly universal and uniform way across programming languages, package managers, packaging conventions, tools, APIs and databases." ;
    skos:inScheme ocsf:dictionary .

ocsf:query a owl:ObjectProperty ;
    rdfs:label "query" ;
    rdfs:range ocsf:DnsQuery ;
    skos:altLabel "DNS Query" ;
    skos:definition "The Domain Name System (DNS) query." ;
    skos:inScheme ocsf:dictionary .

ocsf:query_info a owl:ObjectProperty ;
    rdfs:label "query_info" ;
    rdfs:range ocsf:QueryInfo ;
    skos:altLabel "Query Info" ;
    skos:definition "The query info object holds information related to data access within a datastore. To access, manipulate, delete, or retrieve data from a datastore, a database query must be written using a specific syntax." ;
    skos:inScheme ocsf:dictionary .

ocsf:query_string a owl:DatatypeProperty ;
    rdfs:label "query_string" ;
    rdfs:range xsd:string ;
    skos:altLabel "HTTP Query String" ;
    skos:definition "The query portion of the URL. For example: the query portion of the URL <code>http://www.example.com/search?q=bad&sort=date</code> is <code>q=bad&sort=date</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:query_time a owl:DatatypeProperty ;
    rdfs:label "query_time" ;
    rdfs:range xsd:long ;
    skos:altLabel "Query Time" ;
    skos:definition "The Domain Name System (DNS) query time." ;
    skos:inScheme ocsf:dictionary .

ocsf:rate_limit a owl:DatatypeProperty ;
    rdfs:label "rate_limit" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Rate Limit" ;
    skos:definition "The rate limit for a rate-based rule." ;
    skos:inScheme ocsf:dictionary .

ocsf:related_analytics a owl:ObjectProperty ;
    rdfs:label "related_analytics" ;
    rdfs:range ocsf:Analytic ;
    skos:altLabel "Related Analytics" ;
    skos:definition "Describes analytics related to the analytic of a finding or detection as identified by the security product." ;
    skos:inScheme ocsf:dictionary .

ocsf:request a owl:ObjectProperty ;
    rdfs:label "request" ;
    rdfs:range ocsf:Request ;
    skos:altLabel "API Request Details" ;
    skos:definition "General Purpose API Request Object. See specific usage" ;
    skos:inScheme ocsf:dictionary .

ocsf:requested_permissions a owl:DatatypeProperty ;
    rdfs:label "requested_permissions" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Requested Permissions" ;
    skos:definition "The permissions mask. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:rule a owl:ObjectProperty ;
    rdfs:label "rule" ;
    rdfs:range ocsf:Rule ;
    skos:altLabel "Rule" ;
    skos:definition "The rules that reported the events." ;
    skos:inScheme ocsf:dictionary .

ocsf:run_state a owl:DatatypeProperty ;
    rdfs:label "run_state" ;
    rdfs:range xsd:string ;
    skos:altLabel "Run State" ;
    skos:definition "The state of the job or service, normalized to the caption of the run_state_id value. In the case of 'Other', it is defined by the event source. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:run_state_id a owl:ObjectProperty ;
    rdfs:label "run_state_id" ;
    rdfs:range ocsf:RunStateIdEnum ;
    skos:altLabel "Run State ID" ;
    skos:definition "The normalized identifier of the state of the job or service. See specific usage." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "run_state" .

ocsf:sbom a owl:ObjectProperty ;
    rdfs:label "sbom" ;
    rdfs:range ocsf:Sbom ;
    skos:altLabel "Software Bill Of Materials" ;
    skos:definition "The Software Bill of Materials (SBOM) object describes the characteristics of a generated SBOM for a software package." ;
    skos:inScheme ocsf:dictionary .

ocsf:scan a owl:ObjectProperty ;
    rdfs:label "scan" ;
    rdfs:range ocsf:Scan ;
    skos:altLabel "Scan" ;
    skos:definition "The Scan object describes characteristics of a scan.  See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:score a owl:DatatypeProperty ;
    rdfs:label "score" ;
    rdfs:range xsd:string ;
    skos:altLabel "Reputation Score" ;
    skos:definition "The reputation score, normalized to the caption of the score_id value. In the case of 'Other', it is defined by the event source." ;
    skos:inScheme ocsf:dictionary .

ocsf:security_descriptor a owl:DatatypeProperty ;
    rdfs:label "security_descriptor" ;
    rdfs:range xsd:string ;
    skos:altLabel "Security Descriptor" ;
    skos:definition "The object security descriptor." ;
    skos:inScheme ocsf:dictionary .

ocsf:share a owl:DatatypeProperty ;
    rdfs:label "share" ;
    rdfs:range xsd:string ;
    skos:altLabel "Share" ;
    skos:definition "The share name. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:share_type a owl:DatatypeProperty ;
    rdfs:label "share_type" ;
    rdfs:range xsd:string ;
    skos:altLabel "Share Type" ;
    skos:definition "The share type, normalized to the caption of the share_type_id value. In the case of 'Other', it is defined by the event source." ;
    skos:inScheme ocsf:dictionary .

ocsf:share_type_id a owl:ObjectProperty ;
    rdfs:label "share_type_id" ;
    rdfs:range ocsf:ShareTypeIdEnum ;
    skos:altLabel "Share Type ID" ;
    skos:definition "The normalized identifier of the share type." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "share_type" .

ocsf:start_line a owl:DatatypeProperty ;
    rdfs:label "start_line" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Start Line" ;
    skos:definition "The line number of the first line of code block identified as vulnerable." ;
    skos:inScheme ocsf:dictionary .

ocsf:startup_item a owl:ObjectProperty ;
    rdfs:label "startup_item" ;
    rdfs:range ocsf:StartupItem ;
    skos:altLabel "Startup Item" ;
    skos:definition "The startup item object describes an application component that has associated startup criteria and configurations." ;
    skos:inScheme ocsf:dictionary .

ocsf:status_details a owl:DatatypeProperty ;
    rdfs:label "status_details" ;
    rdfs:range xsd:string ;
    skos:altLabel "Status Details" ;
    skos:definition "A list of descriptions, containing additional information about the event/finding status." ;
    skos:inScheme ocsf:dictionary .

ocsf:subject a owl:DatatypeProperty ;
    rdfs:label "subject" ;
    rdfs:range xsd:string ;
    skos:altLabel "Subject Details" ;
    skos:definition "The identifier of the subject. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:svc_name a owl:DatatypeProperty ;
    rdfs:label "svc_name" ;
    rdfs:range xsd:string ;
    skos:altLabel "Service Name" ;
    skos:definition "The service name in service-to-service connections. For example, AWS VPC logs the pkt-src-aws-service and pkt-dst-aws-service fields identify the connection is coming from or going to an AWS service." ;
    skos:inScheme ocsf:dictionary .

ocsf:tag a owl:DatatypeProperty ;
    rdfs:label "tag" ;
    rdfs:range xsd:string ;
    skos:altLabel "Image Tag" ;
    skos:definition "The image tag. For example: <code>1.11-alpine</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:ticket a owl:ObjectProperty ;
    rdfs:label "ticket" ;
    rdfs:range ocsf:Ticket ;
    skos:altLabel "Ticket" ;
    skos:definition "The linked ticket in the ticketing system." ;
    skos:inScheme ocsf:dictionary .

ocsf:time a owl:DatatypeProperty ;
    rdfs:label "time" ;
    rdfs:range xsd:long ;
    skos:altLabel "Event Time" ;
    skos:definition "The normalized event occurrence time or the finding creation time." ;
    skos:inScheme ocsf:dictionary .

ocsf:timespan a owl:ObjectProperty ;
    rdfs:label "timespan" ;
    rdfs:range ocsf:Timespan ;
    skos:altLabel "Time Span" ;
    skos:definition "The Time Span object represents different time period durations. If a timespan is fractional, i.e. crosses one period, e.g. a week and 3 days, more than one may be populated since each member is of integral type. In that case <code>type_id</code> if present should be set to <code>Other.</code><P>A timespan may also be defined by its time interval boundaries, <code>start_time</code> and <code>end_time</code>." ;
    skos:inScheme ocsf:dictionary .

ocsf:total a owl:DatatypeProperty ;
    rdfs:label "total" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Total" ;
    skos:definition "The total number of items. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:transmit_time a owl:DatatypeProperty ;
    rdfs:label "transmit_time" ;
    rdfs:range xsd:long ;
    skos:altLabel "Transmission Time" ;
    skos:definition "The event transmission time from one device to another.  See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:type_name a owl:DatatypeProperty ;
    rdfs:label "type_name" ;
    rdfs:range xsd:string ;
    skos:altLabel "Type Name" ;
    skos:definition "The event/finding type name, as defined by the type_uid." ;
    skos:inScheme ocsf:dictionary .

ocsf:unmanned_aerial_system a owl:ObjectProperty ;
    rdfs:label "unmanned_aerial_system" ;
    rdfs:range ocsf:UnmannedAerialSystem ;
    skos:altLabel "Unmanned Aerial System" ;
    skos:definition "The Unmanned Aerial System object describes the characteristics, Position Location Information (PLI), and other metadata of Unmanned Aerial Systems (UAS) and other unmanned and drone systems used in Remote ID. Remote ID is defined in the Standard Specification for Remote ID and Tracking (ASTM Designation: F3411-22a) <a target='_blank' href='https://cdn.standards.iteh.ai/samples/112830/71297057ac42432880a203654f213709/ASTM-F3411-22a.pdf'>ASTM F3411-22a</a>." ;
    skos:inScheme ocsf:dictionary .

ocsf:unmanned_system_operating_area a owl:ObjectProperty ;
    rdfs:label "unmanned_system_operating_area" ;
    rdfs:range ocsf:UnmannedSystemOperatingArea ;
    skos:altLabel "UAS Operating Area" ;
    skos:definition "The UAS Operating Area object describes details about a precise area of operations for a UAS flight or mission." ;
    skos:inScheme ocsf:dictionary .

ocsf:unmanned_system_operator a owl:ObjectProperty ;
    rdfs:label "unmanned_system_operator" ;
    rdfs:range ocsf:User ;
    skos:altLabel "Unmanned Systems Operator" ;
    skos:definition "The human or machine operator of an Unmanned System." ;
    skos:inScheme ocsf:dictionary .

ocsf:unused_privileges_count a owl:DatatypeProperty ;
    rdfs:label "unused_privileges_count" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Unused Privileges Count" ;
    skos:definition "The number of unused Privileges. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:vendor_attributes a owl:ObjectProperty ;
    rdfs:label "vendor_attributes" ;
    rdfs:range ocsf:VendorAttributes ;
    skos:altLabel "Vendor Attributes" ;
    skos:definition "The Vendor Attributes object can be used to represent values of attributes populated by the Vendor/Finding Provider. It can help distinguish between the vendor-provided values and consumer-updated values, of key attributes like <code>severity_id</code>.<br>The original finding producer should not populate this object. It should be populated by consuming systems that support data mutability." ;
    skos:inScheme ocsf:dictionary .

ocsf:xattributes a owl:ObjectProperty ;
    rdfs:label "xattributes" ;
    rdfs:range ocsf:Object ;
    skos:altLabel "Extended Attributes" ;
    skos:definition "An unordered collection of zero or more name/value pairs where each pair represents a file or folder extended attribute.</p>For example: Windows alternate data stream attributes (ADS stream name, ADS size, etc.), user-defined or application-defined attributes, ACL, owner, primary group, etc. Examples from DCS: </p><ul><li><strong>ads_name</strong></li><li><strong>ads_size</strong></li><li><strong>dacl</strong></li><li><strong>owner</strong></li><li><strong>primary_group</strong></li><li><strong>link_name</strong> - name of the link associated to the file.</li><li><strong>hard_link_count</strong> - the number of links that are associated to the file.</li></ul>" ;
    skos:inScheme ocsf:dictionary .


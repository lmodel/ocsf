        ocsf:IamEvent ;
    skos:altLabel "Authentication" ;
    skos:definition "Authentication events report authentication session activities, including user attempts to log on or log off, regardless of success, as well as other key stages within the authentication process. These events are typically generated by authentication services, such as Kerberos, OIDC, or SAML, and may include information about the user, the authentication method used, and the status of the authentication attempt." ;
    skos:editorialNote "D3FEND™ Ontology d3f:AuthenticationEvent — https://d3fend.mitre.org/event/d3f:AuthenticationEvent" ;
    skos:inScheme ocsf:events ;
    ocsf:associations "{\"actor.user\": [\"src_endpoint\"], \"dst_endpoint\": [\"user\"], \"src_endpoint\": [\"actor.user\"], \"user\": [\"dst_endpoint\"]}" ;
    ocsf:ocsf_constraints "{\"at_least_one\": [\"service\", \"dst_endpoint\"]}" ;
    ocsf:ocsf_event_uid 2 .


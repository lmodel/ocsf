<https://w3id.org/lmodel/ocsf/LaunchTypeIdEnum#EXEC> a owl:Class ;
    rdfs:label "EXEC" ;
    rdfs:subClassOf ocsf:LaunchTypeIdEnum ;
    skos:definition "Denotes that the <code>Launch</code> event represents the \"exec\" step of Unix process creation, where a process replaces its executable image, command line, and environment. WSL1 pico processes on Windows also use the 2-step Unix model." ;
    ocsf:caption "Exec" ;
    ocsf:ocsf_uid "3" .

<https://w3id.org/lmodel/ocsf/LaunchTypeIdEnum#FORK> a owl:Class ;
    rdfs:label "FORK" ;
    rdfs:subClassOf ocsf:LaunchTypeIdEnum ;
    skos:definition "Denotes that the <code>Launch</code> event represents the \"fork\" step of Unix process creation, where a process creates a clone of itself in a parent-child relationship. WSL1 pico processes on Windows also use the 2-step Unix model." ;
    ocsf:caption "Fork" ;
    ocsf:ocsf_uid "2" .

<https://w3id.org/lmodel/ocsf/LaunchTypeIdEnum#OTHER> a owl:Class ;

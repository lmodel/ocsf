<https://w3id.org/lmodel/ocsf/DigitalSignatureStateIdEnum#BAD> a owl:Class ;
    rdfs:label "BAD" ;
    rdfs:subClassOf ocsf:DigitalSignatureStateIdEnum ;
    skos:definition "The digital signature is cryptographically invalid, e.g. a mismatched digest. This indicates possible tampering." ;
    ocsf:caption "Bad" ;
    ocsf:ocsf_uid "9" .

<https://w3id.org/lmodel/ocsf/DigitalSignatureStateIdEnum#BROKEN> a owl:Class ;
    rdfs:label "BROKEN" ;
    rdfs:subClassOf ocsf:DigitalSignatureStateIdEnum ;
    skos:definition "The digital signature is malformed and could not be processed." ;
    ocsf:caption "Broken" ;
    ocsf:ocsf_uid "10" .

<https://w3id.org/lmodel/ocsf/DigitalSignatureStateIdEnum#DISTRUSTED> a owl:Class ;
    rdfs:label "DISTRUSTED" ;
    rdfs:subClassOf ocsf:DigitalSignatureStateIdEnum ;
    skos:definition "The digital signature is invalid because the certificate is explicitly distrusted. Note that whereas revocation is global, distrust reflects local IT/security policy." ;
    ocsf:caption "Distrusted" ;
    ocsf:ocsf_uid "7" .

<https://w3id.org/lmodel/ocsf/DigitalSignatureStateIdEnum#EXPIRED> a owl:Class ;
    rdfs:label "EXPIRED" ;
    rdfs:subClassOf ocsf:DigitalSignatureStateIdEnum ;
    skos:definition "The digital signature is invalid because its timestamp does not fall within the certificate's validity period." ;
    ocsf:caption "Expired" ;
    ocsf:ocsf_uid "2" .

<https://w3id.org/lmodel/ocsf/DigitalSignatureStateIdEnum#OTHER> a owl:Class ;
    rdfs:label "OTHER" ;
    rdfs:subClassOf ocsf:DigitalSignatureStateIdEnum ;
    skos:definition "The state is not mapped. See the <code>state</code> attribute, which contains a data source specific value." ;
    ocsf:caption "Other" ;
    ocsf:ocsf_uid "99" .

<https://w3id.org/lmodel/ocsf/DigitalSignatureStateIdEnum#PENDING> a owl:Class ;
    rdfs:label "PENDING" ;
    rdfs:subClassOf ocsf:DigitalSignatureStateIdEnum ;
    skos:definition "The digital signature state is pending." ;
    ocsf:caption "Pending" ;
    ocsf:ocsf_uid "5" .

<https://w3id.org/lmodel/ocsf/DigitalSignatureStateIdEnum#REVOKED> a owl:Class ;
    rdfs:label "REVOKED" ;
    rdfs:subClassOf ocsf:DigitalSignatureStateIdEnum ;
    skos:definition "The digital signature is invalid due to certificate revocation." ;
    ocsf:caption "Revoked" ;
    ocsf:ocsf_uid "3" .

<https://w3id.org/lmodel/ocsf/DigitalSignatureStateIdEnum#SUSPENDED> a owl:Class ;
    rdfs:label "SUSPENDED" ;
    rdfs:subClassOf ocsf:DigitalSignatureStateIdEnum ;
    skos:definition "The digital signature is invalid due to certificate suspension." ;
    ocsf:caption "Suspended" ;
    ocsf:ocsf_uid "4" .

<https://w3id.org/lmodel/ocsf/DigitalSignatureStateIdEnum#UNKNOWN> a owl:Class ;
    rdfs:label "UNKNOWN" ;
    rdfs:subClassOf ocsf:DigitalSignatureStateIdEnum ;
    skos:definition "The state is unknown." ;
    ocsf:caption "Unknown" ;
    ocsf:ocsf_uid "0" .

<https://w3id.org/lmodel/ocsf/DigitalSignatureStateIdEnum#UNTRUSTED> a owl:Class ;
    rdfs:label "UNTRUSTED" ;
    rdfs:subClassOf ocsf:DigitalSignatureStateIdEnum ;
    skos:definition "The digital signature is invalid because the certificate is rooted in an untrusted CA or is an untrusted self-signed certificate." ;
    ocsf:caption "Untrusted" ;
    ocsf:ocsf_uid "6" .

<https://w3id.org/lmodel/ocsf/DigitalSignatureStateIdEnum#VALID> a owl:Class ;
    rdfs:label "VALID" ;
    rdfs:subClassOf ocsf:DigitalSignatureStateIdEnum ;
    skos:definition "The digital signature is valid." ;
    ocsf:caption "Valid" ;
    ocsf:ocsf_uid "1" .

<https://w3id.org/lmodel/ocsf/DigitalSignatureStateIdEnum#WRONGUSAGE> a owl:Class ;
    rdfs:label "WRONGUSAGE" ;
    rdfs:subClassOf ocsf:DigitalSignatureStateIdEnum ;
    skos:definition "The digital signature is invalid because the certificate is not intended for code signing purposes." ;

ocsf:confidence_score a owl:DatatypeProperty ;
    rdfs:label "confidence_score" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Confidence Score" ;
    skos:definition "The confidence score as reported by the event source." ;
    skos:inScheme ocsf:dictionary .

ocsf:count a owl:DatatypeProperty ;
    rdfs:label "count" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Count" ;
    skos:definition "The number of times that events in the same logical group occurred during the event <strong>Start Time</strong> to <strong>End Time</strong> period." ;
    skos:inScheme ocsf:dictionary .

ocsf:duration a owl:DatatypeProperty ;
    rdfs:label "duration" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Duration Milliseconds" ;
    skos:definition "This represents the duration of the activity in milliseconds. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:first_seen_time a owl:DatatypeProperty ;
    rdfs:label "first_seen_time" ;
    rdfs:range xsd:long ;
    skos:altLabel "First Seen" ;
    skos:definition "The initial detection time of the activity or object. See specific usage" ;
    skos:inScheme ocsf:dictionary .

ocsf:labels a owl:DatatypeProperty ;
    rdfs:label "labels" ;
    rdfs:range xsd:string ;
    skos:altLabel "Labels" ;
    skos:definition "The list of labels attached to an entity. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:message a owl:DatatypeProperty ;
    rdfs:label "message" ;
    rdfs:range xsd:string ;
    skos:altLabel "Message" ;
    skos:definition "The description of the event/finding, as defined by the source." ;
    skos:inScheme ocsf:dictionary .

ocsf:owner a owl:ObjectProperty ;
    rdfs:label "owner" ;
    rdfs:range ocsf:User ;
    skos:altLabel "Owner" ;
    skos:definition "The user that owns the file/object." ;
    skos:inScheme ocsf:dictionary .

ocsf:severity_id a owl:ObjectProperty ;
    rdfs:label "severity_id" ;
    rdfs:range ocsf:SeverityIdEnum ;
    skos:altLabel "Severity ID" ;
    skos:definition "<p>The normalized identifier of the event/finding severity.</p>The normalized severity is a measurement the effort and expense required to manage and resolve an event or incident. Smaller numerical values represent lower impact events, and larger numerical values represent higher impact events." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "severity" .

ocsf:traffic a owl:ObjectProperty ;
    rdfs:label "traffic" ;
    rdfs:range ocsf:NetworkTraffic ;
    skos:altLabel "Traffic" ;
    skos:definition "The network traffic refers to the amount of data moving across a network at a given point of time. Intended to be used alongside Network Connection." ;
    skos:inScheme ocsf:dictionary .

ocsf:url a owl:ObjectProperty ;
    rdfs:label "url" ;
    rdfs:range ocsf:Url ;
    skos:altLabel "URL" ;
    skos:definition "The URL object that pertains to the event or object. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:url_string a owl:DatatypeProperty ;
    rdfs:label "url_string" ;
    rdfs:range xsd:anyURI ;
    skos:altLabel "URL String" ;
    skos:definition "The URL string. See RFC 1738. For example: <code>http://www.example.com/download/trouble.exe</code>." ;
    skos:inScheme ocsf:dictionary .


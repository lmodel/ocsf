    ocsf:ocsf_uid "99" .

<https://w3id.org/lmodel/ocsf/DispositionIdEnum#PARTIALLY_CORRECTED> a owl:Class ;
    rdfs:label "PARTIALLY_CORRECTED" ;
    rdfs:subClassOf ocsf:DispositionIdEnum ;

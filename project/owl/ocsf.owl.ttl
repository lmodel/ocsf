    ocsf:ocsf_uid "4" .

<https://w3id.org/lmodel/ocsf/DispositionIdEnum#LOGGED> a owl:Class ;
    rdfs:label "LOGGED" ;
    rdfs:subClassOf ocsf:DispositionIdEnum ;
    skos:definition "The operation or action was logged without further action." ;
    ocsf:caption "Logged" ;
    ocsf:ocsf_uid "17" .

<https://w3id.org/lmodel/ocsf/DispositionIdEnum#NO_ACTION> a owl:Class ;
    rdfs:label "NO_ACTION" ;
    rdfs:subClassOf ocsf:DispositionIdEnum ;
    skos:definition "The outcome of an operation had no action taken." ;
    ocsf:caption "No Action" ;
    ocsf:ocsf_uid "16" .

<https://w3id.org/lmodel/ocsf/DispositionIdEnum#OTHER> a owl:Class ;
    rdfs:label "OTHER" ;
    rdfs:subClassOf ocsf:DispositionIdEnum ;
    skos:definition "The disposition is not mapped. See the <code>disposition</code> attribute, which contains a data source specific value." ;

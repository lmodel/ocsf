    ocsf:caption "Low" ;
    ocsf:ocsf_uid "1" .

<https://w3id.org/lmodel/ocsf/PriorityIdEnum#MEDIUM> a owl:Class ;
    rdfs:label "MEDIUM" ;
    rdfs:subClassOf ocsf:PriorityIdEnum ;

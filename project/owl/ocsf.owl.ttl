            owl:onProperty ocsf:attack ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:privilege_info_list ],
        ocsf:Object ;
    skos:altLabel "Privilege Attack Info" ;
    skos:definition "The Privilege Attack Info object groups privileges by the potential attack they could enable. It maps specific privileges to MITRE ATT&CK techniques, helping identify security risks associated with granted permissions." ;
    skos:inScheme ocsf:objects .


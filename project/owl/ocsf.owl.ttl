    owl:unionOf ( <https://w3id.org/lmodel/ocsf/VerdictIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/VerdictIdEnum#FALSE_POSITIVE> <https://w3id.org/lmodel/ocsf/VerdictIdEnum#TRUE_POSITIVE> <https://w3id.org/lmodel/ocsf/VerdictIdEnum#DISREGARD> <https://w3id.org/lmodel/ocsf/VerdictIdEnum#SUSPICIOUS> <https://w3id.org/lmodel/ocsf/VerdictIdEnum#BENIGN> <https://w3id.org/lmodel/ocsf/VerdictIdEnum#TEST> <https://w3id.org/lmodel/ocsf/VerdictIdEnum#INSUFFICIENT_DATA> <https://w3id.org/lmodel/ocsf/VerdictIdEnum#SECURITY_RISK> <https://w3id.org/lmodel/ocsf/VerdictIdEnum#MANAGED_EXTERNALLY> <https://w3id.org/lmodel/ocsf/VerdictIdEnum#DUPLICATE> <https://w3id.org/lmodel/ocsf/VerdictIdEnum#OTHER> ) ;
    skos:definition "The normalized verdict of an Incident." ;

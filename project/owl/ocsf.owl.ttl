ocsf:Technique a owl:Class ;
    rdfs:label "Technique" ;
    rdfs:seeAlso <https://atlas.mitre.org/matrices/ATLAS>,
        <https://attack.mitre.org> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:src_url ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:src_url ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty ocsf:src_url ],
        ocsf:Entity ;
    skos:altLabel "MITRE Technique" ;
    skos:definition "The MITRE Technique object describes the ATT&CK® or ATLAS™ Technique ID and/or name associated to an attack." ;
    skos:editorialNote "ATLAS™ Matrix — https://atlas.mitre.org/matrices/ATLAS",
        "ATT&CK® Matrix — https://attack.mitre.org" ;
    skos:exactMatch attack:Technique,
        capec:Technique ;
    skos:inScheme ocsf:objects .

ocsf:ThreatActor a owl:Class ;
    rdfs:label "ThreatActor" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:type_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:ThreatActorTypeIdEnum ;
            owl:onProperty ocsf:type_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:type_id ],
        ocsf:Object ;
    skos:altLabel "Threat Actor" ;
    skos:closeMatch attack:Group ;
    skos:definition "Threat actor is responsible for the observed malicious activity." ;
    skos:exactMatch stix:ThreatActor ;
    skos:inScheme ocsf:objects .


<https://w3id.org/lmodel/ocsf/PriorityIdEnum#CRITICAL> a owl:Class ;
    rdfs:label "CRITICAL" ;
    rdfs:subClassOf ocsf:PriorityIdEnum ;
    skos:definition "Interruption making a critical functionality inaccessible or a complete network interruption causing a severe impact on services availability. There is no possible alternative." ;
    ocsf:caption "Critical" ;
    ocsf:ocsf_uid "4" .

<https://w3id.org/lmodel/ocsf/PriorityIdEnum#HIGH> a owl:Class ;
    rdfs:label "HIGH" ;
    rdfs:subClassOf ocsf:PriorityIdEnum ;
    skos:definition "Critical functionality or network access is interrupted, degraded or unusable, having a severe impact on services availability. No acceptable alternative is possible." ;
    ocsf:caption "High" ;
    ocsf:ocsf_uid "3" .

<https://w3id.org/lmodel/ocsf/PriorityIdEnum#LOW> a owl:Class ;
    rdfs:label "LOW" ;
    rdfs:subClassOf ocsf:PriorityIdEnum ;

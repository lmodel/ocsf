            owl:onProperty ocsf:expiration_time ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:serial_number ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:issuer ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:issuer ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:expiration_time ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:created_time ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:San ;
            owl:onProperty ocsf:sans ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:fingerprints ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:serial_number ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:subject ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:subject ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:version ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:expiration_time ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty ocsf:is_self_signed ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:version ],
        ocsf:Object ;
    skos:altLabel "Digital Certificate" ;
    skos:definition "The Digital Certificate, also known as a Public Key Certificate, object contains information about the ownership and usage of a public key. It serves as a means to establish trust in the authenticity and integrity of the public key and the associated entity." ;
    skos:editorialNote "D3FEND™ Ontology d3f:Certificate. — https://d3fend.mitre.org/dao/artifact/d3f:Certificate/" ;
    skos:exactMatch stix:X509Certificate ;
    skos:inScheme ocsf:objects .

ocsf:DataClassification a owl:Class ;
    rdfs:label "DataClassification" ;
    rdfs:subClassOf [ a owl:Restriction ;

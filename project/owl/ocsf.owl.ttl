    skos:altLabel "Security Control" ;
    skos:definition "The attributes including disposition that represent the outcome of a security control including but not limited to access control, malware or policy violation, network proxy, intrusion detection, firewall, or data control.  The profile is intended to augment activities or findings with an outcome when a security control has observed or intervened. If the control detected a security violation, and the <code>disposition_id</code> or <code>action_id</code> is an alertable outcome or action, the <code>is_alert</code> flag may be set to <code>true</code>." ;
    skos:inScheme ocsf:profiles ;
    ocsf:group "primary" ;
    ocsf:ocsf_profile "security_control" .

ocsf:AccessAnalysisResult a owl:Class ;
    rdfs:label "AccessAnalysisResult" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:additional_restrictions ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:granted_privileges ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:access_level ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:access_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:access_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:User ;
            owl:onProperty ocsf:accessors ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:condition_keys ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:accessors ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:access_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:granted_privileges ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:access_level ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:access_level ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:AdditionalRestriction ;
            owl:onProperty ocsf:additional_restrictions ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:KeyValueObject ;
            owl:onProperty ocsf:condition_keys ],
        ocsf:Object ;
    skos:altLabel "Access Analysis Result" ;
    skos:definition "The Access Analysis Result object describes access relationships and pathways between identities, resources, focusing on who can access what and through which mechanisms. This evaluates access levels (read/write/admin), access types (direct, cross-account, public, federated), and the conditions under which access is granted. Use this for resource-centric security assessments such as external access discovery, public exposure analysis, etc." ;
    skos:inScheme ocsf:objects .


            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:type ],
        ocsf:OcsfObject ;
    skos:altLabel "Analysis Target" ;
    skos:definition "The analysis target defines the scope of monitored activities, specifying what entity, system or process is analyzed for activity patterns." ;
    skos:inScheme ocsf:objects .

<https://w3id.org/lmodel/ocsf/AnalyticStateIdEnum#ACTIVE> a owl:Class ;

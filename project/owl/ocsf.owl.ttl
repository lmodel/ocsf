            owl:onProperty ocsf:message_context ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:message_context ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:AiModel ;
            owl:onProperty ocsf:ai_model ] ;
    skos:altLabel "AI Operation" ;
    skos:definition "AI-specific attributes for model operations, retrieval systems, and agent activities. e.g. model_name, total_token_counts etc." ;
    skos:inScheme ocsf:profiles ;
    ocsf:ocsf_profile "ai_operation" .

ocsf:Aircraft a owl:Class ;

<https://w3id.org/lmodel/ocsf/LogonTypeIdEnum#NEW_CREDENTIALS> a owl:Class ;
    rdfs:label "NEW_CREDENTIALS" ;
    rdfs:subClassOf ocsf:LogonTypeIdEnum ;
    skos:definition "A caller cloned its current token and specified new credentials for outbound connections. The new logon session has the same local identity, but uses different credentials for other network connections." ;
    ocsf:caption "New Credentials" ;
    ocsf:ocsf_uid "9" .


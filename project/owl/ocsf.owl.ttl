    ocsf:ocsf_event_uid 6 .

ocsf:LinuxProcess a owl:Class ;
    rdfs:label "LinuxProcess" ;
    rdfs:subClassOf ocsf:LinuxUsersProfile,
        ocsf:Process ;
    skos:altLabel "Linux Process" ;
    skos:definition "Extends the process object to add Linux specific fields" ;
    skos:exactMatch uco_master:UNIXProcess ;
    skos:inScheme ocsf:extensions ;
    ocsf:ocsf_extension "linux" .

ocsf:MacosProcess a owl:Class ;
    rdfs:label "MacosProcess" ;
    rdfs:subClassOf ocsf:MacosUsersProfile,
        ocsf:Process ;
    skos:altLabel "macOS Process" ;

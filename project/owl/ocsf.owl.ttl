    skos:definition "AuthorizeSession activity_id values." ;
    skos:inScheme ocsf:enums ;
    linkml:permissible_values <https://w3id.org/lmodel/ocsf/AuthorizeSessionActivityIdEnum#ASSIGN_GROUPS>,
        <https://w3id.org/lmodel/ocsf/AuthorizeSessionActivityIdEnum#ASSIGN_PRIVILEGES>,
        <https://w3id.org/lmodel/ocsf/AuthorizeSessionActivityIdEnum#OTHER>,
        <https://w3id.org/lmodel/ocsf/AuthorizeSessionActivityIdEnum#UNKNOWN> .

ocsf:Certificate a owl:Class ;
    rdfs:label "Certificate" ;
    rdfs:seeAlso <https://d3fend.mitre.org/dao/artifact/d3f:Certificate/> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:long ;
            owl:onProperty ocsf:created_time ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:is_self_signed ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:is_self_signed ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:sans ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:created_time ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Fingerprint ;
            owl:onProperty ocsf:fingerprints ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:subject ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:version ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:serial_number ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:issuer ],
        [ a owl:Restriction ;

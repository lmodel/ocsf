ocsf:Node a owl:Class ;
    rdfs:label "Node" ;
    rdfs:seeAlso <https://github.com/jsongraph/json-graph-specification/> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:data ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:data ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:data ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:desc ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:desc ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:desc ],
        ocsf:Object ;
    skos:altLabel "Node" ;
    skos:definition "Represents a node or a vertex in a graph structure." ;
    skos:editorialNote "JSON graph specification. — https://github.com/jsongraph/json-graph-specification/" ;
    skos:inScheme ocsf:objects .


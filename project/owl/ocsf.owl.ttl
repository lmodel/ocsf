            owl:onProperty ocsf:client_ciphers ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:client_ciphers ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:sans ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:ja3s_hash ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:certificate ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:server_ciphers ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:San ;
            owl:onProperty ocsf:sans ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ocsf:handshake_dur ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Fingerprint ;
            owl:onProperty ocsf:ja3_hash ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:handshake_dur ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:version ],
        ocsf:Object ;
    skos:altLabel "Transport Layer Security (TLS)" ;
    skos:definition "The Transport Layer Security (TLS) object describes the negotiated TLS protocol used for secure communications over an establish network connection." ;

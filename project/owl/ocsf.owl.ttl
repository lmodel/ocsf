    linkml:permissible_values <https://w3id.org/lmodel/ocsf/ClassificationIdsEnum#OTHER>,
        <https://w3id.org/lmodel/ocsf/ClassificationIdsEnum#UNKNOWN> .

ocsf:Cloud a owl:Class ;
    rdfs:label "Cloud" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;

<https://w3id.org/lmodel/ocsf/DispositionIdEnum#ACCESS_REVOKED> a owl:Class ;
    rdfs:label "ACCESS_REVOKED" ;
    rdfs:subClassOf ocsf:DispositionIdEnum ;
    skos:definition "The requestor's access has been revoked due to security policy enforcements. Note: use the <code>Host</code> profile if the <code>User</code> or <code>Actor</code> requestor is not present in the event class." ;
    ocsf:caption "Access Revoked" ;
    ocsf:ocsf_uid "24" .

<https://w3id.org/lmodel/ocsf/DispositionIdEnum#ALERT> a owl:Class ;
    rdfs:label "ALERT" ;
    rdfs:subClassOf ocsf:DispositionIdEnum ;
    skos:definition "The request or activity was detected as a threat and resulted in a notification but request was not blocked." ;
    ocsf:caption "Alert" ;
    ocsf:ocsf_uid "19" .

<https://w3id.org/lmodel/ocsf/DispositionIdEnum#ALLOWED> a owl:Class ;
    rdfs:label "ALLOWED" ;
    rdfs:subClassOf ocsf:DispositionIdEnum ;
    skos:definition "Granted access or allowed the action to the protected resource." ;
    ocsf:caption "Allowed" ;
    ocsf:ocsf_uid "1" .

<https://w3id.org/lmodel/ocsf/DispositionIdEnum#APPROVED> a owl:Class ;
    rdfs:label "APPROVED" ;
    rdfs:subClassOf ocsf:DispositionIdEnum ;
    skos:definition "A request or submission was approved. For example, when a form was properly filled out and submitted. This is distinct from <code>1</code> 'Allowed'." ;
    ocsf:caption "Approved" ;
    ocsf:ocsf_uid "8" .

<https://w3id.org/lmodel/ocsf/DispositionIdEnum#BLOCKED> a owl:Class ;
    rdfs:label "BLOCKED" ;
    rdfs:subClassOf ocsf:DispositionIdEnum ;
    skos:definition "Denied access or blocked the action to the protected resource." ;
    ocsf:caption "Blocked" ;
    ocsf:ocsf_uid "2" .

<https://w3id.org/lmodel/ocsf/DispositionIdEnum#CAPTCHA> a owl:Class ;
    rdfs:label "CAPTCHA" ;
    rdfs:subClassOf ocsf:DispositionIdEnum ;
    skos:definition "Required the end user to solve a CAPTCHA puzzle to prove that a human being is sending the request." ;
    ocsf:caption "Captcha" ;
    ocsf:ocsf_uid "22" .

<https://w3id.org/lmodel/ocsf/DispositionIdEnum#CHALLENGE> a owl:Class ;
    rdfs:label "CHALLENGE" ;
    rdfs:subClassOf ocsf:DispositionIdEnum ;
    skos:definition "Ran a silent challenge that required the client session to verify that it's a browser, and not a bot." ;
    ocsf:caption "Challenge" ;
    ocsf:ocsf_uid "23" .

<https://w3id.org/lmodel/ocsf/DispositionIdEnum#CORRECTED> a owl:Class ;
    rdfs:label "CORRECTED" ;
    rdfs:subClassOf ocsf:DispositionIdEnum ;
    skos:definition "A corrupt file or configuration was corrected." ;
    ocsf:caption "Corrected" ;
    ocsf:ocsf_uid "11" .

<https://w3id.org/lmodel/ocsf/DispositionIdEnum#COUNT> a owl:Class ;
    rdfs:label "COUNT" ;
    rdfs:subClassOf ocsf:DispositionIdEnum ;
    skos:definition "Counted the request or activity but did not determine whether to allow it or block it." ;
    ocsf:caption "Count" ;
    ocsf:ocsf_uid "20" .

<https://w3id.org/lmodel/ocsf/DispositionIdEnum#CUSTOM_ACTION> a owl:Class ;
    rdfs:label "CUSTOM_ACTION" ;
    rdfs:subClassOf ocsf:DispositionIdEnum ;
    skos:definition "A custom action was executed such as running of a command script. Use the <code>message</code> attribute of the base class for details." ;

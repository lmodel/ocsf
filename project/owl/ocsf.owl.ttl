    skos:altLabel "File" ;
    skos:definition "The File object represents the metadata associated with a file stored in a computer system. It encompasses information about the file itself, including its attributes, properties, and organizational details." ;
    skos:editorialNote "D3FEND™ Ontology d3f:File — https://next.d3fend.mitre.org/dao/artifact/d3f:File/" ;
    skos:exactMatch stix:File,
        uco_master:File ;
    skos:inScheme ocsf:objects ;
    ocsf:observable_id 24 .


            owl:maxCardinality 1 ;
            owl:onProperty ocsf:network_driver ],
        ocsf:Object ;
    skos:altLabel "Container" ;
    skos:definition "The Container object describes an instance of a specific container. A container is a prepackaged, portable system image that runs isolated on an existing system using a container runtime like containerd." ;
    skos:editorialNote "D3FEND™ Ontology d3f:ContainerProcess. — https://d3fend.mitre.org/dao/artifact/d3f:ContainerProcess/" ;
    skos:inScheme ocsf:objects ;
    skos:relatedMatch uco_master:Software ;
    ocsf:observable_id 27 ;
    ocsf:ocsf_constraints "{\"at_least_one\": [\"uid\", \"name\"]}" .

ocsf:CpuArchitectureIdEnum a owl:Class ;
    rdfs:label "CpuArchitectureIdEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/ocsf/CpuArchitectureIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/CpuArchitectureIdEnum#X86> <https://w3id.org/lmodel/ocsf/CpuArchitectureIdEnum#ARM> <https://w3id.org/lmodel/ocsf/CpuArchitectureIdEnum#RISC_V> <https://w3id.org/lmodel/ocsf/CpuArchitectureIdEnum#OTHER> ) ;
    skos:definition "The normalized identifier of the CPU architecture." ;
    skos:inScheme ocsf:enums ;
    linkml:permissible_values <https://w3id.org/lmodel/ocsf/CpuArchitectureIdEnum#ARM>,
        <https://w3id.org/lmodel/ocsf/CpuArchitectureIdEnum#OTHER>,
        <https://w3id.org/lmodel/ocsf/CpuArchitectureIdEnum#RISC_V>,
        <https://w3id.org/lmodel/ocsf/CpuArchitectureIdEnum#UNKNOWN>,
        <https://w3id.org/lmodel/ocsf/CpuArchitectureIdEnum#X86> .

ocsf:DataClassificationProfile a owl:Class ;
    rdfs:label "DataClassificationProfile" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:data_classification ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:data_classifications ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:data_classification ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:DataClassification ;
            owl:onProperty ocsf:data_classifications ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:DataClassification ;
            owl:onProperty ocsf:data_classification ] ;
    skos:altLabel "Data Classification" ;
    skos:definition "The Data Classification profile adds attributes to specific resource objects, allowing users to describe information about classifiers & data classification results." ;
    skos:inScheme ocsf:profiles ;
    ocsf:ocsf_profile "data_classification" .

ocsf:DataLifecycleStateIdEnum a owl:Class ;
    rdfs:label "DataLifecycleStateIdEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/ocsf/DataLifecycleStateIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/DataLifecycleStateIdEnum#DATA_AT_REST> <https://w3id.org/lmodel/ocsf/DataLifecycleStateIdEnum#DATA_IN_TRANSIT> <https://w3id.org/lmodel/ocsf/DataLifecycleStateIdEnum#DATA_IN_USE> <https://w3id.org/lmodel/ocsf/DataLifecycleStateIdEnum#OTHER> ) ;
    skos:definition "The stage or state that the data was in when it was assessed or scanned by a data security tool." ;
    skos:inScheme ocsf:enums ;
    linkml:permissible_values <https://w3id.org/lmodel/ocsf/DataLifecycleStateIdEnum#DATA_AT_REST>,
        <https://w3id.org/lmodel/ocsf/DataLifecycleStateIdEnum#DATA_IN_TRANSIT>,
        <https://w3id.org/lmodel/ocsf/DataLifecycleStateIdEnum#DATA_IN_USE>,
        <https://w3id.org/lmodel/ocsf/DataLifecycleStateIdEnum#OTHER>,
        <https://w3id.org/lmodel/ocsf/DataLifecycleStateIdEnum#UNKNOWN> .

ocsf:DataSecurityFindingActivityIdEnum a owl:Class ;
    rdfs:label "DataSecurityFindingActivityIdEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/ocsf/DataSecurityFindingActivityIdEnum#CREATE> <https://w3id.org/lmodel/ocsf/DataSecurityFindingActivityIdEnum#UPDATE> <https://w3id.org/lmodel/ocsf/DataSecurityFindingActivityIdEnum#CLOSE> <https://w3id.org/lmodel/ocsf/DataSecurityFindingActivityIdEnum#SUPPRESSED> <https://w3id.org/lmodel/ocsf/DataSecurityFindingActivityIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/DataSecurityFindingActivityIdEnum#OTHER> ) ;
    skos:definition "The normalized identifier of the Data Security Finding activity." ;
    skos:inScheme ocsf:enums ;
    linkml:permissible_values <https://w3id.org/lmodel/ocsf/DataSecurityFindingActivityIdEnum#CLOSE>,
        <https://w3id.org/lmodel/ocsf/DataSecurityFindingActivityIdEnum#CREATE>,
        <https://w3id.org/lmodel/ocsf/DataSecurityFindingActivityIdEnum#OTHER>,
        <https://w3id.org/lmodel/ocsf/DataSecurityFindingActivityIdEnum#SUPPRESSED>,
        <https://w3id.org/lmodel/ocsf/DataSecurityFindingActivityIdEnum#UNKNOWN>,
        <https://w3id.org/lmodel/ocsf/DataSecurityFindingActivityIdEnum#UPDATE> .

ocsf:DigitalSignatureAlgorithmIdEnum a owl:Class ;
    rdfs:label "DigitalSignatureAlgorithmIdEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/ocsf/DigitalSignatureAlgorithmIdEnum#UNKNOWN> <https://w3id.org/lmodel/ocsf/DigitalSignatureAlgorithmIdEnum#DSA> <https://w3id.org/lmodel/ocsf/DigitalSignatureAlgorithmIdEnum#RSA> <https://w3id.org/lmodel/ocsf/DigitalSignatureAlgorithmIdEnum#ECDSA> <https://w3id.org/lmodel/ocsf/DigitalSignatureAlgorithmIdEnum#AUTHENTICODE> <https://w3id.org/lmodel/ocsf/DigitalSignatureAlgorithmIdEnum#OTHER> ) ;
    skos:definition "The identifier of the normalized digital signature algorithm." ;

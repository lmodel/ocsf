ocsf:MessageContext a owl:Class ;
    rdfs:label "MessageContext" ;
    rdfs:seeAlso <https://modelcontextprotocol.io/>,
        <https://owasp.org/www-project-ai-security-and-privacy-guide/> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:ai_role ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:completion_tokens ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ocsf:completion_tokens ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ocsf:prompt_tokens ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:completion_tokens ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:ai_role ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:total_tokens ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:ai_role_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:ApplicationObject ;
            owl:onProperty ocsf:application ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:Service ;
            owl:onProperty ocsf:service ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ocsf:total_tokens ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:total_tokens ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:service ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:service ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:prompt_tokens ],
        [ a owl:Restriction ;
            owl:allValuesFrom ocsf:MessageContextAiRoleIdEnum ;
            owl:onProperty ocsf:ai_role_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:prompt_tokens ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:ai_role ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:ai_role_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:application ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:application ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:name ],
        ocsf:Entity ;
    skos:altLabel "Message Context" ;
    skos:definition "Communication context for AI system interactions including protocols, roles, clients, and session information for MCP and other AI communication systems." ;
    skos:editorialNote "Model Context Protocol (MCP) Specification — https://modelcontextprotocol.io/",
        "OWASP AI Security and Privacy Guide - Agent Security — https://owasp.org/www-project-ai-security-and-privacy-guide/" ;
    skos:inScheme ocsf:objects ;
    ocsf:ocsf_constraints "{\"at_least_one\": [\"application\", \"service\"]}" .


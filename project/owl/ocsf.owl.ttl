ocsf:category a owl:DatatypeProperty ;
    rdfs:label "category" ;
    rdfs:range xsd:string ;
    skos:altLabel "Category" ;
    skos:definition "The object category, normalized to the caption of <code>category_id</code>. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:domain a owl:DatatypeProperty ;
    rdfs:label "domain" ;
    rdfs:range xsd:string ;
    skos:altLabel "Domain" ;
    skos:definition "The name of the domain. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:expiration_time a owl:DatatypeProperty ;
    rdfs:label "expiration_time" ;
    rdfs:range xsd:long ;
    skos:altLabel "Expiration Time" ;
    skos:definition "The expiration time. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:http_request a owl:ObjectProperty ;
    rdfs:label "http_request" ;
    rdfs:range ocsf:HttpRequest ;
    skos:altLabel "HTTP Request" ;
    skos:definition "The HTTP Request Object documents attributes of a request made to a web server." ;
    skos:inScheme ocsf:dictionary .

ocsf:http_response a owl:ObjectProperty ;
    rdfs:label "http_response" ;
    rdfs:range ocsf:HttpResponse ;
    skos:altLabel "HTTP Response" ;
    skos:definition "The HTTP Response from a web server to a requester." ;
    skos:inScheme ocsf:dictionary .

ocsf:location a owl:ObjectProperty ;
    rdfs:label "location" ;
    rdfs:range ocsf:Location ;
    skos:altLabel "Geo Location" ;
    skos:definition "The detailed geographical location usually associated with an IP address." ;
    skos:inScheme ocsf:dictionary .

ocsf:risk_score a owl:DatatypeProperty ;
    rdfs:label "risk_score" ;
    rdfs:range xsd:integer ;
    skos:altLabel "Risk Score" ;
    skos:definition "The risk score as reported by the event source." ;
    skos:inScheme ocsf:dictionary .

ocsf:session a owl:ObjectProperty ;
    rdfs:label "session" ;
    rdfs:range ocsf:Session ;
    skos:altLabel "Session" ;
    skos:definition "The authenticated user or service session." ;
    skos:inScheme ocsf:dictionary .

ocsf:state_id a owl:ObjectProperty ;
    rdfs:label "state_id" ;
    rdfs:range ocsf:StateIdEnum ;
    skos:altLabel "State ID" ;
    skos:definition "The normalized state ID of the event or object. See specific usage." ;
    skos:inScheme ocsf:dictionary ;
    ocsf:sibling "state" .

ocsf:title a owl:DatatypeProperty ;
    rdfs:label "title" ;
    rdfs:range xsd:string ;
    skos:altLabel "Title" ;
    skos:definition "The title of an entity. See specific usage." ;
    skos:inScheme ocsf:dictionary .

ocsf:Group a owl:Class ;
    rdfs:label "Group" ;
    rdfs:seeAlso <https://d3fend.mitre.org/dao/artifact/d3f:AccessControlGroup/> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:domain ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:desc ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:domain ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:desc ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:uid_alt ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:uid_alt ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:domain ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:privileges ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:desc ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ocsf:uid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ocsf:uid_alt ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ocsf:privileges ],
        ocsf:Entity ;
    skos:altLabel "Group" ;
    skos:definition "The Group object represents a collection or association of entities, such as users, policies, or devices. It serves as a logical grouping mechanism to organize and manage entities with similar characteristics or permissions within a system or organization, including but not limited to purposes of access control." ;
    skos:editorialNote "D3FEND™ Ontology d3f:AccessControlGroup. — https://d3fend.mitre.org/dao/artifact/d3f:AccessControlGroup/" ;
    skos:inScheme ocsf:objects .


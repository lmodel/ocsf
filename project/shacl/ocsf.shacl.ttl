            sh:path ocsf:category_uid ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description "Details about server providing the web resources." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:dst_endpoint ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 30 ;
            sh:path ocsf:severity_id ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 58 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:duration ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 42 ;
            sh:path ocsf:cloud ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:status_code ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 56 ;
            sh:path ocsf:is_alert ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 52 ;
            sh:path ocsf:confidence_score ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 37 ;
            sh:path ocsf:timezone_offset ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 27 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 34 ;
            sh:path ocsf:status_detail ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 48 ;
            sh:path ocsf:attacks ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 62 ;
            sh:path ocsf:risk_level_id ],
        [ sh:class ocsf:NetworkTraffic ;
            sh:description """The network traffic refers to the amount of data moving across a network, from
proxy to remote server at a given point of time.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:proxy_traffic ],
        [ sh:class ocsf:WebResource ;
            sh:description """The results of the activity on web resources. It should contain the new values
of the changed attributes of the web resources.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:web_resources_result ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 53 ;
            sh:path ocsf:disposition ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 41 ;
            sh:path ocsf:api ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 61 ;
            sh:path ocsf:risk_level ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:count ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:severity ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 59 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:class_name ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 47 ;
            sh:path ocsf:action_id ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 49 ;
            sh:path ocsf:authorizations ] ;
    sh:targetClass ocsf:WebResourcesActivity .

ocsf:WindowsEvidences a sh:NodeShape ;
    rdfs:comment "Extends the evidences object to add Windows specific fields" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:File ;
            sh:description """Describes details about the file associated to the activity that triggered the
detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:file ],
        [ sh:class ocsf:RegKey ;
            sh:description "Describes details about the registry key that triggered the detection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:reg_key ],
        [ sh:datatype xsd:string ;
            sh:description """Additional evidence data that is not accounted for in the specific evidence
attributes.<code> Use only when absolutely necessary.</code>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:data ],
        [ sh:class ocsf:Actor ;
            sh:description """Describes details about the user/role/process that was the source of the
activity that triggered the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:actor ],
        [ sh:class ocsf:HttpRequest ;
            sh:description """Describes details about the http request associated to the activity that
triggered the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ocsf:http_request ],
        [ sh:class ocsf:Device ;
            sh:description """An addressable device, computer system or host associated to the activity that
triggered the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path ocsf:device ],
        [ sh:class ocsf:ResourceDetails ;
            sh:description """Describes details about the cloud resources directly related to activity that
triggered the detection. For resources impacted by the detection, use
<code>Affected Resources</code> at the top-level of the finding.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path ocsf:resources ],
        [ sh:description """The normalized verdict (or status) ID of the evidence associated with the
security detection. For example, Microsoft Graph Security Alerts contain a
<code>verdict</code> enumeration for each type of <code>evidence</code>
associated with the Alert. This is typically set by an automated investigation
process or an analyst/investigator assigned to the finding.""" ;
            sh:in ( "UNKNOWN" "FALSE_POSITIVE" "TRUE_POSITIVE" "DISREGARD" "SUSPICIOUS" "BENIGN" "TEST" "INSUFFICIENT_DATA" "SECURITY_RISK" "MANAGED_EXTERNALLY" "DUPLICATE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 29 ;
            sh:path ocsf:verdict_id ],
        [ sh:class ocsf:NetworkConnectionInfo ;
            sh:description """Describes details about the network connection associated to the activity that
triggered the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:connection_info ],
        [ sh:class ocsf:DnsQuery ;
            sh:description """Describes details about the DNS query associated to the activity that triggered
the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path ocsf:query ],
        [ sh:class ocsf:Container ;
            sh:description """Describes details about the container associated to the activity that triggered
the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:container ],
        [ sh:datatype xsd:string ;
            sh:description """The naming convention or type identifier of the evidence associated with the
security detection. For example, the <code>@odata.type</code> from Microsoft
Graph Alerts V2 or <code>display_name</code> from CrowdStrike Falcon Incident
Behaviors.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:name ],
        [ sh:class ocsf:User ;
            sh:description """Describes details about the user that was the target or somehow else associated
with the activity that triggered the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 27 ;
            sh:path ocsf:user ],
        [ sh:class ocsf:Process ;
            sh:description """Describes details about the process associated to the activity that triggered
the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path ocsf:process ],
        [ sh:class ocsf:WinService ;
            sh:description "Describes details about the Windows service that triggered the detection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:win_service ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description """Describes details about the source of the network activity that triggered the
detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path ocsf:src_endpoint ],
        [ sh:class ocsf:Job ;
            sh:description """Describes details about the scheduled job that was associated with the activity
that triggered the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path ocsf:job ],
        [ sh:class ocsf:Databucket ;
            sh:description """Describes details about the databucket associated to the activity that
triggered the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:databucket ],
        [ sh:class ocsf:HttpResponse ;
            sh:description """Describes details about the http response associated to the activity that
triggered the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path ocsf:http_response ],
        [ sh:class ocsf:Database ;
            sh:description """Describes details about the database associated to the activity that triggered
the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:database ],
        [ sh:class ocsf:Api ;
            sh:description """Describes details about the API call associated to the activity that triggered
the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:api ],
        [ sh:class ocsf:Url ;
            sh:description """The URL object that pertains to the event or object associated to the activity
that triggered the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 26 ;
            sh:path ocsf:url ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier of the evidence associated with the security detection.
For example, the <code>activity_id</code> from CrowdStrike Falcon Alerts or
<code>behavior_id</code> from CrowdStrike Falcon Incident Behaviors.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:uid ],
        [ sh:class ocsf:RegValue ;
            sh:description "Describes details about the registry value that triggered the detection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:reg_value ],
        [ sh:class ocsf:Email ;
            sh:description "The email object associated to the activity that triggered the detection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:email ],
        [ sh:class ocsf:Ja4Fingerprint ;
            sh:description "Describes details about the JA4+ fingerprints that triggered the detection." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path ocsf:ja4_fingerprint_list ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized verdict of the evidence associated with the security detection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:verdict ],
        [ sh:class ocsf:Script ;
            sh:description """Describes details about the script that was associated with the activity that
triggered the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path ocsf:script ],
        [ sh:class ocsf:Tls ;
            sh:description """Describes details about the Transport Layer Security (TLS) activity that
triggered the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 24 ;
            sh:path ocsf:tls ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description """Describes details about the destination of the network activity that triggered
the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:dst_endpoint ] ;
    sh:targetClass ocsf:WindowsEvidences .

ocsf:WindowsProcess a sh:NodeShape ;
    rdfs:comment "Extends the process object to add Windows specific fields." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The process integrity level, normalized to the caption of the integrity_id
value. In the case of 'Other', it is defined by the event source (Windows
only).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:integrity ],
        [ sh:datatype xsd:string ;
            sh:description """The name of the containment jail (i.e., sandbox). For example, hardened_ps,
high_security_ps, oracle_ps, netsvcs_ps, or default_ps.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:sandbox ],
        [ sh:datatype xsd:string ;
            sh:description "The working directory of a process." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:working_directory ],
        [ sh:class ocsf:Process ;
            sh:description """The parent process of this process object. It is recommended to only populate
this field for the top-level process object, to prevent deep nesting.
Additional ancestry information can be supplied in the <code>ancestry</code>
attribute.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:parent_process ],
        [ sh:class ocsf:ProcessEntity ;
            sh:description """An array of Process Entities describing the extended parentage of this process
object. Direct parent information should be expressed through the
<code>parent_process</code> attribute. The first array element is the direct
parent of this process object. Subsequent list elements go up the process
parentage hierarchy. That is, the array is sorted from newest to oldest
process. It is recommended to only populate this field for the top-level
process object.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:ancestry ],
        [ sh:datatype xsd:integer ;
            sh:description """The identifier of the process thread associated with the event, as returned by
the operating system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:ptid ],
        [ sh:datatype xsd:string ;
            sh:description """A unique process identifier that can be assigned deterministically by multiple
system data producers.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:cpid ;
            sh:pattern "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:integer ;
            sh:description """The identifier of the thread associated with the event, as returned by the
operating system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:tid ],
        [ sh:datatype xsd:string ;
            sh:description """A unique identifier for this process assigned by the producer (tool).
Facilitates correlation of a process event with other events for that process.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the process was terminated." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:terminated_time ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the process was created/started." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:created_time ],
        [ sh:class ocsf:File ;
            sh:description "The process file object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:file ],
        [ sh:datatype xsd:integer ;
            sh:description """The process identifier, as reported by the operating system. Process ID (PID)
is a number used by the operating system to uniquely identify an active
process.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:pid ],
        [ sh:datatype xsd:string ;
            sh:description "The friendly name of the process, for example: <code>Notepad++</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The process file path." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:path ],
        [ sh:class ocsf:Container ;
            sh:description """The information describing an instance of a container. A container is a
prepackaged, portable system image that runs isolated on an existing system
using a container runtime like containerd.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path ocsf:container ],
        [ sh:class ocsf:Session ;
            sh:description "The user session under which this process is running." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:session ],
        [ sh:datatype xsd:integer ;
            sh:description """If running under a process namespace (such as in a container), the process
identifier within that process namespace.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:namespace_pid ],
        [ sh:class ocsf:Object ;
            sh:description """An unordered collection of zero or more name/value pairs that represent a
process extended attribute.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path ocsf:xattributes ],
        [ sh:class ocsf:WinService ;
            sh:description "The Windows services that this process is hosting." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:hosted_services ],
        [ sh:datatype xsd:string ;
            sh:description """The lineage of the process, represented by a list of paths for each ancestor
process. For example: <code>['/usr/sbin/sshd', '/usr/bin/bash',
'/usr/bin/whoami']</code>.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:lineage ],
        [ sh:datatype xsd:string ;
            sh:description """The full command line used to launch an application, service, process, or job.
For example: <code>ssh user@10.0.0.10</code>. If the command line is
unavailable or missing, the empty string <code>''</code> is to be used.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:cmd_line ],
        [ sh:class ocsf:EnvironmentVariable ;
            sh:description "Environment variables associated with the process." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:environment_variables ],
        [ sh:datatype xsd:string ;
            sh:description "The list of loaded module names." ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:loaded_modules ],
        [ sh:class ocsf:User ;
            sh:description "The user under which this process is running." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ocsf:user ],
        [ sh:description "The normalized identifier of the process integrity level (Windows only)." ;
            sh:in ( "UNKNOWN" "UNTRUSTED" "LOW" "MEDIUM" "HIGH" "SYSTEM" "PROTECTED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path ocsf:integrity_id ] ;
    sh:targetClass ocsf:WindowsProcess .

ocsf:WindowsQueryEvidence a sh:NodeShape ;
    rdfs:comment "The resulting evidence information that was queried." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:PeripheralDevice ;
            sh:description """The peripheral device that triggered the event when query_type_id indicates a
Peripheral Device query.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path ocsf:peripheral_device ],
        [ sh:class ocsf:User ;
            sh:description "The user that pertains to the event when query_type_id indicates a User query." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path ocsf:user ],
        [ sh:class ocsf:NetworkConnectionInfo ;
            sh:description "The network connection information related to a Network Connection query type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:connection_info ],
        [ sh:class ocsf:Session ;
            sh:description """The authenticated user or service session when query_type_id indicates a
Session query.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path ocsf:session ],
        [ sh:class ocsf:Service ;
            sh:description """The service that pertains to the event when query_type_id indicates a Service
query.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ocsf:service ],
        [ sh:class ocsf:Process ;
            sh:description """The process that pertains to the event when query_type_id indicates a Process
query.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:process ],
        [ sh:class ocsf:User ;
            sh:description """The users that belong to the administrative group when query_type_id indicates
a Users query.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path ocsf:users ],
        [ sh:description "The state of the TCP socket for the network connection." ;
            sh:in ( "UNKNOWN" "ESTABLISHED" "SYN_SENT" "SYN_RECEIVED" "FIN_WAIT_1" "FIN_WAIT_2" "TIME_WAIT" "CLOSED" "CLOSE_WAIT" "LAST_ACK" "LISTEN" "CLOSING" ) ;
            sh:maxCount 1 ;
            sh:order 18 ;
            sh:path ocsf:tcp_state_id ],
        [ sh:class ocsf:RegKey ;
            sh:description "The registry key object describes a Windows registry key." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:reg_key ],
        [ sh:class ocsf:NetworkInterface ;
            sh:description """The physical or virtual network interfaces that are associated with the device
when query_type_id indicates a Network Interfaces query.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:network_interfaces ],
        [ sh:datatype xsd:string ;
            sh:description """The state of the socket, normalized to the caption of the state_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:state ],
        [ sh:class ocsf:Module ;
            sh:description """The module that pertains to the event when query_type_id indicates a Module
query.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:module ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of query_type_id or the source-specific query type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:query_type ],
        [ sh:class ocsf:RegValue ;
            sh:description "The registry key object describes a Windows registry value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:reg_value ],
        [ sh:class ocsf:File ;
            sh:description """The file that is the target of the query when query_type_id indicates a File
query.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:file ],
        [ sh:class ocsf:File ;
            sh:description """The folder that is the target of the query when query_type_id indicates a
Folder query.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:folder ],
        [ sh:class ocsf:Group ;
            sh:description """The administrative group that is the target of the query when query_type_id
indicates an Admin Group query.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:group ],
        [ sh:class ocsf:StartupItem ;
            sh:description """The startup item object that pertains to the event when query_type_id indicates
a Startup Item query.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path ocsf:startup_item ],
        [ sh:class ocsf:Job ;
            sh:description """The job object that pertains to the event when query_type_id indicates a Job
query.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:job ],
        [ sh:class ocsf:Kernel ;
            sh:description """The kernel object that pertains to the event when query_type_id indicates a
Kernel query.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:kernel ],
        [ sh:description """The normalized type of system query performed against a device or system
component.""" ;
            sh:in ( "UNKNOWN" "KERNEL" "FILE" "FOLDER" "ADMIN_GROUP" "JOB" "MODULE" "NETWORK_CONNECTION" "NETWORK_INTERFACES" "PERIPHERAL_DEVICE" "PROCESS" "SERVICE" "SESSION" "USER" "USERS" "STARTUP_ITEM" "REGISTRY_KEY" "REGISTRY_VALUE" "PREFETCH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 13 ;
            sh:path ocsf:query_type_id ] ;
    sh:targetClass ocsf:WindowsQueryEvidence .

ocsf:WindowsResourceActivity a sh:NodeShape ;
    rdfs:comment """Windows Resource Activity events report when a process accesses a Windows
managed resource object, successful or otherwise.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:timezone_offset ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path ocsf:cloud ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:actor ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:activity_name ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 37 ;
            sh:path ocsf:authorizations ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path ocsf:observables ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path ocsf:confidence_score ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ocsf:metadata ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:type_name ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 20 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path ocsf:disposition ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:raw_data_size ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:start_time ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:type_uid ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 35 ;
            sh:path ocsf:action_id ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path ocsf:risk_details ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:status_detail ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:count ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:category_name ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "ACCESS" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path ocsf:activity_id ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 25 ;
            sh:path ocsf:status_id ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path ocsf:attacks ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:risk_score ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:duration ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:raw_data ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 8 ;
            sh:path ocsf:class_uid ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 47 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 34 ;
            sh:path ocsf:action ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:time ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 45 ;
            sh:path ocsf:malware ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 50 ;
            sh:path ocsf:risk_level_id ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 49 ;
            sh:path ocsf:risk_level ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 6 ;
            sh:path ocsf:category_uid ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 39 ;
            sh:path ocsf:confidence_id ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 33 ;
            sh:path ocsf:osint ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:enrichments ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:severity ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 43 ;
            sh:path ocsf:firewall_rule ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:message ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 30 ;
            sh:path ocsf:unmapped ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:class_name ],
        [ sh:class ocsf:WinResource ;
            sh:description "The Windows resource object that was accessed, such as a mutant or timer." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:win_resource ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:status_code ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 46 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 38 ;
            sh:path ocsf:confidence ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 31 ;
            sh:path ocsf:api ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 42 ;
            sh:path ocsf:disposition_id ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:device ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 44 ;
            sh:path ocsf:is_alert ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:end_time ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:status ] ;
    sh:targetClass ocsf:WindowsResourceActivity .

ocsf:WindowsServiceActivity a sh:NodeShape ;
    rdfs:comment """Windows Service Activity events report when a process interacts with the
Service Control Manager.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:class_name ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:time ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 25 ;
            sh:path ocsf:status_id ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 38 ;
            sh:path ocsf:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path ocsf:risk_details ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:device ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path ocsf:observables ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path ocsf:cloud ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path ocsf:disposition ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 34 ;
            sh:path ocsf:action ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 45 ;
            sh:path ocsf:malware ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path ocsf:confidence_score ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:type_name ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:duration ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 50 ;
            sh:path ocsf:risk_level_id ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:status ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "CREATE" "RECONFIGURE" "START" "STOP" "PAUSE" "CONTINUE" "DELETE" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path ocsf:activity_id ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:enrichments ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 42 ;
            sh:path ocsf:disposition_id ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:start_time ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ocsf:metadata ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 49 ;
            sh:path ocsf:risk_level ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 37 ;
            sh:path ocsf:authorizations ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:category_name ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 39 ;
            sh:path ocsf:confidence_id ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 43 ;
            sh:path ocsf:firewall_rule ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:timezone_offset ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 47 ;
            sh:path ocsf:policy ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:actor ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:status_detail ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 35 ;
            sh:path ocsf:action_id ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 6 ;
            sh:path ocsf:category_uid ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 30 ;
            sh:path ocsf:unmapped ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:count ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:raw_data ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 8 ;
            sh:path ocsf:class_uid ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path ocsf:attacks ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:raw_data_size ],
        [ sh:class ocsf:WinService ;
            sh:description "The Windows service." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:win_service ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 31 ;
            sh:path ocsf:api ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 20 ;
            sh:path ocsf:severity_id ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 33 ;
            sh:path ocsf:osint ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:severity ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:status_code ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:activity_name ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:type_uid ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:risk_score ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 44 ;
            sh:path ocsf:is_alert ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 46 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:end_time ] ;
    sh:targetClass ocsf:WindowsServiceActivity .

ocsf:WindowsStartupItem a sh:NodeShape ;
    rdfs:comment """The startup item object describes an application component that has associated
startup criteria and configurations.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Job ;
            sh:description "The startup item job resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:job ],
        [ sh:description "The start type ID of the startup item." ;
            sh:in ( "UNKNOWN" "AUTO" "BOOT" "ON_DEMAND" "DISABLED" "ALL_LOGINS" "SPECIFIC_USER_LOGIN" "SCHEDULED" "SYSTEM_CHANGED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 10 ;
            sh:path ocsf:start_type_id ],
        [ sh:datatype xsd:string ;
            sh:description "The start type of the startup item." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:start_type ],
        [ sh:class ocsf:WinService ;
            sh:description "The startup item Windows service resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:win_service ],
        [ sh:description "The startup item type identifier." ;
            sh:in ( "UNKNOWN" "KERNEL_MODE_DRIVER" "USER_MODE_DRIVER" "SERVICE" "USER_MODE_APPLICATION" "AUTOLOAD" "SYSTEM_EXTENSION" "KERNEL_EXTENSION" "SCHEDULED_JOB_TASK" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 12 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:string ;
            sh:description "The startup item type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description "The run state of the startup item." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:run_state ],
        [ sh:datatype xsd:string ;
            sh:description """The list of run_modes, normalized to the captions of the run_mode_id values.
In the case of 'Other', they are defined by the event source.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:run_modes ],
        [ sh:description """The list of normalized identifiers that describe the startup items' properties
when it is running.  Use this field to capture extended information about the
process, which may depend on the type of startup item.  E.g., A Windows service
that interacts with the desktop.""" ;
            sh:in ( "INTERACTIVE" "OWN_PROCESS" "SHARED_PROCESS" "UNKNOWN" "OTHER" ) ;
            sh:order 5 ;
            sh:path ocsf:run_mode_ids ],
        [ sh:class ocsf:KernelDriver ;
            sh:description "The startup item kernel driver resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:driver ],
        [ sh:class ocsf:Process ;
            sh:description "The startup item process resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:process ],
        [ sh:description "The run state ID of the startup item." ;
            sh:in ( "STOPPED" "START_PENDING" "STOP_PENDING" "RUNNING" "CONTINUE_PENDING" "PAUSE_PENDING" "PAUSED" "RESTART_PENDING" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path ocsf:run_state_id ],
        [ sh:datatype xsd:string ;
            sh:description "The unique name of the startup item." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:name ] ;
    sh:targetClass ocsf:WindowsStartupItem .

ocsf:AccessAnalysisResult a sh:NodeShape ;
    rdfs:comment """The Access Analysis Result object describes access relationships and pathways
between identities, resources, focusing on who can access what and through
which mechanisms. This evaluates access levels (read/write/admin), access types
(direct, cross-account, public, federated), and the conditions under which
access is granted. Use this for resource-centric security assessments such as
external access discovery, public exposure analysis, etc.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The generalized access level or permission scope granted to the identity
through the analyzed policy configuration. Common examples include Read, Write,
List, Delete, Admin, or custom permission levels.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:access_level ],
        [ sh:class ocsf:AdditionalRestriction ;
            sh:description """Details about supplementary restrictions and guardrails that may limit the
granted access, applied through additional policy types such as Resource
Control Policies (RCPs) and Service Control Policies (SCPs) in AWS, or other
policy constraints.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:additional_restrictions ],
        [ sh:datatype xsd:string ;
            sh:description """The specific privileges, actions, or permissions that are granted through the
analyzed access relationship. This includes the actual operations that the
accessor can perform on the target resource. Examples: AWS actions like
'sts:AssumeRole', 's3:GetObject', 'ec2:DescribeInstances'; Azure actions like
'Microsoft.Storage/storageAccounts/read'; or GCP permissions like
'storage.objects.get'.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:granted_privileges ],
        [ sh:datatype xsd:string ;
            sh:description """The type or category of access being granted to the identity. This describes
the nature of the access relationship, such as cross-account access, public
access, federated access, or third-party integration access. Examples include
'Cross-Account', 'Public', 'Federated', 'Service-to-Service', etc.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:access_type ],
        [ sh:class ocsf:User ;
            sh:description """The identities that are granted access through the analyzed policy
configuration. This identifies the specific entity that can exercise the
permissions and helps assess the access relationship and potential security
implications. Examples include user accounts, service principals, roles,
account identifiers, or system identities.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:accessors ],
        [ sh:class ocsf:KeyValueObject ;
            sh:description """The condition keys and their values that constrain when and how the granted
access can be exercised. These conditions define the circumstances under which
the access relationship is valid and the privileges can be used. Examples: IP
address restrictions like 'aws:SourceIp:192.0.2.0/24', time-based constraints
like 'aws:RequestedRegion:us-east-1', MFA requirements like
'aws:MultiFactorAuthPresent:true', or custom conditions based on resource tags
and request context.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:condition_keys ] ;
    sh:targetClass ocsf:AccessAnalysisResult .

ocsf:AdditionalRestriction a sh:NodeShape ;
    rdfs:comment """The Additional Restriction object describes supplementary access controls and
guardrails that constrain or limit granted permissions beyond the primary
policy. These restrictions are typically applied through hierarchical policy
frameworks, organizational controls, or conditional access mechanisms. Examples
include AWS Service Control Policies (SCPs), Resource Control Policies (RCPs),
Azure Management Group policies, GCP Organization policies, conditional access
policies, IP restrictions, time-based constraints, and MFA requirements.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The current status of the policy restriction, normalized to the caption of the
<code>status_id</code> enum value.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:status ],
        [ sh:class ocsf:Policy ;
            sh:description """Detailed information about the policy document that defines this restriction,
including policy metadata, type, scope, and the specific rules or conditions
that implement the access control.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:policy ],
        [ sh:description """The normalized status identifier indicating the applicability of this policy
restriction.""" ;
            sh:in ( "APPLICABLE" "INAPPLICABLE" "EVALUATION_ERROR" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path ocsf:status_id ] ;
    sh:targetClass ocsf:AdditionalRestriction .

ocsf:Advisory a sh:NodeShape ;
    rdfs:comment """The Advisory object represents publicly disclosed cybersecurity vulnerabilities
defined in a Security advisory. e.g. <code> Microsoft KB Article</code>,
<code>Apple Security Advisory</code>, or a <code>GitHub Security Advisory
(GHSA)</code>""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "The Advisory has been replaced by another." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:is_superseded ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier assigned to the advisory or disclosed vulnerability, e.g,
<code>GHSA-5mrr-rgp6-x4gr</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:uid ],
        [ sh:class ocsf:Os ;
            sh:description "The operating system the Advisory applies to." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:os ],
        [ sh:datatype xsd:string ;
            sh:description "The install state of the Advisory." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:install_state ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the Advisory record was created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:created_time ],
        [ sh:datatype xsd:string ;
            sh:description "A brief description of the Advisory Record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:desc ],
        [ sh:datatype xsd:integer ;
            sh:description "The size in bytes for the Advisory. Usually populated for a KB Article patch." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:size ],
        [ sh:datatype xsd:string ;
            sh:description """A list of reference URLs with additional information about the vulnerabilities
disclosed in the Advisory.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:references ],
        [ sh:datatype xsd:string ;
            sh:description "The Advisory bulletin identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:bulletin ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the Advisory record was last updated." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:modified_time ],
        [ sh:datatype xsd:string ;
            sh:description "The vendors classification of the Advisory." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:classification ],
        [ sh:class ocsf:Cwe ;
            sh:description """A list of Common Weakness Enumeration <a target='_blank'
href='https://cwe.mitre.org/'>(CWE)</a> identifiers related to the
vulnerabilities disclosed in the Advisory.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:related_cwes ],
        [ sh:datatype xsd:string ;
            sh:description "A title or a brief phrase summarizing the Advisory." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:title ],
        [ sh:class ocsf:Product ;
            sh:description "The product where the vulnerability was discovered." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path ocsf:product ],
        [ sh:datatype xsd:anyURI ;
            sh:description "The Advisory link from the source vendor." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:src_url ],
        [ sh:class ocsf:Timespan ;
            sh:description "The average time to patch." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:avg_timespan ],
        [ sh:description "The normalized install state ID of the Advisory." ;
            sh:in ( "UNKNOWN" "INSTALLED" "NOT_INSTALLED" "INSTALLED_PENDING_REBOOT" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path ocsf:install_state_id ],
        [ sh:class ocsf:Cve ;
            sh:description """A list of Common Vulnerabilities and Exposures <a target='_blank'
href='https://cve.mitre.org/'>(CVE)</a> identifiers related to the
vulnerabilities disclosed in the Advisory.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:related_cves ] ;
    sh:targetClass ocsf:Advisory .

ocsf:AffectedCode a sh:NodeShape ;
    rdfs:comment """The Affected Code object describes details about a code block identified as
vulnerable.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description """The column number of the last part of the assessed code identified as
vulnerable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:end_column ],
        [ sh:datatype xsd:integer ;
            sh:description "The line number of the first line of code block identified as vulnerable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:start_line ],
        [ sh:class ocsf:File ;
            sh:description "Details about the file that contains the affected code block." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:file ],
        [ sh:datatype xsd:integer ;
            sh:description """The column number of the first part of the assessed code identified as
vulnerable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:start_column ],
        [ sh:class ocsf:Rule ;
            sh:description """Details about the specific rule, e.g., those defined as part of a larger
<code>policy</code>, that triggered the finding.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:rule ],
        [ sh:class ocsf:Remediation ;
            sh:description "Describes the recommended remediation steps to address identified issue(s)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:remediation ],
        [ sh:datatype xsd:integer ;
            sh:description "The line number of the last line of code block identified as vulnerable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:end_line ],
        [ sh:class ocsf:User ;
            sh:description "Details about the user that owns the affected file." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:owner ] ;
    sh:targetClass ocsf:AffectedCode .

ocsf:AffectedPackage a sh:NodeShape ;
    rdfs:comment """The Affected Package object describes details about a software package
identified as affected by a vulnerability/vulnerabilities.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The Common Platform Enumeration (CPE) name as described by (<a target='_blank'
href='https://nvd.nist.gov/products/cpe'>NIST</a>) For example:
<code>cpe:/a:apple:safari:16.2</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:cpe_name ],
        [ sh:datatype xsd:anyURI ;
            sh:description """The link to the specific library or package such as within <code>GitHub</code>,
this is different from the link to the package manager where the library or
package is hosted.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:src_url ],
        [ sh:class ocsf:Remediation ;
            sh:description "Describes the recommended remediation steps to address identified issue(s)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:remediation ],
        [ sh:datatype xsd:string ;
            sh:description """A unique identifier for the package or library reported by the source tool.
E.g., the <code>libId</code> within the <code>sbom</code> field of an OX
Security Issue or the SPDX <code>components.*.bom-ref</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:uid ],
        [ sh:class ocsf:Fingerprint ;
            sh:description """Cryptographic hash to identify the binary instance of a software component.
This can include any component such file, package, or library.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:hash ],
        [ sh:datatype xsd:string ;
            sh:description "The software package version." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:version ],
        [ sh:datatype xsd:integer ;
            sh:description """The software package epoch. Epoch is a way to define weighted dependencies
based on version numbers.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:epoch ],
        [ sh:datatype xsd:string ;
            sh:description """The software packager manager utilized to manage a package on a system, e.g.
npm, yum, dpkg etc.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:package_manager ],
        [ sh:datatype xsd:string ;
            sh:description "Release is the number of times a version of the software has been packaged." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:release ],
        [ sh:datatype xsd:string ;
            sh:description "The installation path of the affected package." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:path ],
        [ sh:datatype xsd:string ;
            sh:description """The software package version in which a reported vulnerability was
patched/fixed.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:fixed_in_version ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the vendor who published the software package." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:vendor_name ],
        [ sh:datatype xsd:anyURI ;
            sh:description """The URL pointing to the license applied on package or software. This is
typically a <code>LICENSE.md</code> file within a repository.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:license_url ],
        [ sh:datatype xsd:string ;
            sh:description """A purl is a URL string used to identify and locate a software package in a
mostly universal and uniform way across programming languages, package
managers, packaging conventions, tools, APIs and databases.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:purl ],
        [ sh:datatype xsd:string ;
            sh:description "The software package name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:name ],
        [ sh:description "The type of software package." ;
            sh:in ( "APPLICATION" "OPERATING_SYSTEM" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 16 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:string ;
            sh:description """The type of software package, normalized to the caption of the
<code>type_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description "The software license applied to this package." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:license ],
        [ sh:datatype xsd:anyURI ;
            sh:description """The URL of the package or library at the package manager, or the specific URL
or URI of an internal package manager link such as <code>AWS
CodeArtifact</code> or <code>Artifactory</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:package_manager_url ],
        [ sh:datatype xsd:string ;
            sh:description """Architecture is a shorthand name describing the type of computer hardware the
packaged software is meant to run on.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:architecture ] ;
    sh:targetClass ocsf:AffectedPackage .

ocsf:Aircraft a sh:NodeShape ;
    rdfs:comment """The Aircraft object represents any aircraft or otherwise airborne asset such as
an unmanned system, airplane, balloon, spacecraft, or otherwise. The Aircraft
object is intended to normalized data captured or otherwise logged from active
radar, passive radar, multi-spectral systems, or the Automatic Dependant
Broadcast - Surveillance (ADS-B), and/or Mode S systems.""" ;
    sh:closed true ;
    sh:ignoredProperties ( ocsf:uuid rdf:type ocsf:type_id ocsf:type ocsf:hw_info ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The model name of the aircraft or unmanned system." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:model ],
        [ sh:datatype xsd:string ;
            sh:description """The primary identification identifier for an aircraft, such as the 24-bit
International Civil Aviation Organization (ICAO) identifier of the aircraft, as
6 hex digits.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description """A secondary identification identifier for an aircraft, such as the 4-digit
squawk (octal representation).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:uid_alt ],
        [ sh:datatype xsd:string ;
            sh:description """Provides quality/containment on horizontal ground speed. Measured in
meters/second.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:speed_accuracy ],
        [ sh:datatype xsd:string ;
            sh:description """Direction of flight expressed as a “True North-based” ground track angle. This
value is provided in clockwise degrees with a minimum resolution of 1 degree.
If aircraft is not moving horizontally, use the “Unknown” value""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:track_direction ],
        [ sh:datatype xsd:string ;
            sh:description """Ground speed of flight. This value is provided in meters per second with a
minimum resolution of 0.25 m/s. Special Values: <code>Invalid</code>, <code>No
Value</code>, or <code>Unknown: 255 m/s</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:speed ],
        [ sh:datatype xsd:string ;
            sh:description "The serial number of the aircraft." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:serial_number ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the aircraft, such as the such as the flight name or callsign." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description """Vertical speed upward relative to the WGS-84 datum, measured in meters per
second. Special Values: <code>Invalid</code>, <code>No Value</code>, or
<code>Unknown: 63 m/s</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:vertical_speed ],
        [ sh:class ocsf:Location ;
            sh:description "The detailed geographical location usually associated with an IP address." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:location ] ;
    sh:targetClass ocsf:Aircraft .

ocsf:AnalysisTarget a sh:NodeShape ;
    rdfs:comment """The analysis target defines the scope of monitored activities, specifying what
entity, system or process is analyzed for activity patterns.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The category of the analysis target, such as User Account, Kubernetes Cluster,
Network Namespace, or Application Component.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description """The specific name or identifier of the analysis target, such as the username of
a User Account, the name of a Kubernetes Cluster, the identifier of a Network
Namespace, or the name of an Application Component.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:name ] ;
    sh:targetClass ocsf:AnalysisTarget .

ocsf:Anomaly a sh:NodeShape ;
    rdfs:comment """Describes an anomaly or deviation detected in a system. Anomalies are
unexpected activity patterns that could indicate potential issues needing
attention.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The type of analysis methodology used to detect the anomaly. This indicates how
the anomaly was identified through different analytical approaches. Common
types include: Frequency Analysis, Time Pattern Analysis, Volume Analysis,
Sequence Analysis, Distribution Analysis, etc.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:observation_type ],
        [ sh:datatype xsd:string ;
            sh:description """The specific parameter, metric or property where the anomaly was observed.
Examples include: CPU usage percentage, API response time in milliseconds, HTTP
error rate, memory utilization, network latency, transaction volume, etc. This
helps identify the exact aspect of the system exhibiting anomalous behavior.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:observation_parameter ],
        [ sh:datatype xsd:string ;
            sh:description """The specific pattern identified within the observation type. For Frequency
Analysis, this could be 'FREQUENT', 'INFREQUENT', 'RARE', or 'UNSEEN'. For Time
Pattern Analysis, this could be 'BUSINESS_HOURS', 'OFF_HOURS', or
'UNUSUAL_TIME'. For Volume Analysis, this could be 'NORMAL_VOLUME',
'HIGH_VOLUME', or 'SURGE'. The pattern values are specific to each observation
type and indicate how the observed behavior relates to the baseline.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:observed_pattern ],
        [ sh:class ocsf:Observation ;
            sh:description """Details about the observed anomaly or observations that were flagged as
anomalous compared to expected baseline behavior.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:observations ] ;
    sh:targetClass ocsf:Anomaly .

ocsf:AnomalyAnalysis a sh:NodeShape ;
    rdfs:comment """Describes the analysis of activity patterns and anomalies of target entities to
identify potential security threats, performance issues, or other deviations
from established baselines. This includes monitoring and analyzing user
interactions, API usage, resource utilization, access patterns and other
measured indicators.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Baseline ;
            sh:description """List of established patterns representing normal activity that serve as
reference points for anomaly detection. This includes typical user interaction
patterns like common user-agents, expected API access frequencies and patterns,
standard resource utilization levels, and regular traffic flows. These
baselines help establish what constitutes 'normal' activity in the system.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:baselines ],
        [ sh:class ocsf:Anomaly ;
            sh:description """List of detected activities that significantly deviate from the established
baselines. This can include unusual access patterns, unexpected user-agents,
abnormal API usage, suspicious traffic spikes, unauthorized access attempts,
and other activities that may indicate potential security threats or system
issues.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:anomalies ],
        [ sh:class ocsf:AnalysisTarget ;
            sh:description """The analysis targets define the scope of monitored activities, specifying what
entities, systems or processes are analyzed for activity patterns.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:analysis_targets ] ;
    sh:targetClass ocsf:AnomalyAnalysis .

ocsf:AuthenticationToken a sh:NodeShape ;
    rdfs:comment """The Authentication Token object extends the base <code>token</code> object and
represents standardized authentication tokens, tickets, or assertions that
conform to established authentication protocols such as Kerberos, OIDC, and
SAML. This object inherits all attributes from <code>token</code> and adds
protocol-specific attributes (e.g., <code>kerberos_flags</code>,
<code>encryption_details</code>) for authentication events. Use this object in
authentication events to represent protocol-specific tokens: Kerberos Ticket
Granting Tickets (TGT) and Service Tickets (ST), OIDC Identity Tokens and
Refresh Tokens, and SAML Assertions. These tokens are issued by authentication
servers and identity providers and carry protocol-specific metadata, lifecycle
information, and security attributes defined by their respective
specifications. When to use this object: Use <code>authentication_token</code>
when representing protocol-specific authentication tokens (type_id values 1-5:
Kerberos TGT/ST, OIDC ID/Refresh tokens, SAML assertions) in authentication
events. When NOT to use this object: Do NOT use
<code>authentication_token</code> for API tokens or client tokens (type_id
values 6-7) used in API activity events - use the base <code>token</code>
object instead. Do NOT use <code>authentication_token</code> for generic API
keys - use the base <code>token</code> object instead.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description """The normalized authentication token type identifier. This attribute restricts
the base <code>token.type_id</code> enum to only protocol-specific
authentication token types (values 0, 1-5, 99). API tokens and client tokens
(values 6-7) are not valid for <code>authentication_token</code> - use the base
<code>token</code> object for those types.""" ;
            sh:in ( "UNKNOWN" "TICKET_GRANTING_TICKET" "SERVICE_TICKET" "IDENTITY_TOKEN" "REFRESH_TOKEN" "SAML_ASSERTION" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:long ;
            sh:description "The last time the token was updated." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:modified_time ],
        [ sh:datatype xsd:string ;
            sh:description "The type of the authentication token." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description """The unique ID of a token or key, if available, such as the <code>Secret
ID</code> of Entra ID Application Registration Client Secrets.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description """The human-friendly name of a token or key, if available, such as the
<code>name</code> from the Okta API Token API.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:long ;
            sh:description """The time that the authentication token was created or issued. This corresponds
to the token issuance time, such as the <code>iat</code> (issued at) claim in
OIDC tokens, the issue instant in SAML assertions, or the ticket start time in
Kerberos tickets.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:created_time ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether the authentication token is renewable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:is_renewable ],
        [ sh:datatype xsd:string ;
            sh:description """A bitmask, either in hexadecimal or decimal form, which encodes various
attributes or permissions associated with a Kerberos ticket. These flags
delineate specific characteristics of the ticket, such as its renewability or
forwardability.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:kerberos_flags ],
        [ sh:datatype xsd:long ;
            sh:description "The expiration time of the authentication token." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:expiration_time ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier of the tenant or organization that owns the token or key,
or the tenant context in which the token is authorized for use. This is
particularly relevant in multi-tenant Identity Provider scenarios where tokens
are scoped to specific tenants.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:tenant_uid ],
        [ sh:class ocsf:EncryptionDetails ;
            sh:description "The encryption details of the authentication token." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:encryption_details ],
        [ sh:datatype xsd:string ;
            sh:description """The network zone or geographic region that the token or key is authorized to be
used from. This may represent network-based access restrictions, geographic
limitations, or other zone-based authorization policies. Examples include
Okta's network zone restrictions or cloud provider region restrictions.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:zone ] ;
    sh:targetClass ocsf:AuthenticationToken .

ocsf:Baseline a sh:NodeShape ;
    rdfs:comment """Describes the baseline or expected behavior of a system, service, or component
based on historical observations and measurements. It establishes reference
points for comparison to detect anomalies, trends, and deviations from typical
patterns.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The specific pattern identified within the observation type. For Frequency
Analysis, this could be 'FREQUENT', 'INFREQUENT', 'RARE', or 'UNSEEN'. For Time
Pattern Analysis, this could be 'BUSINESS_HOURS', 'OFF_HOURS', or
'UNUSUAL_TIME'. For Volume Analysis, this could be 'NORMAL_VOLUME',
'HIGH_VOLUME', or 'SURGE'. The pattern values are specific to each observation
type and indicate the baseline behavior.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:observed_pattern ],
        [ sh:datatype xsd:string ;
            sh:description """The specific parameter or property being monitored. Examples include: CPU usage
percentage, API response time in milliseconds, HTTP error rate, memory
utilization, network latency, transaction volume, etc.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:observation_parameter ],
        [ sh:class ocsf:Observation ;
            sh:description """Collection of actual measured values, data points and observations recorded for
this baseline.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:observations ],
        [ sh:datatype xsd:string ;
            sh:description """The type of analysis being performed to establish baseline behavior. Common
types include: Frequency Analysis, Time Pattern Analysis, Volume Analysis,
Sequence Analysis, Distribution Analysis, etc.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:observation_type ] ;
    sh:targetClass ocsf:Baseline .

ocsf:Campaign a sh:NodeShape ;
    rdfs:comment """Campaign represent organized efforts by threat actors to achieve malicious
objectives over a period, often characterized by shared tactics, techniques,
and procedures (TTPs).""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The name of a specific campaign associated with a cyber threat." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:name ] ;
    sh:targetClass ocsf:Campaign .

ocsf:Check a sh:NodeShape ;
    rdfs:comment """The check object defines a specific, testable compliance verification point
that evaluates a target device against a standard, framework, or custom
requirement. While checks are typically associated with formal standards (like
CIS, NIST, or ISO), they can also represent custom or organizational
requirements. When mapped to controls, checks can evaluate specific
control_parameters to determine compliance status, but neither the control
mapping nor control_parameters are required for a valid check.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The normalized status identifier of the compliance check." ;
            sh:in ( "UNKNOWN" "PASS" "WARNING" "FAIL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path ocsf:status_id ],
        [ sh:datatype xsd:string ;
            sh:description """The severity level as defined in the source document. For example CIS
Benchmarks, valid values are: <code>Level 1</code> (security-forward, essential
settings), <code>Level 2</code> (security-focused environment, more
restrictive), or <code>Scored/Not Scored</code> (whether compliance can be
automatically checked). For DISA STIG, valid values are: <code>CAT I</code>
(maps to severity_id 5/Critical), <code>CAT II</code> (maps to severity_id
4/High), or <code>CAT III</code> (maps to severity_id 3/Medium).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:severity ],
        [ sh:description """The normalized severity identifier that maps severity levels to standard
severity levels. For example CIS Benchmark: <code>Level 2</code> maps to
<code>4</code> (High), <code>Level 1</code> maps to <code>3</code> (Medium).
For DISA STIG: <code>CAT I</code> maps to <code>5</code> (Critical), <code>CAT
II</code> maps to <code>4</code> (High), and <code>CAT III</code> maps to
<code>3</code> (Medium).""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier of the compliance check within its standard or framework.
For example, CIS Benchmark identifier <code>1.1.1.1</code>, DISA STIG
identifier <code>V-230234</code>, or NIST control identifier
<code>AC-17(2)</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description """The detailed description of the compliance check, explaining the security
requirement, vulnerability, or configuration being assessed. For example, CIS:
<code>The cramfs filesystem type is a compressed read-only Linux filesystem.
Removing support for unneeded filesystem types reduces the local attack
surface.</code> or DISA STIG: <code>Unauthorized access to the information
system by foreign entities may result in loss or compromise of data.</code>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:desc ],
        [ sh:datatype xsd:string ;
            sh:description """The check version. For example, CIS Benchmark: <code>1.1.0</code> for Amazon
Linux 2 or DISA STIG: <code>V2R1</code> for Windows 10.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:version ],
        [ sh:class ocsf:ResourceDetails ;
            sh:description "Describes details about the resource that this check evaluated." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:resource ],
        [ sh:datatype xsd:string ;
            sh:description """The name or title of the compliance check. For example, CIS: <code>Ensure
mounting of cramfs filesystems is disabled</code> or DISA STIG: <code>The
Ubuntu operating system must implement DoD-approved encryption to protect the
confidentiality of remote access sessions</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description """The regulatory or industry standard this check is associated with. E.g.,
<code>PCI DSS 3.2.1</code>, <code>HIPAA Security Rule</code>, <code>NIST SP
800-53 Rev. 5</code>, or <code>ISO/IEC 27001:2013</code>.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:standards ],
        [ sh:datatype xsd:string ;
            sh:description """The resultant status of the compliance check normalized to the caption of the
<code>status_id</code> value. For example, CIS Benchmark: <code>Pass</code>
when all requirements are met, <code>Fail</code> when requirements are not met,
or DISA STIG: <code>NotAFinding</code> (maps to status_id 1/Pass),
<code>Open</code> (maps to status_id 3/Fail).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:status ] ;
    sh:targetClass ocsf:Check .

ocsf:CisBenchmarkResult a sh:NodeShape ;
    rdfs:comment """The CIS Benchmark Result object contains information as defined by the Center
for Internet Security (<a target='_blank'
href='https://www.cisecurity.org/cis-benchmarks/'>CIS</a>) benchmark result.
CIS Benchmarks are a collection of best practices for securely configuring IT
systems, software, networks, and cloud infrastructure.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The CIS benchmark name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The CIS benchmark description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:desc ],
        [ sh:class ocsf:Rule ;
            sh:description "The CIS benchmark rule." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:rule ],
        [ sh:class ocsf:Remediation ;
            sh:description "Describes the recommended remediation steps to address identified issue(s)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:remediation ] ;
    sh:targetClass ocsf:CisBenchmarkResult .

ocsf:CisCsc a sh:NodeShape ;
    rdfs:comment """The CIS Critical Security Control (CSC) contains information as defined by the
Center for Internet Security Critical Security Control <a target='_blank'
href='https://www.cisecurity.org/controls'>(CIS CSC)</a>. Prioritized set of
actions to protect your organization and data from cyber-attack vectors.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The CIS critical security control version." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:version ],
        [ sh:datatype xsd:string ;
            sh:description """A Control is prescriptive, prioritized, and simplified set of best practices
that one can use to strengthen their cybersecurity posture. e.g. AWS
SecurityHub Controls, CIS Controls.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:control ] ;
    sh:targetClass ocsf:CisCsc .

ocsf:Cvss a sh:NodeShape ;
    rdfs:comment """The Common Vulnerability Scoring System (<a target='_blank'
href='https://www.first.org/cvss/'>CVSS</a>) object provides a way to capture
the principal characteristics of a vulnerability and produce a numerical score
reflecting its severity.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:float ;
            sh:description """The CVSS overall score, impacted by base, temporal, and environmental metrics.
For example: <code>9.1</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:overall_score ],
        [ sh:datatype xsd:string ;
            sh:description """The vendor that provided the CVSS score. For example: <code>NVD, REDHAT</code>
etc.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:vendor_name ],
        [ sh:datatype xsd:string ;
            sh:description """The CVSS vector string is a text representation of a set of CVSS metrics. It is
commonly used to record or transfer CVSS metric information in a concise form.
For example: <code>3.1/AV:L/AC:L/PR:L/UI:N/S:U/C:H/I:N/A:H</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:vector_string ],
        [ sh:datatype xsd:anyURI ;
            sh:description """The source URL for the CVSS score. For example:
<code>https://nvd.nist.gov/vuln/detail/CVE-2021-44228</code>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:src_url ],
        [ sh:class ocsf:Metric ;
            sh:description """The Common Vulnerability Scoring System metrics. This attribute contains
information on the CVE's impact. If the CVE has been analyzed, this attribute
will contain any CVSSv2 or CVSSv3 information associated with the
vulnerability. For example: <code>{ {"Access Vector", "Network"}, {"Access
Complexity", "Low"}, ...}</code>.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:metrics ],
        [ sh:datatype xsd:string ;
            sh:description "The CVSS version. For example: <code>3.1</code>." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:version ],
        [ sh:description "The CVSS depth represents a depth of the equation used to calculate CVSS score." ;
            sh:in ( "BASE" "ENVIRONMENTAL" "TEMPORAL" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path ocsf:depth ],
        [ sh:datatype xsd:float ;
            sh:description "The CVSS base score. For example: <code>9.1</code>." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:base_score ],
        [ sh:datatype xsd:string ;
            sh:description """<p>The Common Vulnerability Scoring System (CVSS) Qualitative Severity Rating.
A textual representation of the numeric score.</p><strong>CVSS
v2.0</strong><ul><li>Low (0.0 – 3.9)</li><li>Medium (4.0 – 6.9)</li><li>High
(7.0 – 10.0)</li></ul></p><strong>CVSS v3.0</strong><ul><li>None
(0.0)</li><li>Low (0.1 - 3.9)</li><li>Medium (4.0 - 6.9)</li><li>High (7.0 -
8.9)</li><li>Critical (9.0 - 10.0)</li></ul>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:severity ] ;
    sh:targetClass ocsf:Cvss .

ocsf:D3fTactic a sh:NodeShape ;
    rdfs:comment """The MITRE D3FEND™ Tactic object describes the tactic ID and/or name that is
associated to an attack.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description """The versioned permalink of the defensive tactic. For example:
<code>https://d3fend.mitre.org/tactic/d3f:Isolate/</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:src_url ],
        [ sh:datatype xsd:string ;
            sh:description """The tactic name that is associated with the defensive technique. For example:
<code>Isolate</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the defensive tactic." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:uid ] ;
    sh:targetClass ocsf:D3fTactic .

ocsf:D3fTechnique a sh:NodeShape ;
    rdfs:comment """The MITRE D3FEND™ Technique object describes the leaf defensive technique ID
and/or name associated to a countermeasure.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description """The versioned permalink of the defensive technique. For example:
<code>https://d3fend.mitre.org/technique/d3f:IOPortRestriction/</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:src_url ],
        [ sh:datatype xsd:string ;
            sh:description """The name of the defensive technique. For example: <code>IO Port
Restriction</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier of the defensive technique. For example:
<code>D3-IOPR</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:uid ] ;
    sh:targetClass ocsf:D3fTechnique .

ocsf:DataSecurity a sh:NodeShape ;
    rdfs:comment """The Data Security object describes the characteristics, techniques and content
of a Data Loss Prevention (DLP), Data Loss Detection (DLD), Data
Classification, or similar tools' finding, alert, or detection mechanism(s).""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description """The type of data security tool or system that the finding, detection, or alert
originated from.""" ;
            sh:in ( "UNKNOWN" "ENDPOINT" "DLP_GATEWAY" "MOBILE_DEVICE_MANAGEMENT" "DATA_DISCOVERY_CLASSIFICATION" "SECURE_WEB_GATEWAY" "SECURE_EMAIL_GATEWAY" "DIGITAL_RIGHTS_MANAGEMENT" "CLOUD_ACCESS_SECURITY_BROKER" "DATABASE_ACTIVITY_MONITORING" "APPLICATION_LEVEL_DLP" "DEVELOPER_SECURITY" "DATA_SECURITY_POSTURE_MANAGEMENT" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path ocsf:detection_system_id ],
        [ sh:datatype xsd:string ;
            sh:description """The name of the stage or state that the data was in. E.g., Data-at-Rest,
Data-in-Transit, etc.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:data_lifecycle_state ],
        [ sh:datatype xsd:string ;
            sh:description """The name of the type of data security tool or system that the finding,
detection, or alert originated from. E.g., Endpoint, Secure Email Gateway, etc.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:detection_system ],
        [ sh:datatype xsd:string ;
            sh:description """The resultant status of the classification job normalized to the caption of the
<code>status_id</code> value. In the case of 'Other', it is defined by the
event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:integer ;
            sh:description "Size of the data classified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:size ],
        [ sh:datatype xsd:anyURI ;
            sh:description "The source URL pointing towards the full classification job details." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:src_url ],
        [ sh:datatype xsd:string ;
            sh:description "Specific pattern, algorithm, fingerprint, or model used for detection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:detection_pattern ],
        [ sh:description "The normalized identifier of the data classification category." ;
            sh:in ( "UNKNOWN" "PERSONAL" "GOVERNMENTAL" "FINANCIAL" "BUSINESS" "MILITARY_AND_LAW_ENFORCEMENT" "SECURITY" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path ocsf:category_id ],
        [ sh:description "The normalized identifier of the file content confidentiality indicator." ;
            sh:in ( "UNKNOWN" "NOT_CONFIDENTIAL" "CONFIDENTIAL" "SECRET" "TOP_SECRET" "PRIVATE" "RESTRICTED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 11 ;
            sh:path ocsf:confidentiality_id ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the classification job." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:integer ;
            sh:description "The total count of discovered entities, by the classification job." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:total ],
        [ sh:class ocsf:Policy ;
            sh:description "Details about the policy that triggered the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:string ;
            sh:description """The file content confidentiality, normalized to the confidentiality_id value.
In the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:confidentiality ],
        [ sh:datatype xsd:string ;
            sh:description """The name of the data classification category that data matched into, e.g.
Financial, Personal, Governmental, etc.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:category ],
        [ sh:datatype xsd:string ;
            sh:description "The contextual description of the <code>status, status_id</code> value." ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:status_details ],
        [ sh:description """The stage or state that the data was in when it was assessed or scanned by a
data security tool.""" ;
            sh:in ( "UNKNOWN" "DATA_AT_REST" "DATA_IN_TRANSIT" "DATA_IN_USE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path ocsf:data_lifecycle_state_id ],
        [ sh:class ocsf:ClassifierDetails ;
            sh:description "Describes details about the classifier used for data classification." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:classifier_details ],
        [ sh:description "The normalized status identifier of the classification job." ;
            sh:in ( "UNKNOWN" "COMPLETE" "PARTIAL" "FAIL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 17 ;
            sh:path ocsf:status_id ],
        [ sh:class ocsf:DiscoveryDetails ;
            sh:description "Details about the data discovered by classification job." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:discovery_details ],
        [ sh:datatype xsd:string ;
            sh:description "A text, binary, file name, or datastore that matched against a detection rule." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:pattern_match ] ;
    sh:targetClass ocsf:DataSecurity .

ocsf:DceRpc a sh:NodeShape ;
    rdfs:comment """The DCE/RPC, or Distributed Computing Environment/Remote Procedure Call, object
describes the remote procedure call system for distributed computing
environments.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The request command (e.g. REQUEST, BIND)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:command ],
        [ sh:datatype xsd:string ;
            sh:description "The list of interface flags." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:flags ],
        [ sh:class ocsf:RpcInterface ;
            sh:description """The RPC Interface object describes the details pertaining to the remote
procedure call interface.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:rpc_interface ],
        [ sh:datatype xsd:string ;
            sh:description "The reply to the request command (e.g. RESPONSE, BINDACK or FAULT)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:command_response ],
        [ sh:datatype xsd:integer ;
            sh:description """An operation number used to identify a specific remote procedure call (RPC)
method or a method in an interface.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:opnum ] ;
    sh:targetClass ocsf:DceRpc .

ocsf:DomainContact a sh:NodeShape ;
    rdfs:comment """The contact information related to a domain registration, e.g., registrant,
administrator, abuse, billing, or technical contact.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The normalized domain contact type ID." ;
            sh:in ( "REGISTRANT" "ADMINISTRATIVE" "TECHNICAL" "BILLING" "ABUSE" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:string ;
            sh:description """The Domain Contact type, normalized to the caption of the <code>type_id</code>
value. In the case of 'Other', it is defined by the source""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:type ],
        [ sh:class ocsf:Location ;
            sh:description """Location details for the contract such as the city, state/province, country,
etc.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:location ],
        [ sh:datatype xsd:string ;
            sh:description "The number associated with the phone." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:phone_number ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier of the contact information, typically provided in WHOIS
information.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description "The user's primary email address." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:email_addr ;
            sh:pattern "^[\\w.+\\-]+@[\\w\\-]+(\\.[\\w\\-]+)+$" ],
        [ sh:datatype xsd:string ;
            sh:description "The individual or organization name for the contact." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:name ] ;
    sh:targetClass ocsf:DomainContact .

ocsf:Edge a sh:NodeShape ;
    rdfs:comment "Represents a connection or relationship between two nodes in a graph." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the node where the edge terminates." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:target ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the node where the edge originates." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:source ],
        [ sh:datatype xsd:string ;
            sh:description "The human-readable name or label for the edge." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "Additional data about the edge such as weight, distance, or custom properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:data ],
        [ sh:datatype xsd:string ;
            sh:description "The type of relationship between nodes (e.g. is-attached-to , depends-on, etc)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:relation ],
        [ sh:datatype xsd:string ;
            sh:description "Unique identifier of the edge." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates whether the edge is (<code>true</code>) or undirected
(<code>false</code>).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:is_directed ] ;
    sh:targetClass ocsf:Edge .

ocsf:EndpointConnection a sh:NodeShape ;
    rdfs:comment """The Endpoint Connection object contains information detailing a connection
attempt to an endpoint.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:NetworkEndpoint ;
            sh:description "Provides characteristics of the network endpoint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:network_endpoint ],
        [ sh:datatype xsd:integer ;
            sh:description "A numerical response status code providing details about the connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:code ] ;
    sh:targetClass ocsf:EndpointConnection .

ocsf:Epss a sh:NodeShape ;
    rdfs:comment """The Exploit Prediction Scoring System (EPSS) object describes the estimated
probability a vulnerability will be exploited. EPSS is a community-driven
effort to combine descriptive information about vulnerabilities (CVEs) with
evidence of actual exploitation in-the-wild. (<a target='_blank'
href='https://www.first.org/epss/'>EPSS</a>).""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:float ;
            sh:description """The EPSS score's percentile representing relative importance and ranking of the
score in the larger EPSS dataset.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:percentile ],
        [ sh:datatype xsd:long ;
            sh:description "The timestamp indicating when the EPSS score was calculated." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:created_time ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the EPSS model used to calculate the score." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:version ],
        [ sh:datatype xsd:string ;
            sh:description """The EPSS score representing the probability [0-1] of exploitation in the wild
in the next 30 days (following score publication).""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:score ] ;
    sh:targetClass ocsf:Epss .

ocsf:Feature a sh:NodeShape ;
    rdfs:comment """The Feature object provides information about the software product feature that
generated a specific event. It encompasses details related to the capabilities,
components, user interface (UI) design, and performance upgrades associated
with the feature.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The version of the feature." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:version ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the feature." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the feature." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:name ] ;
    sh:targetClass ocsf:Feature .

ocsf:FindingObject a sh:NodeShape ;
    rdfs:comment """The Finding object describes metadata related to a security finding generated
by a security tool or system.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the product that reported the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:product_uid ],
        [ sh:datatype xsd:string ;
            sh:description "One or more types of the reported finding." ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:types ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the finding was first observed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:first_seen_time ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the reported finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:desc ],
        [ sh:datatype xsd:anyURI ;
            sh:description "The URL pointing to the source of the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:src_url ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the reported finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:uid ],
        [ sh:class ocsf:Product ;
            sh:description "Details about the product that reported the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:product ],
        [ sh:datatype xsd:string ;
            sh:description "Additional data supporting a finding as provided by security tool" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:supporting_data ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the finding was created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:created_time ],
        [ sh:datatype xsd:string ;
            sh:description "A title or a brief phrase summarizing the reported finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:title ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the finding was last modified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:modified_time ],
        [ sh:class ocsf:RelatedEvent ;
            sh:description """Describes events and/or other findings related to the finding as identified by
the security product. Note that these events may or may not be in OCSF.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:related_events ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the finding was most recently observed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:last_seen_time ],
        [ sh:class ocsf:Remediation ;
            sh:description "Describes the recommended remediation steps to address identified issue(s)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:remediation ] ;
    sh:targetClass ocsf:FindingObject .

ocsf:FunctionInvocation a sh:NodeShape ;
    rdfs:comment """The Function Invocation object provides details regarding the invocation of a
function.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The value returned from a function." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:return_value ],
        [ sh:datatype xsd:string ;
            sh:description """The error indication returned from the function. This may differ from the
return value (e.g. when <code>errno</code> is used).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:error ],
        [ sh:class ocsf:Parameter ;
            sh:description "The parameters passed into a function invocation." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:parameters ] ;
    sh:targetClass ocsf:FunctionInvocation .

ocsf:GpuInfo a sh:NodeShape ;
    rdfs:comment """The GPU information object contains attributes describing graphical processing
hardware.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The normalized identifier of the attachment bus or interface standard." ;
            sh:in ( "UNKNOWN" "ONBOARD" "PCIE_X16" "PCIE_X8" "MXM_TYPE_A" "MXM_TYPE_B" "M_2" "CXL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path ocsf:bus_type_id ],
        [ sh:description "The normalized identifier of the video memory attachment mode." ;
            sh:in ( "UNKNOWN" "SHARED" "DEDICATED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path ocsf:vram_mode_id ],
        [ sh:datatype xsd:string ;
            sh:description """The model name of the GPU. For example: <code>GeForce RTX A6000</code>,
<code>Radeon PRO W7900</code>, or <code>Intel Data Center GPU Max 1550</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:model ],
        [ sh:datatype xsd:integer ;
            sh:description "The number of processing cores or compute units for the component." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:cores ],
        [ sh:datatype xsd:integer ;
            sh:description "The total amount of installed video RAM." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:vram_size ],
        [ sh:datatype xsd:string ;
            sh:description """The video memory attachment mode, indicating how the VRAM hardware is
integrated with the system (e.g., shared or dedicated), normalized to the
caption of the vram_mode_id value. For 'Other', the exact attachment mode is
defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:vram_mode ],
        [ sh:datatype xsd:string ;
            sh:description """The attachment bus or interface standard, normalized to the caption of the
bus_type_id value. In the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:bus_type ],
        [ sh:datatype xsd:string ;
            sh:description """The name of the vendor of the GPU. For example: <code>NVIDIA</code>,
<code>AMD</code>, or <code>Intel</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:vendor_name ] ;
    sh:targetClass ocsf:GpuInfo .

ocsf:HttpCookie a sh:NodeShape ;
    rdfs:comment """The HTTP Cookie object, also known as a web cookie or browser cookie, contains
details and values pertaining to a small piece of data that a server sends to a
user's web browser. This data is then stored by the browser and sent back to
the server with subsequent requests, allowing the server to remember and track
certain information about the user's browsing session or preferences.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "A cookie attribute to make it inaccessible via JavaScript" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:http_only ],
        [ sh:datatype xsd:boolean ;
            sh:description """The cookie attribute indicates that cookies are sent to the server only when
the request is encrypted using the HTTPS protocol.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:is_secure ],
        [ sh:datatype xsd:string ;
            sh:description "The HTTP cookie value." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:value ],
        [ sh:datatype xsd:long ;
            sh:description "The expiration time of the HTTP cookie." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:expiration_time ],
        [ sh:datatype xsd:boolean ;
            sh:description """The cookie attribute to only send cookies to the server with an encrypted
request over the HTTPS protocol.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:secure ],
        [ sh:datatype xsd:string ;
            sh:description "The path of the HTTP cookie." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:path ],
        [ sh:datatype xsd:string ;
            sh:description """The cookie attribute that lets servers specify whether/when cookies are sent
with cross-site requests. Values are: Strict, Lax or None""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:samesite ],
        [ sh:datatype xsd:boolean ;
            sh:description "This attribute prevents the cookie from being accessed via JavaScript." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:is_http_only ],
        [ sh:datatype xsd:string ;
            sh:description "The HTTP cookie name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The domain name for the server from which the http_cookie is served." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:domain ] ;
    sh:targetClass ocsf:HttpCookie .

ocsf:IdentityActivityMetrics a sh:NodeShape ;
    rdfs:comment """The Identity Activity Metrics object captures usage patterns, authentication
activity, credential usage and other metrics for identities across cloud and
on-premises environments. Example identities include AWS IAM Users, Roles,
Azure AD Principals, GCP Service Accounts, on-premises Active Directory
accounts.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:long ;
            sh:description """The timestamp when password-based authentication was last used by this
identity. This helps distinguish between password and other authentication
methods (MFA, SSO, certificates) and identify password-specific usage patterns.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:password_last_used_time ],
        [ sh:datatype xsd:long ;
            sh:description """The timestamp when this identity was first observed or created in the system.
This helps establish the identity's age and lifecycle stage for risk
assessment.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:first_seen_time ],
        [ sh:class ocsf:ProgrammaticCredential ;
            sh:description """Details about the programmatic credentials associated with this identity, such
as API keys, service account keys, access tokens, and client certificates used
for automated access.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:programmatic_credentials ],
        [ sh:datatype xsd:long ;
            sh:description """The timestamp of the most recent activity performed by this identity, including
authentication, resource access, or API calls. This is the most comprehensive
indicator of identity usage recency.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:last_seen_time ],
        [ sh:datatype xsd:long ;
            sh:description """The timestamp when this identity last successfully authenticated to any system
or service. This differs from <code>last_seen_time</code> as it specifically
tracks authentication events rather than all activities.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:last_authentication_time ] ;
    sh:targetClass ocsf:IdentityActivityMetrics .

ocsf:LdapPerson a sh:NodeShape ;
    rdfs:comment "The additional LDAP attributes that describe a person." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:long ;
            sh:description "The timestamp when the user entry was last modified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:modified_time ],
        [ sh:datatype xsd:long ;
            sh:description "The last time when the user logged in." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:last_login_time ],
        [ sh:class ocsf:KeyValueObject ;
            sh:description "The list of tags; <code>{key:value}</code> pairs associated to the user." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path ocsf:tags ],
        [ sh:datatype xsd:string ;
            sh:description """The primary office location associated with the user. This could be any string
and isn't a specific address. For example, <code>South East Virtual</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:office_location ],
        [ sh:datatype xsd:long ;
            sh:description "The timestamp when the user was created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:created_time ],
        [ sh:class ocsf:User ;
            sh:description """The user's manager. This helps in understanding an org hierarchy. This should
only ever be populated once in an event. I.e. there should not be a manager's
manager in an event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path ocsf:manager ],
        [ sh:datatype xsd:long ;
            sh:description "The timestamp when the user was or will be hired by the organization." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:hire_time ],
        [ sh:datatype xsd:string ;
            sh:description "The user's job title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:job_title ],
        [ sh:datatype xsd:string ;
            sh:description """The LDAP and X.500 <code>commonName</code> attribute, typically the full name
of the person. For example, <code>John Doe</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:ldap_cn ],
        [ sh:datatype xsd:string ;
            sh:description """The telephone number of the user. Corresponds to the LDAP
<code>Telephone-Number</code> CN.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:phone_number ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the department in which the user works." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:department ],
        [ sh:datatype xsd:string ;
            sh:description "The given or first name of the user." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:given_name ],
        [ sh:datatype xsd:string ;
            sh:description """The display name of the LDAP person. According to RFC 2798, this is the
preferred name of a person to be used when displaying entries.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:display_name ],
        [ sh:datatype xsd:string ;
            sh:description "The employee identifier assigned to the user by the organization." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:employee_uid ],
        [ sh:datatype xsd:long ;
            sh:description """The timestamp when the user was deleted. In Active Directory (AD), when a user
is deleted they are moved to a temporary container and then removed after 30
days. So, this field can be populated even after a user is deleted for the next
30 days.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:deleted_time ],
        [ sh:datatype xsd:long ;
            sh:description "The timestamp when the user left or will be leaving the organization." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:leave_time ],
        [ sh:datatype xsd:string ;
            sh:description "A list of additional email addresses for the user." ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:email_addrs ;
            sh:pattern "^[\\w.+\\-]+@[\\w\\-]+(\\.[\\w\\-]+)+$" ],
        [ sh:class ocsf:Location ;
            sh:description """The geographical location associated with a user. This is typically the user's
usual work location.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path ocsf:location ],
        [ sh:datatype xsd:string ;
            sh:description """The X.500 Distinguished Name (DN) is a structured string that uniquely
identifies an entry, such as a user, in an X.500 directory service For example,
<code>cn=John Doe,ou=People,dc=example,dc=com</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:ldap_dn ],
        [ sh:datatype xsd:string ;
            sh:description "The last or family name for the user." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:surname ],
        [ sh:datatype xsd:string ;
            sh:description "The cost center associated with the user." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:cost_center ],
        [ sh:datatype xsd:string ;
            sh:description """The labels associated with the user. For example in AD this could be the
<code>userType</code>, <code>employeeType</code>. For example: <code>Member,
Employee</code>.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:labels ] ;
    sh:targetClass ocsf:LdapPerson .

ocsf:Logger a sh:NodeShape ;
    rdfs:comment """The Logger object represents the device and product where events are stored
with times for receipt and transmission.  This may be at the source device
where the event occurred, a remote scanning device, intermediate hops, or the
ultimate destination.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The name of the logging product instance." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates whether the OCSF event data has been truncated due to size
limitations. When <code>true</code>, some event data may have been omitted to
fit within system constraints.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:is_truncated ],
        [ sh:datatype xsd:integer ;
            sh:description """The original size of the OCSF event data in kilobytes before any truncation
occurred. This field is typically populated when <code>is_truncated</code> is
<code>true</code> to indicate the full size of the original event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:untruncated_size ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the event assigned by the logger." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:event_uid ],
        [ sh:datatype xsd:long ;
            sh:description """The time when the event was transmitted from the logging device to it's next
destination.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:transmit_time ],
        [ sh:datatype xsd:long ;
            sh:description """<p>The time when the logging system collected and logged the event.</p>This
attribute is distinct from the event time in that event time typically contain
the time extracted from the original event. Most of the time, these two times
will be different.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:logged_time ],
        [ sh:class ocsf:Device ;
            sh:description "The device where the events are logged." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:device ],
        [ sh:datatype xsd:string ;
            sh:description """The log name for the logging provider log, or the file name of the system log.
This may be an intermediate store-and-forward log or a vendor destination log.
For example /archive/server1/var/log/messages.0 or /var/log/.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:log_name ],
        [ sh:class ocsf:Product ;
            sh:description """The product logging the event.  This may be the event source product, a
management server product, a scanning product, a SIEM, etc.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path ocsf:product ],
        [ sh:datatype xsd:string ;
            sh:description "The format of data in the log. For example JSON, syslog or CSV." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:log_format ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the logging product instance." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description """The event log schema version of the original event. For example the syslog
version or the Cisco Log Schema version""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:log_version ],
        [ sh:datatype xsd:string ;
            sh:description """The logging provider or logging service that logged the event. This may be an
intermediate application store-and-forward log or a vendor destination log.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:log_provider ],
        [ sh:datatype xsd:string ;
            sh:description """The level at which an event was logged. This can be log provider specific. For
example the audit level.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:log_level ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the logging provider." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:version ] ;
    sh:targetClass ocsf:Logger .

ocsf:LongString a sh:NodeShape ;
    rdfs:comment """This object is a used to capture strings which may be truncated by a security
product due to their length.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The string value, truncated if <code>is_truncated</code> is <code>true</code>." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:value ],
        [ sh:datatype xsd:integer ;
            sh:description """The size in bytes of the string represented by <code>value</code> before
truncation. Should be omitted if truncation has not occurred.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:untruncated_size ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that <code>value</code> has been truncated. May be omitted if
truncation has not occurred.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:is_truncated ] ;
    sh:targetClass ocsf:LongString .

ocsf:Mitigation a sh:NodeShape ;
    rdfs:comment """The MITRE Mitigation object describes the ATT&CK® or ATLAS™ Mitigation ID
and/or name that is associated to an attack.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description """The versioned permalink of the Mitigation. For example:
<code>https://attack.mitre.org/versions/v14/mitigations/M1027</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:src_url ],
        [ sh:datatype xsd:string ;
            sh:description """The Mitigation ID that is associated with the attack technique. For example:
<code>M1027</code>, or <code>AML.M0013</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:uid ],
        [ sh:class ocsf:D3fend ;
            sh:description """The D3FEND countermeasures that are associated with the attack technique. For
example: ATT&CK Technique <code>T1003</code> is addressed by Mitigation
<code>M1027</code>, and D3FEND Technique <code>D3-OTP</code>.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:countermeasures ],
        [ sh:datatype xsd:string ;
            sh:description """The Mitigation name that is associated with the attack technique. For example:
<code>Password Policies</code>, or <code>Code Signing</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:name ] ;
    sh:targetClass ocsf:Mitigation .

ocsf:Node a sh:NodeShape ;
    rdfs:comment "Represents a node or a vertex in a graph structure." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A human-readable description of the node's purpose or meaning in the graph." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:desc ],
        [ sh:datatype xsd:string ;
            sh:description """A unique string or numeric identifier that distinguishes this node from all
others in the graph. Must be unique across all nodes.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description """Additional data about the node stored as key-value pairs. Can include custom
properties specific to the node.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:data ],
        [ sh:datatype xsd:string ;
            sh:description """Categorizes the node into a specific class or type. Useful for grouping and
filtering nodes.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description """A human-readable name or label for the node. Should be descriptive and unique
within the graph context.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:name ] ;
    sh:targetClass ocsf:Node .

ocsf:Parameter a sh:NodeShape ;
    rdfs:comment "The Parameter object provides details regarding a parameter of a a function." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The parameter value before function execution." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:pre_value ],
        [ sh:datatype xsd:string ;
            sh:description "The parameter value after function execution." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:post_value ],
        [ sh:datatype xsd:string ;
            sh:description "The parameter name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:name ] ;
    sh:targetClass ocsf:Parameter .

ocsf:PermissionAnalysisResult a sh:NodeShape ;
    rdfs:comment """The Permission Analysis object describes analysis results of permissions,
policies directly associated with an identity (user, role, or service account).
This evaluates what permissions an identity has been granted through attached
policies, which privileges are actively used versus unused, and identifies
potential over-privileged access. Use this for identity-centric security
assessments such as privilege audits, dormant permission discovery, and
least-privilege compliance analysis.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description """The total count of cloud services or resource types referenced in the policy
that have not been accessed or utilized within the analysis timeframe. This
helps identify unused service permissions that could be removed to reduce
attack surface. Examples: AWS services like S3, SQS, IAM, Lambda; Azure
services like Storage, Compute, KeyVault; or GCP services like Cloud Storage,
Compute Engine, BigQuery.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:unused_services_count ],
        [ sh:datatype xsd:string ;
            sh:description """The specific privileges, actions, or permissions that are explicitly granted by
the analyzed policy. Examples: AWS actions like <code>s3:GetObject</code>,
<code>ec2:RunInstances</code>, <code>iam:CreateUser</code>; Azure actions like
<code>Microsoft.Storage/storageAccounts/read</code>; or GCP permissions like
<code>storage.objects.get</code>.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:granted_privileges ],
        [ sh:datatype xsd:integer ;
            sh:description "The total count of privileges that were analyzed across all services." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:analyzed_privileges_count ],
        [ sh:class ocsf:Policy ;
            sh:description """Detailed information about the policy document that was analyzed, including
policy metadata, version, type (identity-based, resource-based, etc.), and
structural details. This provides context for understanding the scope and
nature of the permission analysis.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:policy ],
        [ sh:class ocsf:KeyValueObject ;
            sh:description """The condition keys and their values that were evaluated during policy analysis,
including contextual constraints that affect permission grants. These
conditions define when and how permissions are applied. Examples:
<code>aws:SourceIp:1.2.3.4</code>, <code>aws:RequestedRegion:us-east-1</code>.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:condition_keys ],
        [ sh:class ocsf:ServicePrivilegeAnalysis ;
            sh:description "The list of privilege analysis results grouped by cloud service or namespace." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:service_privilege_analysis_list ],
        [ sh:datatype xsd:integer ;
            sh:description """The total count of privilege-to-attack technique mappings identified across all
analyzed privileges.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:total_potential_attacks_count ],
        [ sh:datatype xsd:integer ;
            sh:description """The total count of privileges or actions defined in the policy that have not
been utilized within the analysis timeframe. This metric helps identify
over-privileged access and opportunities for privilege reduction to follow the
principle of least privilege. High counts may indicate policy bloat or
excessive permissions.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:unused_privileges_count ] ;
    sh:targetClass ocsf:PermissionAnalysisResult .

ocsf:PortInfo a sh:NodeShape ;
    rdfs:comment """The Port Information object describes a port and its associated protocol
details.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description """The IP protocol number, as defined by the Internet Assigned Numbers Authority
(IANA). For example: <code>6</code> for TCP and <code>17</code> for UDP.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:protocol_num ],
        [ sh:datatype xsd:integer ;
            sh:description """The port number. For example: <code>80</code>, <code>443</code>,
<code>22</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:port ],
        [ sh:datatype xsd:string ;
            sh:description """The IP protocol name in lowercase, as defined by the Internet Assigned Numbers
Authority (IANA). For example: <code>tcp</code> or <code>udp</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:protocol_name ] ;
    sh:targetClass ocsf:PortInfo .

ocsf:PrivilegeAttackInfo a sh:NodeShape ;
    rdfs:comment """The Privilege Attack Info object groups privileges by the potential attack they
could enable. It maps specific privileges to MITRE ATT&CK techniques, helping
identify security risks associated with granted permissions.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Attack ;
            sh:description "The MITRE ATT&CK technique that these privileges could enable." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:attack ],
        [ sh:class ocsf:PrivilegeInfo ;
            sh:description """The list of privilege information objects, where each element describes a
specific privilege that could enable the associated attack technique.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:privilege_info_list ] ;
    sh:targetClass ocsf:PrivilegeAttackInfo .

ocsf:PrivilegeInfo a sh:NodeShape ;
    rdfs:comment """The Privilege Info object describes information about a specific privilege,
action, or permission. It captures the privilege name, type, usage status, and
when it was last used.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The type or category of the privilege, normalized to the caption of the
<code>type_id</code> value. In the case of 'Other', it is defined by the event
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description """The name of the privilege, action, or permission. Examples:
<code>GetObject</code>, <code>CreateStoreImageTask</code> (AWS);
<code>Microsoft.Storage/storageAccounts/read</code> (Azure);
<code>storage.objects.get</code> (GCP).""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:name ],
        [ sh:description "The normalized type of the privilege." ;
            sh:in ( "UNKNOWN" "READ" "WRITE" "EXECUTE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether the privilege is unused within the analysis timeframe." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:is_unused ],
        [ sh:datatype xsd:long ;
            sh:description "The most recent time this privilege was used." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:last_used_time ] ;
    sh:targetClass ocsf:PrivilegeInfo .

ocsf:QueryEvidence a sh:NodeShape ;
    rdfs:comment """The specific resulting evidence information that was queried or discovered.
When mapping raw telemetry data users should select the appropriate child
object that best matches the evidence type as defined by query_type_id.""" ;
    sh:closed true ;
    sh:ignoredProperties ( ocsf:reg_key rdf:type ocsf:reg_value ) ;
    sh:property [ sh:class ocsf:Process ;
            sh:description """The process that pertains to the event when query_type_id indicates a Process
query.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:process ],
        [ sh:class ocsf:StartupItem ;
            sh:description """The startup item object that pertains to the event when query_type_id indicates
a Startup Item query.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ocsf:startup_item ],
        [ sh:class ocsf:Group ;
            sh:description """The administrative group that is the target of the query when query_type_id
indicates an Admin Group query.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:group ],
        [ sh:datatype xsd:string ;
            sh:description """The state of the socket, normalized to the caption of the state_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:state ],
        [ sh:class ocsf:File ;
            sh:description """The file that is the target of the query when query_type_id indicates a File
query.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:file ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of query_type_id or the source-specific query type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:query_type ],
        [ sh:description """The normalized type of system query performed against a device or system
component.""" ;
            sh:in ( "UNKNOWN" "KERNEL" "FILE" "FOLDER" "ADMIN_GROUP" "JOB" "MODULE" "NETWORK_CONNECTION" "NETWORK_INTERFACES" "PERIPHERAL_DEVICE" "PROCESS" "SERVICE" "SESSION" "USER" "USERS" "STARTUP_ITEM" "REGISTRY_KEY" "REGISTRY_VALUE" "PREFETCH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 11 ;
            sh:path ocsf:query_type_id ],
        [ sh:class ocsf:Kernel ;
            sh:description """The kernel object that pertains to the event when query_type_id indicates a
Kernel query.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:kernel ],
        [ sh:class ocsf:NetworkConnectionInfo ;
            sh:description "The network connection information related to a Network Connection query type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:connection_info ],
        [ sh:class ocsf:Service ;
            sh:description """The service that pertains to the event when query_type_id indicates a Service
query.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:service ],
        [ sh:class ocsf:Session ;
            sh:description """The authenticated user or service session when query_type_id indicates a
Session query.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:session ],
        [ sh:class ocsf:Module ;
            sh:description """The module that pertains to the event when query_type_id indicates a Module
query.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:module ],
        [ sh:class ocsf:User ;
            sh:description "The user that pertains to the event when query_type_id indicates a User query." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path ocsf:user ],
        [ sh:class ocsf:File ;
            sh:description """The folder that is the target of the query when query_type_id indicates a
Folder query.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:folder ],
        [ sh:class ocsf:PeripheralDevice ;
            sh:description """The peripheral device that triggered the event when query_type_id indicates a
Peripheral Device query.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:peripheral_device ],
        [ sh:class ocsf:User ;
            sh:description """The users that belong to the administrative group when query_type_id indicates
a Users query.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path ocsf:users ],
        [ sh:class ocsf:NetworkInterface ;
            sh:description """The physical or virtual network interfaces that are associated with the device
when query_type_id indicates a Network Interfaces query.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:network_interfaces ],
        [ sh:description "The state of the TCP socket for the network connection." ;
            sh:in ( "UNKNOWN" "ESTABLISHED" "SYN_SENT" "SYN_RECEIVED" "FIN_WAIT_1" "FIN_WAIT_2" "TIME_WAIT" "CLOSED" "CLOSE_WAIT" "LAST_ACK" "LISTEN" "CLOSING" ) ;
            sh:maxCount 1 ;
            sh:order 16 ;
            sh:path ocsf:tcp_state_id ],
        [ sh:class ocsf:Job ;
            sh:description """The job object that pertains to the event when query_type_id indicates a Job
query.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:job ] ;
    sh:targetClass ocsf:QueryEvidence .

ocsf:Reporter a sh:NodeShape ;
    rdfs:comment "The entity from which an event or finding was reported." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Organization ;
            sh:description "The organization properties of the entity that reported the event or finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:org ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier of the entity from which the event or finding was
reported.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description "The hostname of the entity from which the event or finding was reported." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:hostname ],
        [ sh:datatype xsd:string ;
            sh:description "The IP address of the entity from which the event or finding was reported." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:ip ;
            sh:pattern "^((\\d{1,3}\\.){3}\\d{1,3}|[0-9a-fA-F:]{2,39})$" ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the entity from which the event or finding was reported." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:name ] ;
    sh:targetClass ocsf:Reporter .

ocsf:RpcInterface a sh:NodeShape ;
    rdfs:comment """The RPC Interface represents the remote procedure call interface used in the
DCE/RPC session.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "An integer that denotes the acknowledgment result of the DCE/RPC call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:ack_result ],
        [ sh:datatype xsd:integer ;
            sh:description """An integer that provides a reason code or additional information about the
acknowledgment result.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:ack_reason ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the DCE/RPC protocol being used in the session." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:version ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the particular remote procedure or service." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:uuid ;
            sh:pattern "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" ] ;
    sh:targetClass ocsf:RpcInterface .

ocsf:Scim a sh:NodeShape ;
    rdfs:comment """The System for Cross-domain Identity Management (SCIM) Configuration object
provides a structured set of attributes related to SCIM protocols used for
identity provisioning and management across cloud-based platforms. It
standardizes user and group provisioning details, enabling identity
synchronization and lifecycle management with compatible Identity Providers
(IdPs) and applications. SCIM is defined in <a target='_blank'
href='https://datatracker.ietf.org/doc/html/rfc7643'>RFC-7634</a>""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The name of the SCIM resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description """The provisioning state of the SCIM resource, normalized to the caption of the
<code>state_id</code> value. In the case of <code>Other</code>, it is defined
by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:state ],
        [ sh:datatype xsd:string ;
            sh:description """SCIM provides a resource type for user resources. The core schema for user is
identified using the following schema URI:
<code>urn:ietf:params:scim:schemas:core:2.0:User</code> as defined in <a
target='_blank'
href='https://datatracker.ietf.org/doc/html/rfc7643'>RFC-7634</a>. his
attribute will capture key-value pairs for the scheme implemented in a SCIM
resource. This object is inclusive of both the basic and Enterprise User Schema
Extension.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:scim_user_schema ],
        [ sh:datatype xsd:anyURI ;
            sh:description "The primary URL for SCIM API requests." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:url_string ],
        [ sh:description """The normalized identifier of the authorization protocol used by the SCIM
resource.""" ;
            sh:in ( "UNKNOWN" "NTLM" "KERBEROS" "DIGEST" "OPENID" "SAML" "OAUTH_2_0" "PAP" "CHAP" "EAP" "RADIUS" "BASIC_AUTHENTICATION" "LDAP" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path ocsf:auth_protocol_id ],
        [ sh:description "The normalized state ID of the SCIM resource to reflect its activation status." ;
            sh:in ( "UNKNOWN" "PENDING" "ACTIVE" "FAILED" "DELETED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 14 ;
            sh:path ocsf:state_id ],
        [ sh:datatype xsd:string ;
            sh:description """Name of the vendor or service provider implementing SCIM. E.g.,
<code>Okta</code>, <code>Auth0</code>, <code>Microsoft</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:vendor_name ],
        [ sh:datatype xsd:string ;
            sh:description "SCIM protocol version supported e.g., <code>SCIM 2.0</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:version ],
        [ sh:datatype xsd:string ;
            sh:description "A unique identifier for a SCIM resource as defined by the service provider." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:long ;
            sh:description """The most recent time when the SCIM resource was updated at the service
provider.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:modified_time ],
        [ sh:datatype xsd:string ;
            sh:description "Message or code associated with the last encountered error." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:error_message ],
        [ sh:datatype xsd:integer ;
            sh:description """Maximum number of requests allowed by the SCIM resource within a specified time
frame to avoid throttling.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:rate_limit ],
        [ sh:datatype xsd:long ;
            sh:description "Timestamp of the most recent successful synchronization." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:last_run_time ],
        [ sh:datatype xsd:long ;
            sh:description "When the SCIM resource was added to the service provider." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:created_time ],
        [ sh:datatype xsd:string ;
            sh:description """The supported protocol for the SCIM resource. E.g., <code>SAML</code>,
<code>OIDC</code>, or <code>OAuth2</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:protocol_name ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates whether the SCIM resource is configured to provision groups,
automatically or otherwise.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:is_group_provisioning_enabled ],
        [ sh:datatype xsd:string ;
            sh:description """The authorization protocol as defined by the caption of
<code>auth_protocol_id</code>. In the case of <code>Other</code>, it is defined
by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:auth_protocol ],
        [ sh:datatype xsd:string ;
            sh:description """A String that is an identifier for the resource as defined by the provisioning
client. The <code>externalId</code> may simplify identification of a resource
between the provisioning client and the service provider by allowing the client
to use a filter to locate the resource with an identifier from the provisioning
domain, obviating the need to store a local mapping between the provisioning
domain's identifier of the resource and the identifier used by the service
provider.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:uid_alt ],
        [ sh:datatype xsd:string ;
            sh:description """SCIM provides a schema for representing groups, identified using the following
schema URI: <code>urn:ietf:params:scim:schemas:core:2.0:Group</code> as defined
in <a target='_blank'
href='https://datatracker.ietf.org/doc/html/rfc7643'>RFC-7634</a>. This
attribute will capture key-value pairs for the scheme implemented in a SCIM
resource.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:scim_group_schema ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates whether the SCIM resource is configured to provision users,
automatically or otherwise.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:is_user_provisioning_enabled ] ;
    sh:targetClass ocsf:Scim .

ocsf:ServicePrivilegeAnalysis a sh:NodeShape ;
    rdfs:comment """The Service Privilege Analysis object describes privilege analysis results for
a single cloud service or resource namespace. It provides metrics on privilege
usage, counts by type, and mappings to potential attack techniques.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "The count of execute-type privileges within this service." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:execute_count ],
        [ sh:datatype xsd:integer ;
            sh:description "The total count of privileges analyzed within this service." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:analyzed_privileges_count ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether all privileges within this service are unused." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:all_privileges_unused ],
        [ sh:datatype xsd:long ;
            sh:description "The most recent time any privilege in this service was used." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:last_used_time ],
        [ sh:datatype xsd:integer ;
            sh:description "The count of unused privileges within this service." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:unused_privileges_count ],
        [ sh:class ocsf:PrivilegeAttackInfo ;
            sh:description "The list of privilege-to-attack mappings for this service." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:privilege_attack_info_list ],
        [ sh:datatype xsd:integer ;
            sh:description "The count of write-type privileges within this service." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:write_count ],
        [ sh:datatype xsd:integer ;
            sh:description "The count of read-type privileges within this service." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:read_count ],
        [ sh:datatype xsd:string ;
            sh:description """The service or namespace identifier. Examples: <code>s3</code>,
<code>ec2</code> (AWS); <code>Microsoft.Storage</code> (Azure);
<code>storage</code> (GCP).""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:name ] ;
    sh:targetClass ocsf:ServicePrivilegeAnalysis .

ocsf:SoftwareComponent a sh:NodeShape ;
    rdfs:comment """The Software Component object describes characteristics of a software component
within a software package.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The normalized identifier of the relationship between two software components." ;
            sh:in ( "UNKNOWN" "DEPENDS_ON" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path ocsf:relationship_id ],
        [ sh:datatype xsd:string ;
            sh:description """The Package URL (PURL) to identify the software component. This is a URL that
uniquely identifies the component, including the component's name, version, and
type. The URL is used to locate and retrieve the component's metadata and
content.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:purl ],
        [ sh:datatype xsd:string ;
            sh:description """The package URL (PURL) of the component that this software component has a
relationship with.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:related_component ],
        [ sh:datatype xsd:string ;
            sh:description "The software component name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The author(s) who published the software component." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:author ],
        [ sh:datatype xsd:string ;
            sh:description "The software license applied to this component." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:license ],
        [ sh:description "The type of software component." ;
            sh:in ( "FRAMEWORK" "LIBRARY" "OPERATING_SYSTEM" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 9 ;
            sh:path ocsf:type_id ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "Cryptographic hash to identify the binary instance of a software component." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:hash ],
        [ sh:datatype xsd:string ;
            sh:description "The software component version." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:version ],
        [ sh:datatype xsd:string ;
            sh:description """The type of software component, normalized to the caption of the
<code>type_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description """The relationship between two software components, normalized to the caption of
the <code>relationship_id</code> value. In the case of 'Other', it is defined
by the source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:relationship ] ;
    sh:targetClass ocsf:SoftwareComponent .

ocsf:Span a sh:NodeShape ;
    rdfs:comment """Represents a single unit of work or operation within a distributed trace. A
span typically tracks the execution of a request across a service, capturing
important details such as the operation, timestamps, and status. Spans help
break down the overall trace into smaller, manageable parts, enabling detailed
analysis of the performance and behavior of specific operations within the
system. They are crucial for understanding latency, dependencies, and
bottlenecks in complex distributed systems.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The message in a span (often referred to as a span event) serves as a way to
record significant moments or occurrences during the span's lifecycle. This
content typically manifests as log entries, annotations, or semi-structured
events as a string, providing additional granularity and context about what
happens at specific points during the execution of an operation.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:string ;
            sh:description """Describes an action performed in a span, such as API requests, database
queries, or computations.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:operation ],
        [ sh:datatype xsd:integer ;
            sh:description """The total time, in milliseconds, that the span represents, calculated as the
difference between start_time and end_time. It reflects the operation's
performance and latency, independent of event timestamps, and accounts for
normalized times used by observability tools to ensure consistency across
distributed systems.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:duration ],
        [ sh:datatype xsd:long ;
            sh:description """The start timestamp of the span, essential for identifying latency and
performance bottlenecks. This timestamp is normalized across the observability
system, ensuring consistency even when events occur across distributed services
with potentially unsynchronized clocks. By using normalized time, observability
tools can provide accurate, uniform measurements of operation performance and
latency, regardless of where or when the events actually occur.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:start_time ],
        [ sh:datatype xsd:string ;
            sh:description """The ID of the parent span for this span object, establishing its relationship
in the trace hierarchy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:parent_uid ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier for the span, used in distributed systems and
microservices architectures to track and correlate requests across different
components of an application. It enables tracing the flow of a request through
various services.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description """Indicates the outcome of the operation in the span, such as success, failure,
or error. Issues in a span typically refer to problems such as failed
operations, timeouts, service unavailability, or errors in processing that can
negatively impact the performance or reliability of the system. Tracking the
`status_code` helps pinpoint these issues, enabling quicker identification and
resolution of system inefficiencies or faults.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:status_code ],
        [ sh:class ocsf:Service ;
            sh:description """Identifies the service or component that generates the span, helping trace its
path through the distributed system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:service ],
        [ sh:datatype xsd:long ;
            sh:description """The end timestamp of the span, essential for identifying latency and
performance bottlenecks. Like the start time, this timestamp is normalized
across the observability system to ensure consistency, even when events are
recorded across distributed services with unsynchronized clocks. Normalized
time allows for accurate duration calculations and helps observability tools
track performance across services, regardless of the individual system time
settings.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:end_time ] ;
    sh:targetClass ocsf:Span .

ocsf:Sso a sh:NodeShape ;
    rdfs:comment """The Single Sign-On (SSO) object provides a structure for normalizing SSO
attributes, configuration, and/or settings from Identity Providers.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:long ;
            sh:description "When the SSO resource was created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:created_time ],
        [ sh:datatype xsd:integer ;
            sh:description """Duration (in minutes) of allowed inactivity before Single Sign-On (SSO) session
expiration.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:idle_timeout ],
        [ sh:datatype xsd:string ;
            sh:description """The supported protocol for the SSO resource. E.g., <code>SAML</code> or
<code>OIDC</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:protocol_name ],
        [ sh:datatype xsd:string ;
            sh:description """Name of the vendor or service provider implementing SSO. E.g.,
<code>Okta</code>, <code>Auth0</code>, <code>Microsoft</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:vendor_name ],
        [ sh:class ocsf:Certificate ;
            sh:description """Digital Signature associated with the SSO resource, e.g., SAML X.509
certificate details.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:certificate ],
        [ sh:datatype xsd:integer ;
            sh:description """The duration (in minutes) for an SSO session, after which re-authentication is
required.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:duration_mins ],
        [ sh:description """The normalized identifier of the authentication protocol used by the SSO
resource.""" ;
            sh:in ( "UNKNOWN" "NTLM" "KERBEROS" "DIGEST" "OPENID" "SAML" "OAUTH_2_0" "PAP" "CHAP" "EAP" "RADIUS" "BASIC_AUTHENTICATION" "LDAP" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path ocsf:auth_protocol_id ],
        [ sh:datatype xsd:anyURI ;
            sh:description "URL for initiating an SSO login request." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:login_endpoint ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the SSO resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "A unique identifier for a SSO resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description """Scopes define the specific permissions or actions that the client is allowed to
perform on behalf of the user. Each scope represents a different set of
permissions, and the user can selectively grant or deny access to specific
scopes during the authorization process.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:scopes ],
        [ sh:datatype xsd:string ;
            sh:description """The authorization protocol as defined by the caption of
<code>auth_protocol_id</code>. In the case of <code>Other</code>, it is defined
by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:auth_protocol ],
        [ sh:datatype xsd:long ;
            sh:description "The most recent time when the SSO resource was updated." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:modified_time ],
        [ sh:datatype xsd:anyURI ;
            sh:description """URL for initiating an SSO logout request, allowing sessions to be terminated
across applications.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:logout_endpoint ],
        [ sh:datatype xsd:anyURI ;
            sh:description """URL where metadata about the SSO configuration is available (e.g., for SAML
configurations).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:metadata_endpoint ] ;
    sh:targetClass ocsf:Sso .

ocsf:SubTechnique a sh:NodeShape ;
    rdfs:comment """The MITRE Sub-technique object describes the ATT&CK® or ATLAS™ Sub-technique ID
and/or name associated to an attack.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The name of the attack sub-technique. For example: <code>Scanning IP
Blocks</code> or <code>User Execution: Unsafe ML Artifacts</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier of the attack sub-technique. For example:
<code>T1595.001</code> or <code>AML.T0011.000</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:anyURI ;
            sh:description """The versioned permalink of the attack sub-technique. For example:
<code>https://attack.mitre.org/versions/v14/techniques/T1595/001/</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:src_url ] ;
    sh:targetClass ocsf:SubTechnique .

ocsf:Technique a sh:NodeShape ;
    rdfs:comment """The MITRE Technique object describes the ATT&CK® or ATLAS™ Technique ID and/or
name associated to an attack.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description """The versioned permalink of the attack technique. For example:
<code>https://attack.mitre.org/versions/v14/techniques/T1595/</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:src_url ],
        [ sh:datatype xsd:string ;
            sh:description """The name of the attack technique. For example: <code>Active Scanning</code> or
<code>AI Model Inference API Access</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier of the attack technique. For example: <code>T1595</code>
or <code>AML.T0040</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:uid ] ;
    sh:targetClass ocsf:Technique .

ocsf:ThreatActor a sh:NodeShape ;
    rdfs:comment "Threat actor is responsible for the observed malicious activity." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The classification of the threat actor based on their motivations,
capabilities, or affiliations. Common types include nation-state actors,
cybercriminal groups, hacktivists, or insider threats.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the threat actor." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:name ],
        [ sh:description "The normalized datastore resource type identifier." ;
            sh:in ( "UNKNOWN" "NATION_STATE" "CYBERCRIMINAL" "HACKTIVISTS" "INSIDER" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path ocsf:type_id ] ;
    sh:targetClass ocsf:ThreatActor .

ocsf:Token a sh:NodeShape ;
    rdfs:comment """The Token object is the base object for representing tokens, API keys, and
authentication credentials used across different contexts. This object provides
common attributes for all token types, including protocol-specific
authentication tokens (Kerberos, OIDC, SAML) and API/client tokens used for
service authentication. When to use this object: Use the base
<code>token</code> object directly in API activity events to represent API
tokens, client tokens, or API keys used to authenticate API requests. Examples
include: Okta API tokens, Microsoft Entra ID Application Registration client
secrets, Stripe API keys, AWS API keys. When NOT to use this object: Do NOT use
the base <code>token</code> object for protocol-specific authentication tokens
in authentication events - use <code>authentication_token</code> instead (which
extends this object). Do NOT use <code>token</code> for tracking credential
lifecycle and usage patterns - use <code>programmatic_credential</code>
instead.""" ;
    sh:closed true ;
    sh:ignoredProperties ( ocsf:encryption_details rdf:type ocsf:kerberos_flags ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The network zone or geographic region that the token or key is authorized to be
used from. This may represent network-based access restrictions, geographic
limitations, or other zone-based authorization policies. Examples include
Okta's network zone restrictions or cloud provider region restrictions.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:zone ],
        [ sh:datatype xsd:string ;
            sh:description """The human-friendly name of a token or key, if available, such as the
<code>name</code> from the Okta API Token API.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier of the tenant or organization that owns the token or key,
or the tenant context in which the token is authorized for use. This is
particularly relevant in multi-tenant Identity Provider scenarios where tokens
are scoped to specific tenants.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:tenant_uid ],
        [ sh:description """The normalized token type identifier. Valid values: 0 (Unknown), 1 (Ticket
Granting Ticket - Kerberos), 2 (Service Ticket - Kerberos), 3 (Identity Token -
OIDC), 4 (Refresh Token - OIDC), 5 (SAML Assertion), 6 (Client Token -
IdP-issued), 7 (API Token - generic API keys), 99 (Other).""" ;
            sh:in ( "UNKNOWN" "TICKET_GRANTING_TICKET" "SERVICE_TICKET" "IDENTITY_TOKEN" "REFRESH_TOKEN" "SAML_ASSERTION" "CLIENT_TOKEN" "API_TOKEN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:long ;
            sh:description "The expiration time of the token." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:expiration_time ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether the token is renewable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:is_renewable ],
        [ sh:datatype xsd:string ;
            sh:description """The type of the token, normalized to the caption of the <code>type_id</code>
value. This indicates whether the token is a Client Token, API Token, or one of
the protocol-specific token types.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description """The unique ID of a token or key, if available, such as the <code>Secret
ID</code> of Entra ID Application Registration Client Secrets.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:long ;
            sh:description "The time that the token was created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:created_time ],
        [ sh:datatype xsd:long ;
            sh:description "The last time the token was updated." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:modified_time ] ;
    sh:targetClass ocsf:Token .

ocsf:TransformationInfo a sh:NodeShape ;
    rdfs:comment "The transformation_info object represents the mapping or transformation used." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The transformation language used to transform the data." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:lang ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the mapping or transformation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:long ;
            sh:description "Time of the transformation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:time ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the transformation or mapping." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:name ],
        [ sh:class ocsf:Product ;
            sh:description "The product or instance used to make the transformation" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:product ],
        [ sh:datatype xsd:anyURI ;
            sh:description "The Uniform Resource Locator String where the mapping or transformation exists." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:url_string ] ;
    sh:targetClass ocsf:TransformationInfo .

ocsf:Whois a sh:NodeShape ;
    rdfs:comment """The resources of a WHOIS record for a given domain. This can include domain
names, IP address blocks, autonomous system information, and/or contact and
registration information for a domain.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:AutonomousSystem ;
            sh:description "The autonomous system information associated with a domain." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:autonomous_system ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized value of dnssec_status_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:dnssec_status ],
        [ sh:datatype xsd:string ;
            sh:description "The domain registrar." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:registrar ],
        [ sh:datatype xsd:long ;
            sh:description "When the domain was registered or WHOIS entry was created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:created_time ],
        [ sh:datatype xsd:string ;
            sh:description "The domain name corresponding to the WHOIS record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:domain ],
        [ sh:datatype xsd:string ;
            sh:description "The IP address block (CIDR) associated with a domain." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:subnet ;
            sh:pattern "^((\\d{1,3}\\.){3}\\d{1,3}|[0-9a-fA-F:]{2,39})/(\\d|[1-9]\\d|1[0-1]\\d|12[0-8])$" ],
        [ sh:datatype xsd:string ;
            sh:description "A collection of name servers related to a domain registration or other record." ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:name_servers ],
        [ sh:datatype xsd:string ;
            sh:description "The email address for the registrar's abuse contact" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:email_addr ;
            sh:pattern "^[\\w.+\\-]+@[\\w\\-]+(\\.[\\w\\-]+)+$" ],
        [ sh:datatype xsd:string ;
            sh:description """The organization name of the Internet Service Provider (ISP). This represents
the parent organization or company that owns/operates the ISP. For example,
Comcast Corporation would be the ISP org for Xfinity internet service. This
attribute helps identify the ultimate provider when ISPs operate under
different brand names.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:isp_org ],
        [ sh:datatype xsd:string ;
            sh:description """The status of a domain and its ability to be transferred, e.g.,
<code>clientTransferProhibited</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:status ],
        [ sh:class ocsf:DomainContact ;
            sh:description "An array of <code>Domain Contact</code> objects." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:domain_contacts ],
        [ sh:description """Describes the normalized status of DNS Security Extensions (DNSSEC) for a
domain.""" ;
            sh:in ( "UNKNOWN" "SIGNED" "UNSIGNED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path ocsf:dnssec_status_id ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the Internet Service Provider (ISP)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:isp ],
        [ sh:datatype xsd:string ;
            sh:description """An array of subdomain strings. Can be used to collect several subdomains such
as those from Domain Generation Algorithms (DGAs).""" ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:subdomains ],
        [ sh:datatype xsd:string ;
            sh:description "The phone number for the registrar's abuse contact" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:phone_number ],
        [ sh:datatype xsd:long ;
            sh:description "When the WHOIS record was last updated or seen at." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:last_seen_time ] ;
    sh:targetClass ocsf:Whois .

ocsf:WinResource a sh:NodeShape ;
    rdfs:comment """The Windows resource object describes a resource object managed by Windows,
such as mutant or timer.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The list of labels associated to the resource." ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:labels ],
        [ sh:class ocsf:DataClassification ;
            sh:description """A list of Data Classification objects, that include information about data
classification levels and data category types, identified by a classifier.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:data_classifications ],
        [ sh:datatype xsd:string ;
            sh:description "The Windows provided handle identifier for the resource object" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:uid ],
        [ sh:class ocsf:KeyValueObject ;
            sh:description "The list of tags; <code>{key:value}</code> pairs associated to the resource." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path ocsf:tags ],
        [ sh:datatype xsd:string ;
            sh:description """The Windows service acting as the object server for the resource object, such
as Security or Security Account Manager.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:svc_name ],
        [ sh:datatype xsd:string ;
            sh:description "The string detailing the attributes of the resource object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:details ],
        [ sh:class ocsf:DataClassification ;
            sh:description """The Data Classification object includes information about data classification
levels and data category types.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:data_classification ],
        [ sh:datatype xsd:string ;
            sh:description "The alternative unique identifier of the resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:uid_alt ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the resource was last modified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:modified_time ],
        [ sh:datatype xsd:string ;
            sh:description "The type of the Windows resource object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:type ],
        [ sh:description "The normalized type identifier of the Windows resource object accessed." ;
            sh:in ( "UNKNOWN" "DIRECTORY" "EVENT" "TIMER" "DEVICE" "MUTANT" "TYPE" "FILE" "TOKEN" "THREAD" "SECTION" "WINDOWSTATION" "DEBUGOBJECT" "FILTERCOMMUNICATIONPORT" "EVENTPAIR" "DRIVER" "IOCOMPLETION" "CONTROLLER" "SYMBOLICLINK" "WMIGUID" "PROCESS" "PROFILE" "DESKTOP" "KEYEDEVENT" "ADAPTER" "KEY" "WAITABLEPORT" "CALLBACK" "SEMAPHORE" "JOB" "PORT" "FILTERCONNECTIONPORT" "ALPC_PORT" "SAM_ALIAS" "SAM_GROUP" "SAM_USER" "SAM_DOMAIN" "SAM_SERVER" "ATOM" "WFP_FILTER" "WFP_CALLOUT" "WFP_LAYER" "WFP_SUB_LAYER" "WFP_PROVIDER" "WFP_PROVIDER_CONTEXT" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 4 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the resource was created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:created_time ],
        [ sh:datatype xsd:string ;
            sh:description "Additional data describing the resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:data ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the resource object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:name ] ;
    sh:targetClass ocsf:WinResource .

ocsf:Account a sh:NodeShape ;
    rdfs:comment """The Account object contains details about the account that initiated or
performed a specific activity within a system or application. Additionally, the
Account object refers to logical Cloud and Software-as-a-Service (SaaS) based
containers such as AWS Accounts, Azure Subscriptions, Oracle Cloud
Compartments, Google Cloud Projects, and otherwise.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:KeyValueObject ;
            sh:description "The list of tags; <code>{key:value}</code> pairs associated to the account." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:tags ],
        [ sh:description "The normalized account type identifier." ;
            sh:in ( "UNKNOWN" "LDAP_ACCOUNT" "WINDOWS_ACCOUNT" "AWS_IAM_USER" "AWS_IAM_ROLE" "GCP_ACCOUNT" "AZURE_AD_ACCOUNT" "MAC_OS_ACCOUNT" "APPLE_ACCOUNT" "LINUX_ACCOUNT" "AWS_ACCOUNT" "GCP_PROJECT" "OCI_COMPARTMENT" "AZURE_SUBSCRIPTION" "SALESFORCE_ACCOUNT" "GOOGLE_WORKSPACE" "SERVICENOW_INSTANCE" "M365_TENANT" "EMAIL_ACCOUNT" "ACTIVEDIRECTORY_ACCOUNT" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier of the account (e.g. <code> AWS Account ID </code>,
<code> OCID </code>, <code> GCP Project ID </code>, <code> Azure Subscription
ID </code>, <code> Google Workspace Customer ID </code>, or <code> M365 Tenant
UID</code>).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates if the account is disabled." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:is_disabled ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates whether synchronization with an on-premises directory service is
enabled. For example, Microsoft Entra Connect.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:is_on_premises_sync_enabled ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates if the account is locked. For example, due to the amount of failed
logins.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:is_locked ],
        [ sh:datatype xsd:string ;
            sh:description "The list of labels associated to the account." ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:labels ],
        [ sh:datatype xsd:string ;
            sh:description """The name of the account (e.g. <code> GCP Project name </code>, <code> Linux
Account name </code> or <code> AWS Account name</code>).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description """The account type, normalized to the caption of 'account_type_id'. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:type ] ;
    sh:targetClass ocsf:Account .

ocsf:Assessment a sh:NodeShape ;
    rdfs:comment """The Assessment object describes a point-in-time assessment, check, or
evaluation of a specific configuration or signal against an asset, entity,
person, or otherwise. For example, this can encapsulate <code>os_signals</code>
from CrowdStrike Falcon Zero Trust Assessments, or account for
<code>Datastore</code> configurations from Cyera, or capture details of
Microsoft Intune configuration policies.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The description of the assessment criteria, or a description of the specific
configuration or signal the assessment is targeting.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:desc ],
        [ sh:class ocsf:Policy ;
            sh:description "The details of any policy associated with an assessment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:boolean ;
            sh:description """Determines whether the assessment against the specific configuration or signal
meets the assessments criteria. For example, if the assessment checks if a
<code>Datastore</code> is encrypted or not, having encryption would be
evaluated as <code>true</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:meets_criteria ],
        [ sh:datatype xsd:string ;
            sh:description """The name of the configuration or signal being assessed. For example:
<code>Kernel Mode Code Integrity (KMCI)</code> or
<code>publicAccessibilityState</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description """The category that the assessment is part of. For example:
<code>Prevention</code> or <code>Windows 10</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:category ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier of the configuration or signal being assessed. For
example: the <code>signal_id</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:uid ] ;
    sh:targetClass ocsf:Assessment .

ocsf:CisControl a sh:NodeShape ;
    rdfs:comment """The CIS Control (aka Critical Security Control) object describes a prioritized
set of actions to protect your organization and data from cyber-attack vectors.
The <a target='_blank' href='https://www.cisecurity.org/controls'>CIS
Controls</a> are defined by the Center for Internet Security.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The CIS Control name. For example: <i>4.8 Uninstall or Disable Unnecessary
Services on Enterprise Assets and Software.</i>""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The CIS Control version. For example: <i>v8</i>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:version ],
        [ sh:datatype xsd:string ;
            sh:description """The CIS Control description. For example: <i>Uninstall or disable unnecessary
services on enterprise assets and software, such as an unused file sharing
service, web application module, or service function.</i>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:desc ] ;
    sh:targetClass ocsf:CisControl .

ocsf:ClassifierDetails a sh:NodeShape ;
    rdfs:comment """The Classifier Details object describes details about the classifier used for
data classification.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the classifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the classifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The type of the classifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:type ] ;
    sh:targetClass ocsf:ClassifierDetails .

ocsf:DiscoveryDetails a sh:NodeShape ;
    rdfs:comment "The Discovery Details object describes results of a discovery task/job." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:OccurrenceDetails ;
            sh:description """Details about where in the target entity, specified information was discovered.
Only the attributes, relevant to the target entity type should be populated.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:occurrences ],
        [ sh:datatype xsd:integer ;
            sh:description "The number of discovered entities of the specified type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:count ],
        [ sh:datatype xsd:string ;
            sh:description "Optionally, the specific value of discovered information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:value ],
        [ sh:class ocsf:OccurrenceDetails ;
            sh:description """Details about where in the target entity, specified information was discovered.
Only the attributes, relevant to the target entity type should be populated.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:occurrence_details ],
        [ sh:datatype xsd:string ;
            sh:description """The specific type of information that was discovered. e.g.<code> name,
phone_number, etc.</code>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:type ] ;
    sh:targetClass ocsf:DiscoveryDetails .

ocsf:Display a sh:NodeShape ;
    rdfs:comment """The Display object contains information about the physical or virtual display
connected to a computer system.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "The numeric physical width of display." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:physical_width ],
        [ sh:datatype xsd:integer ;
            sh:description "The numeric color depth." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:color_depth ],
        [ sh:datatype xsd:integer ;
            sh:description "The numeric scale factor of display." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:scale_factor ],
        [ sh:datatype xsd:integer ;
            sh:description "The numeric physical orientation of display." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:physical_orientation ],
        [ sh:datatype xsd:integer ;
            sh:description "The numeric physical height of display." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:physical_height ] ;
    sh:targetClass ocsf:Display .

ocsf:DnsAnswer a sh:NodeShape ;
    rdfs:comment """The DNS Answer object represents a specific response provided by the Domain
Name System (DNS) when querying for information about a domain or performing a
DNS operation. It encapsulates the relevant details and data returned by the
DNS server in response to a query.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The class of DNS data contained in this resource record. See <a target='_blank'
href='https://www.rfc-editor.org/rfc/rfc1035.txt'>RFC1035</a>. For example:
<code>IN</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:class_ ],
        [ sh:datatype xsd:string ;
            sh:description """The type of data contained in this resource record. See <a target='_blank'
href='https://www.rfc-editor.org/rfc/rfc1035.txt'>RFC1035</a>. For example:
<code>CNAME</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description "The list of DNS answer header flags." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:flags ],
        [ sh:datatype xsd:integer ;
            sh:description """The time interval that the resource record may be cached. Zero value means that
the resource record can only be used for the transaction in progress, and
should not be cached.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:ttl ],
        [ sh:datatype xsd:string ;
            sh:description """The data describing the DNS resource. The meaning of this data depends on the
type and class of the resource record.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:rdata ],
        [ sh:description "The list of DNS answer header flag IDs." ;
            sh:in ( "AUTHORITATIVE_ANSWER" "TRUNCATED_RESPONSE" "RECURSION_DESIRED" "RECURSION_AVAILABLE" "AUTHENTIC_DATA" "CHECKING_DISABLED" "UNKNOWN" "OTHER" ) ;
            sh:order 1 ;
            sh:path ocsf:flag_ids ],
        [ sh:datatype xsd:integer ;
            sh:description """The DNS packet identifier assigned by the program that generated the query. The
identifier is copied to the response.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:packet_uid ] ;
    sh:targetClass ocsf:DnsAnswer .

ocsf:EmailAuth a sh:NodeShape ;
    rdfs:comment """The Email Authentication object describes the Sender Policy Framework (SPF),
DomainKeys Identified Mail (DKIM) and Domain-based Message Authentication,
Reporting and Conformance (DMARC) attributes of an email.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The Domain-based Message Authentication, Reporting and Conformance (DMARC)
policy status.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:dmarc_policy ],
        [ sh:datatype xsd:string ;
            sh:description """The DomainKeys Identified Mail (DKIM) signature used by the sending/receiving
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:dkim_signature ],
        [ sh:datatype xsd:string ;
            sh:description """The Domain-based Message Authentication, Reporting and Conformance (DMARC)
override action.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:dmarc_override ],
        [ sh:datatype xsd:string ;
            sh:description "The DomainKeys Identified Mail (DKIM) signing domain of the email." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:dkim_domain ],
        [ sh:datatype xsd:string ;
            sh:description """The Domain-based Message Authentication, Reporting and Conformance (DMARC)
status of the email.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:dmarc ],
        [ sh:datatype xsd:string ;
            sh:description "The Sender Policy Framework (SPF) status of the email." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:spf ],
        [ sh:datatype xsd:string ;
            sh:description "The DomainKeys Identified Mail (DKIM) status of the email." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:dkim ] ;
    sh:targetClass ocsf:EmailAuth .

ocsf:Evidences a sh:NodeShape ;
    rdfs:comment """A collection of evidence artifacts associated to the activity/activities that
triggered a security detection.""" ;
    sh:closed true ;
    sh:ignoredProperties ( ocsf:reg_key rdf:type ocsf:reg_value ocsf:win_service ) ;
    sh:property [ sh:class ocsf:ResourceDetails ;
            sh:description """Describes details about the cloud resources directly related to activity that
triggered the detection. For resources impacted by the detection, use
<code>Affected Resources</code> at the top-level of the finding.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path ocsf:resources ],
        [ sh:class ocsf:User ;
            sh:description """Describes details about the user that was the target or somehow else associated
with the activity that triggered the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 24 ;
            sh:path ocsf:user ],
        [ sh:class ocsf:Databucket ;
            sh:description """Describes details about the databucket associated to the activity that
triggered the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:databucket ],
        [ sh:datatype xsd:string ;
            sh:description """The naming convention or type identifier of the evidence associated with the
security detection. For example, the <code>@odata.type</code> from Microsoft
Graph Alerts V2 or <code>display_name</code> from CrowdStrike Falcon Incident
Behaviors.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:name ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description """Describes details about the source of the network activity that triggered the
detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path ocsf:src_endpoint ],
        [ sh:description """The normalized verdict (or status) ID of the evidence associated with the
security detection. For example, Microsoft Graph Security Alerts contain a
<code>verdict</code> enumeration for each type of <code>evidence</code>
associated with the Alert. This is typically set by an automated investigation
process or an analyst/investigator assigned to the finding.""" ;
            sh:in ( "UNKNOWN" "FALSE_POSITIVE" "TRUE_POSITIVE" "DISREGARD" "SUSPICIOUS" "BENIGN" "TEST" "INSUFFICIENT_DATA" "SECURITY_RISK" "MANAGED_EXTERNALLY" "DUPLICATE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 26 ;
            sh:path ocsf:verdict_id ],
        [ sh:class ocsf:HttpResponse ;
            sh:description """Describes details about the http response associated to the activity that
triggered the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:http_response ],
        [ sh:datatype xsd:string ;
            sh:description """Additional evidence data that is not accounted for in the specific evidence
attributes.<code> Use only when absolutely necessary.</code>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:data ],
        [ sh:class ocsf:Api ;
            sh:description """Describes details about the API call associated to the activity that triggered
the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:api ],
        [ sh:class ocsf:Device ;
            sh:description """An addressable device, computer system or host associated to the activity that
triggered the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:device ],
        [ sh:class ocsf:Url ;
            sh:description """The URL object that pertains to the event or object associated to the activity
that triggered the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path ocsf:url ],
        [ sh:class ocsf:Email ;
            sh:description "The email object associated to the activity that triggered the detection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:email ],
        [ sh:class ocsf:Process ;
            sh:description """Describes details about the process associated to the activity that triggered
the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path ocsf:process ],
        [ sh:class ocsf:Tls ;
            sh:description """Describes details about the Transport Layer Security (TLS) activity that
triggered the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path ocsf:tls ],
        [ sh:class ocsf:Actor ;
            sh:description """Describes details about the user/role/process that was the source of the
activity that triggered the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:actor ],
        [ sh:class ocsf:HttpRequest ;
            sh:description """Describes details about the http request associated to the activity that
triggered the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:http_request ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier of the evidence associated with the security detection.
For example, the <code>activity_id</code> from CrowdStrike Falcon Alerts or
<code>behavior_id</code> from CrowdStrike Falcon Incident Behaviors.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:uid ],
        [ sh:class ocsf:Job ;
            sh:description """Describes details about the scheduled job that was associated with the activity
that triggered the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ocsf:job ],
        [ sh:class ocsf:File ;
            sh:description """Describes details about the file associated to the activity that triggered the
detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path ocsf:file ],
        [ sh:class ocsf:Ja4Fingerprint ;
            sh:description "Describes details about the JA4+ fingerprints that triggered the detection." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:ja4_fingerprint_list ],
        [ sh:class ocsf:Container ;
            sh:description """Describes details about the container associated to the activity that triggered
the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:container ],
        [ sh:class ocsf:NetworkConnectionInfo ;
            sh:description """Describes details about the network connection associated to the activity that
triggered the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:connection_info ],
        [ sh:class ocsf:Script ;
            sh:description """Describes details about the script that was associated with the activity that
triggered the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path ocsf:script ],
        [ sh:class ocsf:DnsQuery ;
            sh:description """Describes details about the DNS query associated to the activity that triggered
the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path ocsf:query ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description """Describes details about the destination of the network activity that triggered
the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:dst_endpoint ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized verdict of the evidence associated with the security detection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:verdict ],
        [ sh:class ocsf:Database ;
            sh:description """Describes details about the database associated to the activity that triggered
the detection.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:database ] ;
    sh:targetClass ocsf:Evidences .

ocsf:Extension a sh:NodeShape ;
    rdfs:comment """The OCSF Schema Extension object provides detailed information about the schema
extension used to construct the event. The schema extensions are registered in
the <a target='_blank'
href='https://github.com/ocsf/ocsf-schema/blob/main/extensions.md'>extensions.md</a>
file.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The schema extension version. For example: <code>1.0.0-alpha.2</code>." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:version ],
        [ sh:datatype xsd:string ;
            sh:description "The schema extension name. For example: <code>dev</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The schema extension unique identifier. For example: <code>999</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:uid ] ;
    sh:targetClass ocsf:Extension .

ocsf:Hassh a sh:NodeShape ;
    rdfs:comment """The HASSH object contains SSH network fingerprinting values for specific
client/server implementations. It provides a standardized way of identifying
and categorizing SSH connections based on their unique characteristics and
behavior.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Fingerprint ;
            sh:description """The hash of the key exchange, encryption, authentication and compression
algorithms.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:fingerprint ],
        [ sh:datatype xsd:string ;
            sh:description """The concatenation of key exchange, encryption, authentication and compression
algorithms (separated by ';'). NOTE: This is not the underlying algorithm for
the hash implementation.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:algorithm ] ;
    sh:targetClass ocsf:Hassh .

ocsf:Idp a sh:NodeShape ;
    rdfs:comment """The Identity Provider object contains detailed information about a provider
responsible for creating, maintaining, and managing identity information while
offering authentication services to applications. An Identity Provider (IdP)
serves as a trusted authority that verifies the identity of users and issues
authentication tokens or assertions to enable secure access to applications or
services.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The name of the Identity Provider." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:name ],
        [ sh:class ocsf:Sso ;
            sh:description """The Single Sign-On (SSO) object provides a structure for normalizing SSO
attributes, configuration, and/or settings from Identity Providers.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:sso ],
        [ sh:datatype xsd:anyURI ;
            sh:description "The URL for accessing the configuration or metadata of the Identity Provider." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:url_string ],
        [ sh:description """The normalized state ID of the Identity Provider to reflect its configuration
or activation status.""" ;
            sh:in ( "UNKNOWN" "ACTIVE" "SUSPENDED" "DEPRECATED" "DELETED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 10 ;
            sh:path ocsf:state_id ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the Identity Provider." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description "The tenant ID associated with the Identity Provider." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:tenant_uid ],
        [ sh:datatype xsd:string ;
            sh:description """The configuration state of the Identity Provider, normalized to the caption of
the <code>state_id</code> value. In the case of <code>Other</code>, it is
defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:state ],
        [ sh:class ocsf:AuthFactor ;
            sh:description """The Authentication Factors object describes the different types of Multi-Factor
Authentication (MFA) methods and/or devices supported by the Identity Provider.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:auth_factors ],
        [ sh:datatype xsd:string ;
            sh:description "The primary domain associated with the Identity Provider." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:domain ],
        [ sh:class ocsf:Scim ;
            sh:description """The System for Cross-domain Identity Management (SCIM) resource object provides
a structured set of attributes related to SCIM protocols used for identity
provisioning and management across cloud-based platforms. It standardizes user
and group provisioning details, enabling identity synchronization and lifecycle
management with compatible Identity Providers (IdPs) and applications. SCIM is
defined in <a target='_blank'
href='https://datatracker.ietf.org/doc/html/rfc7643'>RFC-7634</a>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:scim ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier (often a URL) used by the Identity Provider as its
issuer.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:issuer ],
        [ sh:datatype xsd:boolean ;
            sh:description "The Identity Provider enforces Multi Factor Authentication (MFA)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:has_mfa ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The fingerprint of the X.509 certificate used by the Identity Provider." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:fingerprint ],
        [ sh:datatype xsd:string ;
            sh:description """The supported protocol of the Identity Provider. E.g., <code>SAML</code>,
<code>OIDC</code>, or <code>OAuth2</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:protocol_name ] ;
    sh:targetClass ocsf:Idp .

ocsf:Image a sh:NodeShape ;
    rdfs:comment """The Image object provides a description of a specific Virtual Machine (VM) or
Container image.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The full path to the image file." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:path ],
        [ sh:datatype xsd:string ;
            sh:description "The unique image ID. For example: <code>77af4d6b9913</code>." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:uid ],
        [ sh:class ocsf:KeyValueObject ;
            sh:description "The list of tags; <code>{key:value}</code> pairs associated to the image." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:tags ],
        [ sh:datatype xsd:string ;
            sh:description "The list of labels associated to the image." ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:labels ],
        [ sh:datatype xsd:string ;
            sh:description "The image tag. For example: <code>1.11-alpine</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:tag ],
        [ sh:datatype xsd:string ;
            sh:description "The image name. For example: <code>elixir</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:name ] ;
    sh:targetClass ocsf:Image .

ocsf:KeyboardInfo a sh:NodeShape ;
    rdfs:comment """The Keyboard Information object contains details and attributes related to a
computer or device keyboard. It encompasses information that describes the
characteristics, capabilities, and configuration of the keyboard.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "The number of function keys on client keyboard." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:function_keys ],
        [ sh:datatype xsd:string ;
            sh:description "The keyboard type (e.g., xt, ico)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:keyboard_type ],
        [ sh:datatype xsd:string ;
            sh:description "The Input Method Editor (IME) file name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:ime ],
        [ sh:datatype xsd:string ;
            sh:description "The keyboard locale identifier name (e.g., en-US)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:keyboard_layout ],
        [ sh:datatype xsd:integer ;
            sh:description "The keyboard numeric code." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:keyboard_subtype ] ;
    sh:targetClass ocsf:KeyboardInfo .

ocsf:ManagedEntity a sh:NodeShape ;
    rdfs:comment """The Managed Entity object describes the type and version of an entity, such as
a user, device, or policy.  For types in the <code>type_id</code> enum list, an
associated attribute should be populated.  If the type of entity is not in the
<code>type_id</code> list, information can be put into the <code>data</code>
attribute, <code>type_id</code> should be 'Other' and the <code>type</code>
attribute should label the entity type.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The managed entity type. For example: <code>Policy</code>, <code>User</code>,
<code>Organization</code>, <code>Device</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:type ],
        [ sh:class ocsf:Organization ;
            sh:description """The Organization object containing details about the managed organizational
entity. This object includes properties such as the organization name, unique
identifier, type, and other organizational metadata. This attribute should be
populated when <code>type_id</code> is <code>4</code> (Organization).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:org ],
        [ sh:class ocsf:Group ;
            sh:description "The group object associated with an entity such as user, policy, or rule." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:group ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:device ],
        [ sh:datatype xsd:string ;
            sh:description """The identifier of the managed entity. It should match the <code>uid</code> of
the specific entity's object UID if populated, or the source specific ID if the
<code>type_id</code> is 'Other'.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:uid ],
        [ sh:description """The type of the Managed Entity. It is recommended to also populate the
<code>type</code> attribute with the associated label, or the source specific
name if <code>Other</code>.""" ;
            sh:in ( "DEVICE" "USER" "GROUP" "ORGANIZATION" "POLICY" "EMAIL" "NETWORK_ZONE" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 9 ;
            sh:path ocsf:type_id ],
        [ sh:class ocsf:Email ;
            sh:description "The email object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:email ],
        [ sh:class ocsf:User ;
            sh:description "The user that pertains to the event or object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:user ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the managed entity. For example: <code>1.2.3</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:version ],
        [ sh:class ocsf:Policy ;
            sh:description "Describes details of a managed policy." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:string ;
            sh:description """The name of the managed entity. It should match the name of the specific entity
object's name if populated, or the name of the managed entity if the
<code>type_id</code> is 'Other'.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:name ],
        [ sh:class ocsf:Location ;
            sh:description "The detailed geographical location usually associated with an IP address." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:location ],
        [ sh:datatype xsd:string ;
            sh:description "The managed entity content as a JSON object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:data ] ;
    sh:targetClass ocsf:ManagedEntity .

ocsf:Metric a sh:NodeShape ;
    rdfs:comment "The Metric object defines a simple name/value pair entity for a metric." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The name of the metric." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The value of the metric." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:value ] ;
    sh:targetClass ocsf:Metric .

ocsf:Observation a sh:NodeShape ;
    rdfs:comment """A record of an observed value or event that captures the timing and frequency
of its occurrence. Used to track when values/events were first detected, last
detected, and their total occurrence count.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Timespan ;
            sh:description """The time window when the value or event was first observed. It is used to
analyze activity patterns, detect trends, or correlate events within a specific
timeframe.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:timespan ],
        [ sh:datatype xsd:string ;
            sh:description """The specific value, event, indicator or data point that was observed and
recorded. This is the core piece of information being tracked.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:value ],
        [ sh:datatype xsd:integer ;
            sh:description """Integer representing the total number of times this specific value/event was
observed across all occurrences. Helps establish prevalence and patterns.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:count ] ;
    sh:targetClass ocsf:Observation .

ocsf:OccurrenceDetails a sh:NodeShape ;
    rdfs:comment """Details about where in the target entity, specified information was discovered.
Only the attributes, relevant to the target entity type should be populated.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The column name in a spreadsheet, where the information was discovered." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:column_name ],
        [ sh:datatype xsd:integer ;
            sh:description "The page number in a document, where the information was discovered." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:page_number ],
        [ sh:datatype xsd:integer ;
            sh:description """The line number of the last line of the file, where the information was
discovered.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:end_line ],
        [ sh:datatype xsd:integer ;
            sh:description """The line number of the first line of the file, where the information was
discovered.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:start_line ],
        [ sh:datatype xsd:string ;
            sh:description """The JSON path of the attribute in a json record, where the information was
discovered""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:json_path ],
        [ sh:datatype xsd:integer ;
            sh:description """The index of the record in the array of records, where the information was
discovered. e.g. the index of a record in an array of JSON records in a file.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:record_index_in_array ],
        [ sh:datatype xsd:string ;
            sh:description "The cell name/reference in a spreadsheet. e.g <code>A2</code>" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:cell_name ],
        [ sh:datatype xsd:integer ;
            sh:description "The row number in a spreadsheet, where the information was discovered." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:row_number ],
        [ sh:datatype xsd:integer ;
            sh:description """The column number in a spreadsheet or a plain text document, where the
information was discovered.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:column_number ] ;
    sh:targetClass ocsf:OccurrenceDetails .

ocsf:ProgrammaticCredential a sh:NodeShape ;
    rdfs:comment """The Programmatic Credential object describes service-specific credentials used
for direct API access and system integration. These credentials are typically
issued by individual services or platforms for accessing their APIs and
resources, focusing on credential lifecycle management and usage tracking.
Examples include API keys, service account keys, client certificates, and
vendor-specific access tokens.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:long ;
            sh:description """The timestamp when this programmatic credential was last used for
authentication or API access. This helps track credential usage patterns,
identify dormant credentials that may pose security risks, and support
credential lifecycle management. The timestamp should reflect the most recent
successful authentication or API call using this credential.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:last_used_time ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier of the programmatic credential. This could be an API key
ID, service account key ID, access token identifier, certificate serial number,
or other unique identifier that distinguishes this credential from others.
Examples: AWS Access Key ID, GCP Service Account Key ID, Azure Application ID,
or OAuth2 token identifier.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description """The type or category of programmatic credential, normalized to the caption of
the type_id value. In the case of 'Other', it is defined by the event source.
Examples include 'API Key', 'Service Account Key', 'Access Token', 'Client
Certificate', 'OAuth Token', 'Personal Access Token', etc.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:type ] ;
    sh:targetClass ocsf:ProgrammaticCredential .

ocsf:RelatedEvent a sh:NodeShape ;
    rdfs:comment """The Related Event object describes an event or another finding related to a
finding. It may or may not be an OCSF event.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """<p>The type of the related event/finding.</p>Populate if the related
event/finding is <code>NOT</code> in OCSF. If it is in OCSF, then utilize
<code>type_name, type_uid</code> instead.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the related event/finding was last modified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:modified_time ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:attacks ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 12 ;
            sh:path ocsf:severity_id ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:observables ],
        [ sh:datatype xsd:long ;
            sh:description """<p>The time when the related event/finding was created.</p> If the related
event/finding is in OCSF and is a Finding, then this value should be equal to
<code>finding_info.created_time</code> in the corresponding Finding. If the
related event/finding is in OCSF and is not a Finding, then this value should
be equal to <code>time</code> in the corresponding event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:created_time ],
        [ sh:datatype xsd:string ;
            sh:description """<p>The unique identifier of the related event/finding.</p> If the related
event/finding is in OCSF, then this value must be equal to
<code>metadata.uid</code> in the corresponding event.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description """The related event status. Should correspond to the label of the status_id (or
'Other' status value for status_id = 99) of the related event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:status ],
        [ sh:class ocsf:KillChainPhase ;
            sh:description """The <a target='_blank'
href='https://www.lockheedmartin.com/en-us/capabilities/cyber/cyber-kill-chain.html'>Cyber
Kill Chain®</a> provides a detailed description of each phase and its
associated activities within the broader context of a cyber attack.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:kill_chain ],
        [ sh:datatype xsd:long ;
            sh:description """The time when the finding was first observed. e.g. The time when a
vulnerability was first observed.<br>It can differ from the
<code>created_time</code> timestamp, which reflects the time this finding was
created.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:first_seen_time ],
        [ sh:class ocsf:KeyValueObject ;
            sh:description """The list of tags; <code>{key:value}</code> pairs associated with the related
event/finding.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ocsf:tags ],
        [ sh:datatype xsd:integer ;
            sh:description """The unique identifier of the related OCSF event type. <p>For example:
<code>100701.</code></p>Populate if the related event/finding is in OCSF.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:type_uid ],
        [ sh:datatype xsd:string ;
            sh:description "A description of the related event/finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:desc ],
        [ sh:datatype xsd:string ;
            sh:description """The type of the related OCSF event, as defined by <code>type_uid</code>.<p>For
example: <code>Process Activity: Launch.</code></p>Populate if the related
event/finding is in OCSF.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:type_name ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the product that reported the related event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:product_uid ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:severity ],
        [ sh:datatype xsd:long ;
            sh:description """The time when the finding was most recently observed. e.g. The time when a
vulnerability was most recently observed.<br>It can differ from the
<code>modified_time</code> timestamp, which reflects the time this finding was
last modified.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:last_seen_time ],
        [ sh:datatype xsd:string ;
            sh:description "A title or a brief phrase summarizing the related event/finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:title ],
        [ sh:class ocsf:Product ;
            sh:description "Details about the product that reported the related event/finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:product ],
        [ sh:class ocsf:Trait ;
            sh:description """The list of key traits or characteristics extracted from the related
event/finding that influenced or contributed to the overall finding's outcome.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path ocsf:traits ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that activity in the same logical group occurred, as
reported by the related Finding.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:count ] ;
    sh:targetClass ocsf:RelatedEvent .

ocsf:Request a sh:NodeShape ;
    rdfs:comment "The Request Elements object describes characteristics of an API request." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Container ;
            sh:description """When working with containerized applications, the set of containers which write
to the standard the output of a particular logging driver. For example, this
may be the set of containers involved in handling api requests and responses
for a containerized application.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:containers ],
        [ sh:datatype xsd:string ;
            sh:description "The additional data that is associated with the api request." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:data ],
        [ sh:datatype xsd:string ;
            sh:description "The communication flags that are associated with the api request." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:flags ],
        [ sh:datatype xsd:string ;
            sh:description "The unique request identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:uid ] ;
    sh:targetClass ocsf:Request .

ocsf:Rule a sh:NodeShape ;
    rdfs:comment """The Rule object describes characteristics of a rule associated with a policy or
an event.""" ;
    sh:closed true ;
    sh:ignoredProperties ( ocsf:duration ocsf:match_location ocsf:sensitivity ocsf:rate_limit ocsf:condition rdf:type ocsf:match_details ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The rule type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the rule that generated the event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the rule that generated the event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:desc ],
        [ sh:datatype xsd:string ;
            sh:description "The rule version. For example: <code>1.1</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:version ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the rule that generated the event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description "The rule category." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:category ] ;
    sh:targetClass ocsf:Rule .

ocsf:San a sh:NodeShape ;
    rdfs:comment """The Subject Alternative name (SAN) object describes a SAN secured by a digital
certificate""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Type descriptor of SAN (e.g. IP Address/domain/etc.)" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description "Name of SAN (e.g. The actual IP Address or domain.)" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:name ] ;
    sh:targetClass ocsf:San .

ocsf:Sbom a sh:NodeShape ;
    rdfs:comment """The Software Bill of Materials object describes characteristics of a generated
SBOM.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The type of SBOM." ;
            sh:in ( "SPDX" "CYCLONEDX" "SWID" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path ocsf:type_id ],
        [ sh:class ocsf:Package ;
            sh:description """The software package or library that is being discovered or inventoried by an
SBOM.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:package ],
        [ sh:class ocsf:Product ;
            sh:description """Details about the upstream product that generated the SBOM e.g.
<code>cdxgen</code> or <code>Syft</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:product ],
        [ sh:class ocsf:SoftwareComponent ;
            sh:description "The list of software components used in the software package." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:software_components ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the SBOM was created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:created_time ],
        [ sh:datatype xsd:string ;
            sh:description """A unique identifier for the SBOM or the SBOM generation by a source tool, such
as the SPDX <code>metadata.component.bom-ref</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description """The type of SBOM, normalized to the caption of the <code>type_id</code> value.
In the case of 'Other', it is defined by the source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description """The specification (spec) version of the particular SBOM, e.g.,
<code>1.6</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:version ] ;
    sh:targetClass ocsf:Sbom .

ocsf:SecurityState a sh:NodeShape ;
    rdfs:comment """The Security State object describes the security related state of a managed
entity.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The security state, normalized to the caption of the state_id value. In the
case of 'Other', it is defined by the source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:state ],
        [ sh:description "The security state of the managed entity." ;
            sh:in ( "UNKNOWN" "MISSING_OR_OUTDATED_CONTENT" "POLICY_MISMATCH" "IN_NETWORK_QUARANTINE" "PROTECTION_OFF" "PROTECTION_MALFUNCTION" "PROTECTION_NOT_LICENSED" "UNREMEDIATED_THREAT" "SUSPICIOUS_REPUTATION" "REBOOT_PENDING" "CONTENT_IS_LOCKED" "NOT_INSTALLED" "WRITABLE_SYSTEM_PARTITION" "SAFETYNET_FAILURE" "FAILED_BOOT_VERIFY" "MODIFIED_EXECUTION_ENVIRONMENT" "SELINUX_DISABLED" "ELEVATED_PRIVILEGE_SHELL" "IOS_FILE_SYSTEM_ALTERED" "OPEN_REMOTE_ACCESS" "OTA_UPDATES_DISABLED" "ROOTED" "ANDROID_PARTITION_MODIFIED" "COMPLIANCE_FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path ocsf:state_id ] ;
    sh:targetClass ocsf:SecurityState .

ocsf:Tactic a sh:NodeShape ;
    rdfs:comment """The MITRE Tactic object describes the ATT&CK® or ATLAS™ Tactic ID and/or name
that is associated to an attack.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The Tactic ID that is associated with the attack technique. For example:
<code>TA0043</code>, or <code>AML.TA0000</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description """The Tactic name that is associated with the attack technique. For example:
<code>Reconnaissance</code> or <code>ML Model Access</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:anyURI ;
            sh:description """The versioned permalink of the Tactic. For example:
<code>https://attack.mitre.org/versions/v14/tactics/TA0043/</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:src_url ] ;
    sh:targetClass ocsf:Tactic .

ocsf:TlsExtension a sh:NodeShape ;
    rdfs:comment """The TLS Extension object describes additional attributes that extend the base
Transport Layer Security (TLS) object.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The data contains information specific to the particular extension type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:data ],
        [ sh:datatype xsd:string ;
            sh:description "The TLS extension type. For example: <code>Server Name</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:type ],
        [ sh:description """The TLS extension type identifier. See <a target='_blank'
href='https://datatracker.ietf.org/doc/html/rfc8446#page-35'>The Transport
Layer Security (TLS) extension page</a>.""" ;
            sh:in ( "SERVER_NAME" "MAXIMUM_FRAGMENT_LENGTH" "STATUS_REQUEST" "SUPPORTED_GROUPS" "SIGNATURE_ALGORITHMS" "USE_SRTP" "HEARTBEAT" "APPLICATION_LAYER_PROTOCOL_NEGOTIATION" "SIGNED_CERTIFICATE_TIMESTAMP" "CLIENT_CERTIFICATE_TYPE" "SERVER_CERTIFICATE_TYPE" "PADDING" "PRE_SHARED_KEY" "EARLY_DATA" "SUPPORTED_VERSIONS" "COOKIE" "PSK_KEY_EXCHANGE_MODES" "CERTIFICATE_AUTHORITIES" "OID_FILTERS" "POST_HANDSHAKE_AUTH" "SIGNATURE_ALGORITHMS_CERT" "KEY_SHARE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path ocsf:type_id ] ;
    sh:targetClass ocsf:TlsExtension .

ocsf:Trait a sh:NodeShape ;
    rdfs:comment """Describes a characteristic or feature of an entity that was observed. For
example, this object can be used to represent specific characteristics derived
from events or findings that can be surfaced as distinguishing traits of the
entity in question.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The name of the trait." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description """The type of the trait. For example, this can be used to indicate if the trait
acts as a contributing factor (increases risk/severity) or a mitigating factor
(decreases risk/severity), in the context of the related finding.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description "The high-level grouping or classification this trait belongs to." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:category ],
        [ sh:datatype xsd:string ;
            sh:description "The values of the trait." ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:values ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the trait." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:uid ] ;
    sh:targetClass ocsf:Trait .

ocsf:UnmannedAerialSystem a sh:NodeShape ;
    rdfs:comment """The Unmanned Aerial System object describes the characteristics, Position
Location Information (PLI), and other metadata of Unmanned Aerial Systems (UAS)
and other unmanned and drone systems used in Remote ID. Remote ID is defined in
the Standard Specification for Remote ID and Tracking (ASTM Designation:
F3411-22a) <a target='_blank'
href='https://cdn.standards.iteh.ai/samples/112830/71297057ac42432880a203654f213709/ASTM-F3411-22a.pdf'>ASTM
F3411-22a</a>.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """A secondary identification identifier for an unmanned system. This can be a
Serial Number (in <code>CTA-2063-A</code> format, the Registration ID (provided
by the <code>CAA</code>, a UTM, or a unique Session ID.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:uid_alt ],
        [ sh:class ocsf:DeviceHwInfo ;
            sh:description "The endpoint hardware information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:hw_info ],
        [ sh:datatype xsd:string ;
            sh:description """The Unmanned Aircraft System Traffic Management (UTM) provided universal unique
ID (UUID) traceable to a non-obfuscated ID where this UTM UUID acts as a
'session id' to protect exposure of operationally sensitive information.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:uuid ;
            sh:pattern "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description """Ground speed of flight. This value is provided in meters per second with a
minimum resolution of 0.25 m/s. Special Values: <code>Invalid</code>, <code>No
Value</code>, or <code>Unknown: 255 m/s</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:speed ],
        [ sh:datatype xsd:string ;
            sh:description """Provides quality/containment on horizontal ground speed. Measured in
meters/second.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:speed_accuracy ],
        [ sh:datatype xsd:string ;
            sh:description "The model name of the aircraft or unmanned system." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:model ],
        [ sh:datatype xsd:string ;
            sh:description "The type of the UAS. For example, Helicopter, Gyroplane, Rocket, etc." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description """Direction of flight expressed as a “True North-based” ground track angle. This
value is provided in clockwise degrees with a minimum resolution of 1 degree.
If aircraft is not moving horizontally, use the “Unknown” value""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:track_direction ],
        [ sh:class ocsf:Location ;
            sh:description "The detailed geographical location usually associated with an IP address." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:location ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the unmanned system as reported by tracking or sensing hardware." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description """The primary identification identifier for an unmanned system. This can be a
Serial Number (in <code>CTA-2063-A</code> format, the Registration ID (provided
by the <code>CAA</code>, a UTM, or a unique Session ID.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description """The serial number of the unmanned system. This is expressed in
<code>CTA-2063-A</code> format.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:serial_number ],
        [ sh:datatype xsd:string ;
            sh:description """Vertical speed upward relative to the WGS-84 datum, measured in meters per
second. Special Values: <code>Invalid</code>, <code>No Value</code>, or
<code>Unknown: 63 m/s</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:vertical_speed ],
        [ sh:description "The UAS type identifier." ;
            sh:in ( "UNKNOWN_UNDECLARED" "AIRPLANE" "HELICOPTER" "GYROPLANE" "HYBRID_LIFT" "ORNITHOPTER" "GLIDER" "KITE" "FREE_BALLOON" "CAPTIVE_BALLOON" "AIRSHIP" "FREE_FALL_PARACHUTE" "ROCKET" "TETHERED_POWERED_AIRCRAFT" "GROUND_OBSTACLE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path ocsf:type_id ] ;
    sh:targetClass ocsf:UnmannedAerialSystem .

ocsf:UnmannedSystemOperatingArea a sh:NodeShape ;
    rdfs:comment """The Unmanned System Operating Area object describes details about a precise
area of operations for a UAS flight or mission.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """Provides quality/containment on horizontal position. This is based on ADS-B
NACp. Measured in meters.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:horizontal_accuracy ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the geographical location." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:desc ],
        [ sh:datatype xsd:integer ;
            sh:description "Indicates the number of UAS in the operating area." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:count ],
        [ sh:datatype xsd:string ;
            sh:description """The ISO 3166-1 Alpha-2 country code.<p><b>Note:</b> The two letter country code
should be capitalized. For example: <code>US</code> or <code>CA</code>.</p>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:country ],
        [ sh:datatype xsd:float ;
            sh:description """The geographical Latitude coordinate represented in Decimal Degrees (DD). For
example: <code>42.361145</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:lat ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether the location is on-premises." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:is_on_premises ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the continent." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:continent ],
        [ sh:datatype xsd:string ;
            sh:description """The alphanumeric code that identifies the principal subdivision (e.g. province
or state) of the country. For example, 'CH-VD' for the Canton of Vaud,
Switzerland""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:region ],
        [ sh:datatype xsd:string ;
            sh:description """The aircraft distance above or below the ellipsoid as measured along a line
that passes through the aircraft and is normal to the surface of the WGS-84
ellipsoid. This value is provided in meters and must have a minimum resolution
of 1 m. Special Values: <code>Invalid</code>, <code>No Value</code>, or
<code>Unknown: -1000 m</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:geodetic_altitude ],
        [ sh:class ocsf:Location ;
            sh:description """A list of Position Location Information (PLI) (latitude/longitude pairs)
defining the area where a group or Intent-Based Network Participant operation
is taking place. (This field is only applicable to Network Remote ID.)""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:locations ],
        [ sh:datatype xsd:string ;
            sh:description """Farthest horizontal distance from the reported location at which any UA in a
group may be located (meters). Also allows defining the area where an
Intent-Based Network Participant operation is taking place. Default: 0 m.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:radius ],
        [ sh:datatype xsd:string ;
            sh:description """Expressed as either height above takeoff location or height above ground level
(AGL) for a UAS current location. This value is provided in meters and must
have a minimum resolution of 1 m. Special Values: <code>Invalid</code>,
<code>No Value</code>, or <code>Unknown: -1000 m</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:aerial_height ],
        [ sh:datatype xsd:string ;
            sh:description """Maximum altitude (WGS-84 HAE) for a group or an Intent-Based Network
Participant. Measured in meters. Special Values: <code>Invalid</code>, <code>No
Value</code>, or <code>Unknown: -1000 m</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:altitude_ceiling ],
        [ sh:datatype xsd:string ;
            sh:description "The postal code of the location." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:postal_code ],
        [ sh:datatype xsd:string ;
            sh:description """Minimum altitude (WGS-84 HAE) for a group or an Intent-Based Network
Participant. Measured in meters. Special Values: <code>Invalid</code>, <code>No
Value</code>, or <code>Unknown: -1000 m</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:altitude_floor ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the city." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:city ],
        [ sh:datatype xsd:string ;
            sh:description """Provides quality/containment on geodetic altitude. This is based on ADS-B
Geodetic Vertical Accuracy (GVA). Measured in meters.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:geodetic_vertical_accuracy ],
        [ sh:datatype xsd:float ;
            sh:description """The geographical Longitude coordinate represented in Decimal Degrees (DD). For
example: <code>-71.057083</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:long ],
        [ sh:datatype xsd:float ;
            sh:description """A two-element array, containing a longitude/latitude pair. The format conforms
with <a target='_blank' href='https://geojson.org'>GeoJSON</a>. For example:
<code>[-73.983, 40.719]</code>.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:coordinates ],
        [ sh:description "The operating area type identifier." ;
            sh:in ( "UNKNOWN_UNDECLARED" "TAKEOFF_LOCATION" "FIXED_LOCATION" "DYNAMIC_LOCATION" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the Internet Service Provider (ISP)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:isp ],
        [ sh:datatype xsd:long ;
            sh:description """The date and time at which a group or an Intent-Based Network Participant
operation ends. (This field is only applicable to Network Remote ID.)""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:end_time ],
        [ sh:datatype xsd:long ;
            sh:description """The date and time at which a group or an Intent-Based Network Participant
operation starts. (This field is only applicable to Network Remote ID.)""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:start_time ],
        [ sh:datatype xsd:string ;
            sh:description """<p>Geohash of the geo-coordinates (latitude and longitude).</p><a
target='_blank' href='https://en.wikipedia.org/wiki/Geohash'>Geohashing</a> is
a geocoding system used to encode geographic coordinates in decimal degrees, to
a single string.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:geohash ],
        [ sh:datatype xsd:string ;
            sh:description "The provider of the geographical location data." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:provider ],
        [ sh:datatype xsd:string ;
            sh:description """The type of operating area. For example, <code>Takeoff Location</code>,
<code>Fixed Location</code>, <code>Dynamic Location</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description """The uncorrected barometric pressure altitude (based on reference standard 29.92
inHg, 1013.25 mb) provides a reference for algorithms that utilize 'altitude
deltas' between aircraft. This value is provided in meters and must have a
minimum resolution of 1 m.. Special Values: <code>Invalid</code>, <code>No
Value</code>, or <code>Unknown: -1000 m</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:pressure_altitude ] ;
    sh:targetClass ocsf:UnmannedSystemOperatingArea .

ocsf:ApplicationObject a sh:NodeShape ;
    rdfs:comment """An Application describes the details for an inventoried application as reported
by an Application Security tool or other Developer-centric tooling.
Applications can be defined as Kubernetes resources, Containerized resources,
or application hosting-specific cloud sources such as AWS Elastic BeanStalk,
AWS Lightsail, or Azure Logic Apps.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Graph ;
            sh:description """A graph representation showing how this application relates to and interacts
with other entities in the environment. This can include parent/child
relationships, dependencies, or other connections.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:resource_relationship ],
        [ sh:datatype xsd:string ;
            sh:description "Additional data describing the application." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:data ],
        [ sh:class ocsf:KeyValueObject ;
            sh:description "The list of tags; <code>{key:value}</code> pairs associated to the application." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ocsf:tags ],
        [ sh:datatype xsd:string ;
            sh:description "The criticality of the application as defined by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:criticality ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:risk_score ],
        [ sh:class ocsf:User ;
            sh:description "The identity of the service or user account that owns the application." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:owner ],
        [ sh:class ocsf:Sbom ;
            sh:description "The Software Bill of Materials (SBOM) associated with the application" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:sbom ],
        [ sh:datatype xsd:string ;
            sh:description """An alternative or contextual identifier for the application, such as a
configuration, organization, or license UID.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:uid_alt ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 11 ;
            sh:path ocsf:risk_level_id ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the application." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The semantic version of the application, e.g., <code>1.7.4</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:version ],
        [ sh:class ocsf:Url ;
            sh:description "The URL of the application." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path ocsf:url ],
        [ sh:datatype xsd:string ;
            sh:description "The list of labels associated to the application." ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:labels ],
        [ sh:class ocsf:Group ;
            sh:description "The name of the related application or associated resource group." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:group ],
        [ sh:datatype xsd:string ;
            sh:description """A description or commentary for an application, usually retrieved from an
upstream system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:desc ],
        [ sh:datatype xsd:string ;
            sh:description "The cloud region of the resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:region ],
        [ sh:datatype xsd:string ;
            sh:description """The type of application as defined by the event source, e.g.,
<code>GitHub</code>, <code>Azure Logic App</code>, or <code>Amazon Elastic
BeanStalk</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier for the application." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:risk_level ],
        [ sh:datatype xsd:string ;
            sh:description "The fully qualified name of the application." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:hostname ] ;
    sh:targetClass ocsf:ApplicationObject .

ocsf:AuthFactor a sh:NodeShape ;
    rdfs:comment """An Authentication Factor object describes a category of methods used for
identity verification in an authentication attempt.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The type of authentication factor used in an authentication attempt." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:factor_type ],
        [ sh:class ocsf:Device ;
            sh:description "Device used to complete an authentication request." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:device ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether the authentication factor is a Time-based One-time Password (TOTP)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:is_totp ],
        [ sh:datatype xsd:string ;
            sh:description "The email address used in an email-based authentication factor." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:email_addr ;
            sh:pattern "^[\\w.+\\-]+@[\\w\\-]+(\\.[\\w\\-]+)+$" ],
        [ sh:datatype xsd:string ;
            sh:description "The phone number used for a telephony-based authentication request." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:phone_number ],
        [ sh:datatype xsd:string ;
            sh:description "The question(s) provided to user for a question-based authentication factor." ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:security_questions ],
        [ sh:description "The normalized identifier for the authentication factor." ;
            sh:in ( "UNKNOWN" "SMS" "SECURITY_QUESTION" "PHONE_CALL" "BIOMETRIC" "PUSH_NOTIFICATION" "HARDWARE_TOKEN" "OTP" "EMAIL" "U2F" "WEBAUTHN" "PASSWORD" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path ocsf:factor_type_id ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether the authentication factor is an HMAC-based One-time Password (HOTP)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:is_hotp ],
        [ sh:datatype xsd:string ;
            sh:description "The name of provider for an authentication factor." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:provider ] ;
    sh:targetClass ocsf:AuthFactor .

ocsf:Compliance a sh:NodeShape ;
    rdfs:comment """The Compliance object contains information about Industry and Regulatory
Framework standards, controls and requirements or details about custom
assessments utilized in a compliance evaluation. Standards define broad
security frameworks, controls represent specific security requirements within
those frameworks, and checks are the testable verification points used to
determine if controls are properly implemented.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Assessment ;
            sh:description "A list of assessments associated with the compliance requirements evaluation." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:assessments ],
        [ sh:datatype xsd:string ;
            sh:description "The description or criteria of a control." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:desc ],
        [ sh:class ocsf:KbArticle ;
            sh:description """A list of reference KB articles that provide information to help organizations
understand, interpret, and implement compliance standards. They provide
guidance, best practices, and examples.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:compliance_references ],
        [ sh:datatype xsd:string ;
            sh:description "The contextual description of the <code>status, status_code</code> values." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:status_detail ],
        [ sh:class ocsf:KeyValueObject ;
            sh:description """The list of control parameters evaluated in a Compliance check. E.g.,
parameters for CloudTrail configuration might include
<code>multiRegionTrailEnabled: true</code>, <code>logFileValidationEnabled:
true</code>, and <code>requiredRegions: [us-east-1, us-west-2]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:control_parameters ],
        [ sh:datatype xsd:string ;
            sh:description """A list of contextual descriptions of the <code>status, status_code</code>
values.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:status_details ],
        [ sh:class ocsf:KbArticle ;
            sh:description """A list of established guidelines or criteria that define specific requirements
an organization must follow.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:compliance_standards ],
        [ sh:datatype xsd:string ;
            sh:description "The regulatory or industry standards being evaluated for compliance." ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:standards ],
        [ sh:datatype xsd:string ;
            sh:description "The resultant status code of the compliance check." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:status_code ],
        [ sh:description "The normalized status identifier of the compliance check." ;
            sh:in ( "PASS" "WARNING" "FAIL" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 14 ;
            sh:path ocsf:status_id ],
        [ sh:datatype xsd:string ;
            sh:description """A Control is a prescriptive, actionable set of specifications that strengthens
device posture. The control specifies required security measures, while the
specific implementation values are defined in control_parameters. E.g., CIS AWS
Foundations Benchmark 1.2.0 - Control 2.1 - Ensure CloudTrail is enabled in all
regions""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:control ],
        [ sh:datatype xsd:string ;
            sh:description """The category a control framework pertains to, as reported by the source tool,
such as <code>Asset Management</code> or <code>Risk Assessment</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:category ],
        [ sh:datatype xsd:string ;
            sh:description """The specific compliance requirements being evaluated. E.g., <code>PCI DSS
Requirement 8.2.3 - Passwords must meet minimum complexity requirements</code>
or <code>HIPAA Security Rule 164.312(a)(2)(iv) - Implement encryption and
decryption mechanisms</code>""" ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:requirements ],
        [ sh:datatype xsd:string ;
            sh:description """The resultant status of the compliance check normalized to the caption of the
<code>status_id</code> value. In the case of 'Other', it is defined by the
event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:status ],
        [ sh:class ocsf:Check ;
            sh:description """A list of compliance checks associated with specific industry standards or
frameworks. Each check represents an individual rule or requirement that has
been evaluated against a target device. Checks typically include details such
as the check name (e.g., CIS: 'Ensure mounting of cramfs filesystems is
disabled' or DISA STIG descriptive titles), unique identifiers (such as CIS
identifier '1.1.1.1' or DISA STIG identifier 'V-230234'), descriptions
(detailed explanations of security requirements or vulnerability discussions),
and version information.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:checks ] ;
    sh:targetClass ocsf:Compliance .

ocsf:Cve a sh:NodeShape ;
    rdfs:comment """The Common Vulnerabilities and Exposures (CVE) object represents publicly
disclosed cybersecurity vulnerabilities defined in CVE Program catalog (<a
target='_blank' href='https://cve.mitre.org/'>CVE</a>). There is one CVE Record
for each vulnerability in the catalog.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Cwe ;
            sh:description """The CWE object represents a weakness in a software system that can be exploited
by a threat actor to perform an attack. The CWE object is based on the <a
target='_blank' href='https://cwe.mitre.org/'>Common Weakness Enumeration
(CWE)</a> catalog.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:cwe ],
        [ sh:datatype xsd:string ;
            sh:description """The <a target='_blank' href='https://cwe.mitre.org/'>Common Weakness
Enumeration (CWE)</a> unique identifier. For example: <code>CWE-787</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:cwe_uid ],
        [ sh:datatype xsd:long ;
            sh:description "The Record Modified Date identifies when the CVE record was last updated." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:modified_time ],
        [ sh:class ocsf:Cwe ;
            sh:description """Describes the Common Weakness Enumeration <a target='_blank'
href='https://cwe.mitre.org/'>(CWE)</a> details related to the CVE Record.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path ocsf:related_cwes ],
        [ sh:datatype xsd:string ;
            sh:description """<p>The vulnerability type as selected from a large dropdown menu during CVE
refinement.</p>Most frequently used vulnerability types are: <code>DoS</code>,
<code>Code Execution</code>, <code>Overflow</code>, <code>Memory
Corruption</code>, <code>Sql Injection</code>, <code>XSS</code>,
<code>Directory Traversal</code>, <code>Http Response Splitting</code>,
<code>Bypass something</code>, <code>Gain Information</code>, <code>Gain
Privileges</code>, <code>CSRF</code>, <code>File Inclusion</code>. For more
information see <a target='_blank'
href='https://www.cvedetails.com/vulnerabilities-by-types.php'>Vulnerabilities
By Type</a> distributions.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description """The Common Vulnerabilities and Exposures unique number assigned to a specific
computer vulnerability. A CVE Identifier begins with 4 digits representing the
year followed by a sequence of digits that acts as a unique identifier. For
example: <code>CVE-2021-12345</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:long ;
            sh:description """The Record Creation Date identifies when the CVE ID was issued to a CVE
Numbering Authority (CNA) or the CVE Record was published on the CVE List. Note
that the Record Creation Date does not necessarily indicate when this
vulnerability was discovered, shared with the affected vendor, publicly
disclosed, or updated in CVE.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:created_time ],
        [ sh:class ocsf:Epss ;
            sh:description """The Exploit Prediction Scoring System (EPSS) object describes the estimated
probability a vulnerability will be exploited. EPSS is a community-driven
effort to combine descriptive information about vulnerabilities (CVEs) with
evidence of actual exploitation in-the-wild. (<a target='_blank'
href='https://www.first.org/epss/'>EPSS</a>).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:epss ],
        [ sh:datatype xsd:string ;
            sh:description "A list of reference URLs with additional information about the CVE Record." ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:references ],
        [ sh:datatype xsd:string ;
            sh:description "A brief description of the CVE Record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:desc ],
        [ sh:class ocsf:Product ;
            sh:description "The product where the vulnerability was discovered." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:product ],
        [ sh:class ocsf:Cvss ;
            sh:description """The CVSS object details Common Vulnerability Scoring System (<a target='_blank'
href='https://www.first.org/cvss/'>CVSS</a>) scores from the advisory that are
related to the vulnerability.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:cvss ],
        [ sh:datatype xsd:string ;
            sh:description "A title or a brief phrase summarizing the CVE record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:title ],
        [ sh:datatype xsd:anyURI ;
            sh:description """Common Weakness Enumeration (CWE) definition URL. For example:
<code>https://cwe.mitre.org/data/definitions/787.html</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:cwe_url ] ;
    sh:targetClass ocsf:Cve .

ocsf:DigitalSignature a sh:NodeShape ;
    rdfs:comment """The Digital Signature object contains information about the cryptographic
mechanism used to verify the authenticity, integrity, and origin of the file or
application.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:long ;
            sh:description "The time when the digital signature was created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:created_time ],
        [ sh:datatype xsd:string ;
            sh:description "The developer ID on the certificate that signed the file." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:developer_uid ],
        [ sh:class ocsf:Fingerprint ;
            sh:description """The message digest attribute contains the fixed length message hash
representation and the corresponding hashing algorithm information.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:digest ],
        [ sh:description "The identifier of the normalized digital signature algorithm." ;
            sh:in ( "UNKNOWN" "DSA" "RSA" "ECDSA" "AUTHENTICODE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path ocsf:algorithm_id ],
        [ sh:datatype xsd:string ;
            sh:description """The digital signature state defines the signature state, normalized to the
caption of 'state_id'. In the case of 'Other', it is defined by the event
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:state ],
        [ sh:datatype xsd:string ;
            sh:description """The digital signature algorithm used to create the signature, normalized to the
caption of 'algorithm_id'. In the case of 'Other', it is defined by the event
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:algorithm ],
        [ sh:description "The normalized identifier of the signature state." ;
            sh:in ( "VALID" "EXPIRED" "REVOKED" "SUSPENDED" "PENDING" "UNTRUSTED" "DISTRUSTED" "WRONGUSAGE" "BAD" "BROKEN" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path ocsf:state_id ],
        [ sh:class ocsf:Certificate ;
            sh:description "The certificate object containing information about the digital certificate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:certificate ] ;
    sh:targetClass ocsf:DigitalSignature .

ocsf:DnsQuery a sh:NodeShape ;
    rdfs:comment """The DNS query object represents a specific request made to the Domain Name
System (DNS) to retrieve information about a domain or perform a DNS operation.
This object encapsulates the necessary attributes and methods to construct and
send DNS queries, specify the query type (e.g., A, AAAA, MX).""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The class of resource records being queried. See <a target='_blank'
href='https://www.rfc-editor.org/rfc/rfc1035.txt'>RFC1035</a>. For example:
<code>IN</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:class_ ],
        [ sh:description """The DNS opcode ID specifies the normalized query message type as defined in <a
target='_blank'
href='https://www.rfc-editor.org/rfc/rfc5395.html'>RFC-5395</a>.""" ;
            sh:in ( "QUERY" "INVERSE_QUERY" "STATUS" "RESERVED" "NOTIFY" "UPDATE" "DSO_MESSAGE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path ocsf:opcode_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The DNS packet identifier assigned by the program that generated the query. The
identifier is copied to the response.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:packet_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The hostname or domain being queried. For example: <code>www.example.com</code>" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:hostname ],
        [ sh:datatype xsd:string ;
            sh:description """The type of resource records being queried. See <a target='_blank'
href='https://www.rfc-editor.org/rfc/rfc1035.txt'>RFC1035</a>. For example: A,
AAAA, CNAME, MX, and NS.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description "The DNS opcode specifies the type of the query message." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:opcode ] ;
    sh:targetClass ocsf:DnsQuery .

ocsf:EncryptionDetails a sh:NodeShape ;
    rdfs:comment "Details about the encryption methodology utilized." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The encryption algorithm used." ;
            sh:in ( "DES" "TRIPLEDES" "AES" "RSA" "ECC" "SM2" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path ocsf:algorithm_id ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier of the key used for encryption. For example, AWS KMS Key
ARN.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:key_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The type of the encryption used." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description "The encryption algorithm used, normalized to the caption of 'algorithm_id" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:algorithm ],
        [ sh:datatype xsd:integer ;
            sh:description "The length of the encryption key used." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:key_length ] ;
    sh:targetClass ocsf:EncryptionDetails .

ocsf:HttpHeader a sh:NodeShape ;
    rdfs:comment """The HTTP Header object represents the headers sent in an HTTP request or
response. HTTP headers are key-value pairs that convey additional information
about the HTTP message, including details about the content, caching,
authentication, encoding, and other aspects of the communication.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The name of the HTTP header." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The value of the HTTP header." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:value ] ;
    sh:targetClass ocsf:HttpHeader .

ocsf:KernelDriver a sh:NodeShape ;
    rdfs:comment """The Kernel Extension object describes a kernel driver that has been loaded or
unloaded into the operating system (OS) kernel.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:File ;
            sh:description "The driver/extension file object." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:file ] ;
    sh:targetClass ocsf:KernelDriver .

ocsf:Package a sh:NodeShape ;
    rdfs:comment "The Software Package object describes details about a software package." ;
    sh:closed true ;
    sh:ignoredProperties ( ocsf:fixed_in_version rdf:type ocsf:path ocsf:remediation ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description """The software package epoch. Epoch is a way to define weighted dependencies
based on version numbers.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:epoch ],
        [ sh:datatype xsd:anyURI ;
            sh:description """The link to the specific library or package such as within <code>GitHub</code>,
this is different from the link to the package manager where the library or
package is hosted.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:src_url ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the vendor who published the software package." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:vendor_name ],
        [ sh:datatype xsd:string ;
            sh:description """A purl is a URL string used to identify and locate a software package in a
mostly universal and uniform way across programming languages, package
managers, packaging conventions, tools, APIs and databases.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:purl ],
        [ sh:datatype xsd:string ;
            sh:description """The type of software package, normalized to the caption of the
<code>type_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description "The software license applied to this package." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:license ],
        [ sh:datatype xsd:string ;
            sh:description """A unique identifier for the package or library reported by the source tool.
E.g., the <code>libId</code> within the <code>sbom</code> field of an OX
Security Issue or the SPDX <code>components.*.bom-ref</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description """The software packager manager utilized to manage a package on a system, e.g.
npm, yum, dpkg etc.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:package_manager ],
        [ sh:datatype xsd:string ;
            sh:description """The Common Platform Enumeration (CPE) name as described by (<a target='_blank'
href='https://nvd.nist.gov/products/cpe'>NIST</a>) For example:
<code>cpe:/a:apple:safari:16.2</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:cpe_name ],
        [ sh:datatype xsd:string ;
            sh:description "Release is the number of times a version of the software has been packaged." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:release ],
        [ sh:datatype xsd:anyURI ;
            sh:description """The URL pointing to the license applied on package or software. This is
typically a <code>LICENSE.md</code> file within a repository.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:license_url ],
        [ sh:datatype xsd:anyURI ;
            sh:description """The URL of the package or library at the package manager, or the specific URL
or URI of an internal package manager link such as <code>AWS
CodeArtifact</code> or <code>Artifactory</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:package_manager_url ],
        [ sh:datatype xsd:string ;
            sh:description "The software package version." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:version ],
        [ sh:class ocsf:Fingerprint ;
            sh:description """Cryptographic hash to identify the binary instance of a software component.
This can include any component such file, package, or library.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:hash ],
        [ sh:datatype xsd:string ;
            sh:description "The software package name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:name ],
        [ sh:description "The type of software package." ;
            sh:in ( "APPLICATION" "OPERATING_SYSTEM" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 13 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:string ;
            sh:description """Architecture is a shorthand name describing the type of computer hardware the
packaged software is meant to run on.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:architecture ] ;
    sh:targetClass ocsf:Package .

ocsf:Reputation a sh:NodeShape ;
    rdfs:comment """The Reputation object describes the reputation/risk score of an entity (e.g.
device, user, domain).""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The normalized reputation score identifier." ;
            sh:in ( "UNKNOWN" "VERY_SAFE" "SAFE" "PROBABLY_SAFE" "LEANS_SAFE" "MAY_NOT_BE_SAFE" "EXERCISE_CAUTION" "SUSPICIOUS_RISKY" "POSSIBLY_MALICIOUS" "PROBABLY_MALICIOUS" "MALICIOUS" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path ocsf:score_id ],
        [ sh:datatype xsd:float ;
            sh:description "The reputation score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:base_score ],
        [ sh:datatype xsd:string ;
            sh:description "The provider of the reputation information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:provider ],
        [ sh:datatype xsd:string ;
            sh:description """The reputation score, normalized to the caption of the score_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:score ] ;
    sh:targetClass ocsf:Reputation .

ocsf:Response a sh:NodeShape ;
    rdfs:comment "The Response Elements object describes characteristics of an API response." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The additional data that is associated with the api response." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:data ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:string ;
            sh:description "The communication flags that are associated with the api response." ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:flags ],
        [ sh:datatype xsd:string ;
            sh:description "Error Message" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:error_message ],
        [ sh:datatype xsd:integer ;
            sh:description "The numeric response sent to a request." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:code ],
        [ sh:datatype xsd:string ;
            sh:description "Error Code" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:error ],
        [ sh:class ocsf:Container ;
            sh:description """When working with containerized applications, the set of containers which write
to the standard the output of a particular logging driver. For example, this
may be the set of containers involved in handling api requests and responses
for a containerized application.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:containers ] ;
    sh:targetClass ocsf:Response .

ocsf:StartupItem a sh:NodeShape ;
    rdfs:comment """The startup item object describes an application component that has associated
startup criteria and configurations.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ocsf:win_service ) ;
    sh:property [ sh:description "The start type ID of the startup item." ;
            sh:in ( "UNKNOWN" "AUTO" "BOOT" "ON_DEMAND" "DISABLED" "ALL_LOGINS" "SPECIFIC_USER_LOGIN" "SCHEDULED" "SYSTEM_CHANGED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 9 ;
            sh:path ocsf:start_type_id ],
        [ sh:datatype xsd:string ;
            sh:description "The unique name of the startup item." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description """The list of run_modes, normalized to the captions of the run_mode_id values.
In the case of 'Other', they are defined by the event source.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:run_modes ],
        [ sh:description """The list of normalized identifiers that describe the startup items' properties
when it is running.  Use this field to capture extended information about the
process, which may depend on the type of startup item.  E.g., A Windows service
that interacts with the desktop.""" ;
            sh:in ( "INTERACTIVE" "OWN_PROCESS" "SHARED_PROCESS" "UNKNOWN" "OTHER" ) ;
            sh:order 4 ;
            sh:path ocsf:run_mode_ids ],
        [ sh:datatype xsd:string ;
            sh:description "The start type of the startup item." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:start_type ],
        [ sh:class ocsf:Process ;
            sh:description "The startup item process resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:process ],
        [ sh:datatype xsd:string ;
            sh:description "The run state of the startup item." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:run_state ],
        [ sh:description "The startup item type identifier." ;
            sh:in ( "UNKNOWN" "KERNEL_MODE_DRIVER" "USER_MODE_DRIVER" "SERVICE" "USER_MODE_APPLICATION" "AUTOLOAD" "SYSTEM_EXTENSION" "KERNEL_EXTENSION" "SCHEDULED_JOB_TASK" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 11 ;
            sh:path ocsf:type_id ],
        [ sh:class ocsf:KernelDriver ;
            sh:description "The startup item kernel driver resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:driver ],
        [ sh:datatype xsd:string ;
            sh:description "The startup item type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:type ],
        [ sh:description "The run state ID of the startup item." ;
            sh:in ( "STOPPED" "START_PENDING" "STOP_PENDING" "RUNNING" "CONTINUE_PENDING" "PAUSE_PENDING" "PAUSED" "RESTART_PENDING" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path ocsf:run_state_id ],
        [ sh:class ocsf:Job ;
            sh:description "The startup item job resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:job ] ;
    sh:targetClass ocsf:StartupItem .

ocsf:Table a sh:NodeShape ;
    rdfs:comment """The table object represents a table within a structured relational database or
datastore, which contains columns and rows of data that are able to be create,
updated, deleted and queried.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "The size of the data table in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:size ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the table." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the table was known to have been created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:created_time ],
        [ sh:datatype xsd:long ;
            sh:description """The most recent time when any changes, updates, or modifications were made
within the table.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:modified_time ],
        [ sh:class ocsf:Group ;
            sh:description "The group names to which the table belongs." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:groups ],
        [ sh:datatype xsd:string ;
            sh:description "The table name, ordinarily as assigned by a database administrator." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the table." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:desc ] ;
    sh:targetClass ocsf:Table .

ocsf:Trace a sh:NodeShape ;
    rdfs:comment """The trace object contains information about a distributed trace,  which is
crucial for observability. Traces are made up of one or more spans, which are
individual units of work in application activity. Traces track the journey of a
request as it moves through various services in a system, capturing key details
like timing, status, and dependencies at each step. Traces provide insights
into system performance, helping to identify latency, bottlenecks, and issues
in complex, distributed environments.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:long ;
            sh:description """The start timestamp of the trace, essential for identifying latency and
performance bottlenecks. Like the end time, this timestamp is normalized across
the trace system to ensure consistency, even when events are recorded across
distributed services with unsynchronized clocks. Normalized time enables
accurate trace duration calculations and helps observability tools track
performance across services, regardless of the individual system time settings.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:start_time ],
        [ sh:class ocsf:Span ;
            sh:description """Represents a single unit of work or operation within a distributed trace. A
span typically tracks the execution of a request across a service, capturing
important details such as the operation, timestamps, and status. Spans help
break down the overall trace into smaller, manageable parts, enabling detailed
analysis of the performance and behavior of specific operations within the
system. They are crucial for understanding latency, dependencies, and
bottlenecks in complex distributed systems.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:span ],
        [ sh:datatype xsd:long ;
            sh:description """The end timestamp of the trace, essential for identifying latency and
performance bottlenecks. Like the start time, this timestamp is normalized
across the trace system to ensure consistency, even when events are recorded
across distributed services with unsynchronized clocks. Normalized time allows
for accurate trace duration calculations and helps observability tools track
overall performance across services, regardless of the individual system time
settings.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:end_time ],
        [ sh:datatype xsd:integer ;
            sh:description """The total time, in milliseconds, that the trace covers, calculated as the
difference between start_time and end_time. This duration helps assess the
overall performance of a request as it travels across various services, and is
essential for identifying latency and potential bottlenecks within the
distributed system. The trace duration may differ from individual span
durations due to the propagation and processing times of the trace as it spans
multiple components.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:duration ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier of the trace used in distributed systems and
microservices architecture to track and correlate requests across various
components of an application.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description """The flags associated with the trace, used to indicate specific properties or
behaviors, such as whether the trace is sampled or if it has special handling.
Flags help control how traces are processed, logged, and analyzed, providing
valuable context for tracing and observability tools in identifying trace
characteristics or specific tracking requirements.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:flags ],
        [ sh:class ocsf:Service ;
            sh:description """Identifies the service or component generating the trace, helping to track and
correlate the flow of requests through various parts of a distributed system.
This information is essential for understanding the role and performance of
specific services within the broader context of system operations and for
diagnosing issues across different components.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:service ] ;
    sh:targetClass ocsf:Trace .

ocsf:WebResource a sh:NodeShape ;
    rdfs:comment """The Web Resource object describes characteristics of a web resource that was
affected by the activity/event.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Description of the web resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:desc ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the web resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the resource was last modified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:modified_time ],
        [ sh:class ocsf:DataClassification ;
            sh:description """A list of Data Classification objects, that include information about data
classification levels and data category types, identified by a classifier.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:data_classifications ],
        [ sh:class ocsf:KeyValueObject ;
            sh:description "The list of tags; <code>{key:value}</code> pairs associated to the resource." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:tags ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the resource was created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:created_time ],
        [ sh:datatype xsd:anyURI ;
            sh:description "The URL pointing towards the source of the web resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:url_string ],
        [ sh:datatype xsd:string ;
            sh:description "The alternative unique identifier of the resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:uid_alt ],
        [ sh:datatype xsd:string ;
            sh:description "The list of labels associated to the resource." ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:labels ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the web resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:uid ],
        [ sh:class ocsf:DataClassification ;
            sh:description """The Data Classification object includes information about data classification
levels and data category types.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:data_classification ],
        [ sh:datatype xsd:string ;
            sh:description """Details of the web resource, e.g, <code>file</code> details,
<code>search</code> results or application-defined resource.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:data ],
        [ sh:datatype xsd:string ;
            sh:description "The web resource type as defined by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:type ] ;
    sh:targetClass ocsf:WebResource .

ocsf:AiModel a sh:NodeShape ;
    rdfs:comment """The AI Model object describes the characteristics of an AI/ML model. Examples
include language models like GPT-4, embedding models like
text-embedding-ada-002, and computer vision models like CLIP.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """AI service provider or organization name. For example: <code>OpenAI</code>,
<code>Anthropic</code>, <code>Google</code>, or <code>Internal</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:ai_provider ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the AI model." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description """Model version identifier. For example: <code>2024-05-13</code>,
<code>v2.1.0</code>, or <code>beta</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:version ],
        [ sh:datatype xsd:string ;
            sh:description """Human-readable model name. For example: <code>gpt-4o</code>,
<code>claude-3-sonnet</code>, or <code>text-embedding-ada-002</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:name ] ;
    sh:targetClass ocsf:AiModel .

ocsf:AutonomousSystem a sh:NodeShape ;
    rdfs:comment """An autonomous system (AS) is a collection of connected Internet Protocol (IP)
routing prefixes under the control of one or more network operators on behalf
of a single administrative entity or domain that presents a common, clearly
defined routing policy to the internet.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "Unique number that the AS is identified by." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:number ],
        [ sh:datatype xsd:string ;
            sh:description "Organization name for the Autonomous System." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:name ] ;
    sh:targetClass ocsf:AutonomousSystem .

ocsf:Certificate a sh:NodeShape ;
    rdfs:comment """The Digital Certificate, also known as a Public Key Certificate, object
contains information about the ownership and usage of a public key. It serves
as a means to establish trust in the authenticity and integrity of the public
key and the associated entity.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:San ;
            sh:description """The list of subject alternative names that are secured by a specific
certificate.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:sans ],
        [ sh:datatype xsd:string ;
            sh:description "The certificate issuer distinguished name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:issuer ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the certificate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description "The certificate subject distinguished name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:subject ],
        [ sh:datatype xsd:string ;
            sh:description "The certificate version." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:version ],
        [ sh:datatype xsd:boolean ;
            sh:description """Denotes whether a digital certificate is self-signed or signed by a known
certificate authority (CA).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:is_self_signed ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the certificate was created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:created_time ],
        [ sh:datatype xsd:string ;
            sh:description "The serial number of the certificate used to create the digital signature." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:serial_number ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The fingerprint list of the certificate." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:fingerprints ],
        [ sh:datatype xsd:long ;
            sh:description "The expiration time of the certificate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:expiration_time ] ;
    sh:targetClass ocsf:Certificate .

ocsf:Cwe a sh:NodeShape ;
    rdfs:comment """The CWE object represents a weakness in a software system that can be exploited
by a threat actor to perform an attack. The CWE object is based on the <a
target='_blank' href='https://cwe.mitre.org/'>Common Weakness Enumeration
(CWE)</a> catalog.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The Common Weakness Enumeration unique number assigned to a specific weakness.
A CWE Identifier begins "CWE" followed by a sequence of digits that acts as a
unique identifier. For example: <code>CWE-123</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:anyURI ;
            sh:description """URL pointing to the CWE Specification. For more information see <a
target='_blank' href='https://cwe.mitre.org/'>CWE.</a>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:src_url ],
        [ sh:datatype xsd:string ;
            sh:description "The caption assigned to the Common Weakness Enumeration unique identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:caption ] ;
    sh:targetClass ocsf:Cwe .

ocsf:EnvironmentVariable a sh:NodeShape ;
    rdfs:comment "An environment variable." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The value of the environment variable." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:value ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the environment variable." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:name ] ;
    sh:targetClass ocsf:EnvironmentVariable .

ocsf:Graph a sh:NodeShape ;
    rdfs:comment "A graph data structure representation with nodes and edges." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The graph name - a human readable identifier for the graph." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description """The graph description - provides additional details about the graph's purpose
and contents.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:desc ],
        [ sh:class ocsf:Edge ;
            sh:description """The edges/connections between nodes in the graph - contains the collection of
<code>edge</code> objects defining relationships between nodes.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:edges ],
        [ sh:datatype xsd:string ;
            sh:description "Unique identifier of the graph - a unique ID to reference this specific graph." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates if the graph is directed (<code>true</code>) or undirected
(<code>false</code>).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:is_directed ],
        [ sh:datatype xsd:string ;
            sh:description """The graph type. Typically useful to represent the specific type of graph that
is used.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:type ],
        [ sh:description """The normalized identifier of a graph query language that can be used to
interact with the graph.""" ;
            sh:in ( "CYPHER" "GRAPHQL" "GREMLIN" "GQL" "G_CORE" "PGQL" "SPARQL" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path ocsf:query_language_id ],
        [ sh:datatype xsd:string ;
            sh:description """The graph query language, normalized to the caption of the
<code>query_language_id</code> value.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:query_language ],
        [ sh:class ocsf:Node ;
            sh:description """The nodes/vertices of the graph - contains the collection of <code>node</code>
objects that make up the graph.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:nodes ] ;
    sh:targetClass ocsf:Graph .

ocsf:Kernel a sh:NodeShape ;
    rdfs:comment """The Kernel Resource object provides information about a specific kernel
resource, including its name and type. It describes essential attributes
associated with a resource managed by the kernel of an operating system.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The system call that was invoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:system_call ],
        [ sh:description "The type of the kernel resource." ;
            sh:in ( "SHARED_MUTEX" "SYSTEM_CALL" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:boolean ;
            sh:description "The indication of whether the object is part of the operating system." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:is_system ],
        [ sh:datatype xsd:string ;
            sh:description "The type of the kernel resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the kernel resource." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The full path of the kernel resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:path ] ;
    sh:targetClass ocsf:Kernel .

ocsf:KillChainPhase a sh:NodeShape ;
    rdfs:comment """The Kill Chain Phase object represents a single phase of a cyber attack,
including the initial reconnaissance and planning stages up to the final
objective of the attacker. It provides a detailed description of each phase and
its associated activities within the broader context of a cyber attack. See <a
target='_blank'
href='https://www.lockheedmartin.com/en-us/capabilities/cyber/cyber-kill-chain.html'>Cyber
Kill Chain®</a>.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The cyber kill chain phase." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:phase ],
        [ sh:description "The cyber kill chain phase identifier." ;
            sh:in ( "UNKNOWN" "RECONNAISSANCE" "WEAPONIZATION" "DELIVERY" "EXPLOITATION" "INSTALLATION" "COMMAND_CONTROL" "ACTIONS_ON_OBJECTIVES" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path ocsf:phase_id ] ;
    sh:targetClass ocsf:KillChainPhase .

ocsf:MessageContext a sh:NodeShape ;
    rdfs:comment """Communication context for AI system interactions including protocols, roles,
clients, and session information for MCP and other AI communication systems.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Service ;
            sh:description """The server or service handling the request. In AI systems, this represents the
AI service, API endpoint, or agent that processes and responds to requests
(e.g., OpenAI API service, Claude API service, internal AI model service).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:service ],
        [ sh:class ocsf:ApplicationObject ;
            sh:description """The initiating client application. In AI systems, this represents the
client-side application or framework that initiates requests (e.g., LangChain
application, web browser, mobile app, SDK implementation).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:application ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of the <code>ai_role_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:ai_role ],
        [ sh:datatype xsd:integer ;
            sh:description "Total number of tokens used for this message (prompt + completion)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:total_tokens ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier of the message context. This could be a session ID,
conversation ID, or other unique identifier that allows correlation of messages
within the same context.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description """The name or identifier of the message context. In AI systems, this could be the
conversation ID, session name, thread identifier, or interaction name (e.g.,
'user-session-123', 'conversation-abc', 'chat-thread-456').""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:name ],
        [ sh:description """Specifies the functional role of the AI within the context of this message,
such as retrieving information, assisting reasoning, executing a tool, or
generating content.""" ;
            sh:in ( "UNKNOWN" "USER" "ASSISTANT" "TOOL" "AGENT" "ORCHESTRATOR" "RETRIEVER" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path ocsf:ai_role_id ],
        [ sh:datatype xsd:integer ;
            sh:description "Number of tokens in the input prompt for this message." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:prompt_tokens ],
        [ sh:datatype xsd:integer ;
            sh:description "Number of tokens in the model's response/completion for this message." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:completion_tokens ] ;
    sh:targetClass ocsf:MessageContext .

ocsf:PeripheralDevice a sh:NodeShape ;
    rdfs:comment """The peripheral device object describes the properties of external, connectable,
and detachable hardware.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The peripheral device model." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:model ],
        [ sh:description "The normalized peripheral device type ID." ;
            sh:in ( "UNKNOWN" "EXTERNAL_STORAGE" "KEYBOARD" "MOUSE" "PRINTER" "MONITOR" "MICROPHONE" "WEBCAM" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:string ;
            sh:description "The peripheral device serial number." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:serial_number ],
        [ sh:datatype xsd:string ;
            sh:description """The Peripheral Device type, normalized to the caption of the
<code>type_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description "The list of vendor IDs for the peripheral device." ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:vendor_id_list ],
        [ sh:datatype xsd:string ;
            sh:description "The primary vendor name for the peripheral device." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:vendor_name ],
        [ sh:datatype xsd:string ;
            sh:description "The class of the peripheral device." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:class_ ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the peripheral device." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the peripheral device." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:uid ] ;
    sh:targetClass ocsf:PeripheralDevice .

ocsf:Script a sh:NodeShape ;
    rdfs:comment """The Script object describes a script or command that can be executed by a
shell, script engine, or interpreter. Examples include Bash, JavsScript,
PowerShell, Python, VBScript, etc. Note that the term <em>script</em> here
denotes not only a script contained within a file but also a script or command
typed interactively by a user, supplied on the command line, or provided by
some other file-less mechanism.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """Unique identifier for the script or macro, independent of the containing file,
used for tracking, auditing, and security analysis.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:name ],
        [ sh:class ocsf:File ;
            sh:description """Present if this script is associated with a file. Not present in the case of a
file-less script.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:file ],
        [ sh:class ocsf:Fingerprint ;
            sh:description """An array of the script's cryptographic hashes. Note that these hashes are
calculated on the script in its original encoding, and not on the normalized
UTF-8 encoding found in the <code>script_content</code> attribute.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:hashes ],
        [ sh:datatype xsd:string ;
            sh:description """Some script engines assign a unique ID to each individual execution of a given
script. This attribute captures that unique ID. In the case of PowerShell, the
unique ID corresponds to the <code>ScriptBlockId</code> in the raw ETW events
provided by the OS.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description """The script type, normalized to the caption of the <code>type_id</code> value.
In the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:type ],
        [ sh:class ocsf:LongString ;
            sh:description """The script content, normalized to UTF-8 encoding irrespective of its original
encoding. When emitting this attribute, it may be appropriate to truncate large
scripts. When consuming this attribute, large scripts should be anticipated.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:script_content ],
        [ sh:description "The normalized script type ID." ;
            sh:in ( "UNKNOWN" "WINDOWS_COMMAND_PROMPT" "POWERSHELL" "PYTHON" "JAVASCRIPT" "VBSCRIPT" "UNIX_SHELL" "VBA" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 6 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:string ;
            sh:description """This attribute relates a sub-script to a parent script having the matching
<code>uid</code> attribute. In the case of PowerShell, sub-script execution can
be identified by matching the activity correlation ID of the raw ETW events
provided by the OS.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:parent_uid ] ;
    sh:targetClass ocsf:Script .

ocsf:WinService a sh:NodeShape ;
    rdfs:comment "The Windows Service object describes a Windows service." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The full command line used to launch the service." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:cmd_line ],
        [ sh:description "The normalized identifier of the service start type." ;
            sh:in ( "UNKNOWN" "BOOT" "SYSTEM" "AUTO" "DEMAND" "DISABLED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 13 ;
            sh:path ocsf:service_start_type_id ],
        [ sh:datatype xsd:string ;
            sh:description "The names of other services upon which this service has a dependency." ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:service_dependencies ],
        [ sh:datatype xsd:string ;
            sh:description """The service type, normalized to the caption of the service_type_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:service_type ],
        [ sh:datatype xsd:string ;
            sh:description """The service category, normalized to the caption of the service_category_id
value. In the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:service_category ],
        [ sh:datatype xsd:string ;
            sh:description """The service start type, normalized to the caption of the
<code>service_start_type_id</code> value. In the case of 'Other', it is defined
by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:service_start_type ],
        [ sh:datatype xsd:string ;
            sh:description """The service error control, normalized to the caption of the
<code>service_error_control_id</code> value. In the case of 'Other', it is
defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:service_error_control ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the load ordering group of which this service is a member." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:load_order_group ],
        [ sh:class ocsf:KeyValueObject ;
            sh:description "The list of tags; <code>{key:value}</code> pairs associated to the service." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path ocsf:tags ],
        [ sh:datatype xsd:string ;
            sh:description "The unique name of the service." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description """For a user mode service, this attribute represents the name of the account
under which the service is run. For a kernel mode driver, this attribute
represents the object name used to load the driver.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:service_start_name ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the service." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:version ],
        [ sh:description "The normalized identifier of the service type." ;
            sh:in ( "UNKNOWN" "KERNEL_DRIVER" "FILE_SYSTEM_DRIVER" "OWN_PROCESS" "SHARE_PROCESS" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 15 ;
            sh:path ocsf:service_type_id ],
        [ sh:description "The normalized identifier of the service category." ;
            sh:in ( "UNKNOWN" "KERNEL_MODE" "USER_MODE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path ocsf:service_category_id ],
        [ sh:datatype xsd:string ;
            sh:description "The list of labels associated with the service." ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:labels ],
        [ sh:class ocsf:ProcessEntity ;
            sh:description "The process that is hosting this service." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:hosting_process ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the service." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:uid ],
        [ sh:description "The normalized identifier of the service error control." ;
            sh:in ( "UNKNOWN" "IGNORE" "NORMAL" "SEVERE" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 9 ;
            sh:path ocsf:service_error_control_id ],
        [ sh:class ocsf:File ;
            sh:description """For a user mode service (<code>service_type_id</code> 3 or 4) this is the
executable program that the SCM launches as the service process.<br>For a
kernel mode driver (<code>service_type_id</code> 1 or 2) this is the driver
file loaded into the kernel at the request of the SCM.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path ocsf:service_file ],
        [ sh:class ocsf:File ;
            sh:description """For a shared user mode service (<code>service_type_id</code> is 4) this is the
DLL that gets loaded by the generic service host process (e.g.
<code>svchost.exe</code>) to implement the service.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:service_dll_file ] ;
    sh:targetClass ocsf:WinService .

ocsf:Analytic a sh:NodeShape ;
    rdfs:comment """The Analytic object contains details about the analytic technique used to
analyze and derive insights from the data or information that led to the
creation of a finding or conclusion.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The name of the analytic that generated the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The Analytic state." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:state ],
        [ sh:datatype xsd:string ;
            sh:description "The analytic version. For example: <code>1.1</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:version ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the analytic that generated the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:desc ],
        [ sh:datatype xsd:string ;
            sh:description "The algorithm used by the underlying analytic to generate the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:algorithm ],
        [ sh:datatype xsd:string ;
            sh:description "The analytic type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:type ],
        [ sh:class ocsf:Analytic ;
            sh:description "Other analytics related to this analytic." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:related_analytics ],
        [ sh:description "The analytic type ID." ;
            sh:in ( "UNKNOWN" "RULE" "BEHAVIORAL" "STATISTICAL" "LEARNING_ML_DL" "FINGERPRINTING" "TAGGING" "KEYWORD_MATCH" "REGULAR_EXPRESSIONS" "EXACT_DATA_MATCH" "PARTIAL_DATA_MATCH" "INDEXED_DATA_MATCH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 8 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:string ;
            sh:description "The analytic category." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:category ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the analytic that generated the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:uid ],
        [ sh:description "The Analytic state identifier." ;
            sh:in ( "ACTIVE" "SUPPRESSED" "EXPERIMENTAL" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path ocsf:state_id ] ;
    sh:targetClass ocsf:Analytic .

ocsf:D3fend a sh:NodeShape ;
    rdfs:comment """The MITRE D3FEND™ object describes the tactic & technique associated with a
countermeasure.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:D3fTactic ;
            sh:description """The Tactic object describes the tactic ID and/or name that is associated with a
countermeasure.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:d3f_tactic ],
        [ sh:class ocsf:D3fTechnique ;
            sh:description """The Technique object describes the technique ID and/or name associated with a
countermeasure.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:d3f_technique ],
        [ sh:datatype xsd:string ;
            sh:description "The D3FEND™ Matrix version." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:version ] ;
    sh:targetClass ocsf:D3fend .

ocsf:Database a sh:NodeShape ;
    rdfs:comment """The database object is used for databases which are typically datastore
services that contain an organized collection of structured and unstructured
data or a types of data.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the database." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the database was known to have been created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:created_time ],
        [ sh:datatype xsd:string ;
            sh:description "The database type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description "The database name, ordinarily as assigned by a database administrator." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:name ],
        [ sh:description "The normalized identifier of the database type." ;
            sh:in ( "UNKNOWN" "RELATIONAL" "NETWORK" "OBJECT_ORIENTED" "CENTRALIZED" "OPERATIONAL" "NOSQL" "VECTOR" "KNOWLEDGE_GRAPH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 8 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the database in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:size ],
        [ sh:class ocsf:DataClassification ;
            sh:description """A list of Data Classification objects, that include information about data
classification levels and data category types, identified by a classifier.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:data_classifications ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the database." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:desc ],
        [ sh:class ocsf:Group ;
            sh:description "The group names to which the database belongs." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:groups ],
        [ sh:datatype xsd:string ;
            sh:description """Model used for creating embeddings (if applicable). For example:
<code>text-embedding-ada-002</code> or <code>all-MiniLM-L6-v2</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:embedding_model ],
        [ sh:datatype xsd:long ;
            sh:description """The most recent time when any changes, updates, or modifications were made
within the database.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:modified_time ],
        [ sh:class ocsf:DataClassification ;
            sh:description """The Data Classification object includes information about data classification
levels and data category types.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path ocsf:data_classification ] ;
    sh:targetClass ocsf:Database .

ocsf:Databucket a sh:NodeShape ;
    rdfs:comment """The databucket object is a basic container that holds data, typically organized
through the use of data partitions.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Group ;
            sh:description "The name of the related resource group." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:group ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the databucket." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description "The databucket name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:name ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 29 ;
            sh:path ocsf:cloud ],
        [ sh:datatype xsd:string ;
            sh:description "The databucket type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description """The logical grouping or isolated segment within a cloud provider's
infrastructure where the databucket is located.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:cloud_partition ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates if the databucket is publicly accessible." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:is_public ],
        [ sh:datatype xsd:long ;
            sh:description """The most recent time when any changes, updates, or modifications were made
within the databucket.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:modified_time ],
        [ sh:class ocsf:EncryptionDetails ;
            sh:description """The encryption details of the databucket. Should be populated if the databucket
is encrypted.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:encryption_details ],
        [ sh:datatype xsd:string ;
            sh:description """The namespace is useful when similar entities exist that you need to keep
separate.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:namespace ],
        [ sh:datatype xsd:string ;
            sh:description "The cloud region of the databucket." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:region ],
        [ sh:datatype xsd:string ;
            sh:description "The list of labels associated to the resource." ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path ocsf:labels ],
        [ sh:class ocsf:KeyValueObject ;
            sh:description "The list of tags; <code>{key:value}</code> pairs associated to the resource." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path ocsf:tags ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates whether the device or resource has a backup enabled, such as an
automated snapshot or a cloud backup. For example, this is indicated by the
<code>cloudBackupEnabled</code> value within JAMF Pro mobile devices or the
registration of an AWS ARN with the AWS Backup service.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:is_backed_up ],
        [ sh:class ocsf:DataClassification ;
            sh:description """The Data Classification object includes information about data classification
levels and data category types.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 26 ;
            sh:path ocsf:data_classification ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the databucket was known to have been created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:created_time ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the databucket in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:size ],
        [ sh:description "The normalized identifier of the databucket type." ;
            sh:in ( "UNKNOWN" "S3" "AZURE_BLOB" "GCP_BUCKET" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 22 ;
            sh:path ocsf:type_id ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 28 ;
            sh:path ocsf:api ],
        [ sh:datatype xsd:string ;
            sh:description "The criticality of the databucket as defined by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:criticality ],
        [ sh:datatype xsd:string ;
            sh:description "Additional data describing the resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:data ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the resource. For example <code>1.2.3</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:version ],
        [ sh:datatype xsd:string ;
            sh:description "The alternative unique identifier of the resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:uid_alt ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates if the databucket is encrypted." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:is_encrypted ],
        [ sh:class ocsf:DataClassification ;
            sh:description """A list of Data Classification objects, that include information about data
classification levels and data category types, identified by a classifier.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 27 ;
            sh:path ocsf:data_classifications ],
        [ sh:datatype xsd:string ;
            sh:description """The specific availability zone within a cloud region where the databucket is
located.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:zone ],
        [ sh:datatype xsd:string ;
            sh:description "The IP address of the resource, in either IPv4 or IPv6 format." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:ip ;
            sh:pattern "^((\\d{1,3}\\.){3}\\d{1,3}|[0-9a-fA-F:]{2,39})$" ],
        [ sh:class ocsf:Graph ;
            sh:description """A graph representation showing how this databucket relates to and interacts
with other entities in the environment. This can include parent/child
relationships, dependencies, or other connections.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path ocsf:resource_relationship ],
        [ sh:class ocsf:File ;
            sh:description "Details about the file/object within a databucket." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:file ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the databucket." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:desc ],
        [ sh:class ocsf:Group ;
            sh:description "The group names to which the databucket belongs." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:groups ],
        [ sh:class ocsf:User ;
            sh:description "The identity of the service or user account that owns the databucket." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path ocsf:owner ],
        [ sh:datatype xsd:string ;
            sh:description "The fully qualified hostname of the databucket." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:hostname ],
        [ sh:class ocsf:Agent ;
            sh:description """A list of <code>agent</code> objects associated with a device, endpoint, or
resource.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:agent_list ] ;
    sh:targetClass ocsf:Databucket .

ocsf:DeviceHwInfo a sh:NodeShape ;
    rdfs:comment """The Device Hardware Information object contains details and specifications of
the physical components that make up a device. This information provides an
overview of the hardware capabilities, configuration, and characteristics of
the device.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The BIOS version. For example: <code>LENOVO G5ETA2WW (2.62)</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:bios_ver ],
        [ sh:datatype xsd:integer ;
            sh:description """The cpu architecture, the number of bits used for addressing in memory. For
example: <code>32</code> or <code>64</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:cpu_bits ],
        [ sh:datatype xsd:string ;
            sh:description "The device manufacturer serial number." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:serial_number ],
        [ sh:description "The normalized identifier of the CPU architecture." ;
            sh:in ( "UNKNOWN" "X86" "ARM" "RISC_V" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path ocsf:cpu_architecture_id ],
        [ sh:class ocsf:GpuInfo ;
            sh:description """A list of GPU objects describing the hardware properties of each graphics
processor installed on the device.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:gpu_info_list ],
        [ sh:datatype xsd:string ;
            sh:description "The device manufacturer." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:vendor_name ],
        [ sh:datatype xsd:string ;
            sh:description "The BIOS manufacturer. For example: <code>LENOVO</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:bios_manufacturer ],
        [ sh:datatype xsd:string ;
            sh:description """The CPU architecture, normalized to the caption of the
<code>cpu_architecture_id</code> value. In the case of <code>Other</code>, it
is defined by the source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:cpu_architecture ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of processor cores in all installed processors. For Example:
<code>42</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:cpu_cores ],
        [ sh:class ocsf:KeyboardInfo ;
            sh:description "The keyboard detailed information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ocsf:keyboard_info ],
        [ sh:datatype xsd:integer ;
            sh:description "The number of physical processors on a system. For example: <code>1</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:cpu_count ],
        [ sh:class ocsf:Display ;
            sh:description "The desktop display affiliated with the event" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:desktop_display ],
        [ sh:datatype xsd:string ;
            sh:description "The processor type. For example: <code>x86 Family 6 Model 37 Stepping 5</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:cpu_type ],
        [ sh:datatype xsd:integer ;
            sh:description "The speed of the processor in Mhz. For Example: <code>4200</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:cpu_speed ],
        [ sh:datatype xsd:string ;
            sh:description "The BIOS date. For example: <code>03/31/16</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:bios_date ],
        [ sh:datatype xsd:string ;
            sh:description """The device manufacturer assigned universally unique hardware identifier. For
SMBIOS compatible devices such as those running Linux and Windows, it is the
UUID member of the System Information structure in the SMBIOS information. For
macOS devices, it is the Hardware UUID (also known as IOPlatformUUID in the I/O
Registry).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:uuid ;
            sh:pattern "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:integer ;
            sh:description "The number of GPU's on a system. For example: <code>1</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:gpu_count ],
        [ sh:datatype xsd:string ;
            sh:description """The chassis type describes the system enclosure or physical form factor. Such
as the following examples for Windows <a target='_blank'
href='https://docs.microsoft.com/en-us/windows/win32/cimwin32prov/win32-systemenclosure'>Windows
Chassis Types</a>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:chassis ],
        [ sh:datatype xsd:integer ;
            sh:description """The total amount of installed RAM, in Megabytes. For example:
<code>2048</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:ram_size ] ;
    sh:targetClass ocsf:DeviceHwInfo .

ocsf:Email a sh:NodeShape ;
    rdfs:comment """The Email object describes the email metadata such as sender, recipients, and
direction, and can include embedded URLs and files.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:DataClassification ;
            sh:description """The Data Classification object includes information about data classification
levels and data category types.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 28 ;
            sh:path ocsf:data_classification ],
        [ sh:datatype xsd:integer ;
            sh:description "The size in bytes of the email, including attachments." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:size ],
        [ sh:class ocsf:Url ;
            sh:description "The URLs embedded in the email." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 26 ;
            sh:path ocsf:urls ],
        [ sh:class ocsf:DataClassification ;
            sh:description """A list of Data Classification objects, that include information about data
classification levels and data category types, identified by a classifier.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 29 ;
            sh:path ocsf:data_classifications ],
        [ sh:datatype xsd:boolean ;
            sh:description "The indication of whether the email has been read." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:is_read ],
        [ sh:datatype xsd:string ;
            sh:description "The email header Message-ID value, as defined by RFC 5322." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:message_uid ],
        [ sh:class ocsf:File ;
            sh:description "The files embedded or attached to the email." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:files ],
        [ sh:datatype xsd:string ;
            sh:description """The machine-readable email header From values. This array should contain the
value in <code>from</code>. For example
<code>example.user@usersdomain.com</code>.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:from_list ;
            sh:pattern "^[\\w.+\\-]+@[\\w\\-]+(\\.[\\w\\-]+)+$" ],
        [ sh:datatype xsd:string ;
            sh:description """The machine-readable email header Reply-To values, as defined by RFC 5322. For
example <code>example.user@usersdomain.com</code>""" ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:reply_to_list ;
            sh:pattern "^[\\w.+\\-]+@[\\w\\-]+(\\.[\\w\\-]+)+$" ],
        [ sh:datatype xsd:string ;
            sh:description """The human-readable email header To Mailbox values. For example <code>'Example
User &lt;example.user@usersdomain.com&gt;'</code>.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:to_mailboxes ],
        [ sh:class ocsf:HttpHeader ;
            sh:description "Additional HTTP headers of an HTTP request or response." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:http_headers ],
        [ sh:datatype xsd:string ;
            sh:description "The value of the SMTP MAIL FROM command." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:smtp_from ;
            sh:pattern "^[\\w.+\\-]+@[\\w\\-]+(\\.[\\w\\-]+)+$" ],
        [ sh:datatype xsd:string ;
            sh:description """The human-readable email header Reply To Mailbox values. For example
<code>'Example User &lt;example.user@usersdomain.com&gt;'</code>.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:reply_to_mailboxes ],
        [ sh:datatype xsd:string ;
            sh:description """The machine-readable <strong>Delivered-To</strong> email header values. For
example <code>example.user@usersdomain.com</code>""" ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:delivered_to_list ;
            sh:pattern "^[\\w.+\\-]+@[\\w\\-]+(\\.[\\w\\-]+)+$" ],
        [ sh:datatype xsd:string ;
            sh:description """The human readable email address of the system or server that actually
transmitted the email message, extracted from the email headers per RFC 5322.
This differs from the <code>from_mailbox</code> field, which shows the message
author. The sender mailbox field is most commonly used when multiple addresses
appear in the <code> from_mailboxes </code> field, or when the transmitting
system is different from the message author (such as when sending on behalf of
someone else).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:sender_mailbox ],
        [ sh:datatype xsd:string ;
            sh:description """The address found in the 'Return-Path' header, which indicates where bounce
messages (non-delivery reports) should be sent. This address is often set by
the sending system and may differ from the 'From' or 'Sender' addresses. For
example, <code>mailer-daemon@senderserver.com</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:return_path ;
            sh:pattern "^[\\w.+\\-]+@[\\w\\-]+(\\.[\\w\\-]+)+$" ],
        [ sh:datatype xsd:string ;
            sh:description """The human-readable email header Cc Mailbox values. For example <code>'Example
User &lt;example.user@usersdomain.com&gt;'</code>.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:cc_mailboxes ],
        [ sh:datatype xsd:string ;
            sh:description """The machine-readable email header To values, as defined by RFC 5322. For
example <code>example.user@usersdomain.com</code>""" ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:to ;
            sh:pattern "^[\\w.+\\-]+@[\\w\\-]+(\\.[\\w\\-]+)+$" ],
        [ sh:datatype xsd:string ;
            sh:description """The machine-readable email header From value, as defined by RFC 5322. For
example <code>example.user@usersdomain.com</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:from_ ;
            sh:pattern "^[\\w.+\\-]+@[\\w\\-]+(\\.[\\w\\-]+)+$" ],
        [ sh:datatype xsd:string ;
            sh:description """The machine-readable <strong>Delivered-To</strong> email header field. For
example <code>example.user@usersdomain.com</code>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:delivered_to ;
            sh:pattern "^[\\w.+\\-]+@[\\w\\-]+(\\.[\\w\\-]+)+$" ],
        [ sh:datatype xsd:string ;
            sh:description "The value of the SMTP envelope RCPT TO command." ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:smtp_to ;
            sh:pattern "^[\\w.+\\-]+@[\\w\\-]+(\\.[\\w\\-]+)+$" ],
        [ sh:datatype xsd:string ;
            sh:description """The machine readable email address of the system or server that actually
transmitted the email message, extracted from the email headers per RFC 5322.
This differs from the <code>from</code> field, which shows the message author.
The sender field is most commonly used when multiple addresses appear in the
<code> from_list </code> field, or when the transmitting system is different
from the message author (such as when sending on behalf of someone else).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:sender ;
            sh:pattern "^[\\w.+\\-]+@[\\w\\-]+(\\.[\\w\\-]+)+$" ],
        [ sh:datatype xsd:string ;
            sh:description "The email header Subject value, as defined by RFC 5322." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:subject ],
        [ sh:datatype xsd:string ;
            sh:description "The X-Originating-IP header identifying the emails originating IP address(es)." ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:x_originating_ip ;
            sh:pattern "^((\\d{1,3}\\.){3}\\d{1,3}|[0-9a-fA-F:]{2,39})$" ],
        [ sh:datatype xsd:string ;
            sh:description """The machine-readable email header Cc values, as defined by RFC 5322. For
example <code>example.user@usersdomain.com</code>.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:cc ;
            sh:pattern "^[\\w.+\\-]+@[\\w\\-]+(\\.[\\w\\-]+)+$" ],
        [ sh:datatype xsd:string ;
            sh:description "The email authentication header." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:raw_header ],
        [ sh:datatype xsd:string ;
            sh:description """The human-readable email header From Mailbox value. For example <code>'Example
User &lt;example.user@usersdomain.com&gt;'</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:from_mailbox ],
        [ sh:datatype xsd:string ;
            sh:description """The human-readable email header From Mailbox values. This array should contain
the value in <code>from_mailbox</code>. For example <code>'Example User
&lt;example.user@usersdomain.com&gt;'</code>.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:from_mailboxes ;
            sh:pattern "^[\\w.+\\-]+@[\\w\\-]+(\\.[\\w\\-]+)+$" ],
        [ sh:datatype xsd:string ;
            sh:description """The machine-readable email header Reply-To value, as defined by RFC 5322. For
example <code>example.user@usersdomain.com</code>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:reply_to ;
            sh:pattern "^[\\w.+\\-]+@[\\w\\-]+(\\.[\\w\\-]+)+$" ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the email thread." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:uid ] ;
    sh:targetClass ocsf:Email .

ocsf:KbArticle a sh:NodeShape ;
    rdfs:comment "The KB Article object contains metadata that describes the patch or update." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The title of the kb article." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:title ],
        [ sh:datatype xsd:long ;
            sh:description "The date the kb article was released by the vendor." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:created_time ],
        [ sh:datatype xsd:anyURI ;
            sh:description "The kb article link from the source vendor." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:src_url ],
        [ sh:datatype xsd:integer ;
            sh:description "The size in bytes for the kb article." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:size ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier for the kb article." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description "The kb article bulletin identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:bulletin ],
        [ sh:datatype xsd:string ;
            sh:description "The severity of the kb article." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:severity ],
        [ sh:class ocsf:Os ;
            sh:description "The operating system the kb article applies." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:os ],
        [ sh:description "The normalized install state ID of the kb article." ;
            sh:in ( "UNKNOWN" "INSTALLED" "NOT_INSTALLED" "INSTALLED_PENDING_REBOOT" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path ocsf:install_state_id ],
        [ sh:datatype xsd:string ;
            sh:description "The vendors classification of the kb article." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:classification ],
        [ sh:class ocsf:Product ;
            sh:description "The product details the kb article applies." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:product ],
        [ sh:datatype xsd:string ;
            sh:description "The install state of the kb article." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:install_state ],
        [ sh:class ocsf:Timespan ;
            sh:description "The average time to patch." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:avg_timespan ],
        [ sh:datatype xsd:boolean ;
            sh:description "The kb article has been replaced by another." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:is_superseded ] ;
    sh:targetClass ocsf:KbArticle .

ocsf:Module a sh:NodeShape ;
    rdfs:comment "The Module object describes the attributes of a module." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The module type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description """The load type, normalized to the caption of the load_type_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:load_type ],
        [ sh:datatype xsd:string ;
            sh:description "The start address of the execution." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:start_address ],
        [ sh:description "The normalized identifier for how the module was loaded in memory." ;
            sh:in ( "STANDARD" "NON_STANDARD" "SHELLCODE" "MAPPED" "NONSTANDARD_BACKED" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path ocsf:load_type_id ],
        [ sh:datatype xsd:string ;
            sh:description "The memory address where the module was loaded." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:base_address ],
        [ sh:datatype xsd:string ;
            sh:description """The invoked function in the module. For load and unload events, this is the
entry-point function of the module. The system calls the entry-point function
whenever a process or thread loads or unloads the module.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:function_name ],
        [ sh:class ocsf:FunctionInvocation ;
            sh:description """Details about the invocation of the function given in
<code>function_name</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:function_invocation ],
        [ sh:class ocsf:File ;
            sh:description "The module file object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:file ] ;
    sh:targetClass ocsf:Module .

ocsf:Organization a sh:NodeShape ;
    rdfs:comment """The Organization object describes characteristics of an organization or company
and its division if any. Additionally, it also describes cloud and
Software-as-a-Service (SaaS) logical hierarchies such as AWS Organizations,
Google Cloud Organizations, Oracle Cloud Tenancies, and similar constructs.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The name of an organizational unit, Google Cloud Folder, or AWS Org Unit. For
example, the <code> GCP Project Name </code>, or <code> Dev_Prod_OU </code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:ou_name ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier of an organizational unit, Google Cloud Folder, or AWS
Org Unit. For example, an  <code> Oracle Cloud Tenancy ID </code>, <code> AWS
OU ID </code>, or <code> GCP Folder ID </code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:ou_uid ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier of the organization, Oracle Cloud Tenancy, Google Cloud
Organization, or AWS Organization. For example, an <code> AWS Org ID </code> or
<code> Oracle Cloud Domain ID </code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description """The name of the organization, Oracle Cloud Tenancy, Google Cloud Organization,
or AWS Organization. For example, <code> Widget, Inc. </code> or the <code> AWS
Organization name </code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:name ] ;
    sh:targetClass ocsf:Organization .

ocsf:ProcessEntity a sh:NodeShape ;
    rdfs:comment "The Process Entity object provides critical fields for referencing a process." ;
    sh:closed true ;
    sh:ignoredProperties ( ocsf:sandbox ocsf:loaded_modules ocsf:file ocsf:integrity ocsf:ancestry ocsf:environment_variables ocsf:session ocsf:namespace_pid ocsf:tid ocsf:group ocsf:auid ocsf:terminated_time ocsf:euid ocsf:parent_process ocsf:user ocsf:hosted_services ocsf:working_directory rdf:type ocsf:lineage ocsf:container ocsf:egid ocsf:integrity_id ocsf:ptid ocsf:xattributes ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The process file path." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:path ],
        [ sh:datatype xsd:string ;
            sh:description """The full command line used to launch an application, service, process, or job.
For example: <code>ssh user@10.0.0.10</code>. If the command line is
unavailable or missing, the empty string <code>''</code> is to be used.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:cmd_line ],
        [ sh:datatype xsd:integer ;
            sh:description """The process identifier, as reported by the operating system. Process ID (PID)
is a number used by the operating system to uniquely identify an active
process.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:pid ],
        [ sh:datatype xsd:string ;
            sh:description """A unique identifier for this process assigned by the producer (tool).
Facilitates correlation of a process event with other events for that process.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description """A unique process identifier that can be assigned deterministically by multiple
system data producers.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:cpid ;
            sh:pattern "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "The friendly name of the process, for example: <code>Notepad++</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the process was created/started." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:created_time ] ;
    sh:targetClass ocsf:ProcessEntity .

ocsf:RegKey a sh:NodeShape ;
    rdfs:comment "The registry key object describes a Windows registry key." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:long ;
            sh:description "The time when the registry key was last modified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:modified_time ],
        [ sh:datatype xsd:string ;
            sh:description "The full path to the registry key." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:path ],
        [ sh:datatype xsd:boolean ;
            sh:description "The indication of whether the object is part of the operating system." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:is_system ],
        [ sh:datatype xsd:string ;
            sh:description "The security descriptor of the registry key." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:security_descriptor ] ;
    sh:targetClass ocsf:RegKey .

ocsf:RegValue a sh:NodeShape ;
    rdfs:comment "The registry value object describes a Windows registry value." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The data of the registry value. Where the value type is known, implementers
should instead use a type-specific attribute, i.e.
<code>reg_binary_data</code>, <code>reg_integer_data</code>,
<code>reg_string_data</code>, or <code>reg_string_list_data</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:data ],
        [ sh:datatype xsd:string ;
            sh:description """The data of the registry value when <code>type_id</code> is
<code>REG_BINARY</code> or <code>REG_NONE</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:reg_binary_data ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the registry value." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description """A string representation of the value type as specified in <a target='_blank'
href='https://learn.microsoft.com/en-us/windows/win32/sysinfo/registry-value-types'>Registry
Value Types</a>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:type ],
        [ sh:description "The value type ID." ;
            sh:in ( "REG_BINARY" "REG_DWORD" "REG_DWORD_BIG_ENDIAN" "REG_EXPAND_SZ" "REG_LINK" "REG_MULTI_SZ" "REG_NONE" "REG_QWORD" "REG_QWORD_LITTLE_ENDIAN" "REG_SZ" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 11 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:boolean ;
            sh:description """The indication of whether the value is from a default value name. For example,
the value name could be missing.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:is_default ],
        [ sh:datatype xsd:string ;
            sh:description """The data of the registry value when <code>type_id</code> is
<code>REG_SZ</code>, <code>REG_EXPAND_SZ</code>, or <code>REG_LINK</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:reg_string_data ],
        [ sh:datatype xsd:integer ;
            sh:description """The data of the registry value when <code>type_id</code> is
<code>REG_DWORD</code>, <code>REG_DWORD_BIG_ENDIAN</code>, or
<code>REG_QWORD</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:reg_integer_data ],
        [ sh:datatype xsd:string ;
            sh:description """The data of the registry value when <code>type_id</code> is
<code>REG_MULTI_SZ</code>.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:reg_string_list_data ],
        [ sh:datatype xsd:string ;
            sh:description "The full path to the registry key, where the value is located." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:path ],
        [ sh:datatype xsd:boolean ;
            sh:description "The indication of whether the object is part of the operating system." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:is_system ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the registry value was last modified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:modified_time ] ;
    sh:targetClass ocsf:RegValue .

ocsf:Scan a sh:NodeShape ;
    rdfs:comment "The Scan object describes characteristics of a proactive scan." ;
    sh:closed true ;
    sh:ignoredProperties ( ocsf:unique_malware_count ocsf:num_files ocsf:start_time ocsf:num_infected rdf:type ocsf:end_time ocsf:num_volumes ocsf:size ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The administrator-supplied or application-generated name of the scan. For
example: "Home office weekly user database scan", "Scan folders for viruses",
"Full system virus scan\"""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The type of scan." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:type ],
        [ sh:description "The type id of the scan." ;
            sh:in ( "UNKNOWN" "MANUAL" "SCHEDULED" "UPDATED_CONTENT" "QUARANTINED_ITEMS" "ATTACHED_MEDIA" "USER_LOGON" "ELAM" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:string ;
            sh:description "The application-defined unique identifier assigned to an instance of a scan." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:uid ] ;
    sh:targetClass ocsf:Scan .

ocsf:Timespan a sh:NodeShape ;
    rdfs:comment """The Time Span object represents different time period durations. If a timespan
is fractional, i.e. crosses one period, e.g. a week and 3 days, more than one
may be populated since each member is of integral type. In that case
<code>type_id</code> if present should be set to <code>Other.</code><P>A
timespan may also be defined by its time interval boundaries,
<code>start_time</code> and <code>end_time</code>.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "The duration of the time span in years." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:duration_years ],
        [ sh:datatype xsd:integer ;
            sh:description "The duration of the time span in hours." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:duration_hours ],
        [ sh:datatype xsd:long ;
            sh:description "The end time or conclusion of the timespan's interval." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:end_time ],
        [ sh:datatype xsd:integer ;
            sh:description "The duration of the time span in minutes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:duration_mins ],
        [ sh:datatype xsd:long ;
            sh:description "The start time or beginning of the timespan's interval." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:start_time ],
        [ sh:datatype xsd:integer ;
            sh:description "The duration of the time span in months." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:duration_months ],
        [ sh:description "The normalized identifier for the time span duration type." ;
            sh:in ( "UNKNOWN" "MILLISECONDS" "SECONDS" "MINUTES" "HOURS" "DAYS" "WEEKS" "MONTHS" "YEARS" "TIME_INTERVAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 11 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:string ;
            sh:description "The type of time span duration the object represents." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:integer ;
            sh:description "The duration of the time span in seconds." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:duration_secs ],
        [ sh:datatype xsd:integer ;
            sh:description "The duration of the time span in milliseconds." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:duration ],
        [ sh:datatype xsd:integer ;
            sh:description "The duration of the time span in days." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:duration_days ],
        [ sh:datatype xsd:integer ;
            sh:description "The duration of the time span in weeks." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:duration_weeks ] ;
    sh:targetClass ocsf:Timespan .

ocsf:Vulnerability a sh:NodeShape ;
    rdfs:comment """The vulnerability is an unintended characteristic of a computing component or
system configuration that multiplies the risk of an adverse event or a loss
occurring either due to accidental exposure, deliberate attack, or conflict
with new system components.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Advisory ;
            sh:description """Detail about the security advisory, that is used to publicly disclose
cybersecurity vulnerabilities by a vendor.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:advisory ],
        [ sh:class ocsf:AffectedPackage ;
            sh:description """List of software packages identified as affected by a
vulnerability/vulnerabilities.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:affected_packages ],
        [ sh:datatype xsd:string ;
            sh:description """The fix coverage, normalized to the caption of the <code>fix_coverage_id</code>
value.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:fix_coverage ],
        [ sh:datatype xsd:string ;
            sh:description "The vendor assigned severity of the vulnerability." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:severity ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates if a fix is available for the reported vulnerability." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:fix_available ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the vendor that identified the vulnerability." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:vendor_name ],
        [ sh:datatype xsd:string ;
            sh:description """The categorization or type of Exploit. E.g., <code>Network</code> or
<code>Physical</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:exploit_type ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the vulnerability was most recently observed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:last_seen_time ],
        [ sh:datatype xsd:anyURI ;
            sh:description "The URL of the exploit code or Proof-of-Concept (PoC)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:exploit_ref_url ],
        [ sh:class ocsf:Cwe ;
            sh:description """Describes the Common Weakness Enumeration <a target='_blank'
href='https://cwe.mitre.org/'>(CWE)</a> details related to the vulnerability.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:cwe ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the vulnerability." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:desc ],
        [ sh:datatype xsd:string ;
            sh:description "A list of reference URLs with additional information about the vulnerability." ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:references ],
        [ sh:class ocsf:Package ;
            sh:description "List of vulnerable packages as identified by the security product" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path ocsf:packages ],
        [ sh:datatype xsd:string ;
            sh:description """The requirement description related to any constraints around exploit
execution.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:exploit_requirement ],
        [ sh:class ocsf:KbArticle ;
            sh:description """A list of KB articles or patches related to an endpoint. A KB Article contains
metadata that describes the patch or an update.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path ocsf:kb_article_list ],
        [ sh:description """The normalized identifier for fix coverage, applicable to this vulnerability.
Typically useful, when there are multiple affected packages but only a subset
have available fixes.""" ;
            sh:in ( "COMPLETE" "PARTIAL" "NONE" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 15 ;
            sh:path ocsf:fix_coverage_id ],
        [ sh:class ocsf:Remediation ;
            sh:description """The remediation recommendations on how to mitigate the identified
vulnerability.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 24 ;
            sh:path ocsf:remediation ],
        [ sh:datatype xsd:string ;
            sh:description """The category of a vulnerability or weakness, as reported by the source tool,
such as <code>Container Security</code> or <code>Open Source Security</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:category ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the exploit was most recently observed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:exploit_last_seen_time ],
        [ sh:datatype xsd:string ;
            sh:description """The KB article/s related to the entity. A KB Article contains metadata that
describes the patch or an update.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:kb_articles ],
        [ sh:datatype xsd:string ;
            sh:description "A title or a brief phrase summarizing the discovered vulnerability." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:title ],
        [ sh:datatype xsd:string ;
            sh:description """Information about the chain of dependencies related to the issue as reported by
an Application Security or Vulnerability Management tool. E.g.,
<code>serverless-offline -> @serverless/utils -> memoizee -> es5-ext</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:dependency_chain ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the vulnerability was first observed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:first_seen_time ],
        [ sh:class ocsf:Cve ;
            sh:description """Describes the Common Vulnerabilities and Exposures <a target='_blank'
href='https://cve.mitre.org/'>(CVE)</a> details related to the vulnerability.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:cve ],
        [ sh:datatype xsd:string ;
            sh:description "List of vulnerability IDs (e.g. CVE ID) that are related to this vulnerability." ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:related_vulnerabilities ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates if a fix is available for the reported vulnerability." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:is_fix_available ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates if an exploit or a PoC (proof-of-concept) is available for the
reported vulnerability.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:is_exploit_available ],
        [ sh:class ocsf:AffectedCode ;
            sh:description """List of Affected Code objects that describe details about code blocks
identified as vulnerable.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:affected_code ] ;
    sh:targetClass ocsf:Vulnerability .

ocsf:Agent a sh:NodeShape ;
    rdfs:comment """An Agent (also known as a Sensor) is typically installed on an Operating System
(OS) and serves as a specialized software component that can be designed to
monitor, detect, collect, archive, or take action. These activities and
possible actions are defined by the upstream system controlling the Agent and
its intended purpose. For instance, an Agent can include Endpoint Detection &
Response (EDR) agents, backup/disaster recovery sensors, Application
Performance Monitoring or profiling sensors, and similar software.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The normalized caption of the type_id value for the agent or sensor. In the
case of 'Other' or 'Unknown', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the agent or sensor. For example: <code>AWS SSM Agent</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description """An alternative or contextual identifier for the agent or sensor, such as a
configuration, organization, or license UID.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:uid_alt ],
        [ sh:description """The normalized representation of an agent or sensor. E.g., EDR, vulnerability
management, APM, backup & recovery, etc.""" ;
            sh:in ( "ENDPOINT_DETECTION_AND_RESPONSE" "DATA_LOSS_PREVENTION" "BACKUP_RECOVERY" "PERFORMANCE_MONITORING_OBSERVABILITY" "VULNERABILITY_MANAGEMENT" "LOG_FORWARDING" "MOBILE_DEVICE_MANAGEMENT" "CONFIGURATION_MANAGEMENT" "REMOTE_ACCESS" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path ocsf:type_id ],
        [ sh:class ocsf:Policy ;
            sh:description """Describes the various policies that may be applied or enforced by an agent or
sensor. E.g., Conditional Access, prevention, auto-update, tamper protection,
destination configuration, etc.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:policies ],
        [ sh:datatype xsd:string ;
            sh:description """The UID of the agent or sensor, sometimes known as a Sensor ID or
<code>aid</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description "The semantic version of the agent or sensor, e.g., <code>7.101.50.0</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:version ],
        [ sh:datatype xsd:string ;
            sh:description """The company or author who created the agent or sensor. For example:
<code>Crowdstrike</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:vendor_name ] ;
    sh:targetClass ocsf:Agent .

ocsf:NetworkInterface a sh:NodeShape ;
    rdfs:comment """The Network Interface object describes the type and associated attributes of a
physical or virtual network interface.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The hostname associated with the network interface." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:hostname ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the network interface." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description """The namespace is useful in merger or acquisition situations. For example, when
similar entities exist that you need to keep separate.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:namespace ],
        [ sh:description "The network interface type identifier." ;
            sh:in ( "UNKNOWN" "WIRED" "WIRELESS" "MOBILE" "TUNNEL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:string ;
            sh:description "The MAC address of the network interface." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:mac ;
            sh:pattern "^([0-9a-fA-F]{2}[:\\-]){5}[0-9a-fA-F]{2}$" ],
        [ sh:datatype xsd:string ;
            sh:description "The IP address associated with the network interface." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:ip ;
            sh:pattern "^((\\d{1,3}\\.){3}\\d{1,3}|[0-9a-fA-F:]{2,39})$" ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier for the network interface." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:uid ],
        [ sh:class ocsf:PortInfo ;
            sh:description """The list of open ports on a network interface, including port numbers and
associated protocol information.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:open_ports ],
        [ sh:datatype xsd:integer ;
            sh:description """The subnet prefix length determines the number of bits used to represent the
network part of the IP address. The remaining bits are reserved for identifying
individual hosts within that subnet.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:subnet_prefix ],
        [ sh:datatype xsd:string ;
            sh:description "The type of network interface." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:type ] ;
    sh:targetClass ocsf:NetworkInterface .

ocsf:Os a sh:NodeShape ;
    rdfs:comment """The Operating System (OS) object describes characteristics of an OS, such as
Linux or Windows.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The type of the operating system." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description """The version of the OS running on the device that originated the event. For
example: "Windows 10", "OS X 10.7", or "iOS 9".""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:version ],
        [ sh:datatype xsd:string ;
            sh:description """The operating system country code, as defined by the ISO 3166-1 standard
(Alpha-2 code).<p><b>Note:</b> The two letter country code should be
capitalized. For example: <code>US</code> or <code>CA</code>.</p>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:country ],
        [ sh:description "The type identifier of the operating system." ;
            sh:in ( "WINDOWS" "WINDOWS_MOBILE" "LINUX" "ANDROID" "MACOS" "IOS" "IPADOS" "SOLARIS" "AIX" "HP_UX" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 11 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:string ;
            sh:description "The operating system name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The operating system edition. For example: <code>Professional</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:edition ],
        [ sh:datatype xsd:string ;
            sh:description """The Common Platform Enumeration (CPE) name as described by (<a target='_blank'
href='https://nvd.nist.gov/products/cpe'>NIST</a>) For example:
<code>cpe:/a:apple:safari:16.2</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:cpe_name ],
        [ sh:datatype xsd:string ;
            sh:description "The operating system build number." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:build ],
        [ sh:datatype xsd:string ;
            sh:description """The two letter lower case language codes, as defined by <a target='_blank'
href='https://en.wikipedia.org/wiki/ISO_639-1'>ISO 639-1</a>. For example:
<code>en</code> (English), <code>de</code> (German), or <code>fr</code>
(French).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:lang ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the latest Service Pack." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:sp_name ],
        [ sh:datatype xsd:integer ;
            sh:description """The cpu architecture, the number of bits used for addressing in memory. For
example: <code>32</code> or <code>64</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:cpu_bits ],
        [ sh:datatype xsd:string ;
            sh:description """The kernel release of the operating system. On Unix-based systems, this is
determined from the <code>uname -r</code> command output, for example
"5.15.0-122-generic".""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:kernel_release ],
        [ sh:datatype xsd:integer ;
            sh:description "The version number of the latest Service Pack." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:sp_ver ] ;
    sh:targetClass ocsf:Os .

ocsf:FindingInfo a sh:NodeShape ;
    rdfs:comment """The Finding Information object describes metadata related to a security finding
generated by a security tool or system.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:KeyValueObject ;
            sh:description "The list of tags; <code>{key:value}</code> pairs associated with the finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path ocsf:tags ],
        [ sh:datatype xsd:string ;
            sh:description "One or more types of the reported finding." ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:types ],
        [ sh:datatype xsd:integer ;
            sh:description "Number of related events or findings." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:related_events_count ],
        [ sh:class ocsf:RelatedEvent ;
            sh:description """Describes events and/or other findings related to the finding as identified by
the security product. Note that these events may or may not be in OCSF.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:related_events ],
        [ sh:datatype xsd:string ;
            sh:description "The alternative unique identifier of the reported finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:uid_alt ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the finding was created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:created_time ],
        [ sh:datatype xsd:anyURI ;
            sh:description "The URL pointing to the source of the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:src_url ],
        [ sh:class ocsf:Graph ;
            sh:description """An Attack Graph describes possible routes an attacker could take through an
environment. It describes relationships between resources and their findings,
such as malware detections, vulnerabilities, misconfigurations, and other
security actions.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:attack_graph ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the finding was last modified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:modified_time ],
        [ sh:datatype xsd:long ;
            sh:description """The time when the finding was first observed. e.g. The time when a
vulnerability was first observed. <p>It can differ from the
<code>created_time</code> timestamp, which reflects the time this finding was
created.</p>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:first_seen_time ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the reported finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description "A title or a brief phrase summarizing the reported finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:title ],
        [ sh:class ocsf:KillChainPhase ;
            sh:description """The <a target='_blank'
href='https://www.lockheedmartin.com/en-us/capabilities/cyber/cyber-kill-chain.html'>Cyber
Kill Chain®</a> provides a detailed description of each phase and its
associated activities within the broader context of a cyber attack.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:kill_chain ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the product that reported the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:product_uid ],
        [ sh:class ocsf:Product ;
            sh:description "Details about the product that reported the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path ocsf:product ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the reported finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:desc ],
        [ sh:datatype xsd:string ;
            sh:description "A list of data sources utilized in generation of the finding." ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:data_sources ],
        [ sh:datatype xsd:long ;
            sh:description """The time when the finding was most recently observed. e.g. The time when a
vulnerability was most recently observed. <p>It can differ from the
<code>modified_time</code> timestamp, which reflects the time this finding was
last modified.</p>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:last_seen_time ],
        [ sh:class ocsf:Attack ;
            sh:description """The <a target='_blank' href='https://attack.mitre.org'>MITRE ATT&CK®</a>
technique and associated tactics related to the finding.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:attacks ],
        [ sh:class ocsf:Analytic ;
            sh:description """The analytic technique used to analyze and derive insights from the data or
information that led to the finding or conclusion.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:analytic ],
        [ sh:class ocsf:Analytic ;
            sh:description "Other analytics related to this finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:related_analytics ],
        [ sh:class ocsf:Trait ;
            sh:description "The list of key traits or characteristics extracted from the finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path ocsf:traits ] ;
    sh:targetClass ocsf:FindingInfo .

ocsf:Job a sh:NodeShape ;
    rdfs:comment """The Job object provides information about a scheduled job or task, including
its name, command line, and state. It encompasses attributes that describe the
properties and status of the scheduled job.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:long ;
            sh:description "The time when the job will next be run." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:next_run_time ],
        [ sh:class ocsf:User ;
            sh:description "The user that created the job." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:user ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the job was created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:created_time ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the job." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:name ],
        [ sh:description "The run state ID of the job." ;
            sh:in ( "UNKNOWN" "READY" "QUEUED" "RUNNING" "STOPPED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path ocsf:run_state_id ],
        [ sh:datatype xsd:string ;
            sh:description "The run state of the job." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:run_state ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the job was last run." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:last_run_time ],
        [ sh:datatype xsd:string ;
            sh:description "The job command line." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:cmd_line ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the job." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:desc ],
        [ sh:class ocsf:File ;
            sh:description "The file that pertains to the job." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:file ] ;
    sh:targetClass ocsf:Job .

ocsf:Service a sh:NodeShape ;
    rdfs:comment """The Service object describes characteristics of a service, <code> e.g. AWS EC2.
</code>""" ;
    sh:closed true ;
    sh:ignoredProperties ( ocsf:service_start_type ocsf:service_type_id ocsf:service_error_control_id ocsf:service_error_control ocsf:service_category ocsf:hosting_process ocsf:load_order_group ocsf:service_file ocsf:service_dependencies ocsf:service_type ocsf:service_dll_file rdf:type ocsf:service_start_name ocsf:cmd_line ocsf:service_start_type_id ocsf:service_category_id ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the service." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the service." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:version ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the service." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:name ],
        [ sh:class ocsf:KeyValueObject ;
            sh:description "The list of tags; <code>{key:value}</code> pairs associated to the service." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:tags ],
        [ sh:datatype xsd:string ;
            sh:description "The list of labels associated with the service." ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:labels ] ;
    sh:targetClass ocsf:Service .

ocsf:Url a sh:NodeShape ;
    rdfs:comment """The Uniform Resource Locator (URL) object describes the characteristics of a
URL.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The URL host as extracted from the URL. For example:
<code>www.example.com</code> from
<code>www.example.com/download/trouble</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:hostname ],
        [ sh:datatype xsd:string ;
            sh:description """The subdomain portion of the URL. For example: <code>sub</code> in
<code>https://sub.example.com</code> or <code>sub2.sub1</code> in
<code>https://sub2.sub1.example.com</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:subdomain ],
        [ sh:datatype xsd:string ;
            sh:description """The domain portion of the URL. For example: <code>example.com</code> in
<code>https://sub.example.com</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:domain ],
        [ sh:datatype xsd:string ;
            sh:description "The context in which a resource was retrieved in a web request." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:resource_type ],
        [ sh:datatype xsd:integer ;
            sh:description "The URL port. For example: <code>80</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:port ],
        [ sh:datatype xsd:string ;
            sh:description """The query portion of the URL. For example: the query portion of the URL
<code>http://www.example.com/search?q=bad&sort=date</code> is
<code>q=bad&sort=date</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:query_string ],
        [ sh:datatype xsd:string ;
            sh:description """The Website categorization names, as defined by <code>category_ids</code> enum
values.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:categories ],
        [ sh:datatype xsd:string ;
            sh:description """The scheme portion of the URL. For example: <code>http</code>,
<code>https</code>, <code>ftp</code>, or <code>sftp</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:scheme ],
        [ sh:description "The Website categorization identifiers." ;
            sh:in ( "UNKNOWN" "ADULT_MATURE_CONTENT" "PORNOGRAPHY" "SEX_EDUCATION" "INTIMATE_APPAREL_SWIMSUIT" "NUDITY" "EXTREME" "SCAM_QUESTIONABLE_ILLEGAL" "GAMBLING" "VIOLENCE_HATE_RACISM" "WEAPONS" "ABORTION" "HACKING" "PHISHING" "ENTERTAINMENT" "BUSINESS_ECONOMY" "ALTERNATIVE_SPIRITUALITY_BELIEF" "ALCOHOL" "TOBACCO" "CONTROLLED_SUBSTANCES" "CHILD_PORNOGRAPHY" "EDUCATION" "CHARITABLE_ORGANIZATIONS" "ART_CULTURE" "FINANCIAL_SERVICES" "BROKERAGE_TRADING" "GAMES" "GOVERNMENT_LEGAL" "MILITARY" "POLITICAL_SOCIAL_ADVOCACY" "HEALTH" "TECHNOLOGY_INTERNET" "SEARCH_ENGINES_PORTALS" "MALICIOUS_SOURCES_MALNETS" "MALICIOUS_OUTBOUND_DATA_BOTNETS" "JOB_SEARCH_CAREERS" "NEWS_MEDIA" "PERSONALS_DATING" "REFERENCE" "MIXED_CONTENT_POTENTIALLY_ADULT" "CHAT_IM_SMS" "EMAIL" "NEWSGROUPS_FORUMS" "RELIGION" "SOCIAL_NETWORKING" "FILE_STORAGE_SHARING" "REMOTE_ACCESS_TOOLS" "SHOPPING" "AUCTIONS" "REAL_ESTATE" "SOCIETY_DAILY_LIVING" "PERSONAL_SITES" "RESTAURANTS_DINING_FOOD" "SPORTS_RECREATION" "TRAVEL" "VEHICLES" "HUMOR_JOKES" "SOFTWARE_DOWNLOADS" "PEER_TO_PEER_P2P" "AUDIO_VIDEO_CLIPS" "OFFICE_BUSINESS_APPLICATIONS" "PROXY_AVOIDANCE" "FOR_KIDS" "WEB_ADS_ANALYTICS" "WEB_HOSTING" "UNCATEGORIZED" "SUSPICIOUS" "SEXUAL_EXPRESSION" "TRANSLATION" "NON_VIEWABLE_INFRASTRUCTURE" "CONTENT_SERVERS" "PLACEHOLDERS" "OTHER" "SPAM" "POTENTIALLY_UNWANTED_SOFTWARE" "DYNAMIC_DNS_HOST" "E_CARD_INVITATIONS" "INFORMATIONAL" "COMPUTER_INFORMATION_SECURITY" "INTERNET_CONNECTED_DEVICES" "INTERNET_TELEPHONY" "ONLINE_MEETINGS" "MEDIA_SHARING" "RADIO_AUDIO_STREAMS" "TV_VIDEO_STREAMS" "PIRACY_COPYRIGHT_CONCERNS" "MARIJUANA" ) ;
            sh:order 1 ;
            sh:path ocsf:category_ids ],
        [ sh:datatype xsd:anyURI ;
            sh:description """The URL string. See RFC 1738. For example:
<code>http://www.example.com/download/trouble.exe</code>. Note: The URL path
should not populate the URL string.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:url_string ],
        [ sh:datatype xsd:string ;
            sh:description """The URL path as extracted from the URL. For example:
<code>/download/trouble</code> from
<code>www.example.com/download/trouble</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:path ] ;
    sh:targetClass ocsf:Url .

ocsf:VendorAttributes a sh:NodeShape ;
    rdfs:comment """The Vendor Attributes object can be used to represent values of attributes
populated by the Vendor/Finding Provider. It can help distinguish between the
vendor-provided values and consumer-updated values, of key attributes like
<code>severity_id</code>.<br>The original finding producer should not populate
this object. It should be populated by consuming systems that support data
mutability.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The finding severity ID, as reported by the Vendor (Finding Provider)." ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:string ;
            sh:description """The finding severity, as reported by the Vendor (Finding Provider). The value
should be normalized to the caption of the <code>severity_id</code> value. In
the case of 'Other', it is defined by the source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:severity ] ;
    sh:targetClass ocsf:VendorAttributes .

ocsf:Location a sh:NodeShape ;
    rdfs:comment """The Geo Location object describes a geographical location, usually associated
with an IP address.""" ;
    sh:closed true ;
    sh:ignoredProperties ( ocsf:altitude_floor ocsf:start_time ocsf:radius ocsf:locations rdf:type ocsf:type_id ocsf:type ocsf:altitude_ceiling ocsf:end_time ocsf:count ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The description of the geographical location." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:desc ],
        [ sh:datatype xsd:string ;
            sh:description "The postal code of the location." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:postal_code ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether the location is on-premises." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:is_on_premises ],
        [ sh:datatype xsd:float ;
            sh:description """A two-element array, containing a longitude/latitude pair. The format conforms
with <a target='_blank' href='https://geojson.org'>GeoJSON</a>. For example:
<code>[-73.983, 40.719]</code>.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:coordinates ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the continent." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:continent ],
        [ sh:datatype xsd:string ;
            sh:description """The alphanumeric code that identifies the principal subdivision (e.g. province
or state) of the country. For example, 'CH-VD' for the Canton of Vaud,
Switzerland""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:region ],
        [ sh:datatype xsd:string ;
            sh:description """<p>Geohash of the geo-coordinates (latitude and longitude).</p><a
target='_blank' href='https://en.wikipedia.org/wiki/Geohash'>Geohashing</a> is
a geocoding system used to encode geographic coordinates in decimal degrees, to
a single string.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:geohash ],
        [ sh:datatype xsd:string ;
            sh:description """Provides quality/containment on geodetic altitude. This is based on ADS-B
Geodetic Vertical Accuracy (GVA). Measured in meters.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:geodetic_vertical_accuracy ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the city." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:city ],
        [ sh:datatype xsd:string ;
            sh:description """The uncorrected barometric pressure altitude (based on reference standard 29.92
inHg, 1013.25 mb) provides a reference for algorithms that utilize 'altitude
deltas' between aircraft. This value is provided in meters and must have a
minimum resolution of 1 m.. Special Values: <code>Invalid</code>, <code>No
Value</code>, or <code>Unknown: -1000 m</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:pressure_altitude ],
        [ sh:datatype xsd:float ;
            sh:description """The geographical Latitude coordinate represented in Decimal Degrees (DD). For
example: <code>42.361145</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:lat ],
        [ sh:datatype xsd:string ;
            sh:description """The ISO 3166-1 Alpha-2 country code.<p><b>Note:</b> The two letter country code
should be capitalized. For example: <code>US</code> or <code>CA</code>.</p>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:country ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the Internet Service Provider (ISP)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:isp ],
        [ sh:datatype xsd:string ;
            sh:description """The aircraft distance above or below the ellipsoid as measured along a line
that passes through the aircraft and is normal to the surface of the WGS-84
ellipsoid. This value is provided in meters and must have a minimum resolution
of 1 m. Special Values: <code>Invalid</code>, <code>No Value</code>, or
<code>Unknown: -1000 m</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:geodetic_altitude ],
        [ sh:datatype xsd:float ;
            sh:description """The geographical Longitude coordinate represented in Decimal Degrees (DD). For
example: <code>-71.057083</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:long ],
        [ sh:datatype xsd:string ;
            sh:description """Expressed as either height above takeoff location or height above ground level
(AGL) for a UAS current location. This value is provided in meters and must
have a minimum resolution of 1 m. Special Values: <code>Invalid</code>,
<code>No Value</code>, or <code>Unknown: -1000 m</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:aerial_height ],
        [ sh:datatype xsd:string ;
            sh:description """Provides quality/containment on horizontal position. This is based on ADS-B
NACp. Measured in meters.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:horizontal_accuracy ],
        [ sh:datatype xsd:string ;
            sh:description "The provider of the geographical location data." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:provider ] ;
    sh:targetClass ocsf:Location .

ocsf:Packet a sh:NodeShape ;
    rdfs:comment """The Packet object represents a single captured network packet and its
associated metadata. It describes where the packet came from, how it is stored
or encoded, and how it can be located within a capture file or stream. This
object does not interpret protocol content; it only represents the captured
packet data and its positioning information.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description """A normalized numeric identifier that specifies how the packet was obtained or
generated.""" ;
            sh:in ( "UNKNOWN" "WIRE" "STREAM" "DECODER" "TAP" "SPAN" "ENDPOINT" "VIRTUAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path ocsf:source_id ],
        [ sh:description "The normalized identifier of the packet capture format." ;
            sh:in ( "UNKNOWN" "PCAP" "PCAPNG" "SNOOP" "ERF" "NETMON" "5VIEWS" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path ocsf:format_id ],
        [ sh:datatype xsd:string ;
            sh:description """The human-readable name of the encoding used to represent the packet data in
the <code>value</code> field. This should match the caption associated with
<code>encoding_id</code>. If <code>encoding_id</code> is 99 (Other), this field
contains the original data source–specific encoding value.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:encoding ],
        [ sh:datatype xsd:integer ;
            sh:description "The starting byte position of this packet within a capture file or stream." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:start_offset ],
        [ sh:datatype xsd:string ;
            sh:description """The human-readable name describing how or where the packet was obtained. This
should match the caption associated with <code>source_id</code>. If
<code>source_id</code> is 99 (Other), this field contains the original data
source–specific value.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:source ],
        [ sh:description """The normalized identifier of the encoding method used to represent the packet
data as a string.""" ;
            sh:in ( "UNKNOWN" "BASE64" "HEXADECIMAL" "URL_ENCODED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path ocsf:encoding_id ],
        [ sh:datatype xsd:string ;
            sh:description """The human-readable name of the packet capture file format in which the packet
is stored. This should match the caption associated with
<code>format_id</code>. If <code>format_id</code> is 99 (Other), this field
contains the original data source–specific format value.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:format ],
        [ sh:datatype xsd:integer ;
            sh:description "The ending byte position of this packet within a capture file or stream." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:end_offset ],
        [ sh:datatype xsd:integer ;
            sh:description """The relative order number of this packet within its capture context (such as a
PCAP file, network session, or reconstructed stream). This represents
chronological capture order, distinct from both protocol-level sequencing (such
as TCP sequence numbers).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:sequence_number ],
        [ sh:datatype xsd:string ;
            sh:description """The actual packet data, represented as a string. The format of this string is
determined by the specified <code>encoding_id</code> (e.g., Base64,
Hexadecimal, or URL Encoded).""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:value ] ;
    sh:targetClass ocsf:Packet .

ocsf:Session a sh:NodeShape ;
    rdfs:comment """The Session object describes details about an authenticated session. e.g.
Session Creation Time, Session Issuer.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "The indication of whether the session is a VPN session." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:is_vpn ],
        [ sh:datatype xsd:string ;
            sh:description "The reason which triggered the session expiration." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:expiration_reason ],
        [ sh:datatype xsd:string ;
            sh:description "The universally unique identifier of the session." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:uuid ;
            sh:pattern "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:long ;
            sh:description "The session expiration time." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:expiration_time ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether Multi Factor Authentication was used during authentication." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:is_mfa ],
        [ sh:datatype xsd:string ;
            sh:description "The Pseudo Terminal associated with the session. Ex: the tty or pts value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:terminal ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of identical sessions spawned from the same source IP, destination
IP, application, and content/threat type seen over a period of time.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:count ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the session was created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:created_time ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the user's credential. For example, AWS Access Key ID." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:credential_uid ],
        [ sh:datatype xsd:boolean ;
            sh:description "The indication of whether the session is remote." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:is_remote ],
        [ sh:datatype xsd:string ;
            sh:description "The identifier of the session issuer." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:issuer ],
        [ sh:datatype xsd:string ;
            sh:description """The alternate unique identifier of the session. e.g. AWS ARN -
<code>arn:aws:sts::123344444444:assumed-role/Admin/example-session</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:uid_alt ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the session." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:uid ] ;
    sh:targetClass ocsf:Session .

ocsf:LoadBalancer a sh:NodeShape ;
    rdfs:comment """The load balancer object describes the load balancer entity and contains
additional information regarding the distribution of traffic across a network.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The unique identifier for the load balancer." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description "The request classification as defined by the load balancer." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:classification ],
        [ sh:datatype xsd:string ;
            sh:description """The IP address of the load balancer node that handled the client request. Note:
the load balancer may have other IP addresses, and this is not an IP address of
the target/distribution endpoint - see <code>dst_endpoint</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:ip ;
            sh:pattern "^((\\d{1,3}\\.){3}\\d{1,3}|[0-9a-fA-F:]{2,39})$" ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the load balancer." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:name ],
        [ sh:class ocsf:EndpointConnection ;
            sh:description "An object detailing the load balancer connection attempts and responses." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:endpoint_connections ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description "The destination to which the load balancer is distributing traffic." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:dst_endpoint ],
        [ sh:class ocsf:Metric ;
            sh:description "General purpose metrics associated with the load balancer." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:metrics ],
        [ sh:datatype xsd:integer ;
            sh:description """The numeric response status code detailing the connection from the load
balancer to the destination target.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:code ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional status information about the load
balancer distribution event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:status_detail ],
        [ sh:datatype xsd:string ;
            sh:description "The load balancer error message." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:error_message ],
        [ sh:datatype xsd:string ;
            sh:description "The load balancer message." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:message ] ;
    sh:targetClass ocsf:LoadBalancer .

ocsf:Product a sh:NodeShape ;
    rdfs:comment "The Product object describes characteristics of a software product." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The name of the vendor of the product." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:vendor_name ],
        [ sh:datatype xsd:string ;
            sh:description """The version of the product, as defined by the event source. For example:
<code>2013.1.3-beta</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:version ],
        [ sh:datatype xsd:anyURI ;
            sh:description "The URL pointing towards the product." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:url_string ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the product." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:uid ],
        [ sh:class ocsf:DataClassification ;
            sh:description """The Data Classification object includes information about data classification
levels and data category types.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:data_classification ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the product." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The installation path of the product." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:path ],
        [ sh:class ocsf:DataClassification ;
            sh:description """A list of Data Classification objects, that include information about data
classification levels and data category types, identified by a classifier.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path ocsf:data_classifications ],
        [ sh:datatype xsd:string ;
            sh:description """The Common Platform Enumeration (CPE) name as described by (<a target='_blank'
href='https://nvd.nist.gov/products/cpe'>NIST</a>) For example:
<code>cpe:/a:apple:safari:16.2</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:cpe_name ],
        [ sh:datatype xsd:string ;
            sh:description """The two letter lower case language codes, as defined by <a target='_blank'
href='https://en.wikipedia.org/wiki/ISO_639-1'>ISO 639-1</a>. For example:
<code>en</code> (English), <code>de</code> (German), or <code>fr</code>
(French).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:lang ],
        [ sh:class ocsf:Feature ;
            sh:description "The feature that reported the event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:feature ] ;
    sh:targetClass ocsf:Product .

ocsf:Remediation a sh:NodeShape ;
    rdfs:comment """The Remediation object describes the recommended remediation steps to address
identified issue(s).""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """A list of supporting URL/s, references that help describe the remediation
strategy.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:references ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the remediation strategy." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:desc ],
        [ sh:class ocsf:CisControl ;
            sh:description """An array of Center for Internet Security (CIS) Controls that can be optionally
mapped to provide additional remediation details.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:cis_controls ],
        [ sh:class ocsf:KbArticle ;
            sh:description """A list of KB articles or patches related to an endpoint. A KB Article contains
metadata that describes the patch or an update.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:kb_article_list ],
        [ sh:datatype xsd:string ;
            sh:description """The KB article/s related to the entity. A KB Article contains metadata that
describes the patch or an update.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:kb_articles ] ;
    sh:targetClass ocsf:Remediation .

ocsf:Container a sh:NodeShape ;
    rdfs:comment """The Container object describes an instance of a specific container. A container
is a prepackaged, portable system image that runs isolated on an existing
system using a container runtime like containerd.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The network driver used by the container. For example, bridge, overlay, host,
none, etc.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:network_driver ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier of the pod (or equivalent) that the container is
executing on.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:pod_uuid ;
            sh:pattern "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" ],
        [ sh:class ocsf:Fingerprint ;
            sh:description """Commit hash of image created for docker or the SHA256 hash of the container.
For example:
<code>13550340a8681c84c861aac2e5b440161c2b33a3e4f302ac680ca5b686de48de</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:hash ],
        [ sh:class ocsf:KeyValueObject ;
            sh:description "The list of tags; <code>{key:value}</code> pairs associated to the container." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path ocsf:tags ],
        [ sh:datatype xsd:string ;
            sh:description "The orchestrator managing the container, such as ECS, EKS, K8s, or OpenShift." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:orchestrator ],
        [ sh:datatype xsd:string ;
            sh:description "The backend running the container, such as containerd or cri-o." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:runtime ],
        [ sh:datatype xsd:string ;
            sh:description "The list of labels associated to the container." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:labels ],
        [ sh:datatype xsd:string ;
            sh:description "The container name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The tag used by the container. It can indicate version, format, OS." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:tag ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the container image." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:size ],
        [ sh:datatype xsd:string ;
            sh:description """The full container unique identifier for this instantiation of the container.
For example:
<code>ac2ea168264a08f9aaca0dfc82ff3551418dfd22d02b713142a6843caa2f61bf</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:uid ],
        [ sh:class ocsf:Image ;
            sh:description "The container image used as a template to run the container." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:image ] ;
    sh:targetClass ocsf:Container .

ocsf:Ja4Fingerprint a sh:NodeShape ;
    rdfs:comment """The JA4+ fingerprint object provides detailed fingerprint information about
various aspects of network traffic which is both machine and human readable.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The 'a' section of the JA4 fingerprint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:section_a ],
        [ sh:datatype xsd:string ;
            sh:description "The 'b' section of the JA4 fingerprint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:section_b ],
        [ sh:datatype xsd:string ;
            sh:description """The JA4+ fingerprint type as defined by <a
href='https://blog.foxio.io/ja4+-network-fingerprinting
target='_blank'>FoxIO</a>, normalized to the caption of 'type_id'. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:type ],
        [ sh:description "The identifier of the JA4+ fingerprint type." ;
            sh:in ( "UNKNOWN" "JA4" "JA4SERVER" "JA4HTTP" "JA4LATENCY" "JA4X509" "JA4SSH" "JA4TCP" "JA4TCPSERVER" "JA4TCPSCAN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:string ;
            sh:description "The 'd' section of the JA4 fingerprint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:section_d ],
        [ sh:datatype xsd:string ;
            sh:description "The 'c' section of the JA4 fingerprint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:section_c ],
        [ sh:datatype xsd:string ;
            sh:description "The JA4+ fingerprint value." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:value ] ;
    sh:targetClass ocsf:Ja4Fingerprint .

ocsf:ResourceDetails a sh:NodeShape ;
    rdfs:comment """The Resource Details object describes details about resources that were
affected by the activity/event.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The fully qualified name of the resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:hostname ],
        [ sh:class ocsf:User ;
            sh:description """The details of the entity that owns the resource. This object includes
properties such as the owner's name, unique identifier, type, domain, and other
relevant attributes that help identify the resource owner within the
environment.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:owner ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates whether the device or resource has a backup enabled, such as an
automated snapshot or a cloud backup. For example, this is indicated by the
<code>cloudBackupEnabled</code> value within JAMF Pro mobile devices or the
registration of an AWS ARN with the AWS Backup service.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:is_backed_up ],
        [ sh:datatype xsd:string ;
            sh:description "The criticality of the resource as defined by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:criticality ],
        [ sh:description """The normalized identifier of the resource's role in the context of the event or
finding.""" ;
            sh:in ( "TARGET" "ACTOR" "AFFECTED" "RELATED" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 14 ;
            sh:path ocsf:role_id ],
        [ sh:datatype xsd:string ;
            sh:description "The alternative unique identifier of the resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:uid_alt ],
        [ sh:datatype xsd:string ;
            sh:description "The resource type as defined by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description "The list of labels associated to the resource." ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:labels ],
        [ sh:class ocsf:DataClassification ;
            sh:description """A list of Data Classification objects, that include information about data
classification levels and data category types, identified by a classifier.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 28 ;
            sh:path ocsf:data_classifications ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the resource was created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:created_time ],
        [ sh:datatype xsd:string ;
            sh:description """The cloud region where the resource is hosted, as defined by the cloud
provider. This represents the physical or logical geographic area containing
the infrastructure supporting the resource. Examples include AWS regions
(us-east-1, eu-west-1), Azure regions (East US, West Europe), GCP regions
(us-central1, europe-west1), or Oracle Cloud regions (us-ashburn-1,
uk-london-1).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:region ],
        [ sh:class ocsf:Graph ;
            sh:description """A graph representation showing how this resource relates to and interacts with
other entities in the environment. This can include parent/child relationships,
dependencies, or other connections.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:resource_relationship ],
        [ sh:class ocsf:KeyValueObject ;
            sh:description "The list of tags; <code>{key:value}</code> pairs associated to the resource." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path ocsf:tags ],
        [ sh:datatype xsd:string ;
            sh:description "The IP address of the resource, in either IPv4 or IPv6 format." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:ip ;
            sh:pattern "^((\\d{1,3}\\.){3}\\d{1,3}|[0-9a-fA-F:]{2,39})$" ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the resource. For example <code>1.2.3</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:version ],
        [ sh:datatype xsd:string ;
            sh:description """The availability zone within a cloud region where the resource is located.
Examples include AWS availability zones (us-east-1a, us-east-1b), Azure
availability zones (1, 2, 3 within a region), GCP zones (us-central1-a,
us-central1-b), or Oracle Cloud availability domains (AD-1, AD-2, AD-3).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:zone ],
        [ sh:datatype xsd:string ;
            sh:description """The role of the resource in the context of the event or finding, normalized to
the caption of the role_id value. In the case of 'Other', it is defined by the
event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:role ],
        [ sh:datatype xsd:string ;
            sh:description """The namespace is useful when similar entities exist that you need to keep
separate.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:namespace ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path ocsf:cloud ],
        [ sh:datatype xsd:string ;
            sh:description """The cloud service provider that hosts or manages the resource. This field is
typically used when the resource is managed by a different provider than the
one generating the event or finding. Examples include AWS, Azure, GCP (Google
Cloud Platform), Oracle Cloud, IBM Cloud, Alibaba Cloud, or other public,
private, or hybrid cloud providers.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:provider ],
        [ sh:datatype xsd:string ;
            sh:description """The logical grouping or isolated segment within a cloud provider's
infrastructure where the resource is located. Examples include AWS partitions
(aws, aws-cn, aws-us-gov), Azure cloud environments (AzureCloud,
AzureUSGovernment, AzureChinaCloud), or similar logical divisions in other
cloud providers.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:cloud_partition ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path ocsf:api ],
        [ sh:class ocsf:DataClassification ;
            sh:description """The Data Classification object includes information about data classification
levels and data category types.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 27 ;
            sh:path ocsf:data_classification ],
        [ sh:class ocsf:Agent ;
            sh:description """A list of <code>agent</code> objects associated with a device, endpoint, or
resource.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:agent_list ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:uid ],
        [ sh:class ocsf:Group ;
            sh:description "The name of the related resource group." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:group ],
        [ sh:datatype xsd:string ;
            sh:description "Additional data describing the resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:data ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the resource was last modified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:modified_time ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:name ] ;
    sh:targetClass ocsf:ResourceDetails .

ocsf:Ticket a sh:NodeShape ;
    rdfs:comment """The Ticket object represents ticket in the customer's IT Service Management
(ITSM) systems like ServiceNow, Jira, etc.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The normalized identifier for the ticket status." ;
            sh:in ( "NEW" "IN_PROGRESS" "NOTIFIED" "ON_HOLD" "RESOLVED" "CLOSED" "CANCELED" "REOPENED" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path ocsf:status_id ],
        [ sh:datatype xsd:string ;
            sh:description "The title of the ticket." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:title ],
        [ sh:datatype xsd:anyURI ;
            sh:description "The url of a ticket in the ticket system." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:src_url ],
        [ sh:datatype xsd:string ;
            sh:description """The linked ticket type determines whether the ticket is internal or in an
external ticketing system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description """The status of the ticket normalized to the caption of the
<code>status_id</code> value. In the case of <code>99</code>, this value should
as defined by the source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:status ],
        [ sh:description "The normalized identifier for the ticket type." ;
            sh:in ( "UNKNOWN" "INTERNAL" "EXTERNAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:string ;
            sh:description "Unique identifier of the ticket." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description "A list of contextual descriptions of the <code>status, status_id</code> values." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:status_details ] ;
    sh:targetClass ocsf:Ticket .

ocsf:KeyValueObject a sh:NodeShape ;
    rdfs:comment "A generic object allowing to define a <code>{key:value}</code> pair." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """Optional, the values associated to the key. You can populate this attribute,
when you have multiple values for the same key.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:values ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the key." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The value associated to the key." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:value ] ;
    sh:targetClass ocsf:KeyValueObject .

ocsf:Process a sh:NodeShape ;
    rdfs:comment "The Process object describes a running instance of a launched program." ;
    sh:closed true ;
    sh:ignoredProperties ( ocsf:hosted_services ocsf:group ocsf:auid rdf:type ocsf:euid ocsf:egid ) ;
    sh:property [ sh:description "The normalized identifier of the process integrity level (Windows only)." ;
            sh:in ( "UNKNOWN" "UNTRUSTED" "LOW" "MEDIUM" "HIGH" "SYSTEM" "PROTECTED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path ocsf:integrity_id ],
        [ sh:datatype xsd:string ;
            sh:description """The name of the containment jail (i.e., sandbox). For example, hardened_ps,
high_security_ps, oracle_ps, netsvcs_ps, or default_ps.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:sandbox ],
        [ sh:datatype xsd:string ;
            sh:description """A unique identifier for this process assigned by the producer (tool).
Facilitates correlation of a process event with other events for that process.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:integer ;
            sh:description """The identifier of the thread associated with the event, as returned by the
operating system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:tid ],
        [ sh:datatype xsd:string ;
            sh:description "The process file path." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:path ],
        [ sh:class ocsf:Process ;
            sh:description """The parent process of this process object. It is recommended to only populate
this field for the top-level process object, to prevent deep nesting.
Additional ancestry information can be supplied in the <code>ancestry</code>
attribute.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:parent_process ],
        [ sh:datatype xsd:string ;
            sh:description """The full command line used to launch an application, service, process, or job.
For example: <code>ssh user@10.0.0.10</code>. If the command line is
unavailable or missing, the empty string <code>''</code> is to be used.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:cmd_line ],
        [ sh:datatype xsd:string ;
            sh:description """A unique process identifier that can be assigned deterministically by multiple
system data producers.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:cpid ;
            sh:pattern "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description """The process integrity level, normalized to the caption of the integrity_id
value. In the case of 'Other', it is defined by the event source (Windows
only).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:integrity ],
        [ sh:class ocsf:Object ;
            sh:description """An unordered collection of zero or more name/value pairs that represent a
process extended attribute.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path ocsf:xattributes ],
        [ sh:class ocsf:Container ;
            sh:description """The information describing an instance of a container. A container is a
prepackaged, portable system image that runs isolated on an existing system
using a container runtime like containerd.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path ocsf:container ],
        [ sh:class ocsf:EnvironmentVariable ;
            sh:description "Environment variables associated with the process." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:environment_variables ],
        [ sh:class ocsf:Session ;
            sh:description "The user session under which this process is running." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path ocsf:session ],
        [ sh:datatype xsd:integer ;
            sh:description """If running under a process namespace (such as in a container), the process
identifier within that process namespace.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:namespace_pid ],
        [ sh:datatype xsd:string ;
            sh:description "The list of loaded module names." ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:loaded_modules ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the process was created/started." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:created_time ],
        [ sh:class ocsf:File ;
            sh:description "The process file object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:file ],
        [ sh:datatype xsd:string ;
            sh:description "The working directory of a process." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:working_directory ],
        [ sh:class ocsf:ProcessEntity ;
            sh:description """An array of Process Entities describing the extended parentage of this process
object. Direct parent information should be expressed through the
<code>parent_process</code> attribute. The first array element is the direct
parent of this process object. Subsequent list elements go up the process
parentage hierarchy. That is, the array is sorted from newest to oldest
process. It is recommended to only populate this field for the top-level
process object.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:ancestry ],
        [ sh:datatype xsd:string ;
            sh:description """The lineage of the process, represented by a list of paths for each ancestor
process. For example: <code>['/usr/sbin/sshd', '/usr/bin/bash',
'/usr/bin/whoami']</code>.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:lineage ],
        [ sh:datatype xsd:integer ;
            sh:description """The process identifier, as reported by the operating system. Process ID (PID)
is a number used by the operating system to uniquely identify an active
process.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:pid ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the process was terminated." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:terminated_time ],
        [ sh:class ocsf:User ;
            sh:description "The user under which this process is running." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:user ],
        [ sh:datatype xsd:string ;
            sh:description "The friendly name of the process, for example: <code>Notepad++</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:integer ;
            sh:description """The identifier of the process thread associated with the event, as returned by
the operating system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:ptid ] ;
    sh:targetClass ocsf:Process .

ocsf:QueryInfo a sh:NodeShape ;
    rdfs:comment """The query info object holds information related to data access within a
datastore. To access, manipulate, delete, or retrieve data from a datastore, a
query must be written using a specific syntax.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The data returned from the query execution." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:data ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the query." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description "The query name for a saved or scheduled query." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the query was run." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:query_time ],
        [ sh:datatype xsd:string ;
            sh:description """A string representing the query code being run. For example: <code>SELECT *
FROM my_table</code>""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:query_string ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the data returned from the query." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:bytes ] ;
    sh:targetClass ocsf:QueryInfo .

ocsf:DataClassification a sh:NodeShape ;
    rdfs:comment """The Data Classification object includes information about data classification
levels and data category types.""" ;
    sh:closed true ;
    sh:ignoredProperties ( ocsf:detection_system_id ocsf:detection_system ocsf:data_lifecycle_state rdf:type ocsf:pattern_match ocsf:data_lifecycle_state_id ocsf:detection_pattern ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "The total count of discovered entities, by the classification job." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:total ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the classification job." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:uid ],
        [ sh:description "The normalized status identifier of the classification job." ;
            sh:in ( "UNKNOWN" "COMPLETE" "PARTIAL" "FAIL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 11 ;
            sh:path ocsf:status_id ],
        [ sh:datatype xsd:anyURI ;
            sh:description "The source URL pointing towards the full classification job details." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:src_url ],
        [ sh:datatype xsd:integer ;
            sh:description "Size of the data classified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:size ],
        [ sh:datatype xsd:string ;
            sh:description "The contextual description of the <code>status, status_id</code> value." ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:status_details ],
        [ sh:description "The normalized identifier of the file content confidentiality indicator." ;
            sh:in ( "UNKNOWN" "NOT_CONFIDENTIAL" "CONFIDENTIAL" "SECRET" "TOP_SECRET" "PRIVATE" "RESTRICTED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path ocsf:confidentiality_id ],
        [ sh:datatype xsd:string ;
            sh:description """The name of the data classification category that data matched into, e.g.
Financial, Personal, Governmental, etc.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:category ],
        [ sh:datatype xsd:string ;
            sh:description """The resultant status of the classification job normalized to the caption of the
<code>status_id</code> value. In the case of 'Other', it is defined by the
event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:status ],
        [ sh:description "The normalized identifier of the data classification category." ;
            sh:in ( "UNKNOWN" "PERSONAL" "GOVERNMENTAL" "FINANCIAL" "BUSINESS" "MILITARY_AND_LAW_ENFORCEMENT" "SECURITY" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path ocsf:category_id ],
        [ sh:class ocsf:ClassifierDetails ;
            sh:description "Describes details about the classifier used for data classification." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:classifier_details ],
        [ sh:class ocsf:Policy ;
            sh:description """Details about the data policy that governs data handling and security measures
related to classification.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:string ;
            sh:description """The file content confidentiality, normalized to the confidentiality_id value.
In the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:confidentiality ],
        [ sh:class ocsf:DiscoveryDetails ;
            sh:description "Details about the data discovered by classification job." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:discovery_details ] ;
    sh:targetClass ocsf:DataClassification .

ocsf:HttpRequest a sh:NodeShape ;
    rdfs:comment """The HTTP Request object represents the attributes of a request made to a web
server. It encapsulates the details and metadata associated with an HTTP
request, including the request method, headers, URL, query parameters, body
content, and other relevant information.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "The length of the entire HTTP request, in number of bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:length ],
        [ sh:class ocsf:Url ;
            sh:description "The URL object that pertains to the request." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:url ],
        [ sh:datatype xsd:string ;
            sh:description """The X-Forwarded-For header identifying the originating IP address(es) of a
client connecting to a web server through an HTTP proxy or a load balancer.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:x_forwarded_for ;
            sh:pattern "^((\\d{1,3}\\.){3}\\d{1,3}|[0-9a-fA-F:]{2,39})$" ],
        [ sh:datatype xsd:string ;
            sh:description """The request header that identifies the address of the previous web page, which
is linked to the current web page or resource being requested.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:referrer ],
        [ sh:datatype xsd:string ;
            sh:description "The arguments sent along with the HTTP request." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:args ],
        [ sh:class ocsf:HttpHeader ;
            sh:description "Additional HTTP headers of an HTTP request or response." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:http_headers ],
        [ sh:description """The <a target='_blank'
href='https://developer.mozilla.org/en-US/docs/Web/HTTP/Methods'>HTTP request
method</a> indicates the desired action to be performed for a given resource.""" ;
            sh:in ( "CONNECT" "DELETE" "GET" "HEAD" "OPTIONS" "PATCH" "POST" "PUT" "TRACE" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path ocsf:http_method ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the http request." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:integer ;
            sh:description """The actual length of the HTTP request body, in number of bytes, independent of
a potentially existing Content-Length header.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:body_length ],
        [ sh:datatype xsd:string ;
            sh:description "The Hypertext Transfer Protocol (HTTP) version." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:version ],
        [ sh:datatype xsd:string ;
            sh:description "The request header that identifies the operating system and web browser." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:user_agent ] ;
    sh:targetClass ocsf:HttpRequest .

ocsf:HttpResponse a sh:NodeShape ;
    rdfs:comment """The HTTP Response object contains detailed information about the response sent
from a web server to the requester. It encompasses attributes and metadata that
describe the response status, headers, body content, and other relevant
information.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:HttpHeader ;
            sh:description "Additional HTTP headers of an HTTP request or response." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:http_headers ],
        [ sh:datatype xsd:integer ;
            sh:description "The length of the entire HTTP response, in number of bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:length ],
        [ sh:datatype xsd:string ;
            sh:description """The response status. For example: A successful HTTP status of 'OK' which
corresponds to a code of 200.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:integer ;
            sh:description "The HTTP response latency measured in milliseconds." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:latency ],
        [ sh:datatype xsd:integer ;
            sh:description """The actual length of the HTTP response body, in number of bytes, independent of
a potentially existing Content-Length header.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:body_length ],
        [ sh:datatype xsd:string ;
            sh:description """The request header that identifies the original <a target='_blank'
href='https://www.iana.org/assignments/media-types/media-types.xhtml'>media
type </a> of the resource (prior to any content encoding applied for sending).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:content_type ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:integer ;
            sh:description """The Hypertext Transfer Protocol (HTTP) status code returned from the web server
to the client. For example, 200.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:code ] ;
    sh:targetClass ocsf:HttpResponse .

ocsf:Group a sh:NodeShape ;
    rdfs:comment """The Group object represents a collection or association of entities, such as
users, policies, or devices. It serves as a logical grouping mechanism to
organize and manage entities with similar characteristics or permissions within
a system or organization, including but not limited to purposes of access
control.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The type of the group." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier of the group. For example, for Windows events this is the
security identifier (SID) of the group. Another example, pool id or desktop id
that the device belongs to.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description "The group name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The alternate unique identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:uid_alt ],
        [ sh:datatype xsd:string ;
            sh:description "The group privileges." ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:privileges ],
        [ sh:datatype xsd:string ;
            sh:description """The domain where the group is defined. For example: the LDAP or Active
Directory domain.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:domain ],
        [ sh:datatype xsd:string ;
            sh:description "The group description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:desc ] ;
    sh:targetClass ocsf:Group .

ocsf:NetworkProxy a sh:NodeShape ;
    rdfs:comment """The network proxy endpoint object describes a proxy server, which acts as an
intermediary between a client requesting a resource and the server providing
that resource.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:DeviceHwInfo ;
            sh:description "The endpoint hardware information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path ocsf:hw_info ],
        [ sh:class ocsf:Agent ;
            sh:description """A list of <code>agent</code> objects associated with a device, endpoint, or
resource.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:agent_list ],
        [ sh:datatype xsd:string ;
            sh:description """The intermediate IP Addresses. For example, the IP addresses in the HTTP
X-Forwarded-For header.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:intermediate_ips ;
            sh:pattern "^((\\d{1,3}\\.){3}\\d{1,3}|[0-9a-fA-F:]{2,39})$" ],
        [ sh:datatype xsd:integer ;
            sh:description "The port used for communication within the network connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:port ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the Internet Service Provider (ISP)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:isp ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of a VM instance." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:instance_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The Media Access Control (MAC) address of the endpoint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:mac ;
            sh:pattern "^([0-9a-fA-F]{2}[:\\-]){5}[0-9a-fA-F]{2}$" ],
        [ sh:class ocsf:Location ;
            sh:description "The geographical location of the endpoint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path ocsf:location ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the network interface." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:interface_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the network interface (e.g. eth2)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:interface_name ],
        [ sh:class ocsf:NetworkProxy ;
            sh:description """The network proxy information pertaining to a specific endpoint. This can be
used to describe information pertaining to network address translation (NAT).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:proxy_endpoint ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the Virtual Private Cloud (VPC)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:vpc_uid ],
        [ sh:description "The network endpoint type ID." ;
            sh:in ( "SERVER" "DESKTOP" "LAPTOP" "TABLET" "MOBILE" "VIRTUAL" "IOT" "BROWSER" "FIREWALL" "SWITCH" "HUB" "ROUTER" "IDS" "IPS" "LOAD_BALANCER" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 11 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:string ;
            sh:description """The organization name of the Internet Service Provider (ISP). This represents
the parent organization or company that owns/operates the ISP. For example,
Comcast Corporation would be the ISP org for Xfinity internet service. This
attribute helps identify the ultimate provider when ISPs operate under
different brand names.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:isp_org ],
        [ sh:datatype xsd:string ;
            sh:description """The network endpoint type. For example: <code>unknown</code>,
<code>server</code>, <code>desktop</code>, <code>laptop</code>,
<code>tablet</code>, <code>mobile</code>, <code>virtual</code>,
<code>browser</code>, or <code>other</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:type ],
        [ sh:class ocsf:AutonomousSystem ;
            sh:description "The Autonomous System details associated with an IP address." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:autonomous_system ],
        [ sh:datatype xsd:string ;
            sh:description "The short name of the endpoint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description """The name of the domain that the endpoint belongs to or that corresponds to the
endpoint.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:domain ],
        [ sh:datatype xsd:string ;
            sh:description """The vendor or manufacturer of the endpoint's network interface controller
(NIC), as identified from the MAC address.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:mac_vendor ],
        [ sh:datatype xsd:string ;
            sh:description """Indicates whether the endpoint resides inside the customer’s network, outside
on the Internet, or if its location relative to the customer’s network cannot
be determined. The value is normalized to the caption of the
<code>network_scope_id</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:network_scope ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the endpoint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description "The fully qualified name of the endpoint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:hostname ],
        [ sh:description """The normalized identifier of the endpoint’s network scope. The normalized
network scope identifier indicates whether the endpoint resides inside the
customer’s network, outside on the Internet, or if its location relative to the
customer’s network cannot be determined.""" ;
            sh:in ( "UNKNOWN" "INTERNAL" "EXTERNAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path ocsf:network_scope_id ],
        [ sh:class ocsf:Os ;
            sh:description "The endpoint operating system." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 25 ;
            sh:path ocsf:os ],
        [ sh:class ocsf:User ;
            sh:description """The identity of the service or user account that owns the endpoint or was last
logged into it.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 26 ;
            sh:path ocsf:owner ],
        [ sh:datatype xsd:string ;
            sh:description "The Virtual LAN identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:vlan_uid ],
        [ sh:class ocsf:Container ;
            sh:description """The information describing an instance of a container. A container is a
prepackaged, portable system image that runs isolated on an existing system
using a container runtime like containerd.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path ocsf:container ],
        [ sh:datatype xsd:integer ;
            sh:description """If running under a process namespace (such as in a container), the process
identifier within that process namespace.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:namespace_pid ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of a virtual subnet." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:subnet_uid ],
        [ sh:class ocsf:Group ;
            sh:description "The pool of desktops or virtual machines to which the endpoint belongs." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 27 ;
            sh:path ocsf:pool ],
        [ sh:datatype xsd:string ;
            sh:description """The service name in service-to-service connections. For example, AWS VPC logs
the pkt-src-aws-service and pkt-dst-aws-service fields identify the connection
is coming from or going to an AWS service.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:svc_name ],
        [ sh:class ocsf:Fingerprint ;
            sh:description """Fingerprints that identify the specific application implementation on this
endpoint, such as Cisco NPF or HASSH.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:fingerprints ],
        [ sh:datatype xsd:string ;
            sh:description "The IP address of the endpoint, in either IPv4 or IPv6 format." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:ip ;
            sh:pattern "^((\\d{1,3}\\.){3}\\d{1,3}|[0-9a-fA-F:]{2,39})$" ],
        [ sh:datatype xsd:string ;
            sh:description "The network zone or LAN segment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path ocsf:zone ] ;
    sh:targetClass ocsf:NetworkProxy .

ocsf:Tls a sh:NodeShape ;
    rdfs:comment """The Transport Layer Security (TLS) object describes the negotiated TLS protocol
used for secure communications over an establish network connection.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:TlsExtension ;
            sh:description "The list of TLS extensions." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:extension_list ],
        [ sh:datatype xsd:string ;
            sh:description "The negotiated cipher suite." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:cipher ],
        [ sh:class ocsf:TlsExtension ;
            sh:description "The list of TLS extensions." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:tls_extension_list ],
        [ sh:datatype xsd:string ;
            sh:description "The TLS protocol version." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:version ],
        [ sh:class ocsf:Certificate ;
            sh:description "The certificate object containing information about the digital certificate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:certificate ],
        [ sh:datatype xsd:string ;
            sh:description """The server cipher suites that were exchanged during the TLS handshake
negotiation.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:server_ciphers ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The MD5 hash of a JA3 string." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:ja3_hash ],
        [ sh:datatype xsd:integer ;
            sh:description "The length of the encryption key." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:key_length ],
        [ sh:datatype xsd:string ;
            sh:description " The Server Name Indication (SNI) extension sent by the client." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:sni ],
        [ sh:datatype xsd:integer ;
            sh:description """The amount of total time for the TLS handshake to complete after the TCP
connection is established, including client-side delays, in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:handshake_dur ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The MD5 hash of a JA3S string." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:ja3s_hash ],
        [ sh:datatype xsd:string ;
            sh:description """The Chain of Certificate Serial Numbers field provides a chain of Certificate
Issuer Serial Numbers leading to the Root Certificate Issuer.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:certificate_chain ],
        [ sh:datatype xsd:integer ;
            sh:description """The integer value of TLS alert if present. The alerts are defined in the TLS
specification in <a target='_blank'
href='https://datatracker.ietf.org/doc/html/rfc2246'>RFC-2246</a>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:alert ],
        [ sh:datatype xsd:string ;
            sh:description """The client cipher suites that were exchanged during the TLS handshake
negotiation.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:client_ciphers ],
        [ sh:class ocsf:San ;
            sh:description """The list of subject alternative names that are secured by a specific
certificate.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path ocsf:sans ] ;
    sh:targetClass ocsf:Tls .

ocsf:File a sh:NodeShape ;
    rdfs:comment """The File object represents the metadata associated with a file stored in a
computer system. It encompasses information about the file itself, including
its attributes, properties, and organizational details.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The normalized identifier of the file content confidentiality indicator." ;
            sh:in ( "UNKNOWN" "NOT_CONFIDENTIAL" "CONFIDENTIAL" "SECRET" "TOP_SECRET" "PRIVATE" "RESTRICTED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path ocsf:confidentiality_id ],
        [ sh:description """The file type ID. Note the distinction between a <code>Regular File</code> and
an <code>Executable File</code>. If the distinction is not known, or not
indicated by the log, use <code>Regular File</code>. In this case, it should
not be assumed that a Regular File is not executable.""" ;
            sh:in ( "UNKNOWN" "REGULAR_FILE" "FOLDER" "CHARACTER_DEVICE" "BLOCK_DEVICE" "LOCAL_SOCKET" "NAMED_PIPE" "SYMBOLIC_LINK" "EXECUTABLE_FILE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 36 ;
            sh:path ocsf:type_id ],
        [ sh:class ocsf:Object ;
            sh:description """An unordered collection of zero or more name/value pairs where each pair
represents a file or folder extended attribute.</p>For example: Windows
alternate data stream attributes (ADS stream name, ADS size, etc.),
user-defined or application-defined attributes, ACL, owner, primary group, etc.
Examples from DCS:
</p><ul><li><strong>ads_name</strong></li><li><strong>ads_size</strong></li><li><strong>dacl</strong></li><li><strong>owner</strong></li><li><strong>primary_group</strong></li><li><strong>link_name</strong>
- name of the link associated to the
file.</li><li><strong>hard_link_count</strong> - the number of links that are
associated to the file.</li></ul>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 42 ;
            sh:path ocsf:xattributes ],
        [ sh:datatype xsd:integer ;
            sh:description "The bitmask value that represents the file attributes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:attributes ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the file. For example: <code>svchost.exe</code>" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:name ],
        [ sh:description "Identifies the type of a disk drive, i.e. fixed, removable, etc." ;
            sh:in ( "UNKNOWN" "REMOVABLE" "FIXED" "REMOTE" "CD_ROM" "RAM_DISK" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 10 ;
            sh:path ocsf:drive_type_id ],
        [ sh:datatype xsd:string ;
            sh:description """The extension of the file, excluding the leading dot. For example:
<code>exe</code> from <code>svchost.exe</code>, or <code>gz</code> from
<code>export.tar.gz</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:ext ],
        [ sh:class ocsf:DataClassification ;
            sh:description """The Data Classification object includes information about data classification
levels and data category types.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 43 ;
            sh:path ocsf:data_classification ],
        [ sh:datatype xsd:string ;
            sh:description """The description of the file, as returned by file system. For example: the
description as returned by the Unix file command or the Windows file type.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:desc ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates that the file cannot be modified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:is_readonly ],
        [ sh:class ocsf:DigitalSignature ;
            sh:description "The digital signature of the file." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 30 ;
            sh:path ocsf:signature ],
        [ sh:class ocsf:User ;
            sh:description "The user that owns the file/object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 25 ;
            sh:path ocsf:owner ],
        [ sh:datatype xsd:boolean ;
            sh:description "The indication of whether the object is part of the operating system." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:is_system ],
        [ sh:class ocsf:KeyValueObject ;
            sh:description "The list of tags; <code>{key:value}</code> pairs associated to the file." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 34 ;
            sh:path ocsf:tags ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the file was last modified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:modified_time ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "An array of hash attributes." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:hashes ],
        [ sh:datatype xsd:string ;
            sh:description """The file content confidentiality, normalized to the confidentiality_id value.
In the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:confidentiality ],
        [ sh:datatype xsd:string ;
            sh:description "The object security descriptor." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:security_descriptor ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates if the file is publicly accessible. For example in an object's public
access in AWS S3""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:is_public ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the file was last accessed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:accessed_time ],
        [ sh:class ocsf:Url ;
            sh:description "The URL of the file, when applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 39 ;
            sh:path ocsf:url ],
        [ sh:class ocsf:User ;
            sh:description "The name of the user who last accessed the object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:accessor ],
        [ sh:class ocsf:User ;
            sh:description "The user that last modified the file." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path ocsf:modifier ],
        [ sh:class ocsf:Product ;
            sh:description "The product that created or installed the file." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 28 ;
            sh:path ocsf:product ],
        [ sh:datatype xsd:string ;
            sh:description """The drive type, normalized to the caption of the <code>drive_type_id</code>
value. In the case of <code>Other</code>, it is defined by the source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:drive_type ],
        [ sh:datatype xsd:string ;
            sh:description """The name of the file as identified within the file itself. This contrasts with
the name by which the file is known on disk. Where available, the internal name
is widely used by security practitioners and detection content because the
on-disk file name is not reliable. On the Windows OS, most PE files contain a
<a
href="https://learn.microsoft.com/en-us/windows/win32/menurc/versioninfo-resource">VERSIONINFO</a>
resource from which the internal name can be obtained. On macOS, binaries can
optionally embed a copy of the application's Info.plist file which in turn
contains the name of the executable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:internal_name ],
        [ sh:datatype xsd:string ;
            sh:description """The Multipurpose Internet Mail Extensions (MIME) type of the file, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:mime_type ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates if the file is encrypted." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:is_encrypted ],
        [ sh:class ocsf:DigitalSignature ;
            sh:description "A collection of <code>Digital Signature</code> objects." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 31 ;
            sh:path ocsf:signatures ],
        [ sh:datatype xsd:anyURI ;
            sh:description """The file URI, such as those reporting by static analysis tools. E.g.,
<code>file:///C:/dev/sarif/sarif-tutorials/samples/Introduction/simple-example.js</code>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 38 ;
            sh:path ocsf:uri ],
        [ sh:datatype xsd:string ;
            sh:description """The storage class of the file. For example in AWS S3: <code>STANDARD,
STANDARD_IA, GLACIER</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:storage_class ],
        [ sh:datatype xsd:string ;
            sh:description "A list of symbols imported by the executable file." ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:imported_symbols ],
        [ sh:datatype xsd:string ;
            sh:description "The file type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description "The volume on the storage device where the file is located." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path ocsf:volume ],
        [ sh:datatype xsd:string ;
            sh:description """The parent folder in which the file resides. For example:
<code>c:\\windows\\system32</code>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:parent_folder ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the file was created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:created_time ],
        [ sh:datatype xsd:string ;
            sh:description "The file version. For example: <code>8.0.7601.17514</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path ocsf:version ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of data, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path ocsf:size ],
        [ sh:datatype xsd:string ;
            sh:description """The full path to the file. For example:
<code>c:\\windows\\system32\\svchost.exe</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:path ],
        [ sh:datatype xsd:string ;
            sh:description """The name of the company that published the file. For example: <code>Microsoft
Corporation</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:company_name ],
        [ sh:class ocsf:DataClassification ;
            sh:description """A list of Data Classification objects, that include information about data
classification levels and data category types, identified by a classifier.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 44 ;
            sh:path ocsf:data_classifications ],
        [ sh:class ocsf:EncryptionDetails ;
            sh:description """The encryption details of the file. Should be populated if the file is
encrypted.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:encryption_details ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier of the file as defined by the storage system, such the
file system file ID.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 37 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates if the file was deleted from the filesystem." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:is_deleted ],
        [ sh:class ocsf:User ;
            sh:description "The user that created the file." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:creator ] ;
    sh:targetClass ocsf:File .

ocsf:NetworkConnectionInfo a sh:NodeShape ;
    rdfs:comment """The Network Connection Information object describes characteristics of an OSI
Transport Layer communication, including TCP and UDP.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "The network connection TCP header flags (i.e., control bits)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:tcp_flags ],
        [ sh:datatype xsd:integer ;
            sh:description """The IP protocol number, as defined by the Internet Assigned Numbers Authority
(IANA). For example: <code>6</code> for TCP and <code>17</code> for UDP.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:protocol_num ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description """The IP protocol name in lowercase, as defined by the Internet Assigned Numbers
Authority (IANA). For example: <code>tcp</code> or <code>udp</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:protocol_name ],
        [ sh:datatype xsd:string ;
            sh:description "The Internet Protocol version." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:protocol_ver ],
        [ sh:datatype xsd:string ;
            sh:description """The Connection Flag History summarizes events in a network connection. For
example flags <code> ShAD </code> representing SYN, SYN/ACK, ACK and Data
exchange.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:flag_history ],
        [ sh:class ocsf:Session ;
            sh:description "The authenticated user or service session." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path ocsf:session ],
        [ sh:datatype xsd:string ;
            sh:description "The Community ID of the network connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:community_uid ],
        [ sh:datatype xsd:string ;
            sh:description """The boundary of the connection, normalized to the caption of 'boundary_id'. In
the case of 'Other', it is defined by the event source. <p> For cloud
connections, this translates to the traffic-boundary(same VPC, through IGW,
etc.). For traditional networks, this is described as Local, Internal, or
External.</p>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:boundary ],
        [ sh:datatype xsd:string ;
            sh:description """The direction of the initiated connection, traffic, or email, normalized to the
caption of the direction_id value. In the case of 'Other', it is defined by the
event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:direction ],
        [ sh:description """<p>The normalized identifier of the boundary of the connection. </p><p> For
cloud connections, this translates to the traffic-boundary (same VPC, through
IGW, etc.). For traditional networks, this is described as Local, Internal, or
External.</p>""" ;
            sh:in ( "UNKNOWN" "LOCALHOST" "INTERNAL" "EXTERNAL" "SAME_VPC" "INTERNET_VPC_GATEWAY" "VIRTUAL_PRIVATE_GATEWAY" "INTRA_REGION_VPC" "INTER_REGION_VPC" "LOCAL_GATEWAY" "GATEWAY_VPC" "INTERNET_GATEWAY" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path ocsf:boundary_id ],
        [ sh:description "The Internet Protocol version identifier." ;
            sh:in ( "UNKNOWN" "INTERNET_PROTOCOL_VERSION_4_IPV4" "INTERNET_PROTOCOL_VERSION_6_IPV6" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 9 ;
            sh:path ocsf:protocol_ver_id ],
        [ sh:description """The normalized identifier of the direction of the initiated connection,
traffic, or email.""" ;
            sh:in ( "UNKNOWN" "INBOUND" "OUTBOUND" "LATERAL" "LOCAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 4 ;
            sh:path ocsf:direction_id ] ;
    sh:targetClass ocsf:NetworkConnectionInfo .

ocsf:NetworkTraffic a sh:NodeShape ;
    rdfs:comment """The Network Traffic object describes characteristics of network traffic over a
time period. The metrics represent network data transferred between source and
destination during an observation window.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:long ;
            sh:description "The end time of the observation or reporting period." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:end_time ],
        [ sh:datatype xsd:integer ;
            sh:description """The total number of packets transferred in both directions (sum of packets_in
and packets_out).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:packets ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of bytes that were missed during observation, typically due to
packet loss or sampling limitations.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:bytes_missed ],
        [ sh:datatype xsd:long ;
            sh:description "The start time of the observation or reporting period." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:start_time ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of bytes sent from the source to the destination (outbound
direction).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:bytes_out ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of packets sent from the source to the destination (outbound
direction).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:packets_out ],
        [ sh:datatype xsd:integer ;
            sh:description """The total number of chunks transferred in both directions (sum of chunks_in and
chunks_out).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:chunks ],
        [ sh:datatype xsd:integer ;
            sh:description """The total number of bytes transferred in both directions (sum of bytes_in and
bytes_out).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:bytes ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of packets sent from the destination to the source (inbound
direction).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:packets_in ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of chunks sent from the destination to the source (inbound
direction).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:chunks_in ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of chunks sent from the source to the destination (outbound
direction).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:chunks_out ],
        [ sh:class ocsf:Timespan ;
            sh:description """The time span object representing the duration of the observation or reporting
period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:timespan ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of bytes sent from the destination to the source (inbound
direction).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:bytes_in ] ;
    sh:targetClass ocsf:NetworkTraffic .

ocsf:User a sh:NodeShape ;
    rdfs:comment """The User object describes the characteristics of a user/person or a security
principal.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The alternate user identifier. For example, the Active Directory user GUID or
AWS user Principal ID.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:uid_alt ],
        [ sh:datatype xsd:string ;
            sh:description """The unique user identifier. For example, the Windows user SID, ActiveDirectory
DN or AWS user ARN.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:uid ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 15 ;
            sh:path ocsf:risk_level_id ],
        [ sh:datatype xsd:string ;
            sh:description "The type of the user. For example, System, AWS IAM User, etc." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:risk_score ],
        [ sh:datatype xsd:string ;
            sh:description "The username. For example, <code>janedoe1</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:risk_level ],
        [ sh:datatype xsd:string ;
            sh:description """The domain where the user is defined. For example: the LDAP or Active Directory
domain.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:domain ],
        [ sh:class ocsf:LdapPerson ;
            sh:description "The additional LDAP attributes that describe a person." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:ldap_person ],
        [ sh:datatype xsd:string ;
            sh:description "The full name of the user, as reported by the product." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:full_name ],
        [ sh:description "The account type identifier." ;
            sh:in ( "UNKNOWN" "USER" "ADMIN" "SYSTEM" "SERVICE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 18 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:string ;
            sh:description "The user's primary email address." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:email_addr ;
            sh:pattern "^[\\w.+\\-]+@[\\w\\-]+(\\.[\\w\\-]+)+$" ],
        [ sh:class ocsf:Organization ;
            sh:description "Organization and org unit related to the user." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:org ],
        [ sh:class ocsf:Group ;
            sh:description "The administrative groups to which the user belongs." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:groups ],
        [ sh:datatype xsd:string ;
            sh:description "The user's forwarding email address." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:forward_addr ;
            sh:pattern "^[\\w.+\\-]+@[\\w\\-]+(\\.[\\w\\-]+)+$" ],
        [ sh:datatype xsd:string ;
            sh:description "The telephone number of the user." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:phone_number ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the user's credential. For example, AWS Access Key ID." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:credential_uid ],
        [ sh:datatype xsd:boolean ;
            sh:description "The user has a multi-factor or secondary-factor device assigned." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:has_mfa ],
        [ sh:class ocsf:Account ;
            sh:description "The user's account or the account associated with the user." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:account ],
        [ sh:class ocsf:ProgrammaticCredential ;
            sh:description """Details about the programmatic credential (API keys, access tokens,
certificates, etc) associated to the user.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:programmatic_credentials ],
        [ sh:datatype xsd:string ;
            sh:description "The display name of the user, as reported by the product." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:display_name ] ;
    sh:targetClass ocsf:User .

ocsf:NetworkEndpoint a sh:NodeShape ;
    rdfs:comment """The Network Endpoint object describes characteristics of a network endpoint.
These can be a source or destination of a network connection.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The Virtual LAN identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:vlan_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The Media Access Control (MAC) address of the endpoint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:mac ;
            sh:pattern "^([0-9a-fA-F]{2}[:\\-]){5}[0-9a-fA-F]{2}$" ],
        [ sh:datatype xsd:string ;
            sh:description """Indicates whether the endpoint resides inside the customer’s network, outside
on the Internet, or if its location relative to the customer’s network cannot
be determined. The value is normalized to the caption of the
<code>network_scope_id</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:network_scope ],
        [ sh:datatype xsd:string ;
            sh:description """The vendor or manufacturer of the endpoint's network interface controller
(NIC), as identified from the MAC address.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:mac_vendor ],
        [ sh:datatype xsd:integer ;
            sh:description """If running under a process namespace (such as in a container), the process
identifier within that process namespace.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:namespace_pid ],
        [ sh:description """The normalized identifier of the endpoint’s network scope. The normalized
network scope identifier indicates whether the endpoint resides inside the
customer’s network, outside on the Internet, or if its location relative to the
customer’s network cannot be determined.""" ;
            sh:in ( "UNKNOWN" "INTERNAL" "EXTERNAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path ocsf:network_scope_id ],
        [ sh:datatype xsd:string ;
            sh:description """The service name in service-to-service connections. For example, AWS VPC logs
the pkt-src-aws-service and pkt-dst-aws-service fields identify the connection
is coming from or going to an AWS service.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:svc_name ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the Virtual Private Cloud (VPC)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:vpc_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The IP address of the endpoint, in either IPv4 or IPv6 format." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:ip ;
            sh:pattern "^((\\d{1,3}\\.){3}\\d{1,3}|[0-9a-fA-F:]{2,39})$" ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the Internet Service Provider (ISP)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:isp ],
        [ sh:class ocsf:AutonomousSystem ;
            sh:description "The Autonomous System details associated with an IP address." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:autonomous_system ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the endpoint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:uid ],
        [ sh:class ocsf:Agent ;
            sh:description """A list of <code>agent</code> objects associated with a device, endpoint, or
resource.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:agent_list ],
        [ sh:datatype xsd:string ;
            sh:description """The intermediate IP Addresses. For example, the IP addresses in the HTTP
X-Forwarded-For header.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:intermediate_ips ;
            sh:pattern "^((\\d{1,3}\\.){3}\\d{1,3}|[0-9a-fA-F:]{2,39})$" ],
        [ sh:datatype xsd:integer ;
            sh:description "The port used for communication within the network connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:port ],
        [ sh:class ocsf:User ;
            sh:description """The identity of the service or user account that owns the endpoint or was last
logged into it.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 26 ;
            sh:path ocsf:owner ],
        [ sh:datatype xsd:string ;
            sh:description """The organization name of the Internet Service Provider (ISP). This represents
the parent organization or company that owns/operates the ISP. For example,
Comcast Corporation would be the ISP org for Xfinity internet service. This
attribute helps identify the ultimate provider when ISPs operate under
different brand names.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:isp_org ],
        [ sh:class ocsf:Fingerprint ;
            sh:description """Fingerprints that identify the specific application implementation on this
endpoint, such as Cisco NPF or HASSH.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:fingerprints ],
        [ sh:datatype xsd:string ;
            sh:description "The network zone or LAN segment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path ocsf:zone ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of a virtual subnet." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:subnet_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The fully qualified name of the endpoint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:hostname ],
        [ sh:description "The network endpoint type ID." ;
            sh:in ( "SERVER" "DESKTOP" "LAPTOP" "TABLET" "MOBILE" "VIRTUAL" "IOT" "BROWSER" "FIREWALL" "SWITCH" "HUB" "ROUTER" "IDS" "IPS" "LOAD_BALANCER" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 11 ;
            sh:path ocsf:type_id ],
        [ sh:class ocsf:Location ;
            sh:description "The geographical location of the endpoint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path ocsf:location ],
        [ sh:datatype xsd:string ;
            sh:description """The network endpoint type. For example: <code>unknown</code>,
<code>server</code>, <code>desktop</code>, <code>laptop</code>,
<code>tablet</code>, <code>mobile</code>, <code>virtual</code>,
<code>browser</code>, or <code>other</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description """The name of the domain that the endpoint belongs to or that corresponds to the
endpoint.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:domain ],
        [ sh:class ocsf:Container ;
            sh:description """The information describing an instance of a container. A container is a
prepackaged, portable system image that runs isolated on an existing system
using a container runtime like containerd.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path ocsf:container ],
        [ sh:datatype xsd:string ;
            sh:description "The short name of the endpoint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the network interface (e.g. eth2)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:interface_name ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the network interface." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:interface_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of a VM instance." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:instance_uid ],
        [ sh:class ocsf:Os ;
            sh:description "The endpoint operating system." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 25 ;
            sh:path ocsf:os ],
        [ sh:class ocsf:NetworkProxy ;
            sh:description """The network proxy information pertaining to a specific endpoint. This can be
used to describe information pertaining to network address translation (NAT).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:proxy_endpoint ],
        [ sh:class ocsf:DeviceHwInfo ;
            sh:description "The endpoint hardware information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path ocsf:hw_info ],
        [ sh:class ocsf:Group ;
            sh:description "The pool of desktops or virtual machines to which the endpoint belongs." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 27 ;
            sh:path ocsf:pool ] ;
    sh:targetClass ocsf:NetworkEndpoint .

ocsf:Enrichment a sh:NodeShape ;
    rdfs:comment """The Enrichment object provides inline enrichment data for specific attributes
of interest within an event. It serves as a mechanism to enhance or supplement
the information associated with the event by adding additional relevant details
or context.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "The URL of the source of the enrichment data." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:src_url ],
        [ sh:datatype xsd:string ;
            sh:description """The enrichment data associated with the attribute and value. The meaning of
this data depends on the type the enrichment record.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:data ],
        [ sh:datatype xsd:string ;
            sh:description "The value of the attribute to which the enriched data pertains." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:value ],
        [ sh:class ocsf:Reputation ;
            sh:description "The reputation of the enrichment data." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:reputation ],
        [ sh:datatype xsd:string ;
            sh:description "A long description of the enrichment data." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:desc ],
        [ sh:datatype xsd:string ;
            sh:description "The enrichment data provider name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:provider ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the enrichment data was generated." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:created_time ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the attribute to which the enriched data pertains." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The enrichment type. For example: <code>location</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description "A short description of the enrichment data." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:short_desc ] ;
    sh:targetClass ocsf:Enrichment .

ocsf:Metadata a sh:NodeShape ;
    rdfs:comment "The Metadata object describes the metadata associated with the event." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Logger ;
            sh:description """An array of Logger objects that describe the pipeline of devices and logging
products between the event source and its eventual destination. Note, this
attribute can be used when there is a complex end-to-end path of event flow
and/or to track the chain of custody of the data.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ocsf:loggers ],
        [ sh:class ocsf:TransformationInfo ;
            sh:description """An array of transformation info that describes the mappings or transforms
applied to the data.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 27 ;
            sh:path ocsf:transformation_info_list ],
        [ sh:datatype xsd:long ;
            sh:description """The time when the event was transmitted from the logging device to it's next
destination.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:transmit_time ],
        [ sh:datatype xsd:string ;
            sh:description """A unique identifier assigned to the OCSF event. This ID is specific to the OCSF
event itself and is distinct from the original event identifier in the source
system (see <code>original_event_uid</code>).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description """The log system or component where the data originated. For example, a file
path, syslog server name or a Windows hostname and logging subsystem such as
Security.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:log_source ],
        [ sh:class ocsf:Timespan ;
            sh:description """The amount of time an event spent in a queue awaiting processing. In this case,
the value is the difference between <code>processed_time</code> and
<code>logged_time</code>. This duration is inclusive of all queues between the
originator of the event and the intended long-term storage destination of the
event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 26 ;
            sh:path ocsf:total_queued_duration ],
        [ sh:datatype xsd:long ;
            sh:description "The event processed time, such as an ETL operation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:processed_time ],
        [ sh:class ocsf:DataClassification ;
            sh:description """The Data Classification object includes information about data classification
levels and data category types.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 33 ;
            sh:path ocsf:data_classification ],
        [ sh:datatype xsd:string ;
            sh:description """The event log schema version of the original event. For example the syslog
version or the Cisco Log Schema version""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:log_version ],
        [ sh:datatype xsd:string ;
            sh:description """The level at which an event was logged. This can be log provider specific. For
example the audit level.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:log_level ],
        [ sh:datatype xsd:integer ;
            sh:description """The original size of the OCSF event data in kilobytes before any truncation
occurred. This field is typically populated when <code>is_truncated</code> is
<code>true</code> to indicate the full size of the original event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path ocsf:untruncated_size ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier assigned to the event in its original logging system
before transformation to OCSF format. This field preserves the source system's
native event identifier, enabling traceability back to the raw log entry. For
example, a Windows Event Record ID, a syslog message ID, a Splunk _cd value, or
a database transaction log sequence number.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:original_event_uid ],
        [ sh:class ocsf:DataClassification ;
            sh:description """A list of Data Classification objects, that include information about data
classification levels and data category types, identified by a classifier.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 34 ;
            sh:path ocsf:data_classifications ],
        [ sh:datatype xsd:string ;
            sh:description """The type of the event or finding as a subset of the <code>source</code> of the
event. This can be any distinguishing characteristic of the data. For example
'Management Events' or 'Device Penetration Test'.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description """Debug information about non-fatal issues with this OCSF event. Each issue is a
line in this string array.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:debug ],
        [ sh:class ocsf:KeyValueObject ;
            sh:description "The list of tags; <code>{key:value}</code> pairs associated to the event." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 24 ;
            sh:path ocsf:tags ],
        [ sh:datatype xsd:string ;
            sh:description """The list of labels attached to the event. For example: <code>["sample",
"dev"]</code>""" ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:labels ],
        [ sh:class ocsf:Extension ;
            sh:description "The schema extensions used to create the event." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:extensions ],
        [ sh:class ocsf:Extension ;
            sh:description "The schema extension used to create the event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:extension ],
        [ sh:datatype xsd:string ;
            sh:description """The identifier of the original event. For example the numerical Windows Event
Code or Cisco syslog code.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:event_code ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates whether the OCSF event data has been truncated due to size
limitations. When <code>true</code>, some event data may have been omitted to
fit within system constraints.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:is_truncated ],
        [ sh:datatype xsd:integer ;
            sh:description """Sequence number of the event. The sequence number is a value available in some
events, to make the exact ordering of events unambiguous, regardless of the
event time precision.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:sequence ],
        [ sh:datatype xsd:string ;
            sh:description """The original event time as reported by the event source. For example, the time
in the original format from system event log such as Syslog on Unix/Linux and
the System event file on Windows. Omit if event is generated instead of
collected via logs.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:original_time ],
        [ sh:datatype xsd:string ;
            sh:description """The source of the event or finding. This can be any distinguishing name for the
logical origin of the data — for example, 'CloudTrail Events', or a use case
like 'Attack Simulations' or 'Vulnerability Scans'.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:source ],
        [ sh:class ocsf:Product ;
            sh:description "The product that reported the event." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path ocsf:product ],
        [ sh:datatype xsd:string ;
            sh:description """The list of profiles used to create the event.  Profiles should be referenced
by their <code>name</code> attribute for core profiles, or
<code>extension/name</code> for profiles from extensions.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:profiles ],
        [ sh:datatype xsd:string ;
            sh:description """The version of the OCSF schema, using Semantic Versioning Specification (<a
target='_blank' href='https://semver.org'>SemVer</a>). For example:
<code>1.0.0.</code> Event consumers use the version to determine the available
event attributes.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path ocsf:version ],
        [ sh:datatype xsd:string ;
            sh:description "The unique tenant identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:tenant_uid ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the event was last modified or enriched." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:modified_time ],
        [ sh:datatype xsd:string ;
            sh:description """The logging provider or logging service that logged the event. For example AWS
CloudWatch or Splunk.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:log_provider ],
        [ sh:datatype xsd:string ;
            sh:description """A unique identifier used to correlate this OCSF event with other related OCSF
events, distinct from the event's <code>uid</code> value. This enables linking
multiple OCSF events that are part of the same activity, transaction, or
security incident across different systems or time periods.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:correlation_uid ],
        [ sh:datatype xsd:string ;
            sh:description """The event log name, typically for the consumer of the event. For example, the
storage bucket name, SIEM repository index name, etc.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:log_name ],
        [ sh:datatype xsd:long ;
            sh:description """<p>The time when the logging system collected and logged the event.</p>This
attribute is distinct from the event time in that event time typically contain
the time extracted from the original event. Most of the time, these two times
will be different.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:logged_time ],
        [ sh:class ocsf:Reporter ;
            sh:description "The entity from which the event or finding was first reported." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path ocsf:reporter ],
        [ sh:datatype xsd:string ;
            sh:description """The format of data in the log where the data originated. For example CSV, XML,
Windows Multiline, JSON, syslog or Cisco Log Schema.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:log_format ] ;
    sh:targetClass ocsf:Metadata .

ocsf:FirewallRule a sh:NodeShape ;
    rdfs:comment """The Firewall Rule object represents a specific rule within a firewall policy or
event. It contains information about a rule's configuration, properties, and
associated actions that define how network traffic is handled by the firewall.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The rule category." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:category ],
        [ sh:datatype xsd:string ;
            sh:description "The data in a request that rule matched. For example: '[\"10\",\"and\",\"1\"]'." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:match_details ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the rule that generated the event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:desc ],
        [ sh:datatype xsd:string ;
            sh:description "The rule version. For example: <code>1.1</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:version ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the rule that generated the event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description "The rule trigger condition for the rule. For example: SQL_INJECTION." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:condition ],
        [ sh:datatype xsd:string ;
            sh:description """The location of the matched data in the source which resulted in the triggered
firewall rule. For example: HEADER.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:match_location ],
        [ sh:datatype xsd:string ;
            sh:description "The rule type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description "The sensitivity of the firewall rule in the matched event. For example: HIGH." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:sensitivity ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the rule that generated the event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:integer ;
            sh:description "The rule response time duration, usually used for challenge completion time." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:duration ],
        [ sh:datatype xsd:integer ;
            sh:description "The rate limit for a rate-based rule." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:rate_limit ] ;
    sh:targetClass ocsf:FirewallRule .

ocsf:MalwareScanInfo a sh:NodeShape ;
    rdfs:comment """The malware scan information object describes characteristics, metadata of a
malware scanning job.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "The total size in bytes of all files that were scanned." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:size ],
        [ sh:datatype xsd:integer ;
            sh:description "The number of unique malware detected across all infected files." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:unique_malware_count ],
        [ sh:datatype xsd:string ;
            sh:description """The administrator-supplied or application-generated name of the scan. For
example: "Home office weekly user database scan", "Scan folders for viruses",
"Full system virus scan\"""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:name ],
        [ sh:description "The type id of the scan." ;
            sh:in ( "UNKNOWN" "MANUAL" "SCHEDULED" "UPDATED_CONTENT" "QUARANTINED_ITEMS" "ATTACHED_MEDIA" "USER_LOGON" "ELAM" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 9 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:string ;
            sh:description "The type of scan." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:integer ;
            sh:description "The total number of files identified as infected with malware during the scan." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:num_infected ],
        [ sh:datatype xsd:integer ;
            sh:description "The total number of files analyzed during the scan." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:num_files ],
        [ sh:datatype xsd:long ;
            sh:description "The timestamp indicating when the scan job began execution." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:start_time ],
        [ sh:datatype xsd:long ;
            sh:description "The timestamp indicating when the scan job completed execution." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:end_time ],
        [ sh:datatype xsd:integer ;
            sh:description "The total number of storage volumes examined during the malware scan." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:num_volumes ],
        [ sh:datatype xsd:string ;
            sh:description "The application-defined unique identifier assigned to an instance of a scan." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:uid ] ;
    sh:targetClass ocsf:MalwareScanInfo .

ocsf:Observable a sh:NodeShape ;
    rdfs:comment """The observable object is a pivot element that contains related information
found in many places in the event.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The observable value type name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier (<code>metadata.uid</code>) of the source OCSF event from
which this observable was extracted. This field enables linking observables
back to their originating event data when observables are stored in a separate
location or system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:event_uid ],
        [ sh:class ocsf:Reputation ;
            sh:description "Contains the original and normalized reputation scores." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:reputation ],
        [ sh:datatype xsd:string ;
            sh:description """The full name of the observable attribute. The <code>name</code> is a
pointer/reference to an attribute within the OCSF event data. For example:
<code>file.name</code>. Array attributes may be represented in one of three
ways. For example: <code>resources.uid</code>, <code>resources[].uid</code>,
<code>resources[0].uid</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:name ],
        [ sh:description "The observable value type identifier." ;
            sh:in ( "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 4 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The OCSF event type UID (<code>type_uid</code>) of the source event that this
observable was extracted from. This field enables filtering and categorizing
observables by their originating event type. For example: <code>300101</code>
for Network Activity (class_uid 3001) with activity_id 1.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:type_uid ],
        [ sh:datatype xsd:string ;
            sh:description """The value associated with the observable attribute. The meaning of the value
depends on the observable type.<br/>If the <code>name</code> refers to a scalar
attribute, then the <code>value</code> is the value of the attribute.<br/>If
the <code>name</code> refers to an object attribute, then the
<code>value</code> is not populated.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:value ] ;
    sh:targetClass ocsf:Observable .

ocsf:Osint a sh:NodeShape ;
    rdfs:comment """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:KillChainPhase ;
            sh:description "Lockheed Martin Kill Chain Phases pertinent to an indicator or OSINT analysis." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path ocsf:kill_chain ],
        [ sh:class ocsf:Vulnerability ;
            sh:description "Any vulnerabilities related to an indicator or OSINT analysis." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 45 ;
            sh:path ocsf:vulnerabilities ],
        [ sh:datatype xsd:anyURI ;
            sh:description """The source URL of an indicator or OSINT analysis, e.g., a URL back to a TIP,
report, or otherwise.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 34 ;
            sh:path ocsf:src_url ],
        [ sh:datatype xsd:long ;
            sh:description """The expiration date of the indicator, after which it is no longer considered
reliable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:expiration_time ],
        [ sh:datatype xsd:string ;
            sh:description """The actual indicator value in scope, e.g., a SHA-256 hash hexdigest or a domain
name.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path ocsf:value ],
        [ sh:class ocsf:DigitalSignature ;
            sh:description "Any digital signatures or hashes related to an indicator or OSINT analysis." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 33 ;
            sh:path ocsf:signatures ],
        [ sh:class ocsf:User ;
            sh:description """The identifier of the user, system, or organization that contributed the
indicator.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:creator ],
        [ sh:description "The OSINT indicator type ID." ;
            sh:in ( "UNKNOWN" "IP_ADDRESS" "DOMAIN" "HOSTNAME" "HASH" "URL" "USER_AGENT" "DIGITAL_CERTIFICATE" "EMAIL" "EMAIL_ADDRESS" "VULNERABILITY" "FILE" "REGISTRY_KEY" "REGISTRY_VALUE" "COMMAND_LINE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 40 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:string ;
            sh:description "A unique identifier assigned by an external system for cross-referencing." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:external_uid ],
        [ sh:class ocsf:Analytic ;
            sh:description "Any analytics related to an indicator or OSINT analysis." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 27 ;
            sh:path ocsf:related_analytics ],
        [ sh:datatype xsd:string ;
            sh:description "The OSINT indicator type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 39 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier for the OSINT object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path ocsf:uid ],
        [ sh:class ocsf:AutonomousSystem ;
            sh:description """Any pertinent autonomous system information related to an indicator or OSINT
analysis.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:autonomous_system ],
        [ sh:datatype xsd:integer ;
            sh:description "A numerical representation of the threat indicator’s risk level." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:risk_score ],
        [ sh:datatype xsd:string ;
            sh:description """The <code>name</code> is a pointer/reference to an attribute within the OCSF
event data. For example: file.name.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:name ],
        [ sh:class ocsf:ThreatActor ;
            sh:description """A threat actor is an individual or group that conducts malicious cyber
activities, often with financial, political, or ideological motives.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 37 ;
            sh:path ocsf:threat_actor ],
        [ sh:datatype xsd:string ;
            sh:description """Provides a reference to an external source of information related to the CTI
being represented. This may include a URL, a document, or some other type of
reference that provides additional context or information about the CTI.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:references ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path ocsf:malware ],
        [ sh:class ocsf:EmailAuth ;
            sh:description """Any email authentication information pertinent to an indicator or OSINT
analysis.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path ocsf:email_auth ],
        [ sh:class ocsf:Attack ;
            sh:description """MITRE ATT&CK Tactics, Techniques, and/or Procedures (TTPs) pertinent to an
indicator or OSINT analysis.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:attacks ],
        [ sh:datatype xsd:string ;
            sh:description "Categorizes the threat indicator based on its functional or operational role." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:category ],
        [ sh:class ocsf:Whois ;
            sh:description "Any pertinent WHOIS information related to an indicator or OSINT analysis." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 46 ;
            sh:path ocsf:whois ],
        [ sh:datatype xsd:long ;
            sh:description """The timestamp indicating when the associated indicator or intelligence was
added to the system or repository.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 42 ;
            sh:path ocsf:uploaded_time ],
        [ sh:description """The normalized confidence refers to the accuracy of collected information
related to the OSINT or how pertinent an indicator or analysis is to a specific
event or finding. A low confidence means that the information collected or
analysis conducted lacked detail or is not accurate enough to qualify an
indicator as fully malicious.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path ocsf:confidence_id ],
        [ sh:description """Specifies the type of detection pattern used to identify the associated threat
indicator.""" ;
            sh:in ( "UNKNOWN" "STIX" "PCRE" "SIGMA" "SNORT" "SURICATA" "YARA" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 13 ;
            sh:path ocsf:detection_pattern_type_id ],
        [ sh:datatype xsd:string ;
            sh:description "Tags or keywords associated with the indicator to enhance searchability." ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:labels ],
        [ sh:datatype xsd:string ;
            sh:description "Analyst commentary or source commentary about an indicator or OSINT analysis." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:comment ],
        [ sh:datatype xsd:string ;
            sh:description "The vendor name of a tool which generates intelligence or provides indicators." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 44 ;
            sh:path ocsf:vendor_name ],
        [ sh:class ocsf:Reputation ;
            sh:description """Related reputational analysis from third-party engines and analysts for a given
indicator or OSINT analysis.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 28 ;
            sh:path ocsf:reputation ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence of an indicator being malicious and/or pertinent, normalized to
the caption of the confidence_id value. In the case of 'Other', it is defined
by the event source or analyst.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:confidence ],
        [ sh:datatype xsd:long ;
            sh:description "The timestamp when the indicator was initially created or identified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:created_time ],
        [ sh:datatype xsd:string ;
            sh:description "The specific detection pattern or signature associated with the indicator." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:detection_pattern ],
        [ sh:class ocsf:Campaign ;
            sh:description """The campaign object describes details about the campaign that was the source of
the activity.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:campaign ],
        [ sh:datatype xsd:string ;
            sh:description """Any pertinent subdomain information - such as those generated by a Domain
Generation Algorithm - related to an indicator or OSINT analysis.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path ocsf:subdomains ],
        [ sh:datatype xsd:long ;
            sh:description "The timestamp of the last modification or update to the indicator." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:modified_time ],
        [ sh:class ocsf:File ;
            sh:description "Any pertinent file information related to an indicator or OSINT analysis." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path ocsf:file ],
        [ sh:datatype xsd:string ;
            sh:description """The detection pattern type, normalized to the caption of the
detection_pattern_type_id value. In the case of 'Other', it is defined by the
event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:detection_pattern_type ],
        [ sh:datatype xsd:string ;
            sh:description """Represents the severity level of the threat indicator, typically reflecting its
potential impact or damage.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path ocsf:severity ],
        [ sh:description """The normalized severity level of the threat indicator, typically reflecting its
potential impact or damage.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 32 ;
            sh:path ocsf:severity_id ],
        [ sh:class ocsf:Script ;
            sh:description "Any pertinent script information related to an indicator or OSINT analysis." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 30 ;
            sh:path ocsf:script ],
        [ sh:class ocsf:DnsAnswer ;
            sh:description """Any pertinent DNS answers information related to an indicator or OSINT
analysis.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:answers ],
        [ sh:datatype xsd:string ;
            sh:description """A grouping of adversarial behaviors and resources believed to be associated
with specific threat actors or campaigns. Intrusion sets often encompass
multiple campaigns and are used to organize related activities under a common
label.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:intrusion_sets ],
        [ sh:class ocsf:Email ;
            sh:description "Any email information pertinent to an indicator or OSINT analysis." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ocsf:email ],
        [ sh:description """The <a target='_blank' href='https://www.first.org/tlp/'>Traffic Light
Protocol</a> was created to facilitate greater sharing of potentially sensitive
information and more effective collaboration. TLP provides a simple and
intuitive schema for indicating with whom potentially sensitive information can
be shared.""" ;
            sh:in ( "TLP_AMBER" "TLP_AMBER_STRICT" "TLP_CLEAR" "TLP_GREEN" "TLP_RED" "TLP_WHITE" ) ;
            sh:maxCount 1 ;
            sh:order 38 ;
            sh:path ocsf:tlp ],
        [ sh:datatype xsd:string ;
            sh:description "A CIDR or network block related to an indicator or OSINT analysis." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 36 ;
            sh:path ocsf:subnet ;
            sh:pattern "^((\\d{1,3}\\.){3}\\d{1,3}|[0-9a-fA-F:]{2,39})/(\\d|[1-9]\\d|1[0-1]\\d|12[0-8])$" ],
        [ sh:class ocsf:Location ;
            sh:description """Any pertinent geolocation information related to an indicator or OSINT
analysis.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path ocsf:location ],
        [ sh:datatype xsd:string ;
            sh:description """A detailed explanation of the indicator, including its context, purpose, and
relevance.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:desc ] ;
    sh:targetClass ocsf:Osint .

ocsf:Authorization a sh:NodeShape ;
    rdfs:comment """The Authorization Result object provides details about the authorization
outcome and associated policies related to activity.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Authorization Result/outcome, e.g. allowed, denied." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:decision ],
        [ sh:class ocsf:Policy ;
            sh:description "Details about the Identity/Access management policies that are applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:policy ] ;
    sh:targetClass ocsf:Authorization .

ocsf:Malware a sh:NodeShape ;
    rdfs:comment """The Malware object describes the classification of known malicious software,
which is intentionally designed to cause damage to a computer, server, client,
or computer network.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The name or identifier of the security solution or service that provided the
malware detection information.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:provider ],
        [ sh:datatype xsd:string ;
            sh:description "The malware name, as reported by the detection engine." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description """A unique identifier for the specific malware instance, as assigned by the
detection engine (e.g., virus signature ID or IPS rule ID).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description """The severity of the malware, normalized to the captions of the
<code>severity_id</code> values. In the case of 'Other', they are defined by
the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:severity ],
        [ sh:datatype xsd:string ;
            sh:description "The filesystem path of the malware that was observed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:path ],
        [ sh:description "The normalized identifier of the malware severity." ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 9 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:integer ;
            sh:description "The number of files that were identified to be infected by the malware." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:num_infected ],
        [ sh:description "The list of normalized identifiers of the malware classifications." ;
            sh:in ( "ADWARE" "BACKDOOR" "BOT" "BOOTKIT" "DDOS" "DOWNLOADER" "DROPPER" "EXPLOIT_KIT" "KEYLOGGER" "RANSOMWARE" "REMOTE_ACCESS_TROJAN" "RESOURCE_EXPLOITATION" "ROGUE_SECURITY_SOFTWARE" "ROOTKIT" "SCREEN_CAPTURE" "SPYWARE" "TROJAN" "VIRUS" "WEBSHELL" "WIPER" "WORM" "UNKNOWN" "OTHER" ) ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path ocsf:classification_ids ],
        [ sh:class ocsf:Cve ;
            sh:description """The list of Common Vulnerabilities and Exposures (CVE) identifiers associated
with the malware. Reference: <a target='_blank'
href='https://cve.mitre.org/'>CVE</a>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:cves ],
        [ sh:datatype xsd:string ;
            sh:description """The list of malware classifications, normalized to the captions of the
<code>classification_ids</code> values. In the case of 'Other', they are
defined by the event source.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:classifications ],
        [ sh:class ocsf:File ;
            sh:description """The list of file objects representing files that were identified as infected by
the malware.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:files ] ;
    sh:targetClass ocsf:Malware .

ocsf:Actor a sh:NodeShape ;
    rdfs:comment """The Actor object contains details about the user, role, application, service,
or process that initiated or performed a specific activity. Note that Actor is
not the threat actor of a campaign but may be part of a campaign.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Idp ;
            sh:description "This object describes details about the Identity Provider used." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:idp ],
        [ sh:class ocsf:User ;
            sh:description """The user that initiated the activity or the user context from which the
activity was initiated.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:user ],
        [ sh:class ocsf:Session ;
            sh:description "The user session from which the activity was initiated." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:session ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the service that invoked the activity as described in the event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:invoked_by ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier of the client application or service that initiated the
activity. This can be in conjunction with the <code>user</code> if present.
Note that <code>app_name</code> is distinct from the <code>process.pid</code>
or <code>process.uid</code> if present.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:app_uid ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:authorizations ],
        [ sh:datatype xsd:string ;
            sh:description """The client application or service that initiated the activity. This can be in
conjunction with the <code>user</code> if present.  Note that
<code>app_name</code> is distinct from the <code>process</code> if present.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:app_name ],
        [ sh:class ocsf:Process ;
            sh:description "The process that initiated the activity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:process ] ;
    sh:targetClass ocsf:Actor .

ocsf:Cloud a sh:NodeShape ;
    rdfs:comment """The Cloud object describes the cloud computing environment where an event or
finding originated. It provides comprehensive context about the cloud
infrastructure, including the cloud service provider, account or subscription
details, organizational structure, geographic regions, availability zones, and
logical partitions.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The unique identifier of a Cloud project." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:project_uid ],
        [ sh:datatype xsd:string ;
            sh:description """The logical grouping or isolated segment within a cloud provider's
infrastructure where the event or finding was created, often used for
compliance, governance, or regional
separation.<br/><br/><strong>Examples:</strong><ul><li><strong>AWS:</strong>
Partition where the event occurred (<code>aws</code>, <code>aws-cn</code>,
<code>aws-us-gov</code>)</li><li><strong>Azure:</strong> Cloud environment
where the event occurred (<code>AzureCloud</code>,
<code>AzureUSGovernment</code>, <code>AzureChinaCloud</code>)</li></ul>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:cloud_partition ],
        [ sh:datatype xsd:string ;
            sh:description """The availability zone in the cloud region where the event or finding was
created, as defined by the cloud
provider.<br/><br/><strong>Examples:</strong><ul><li><strong>AWS:</strong>
Availability zone where the event occurred (<code>us-east-1a</code>,
<code>us-east-1b</code>)</li><li><strong>Azure:</strong> Availability zone
where the event occurred (<code>1</code>, <code>2</code>, <code>3</code> within
a region)</li><li><strong>GCP:</strong> Availability zone where the event
occurred (<code>us-central1-a</code>,
<code>us-central1-b</code>)</li><li><strong>Oracle Cloud:</strong> Availability
zone where the event occurred (<code>AD-1</code>, <code>AD-2</code>,
<code>AD-3</code>)</li></ul>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:zone ],
        [ sh:datatype xsd:string ;
            sh:description """The unique name of the Cloud services provider where the event or finding was
created. Examples include AWS, Azure, GCP (Google Cloud Platform), Oracle
Cloud, IBM Cloud, Alibaba Cloud, or other public, private, or hybrid cloud
providers.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:provider ],
        [ sh:datatype xsd:string ;
            sh:description """The cloud region where the event or finding was created, as defined by the
cloud
provider.<br/><br/><strong>Examples:</strong><ul><li><strong>AWS:</strong>
Region where the event occurred (<code>us-east-1</code>,
<code>eu-west-1</code>)</li><li><strong>Azure:</strong> Region where the event
occurred (<code>East US</code>, <code>West
Europe</code>)</li><li><strong>GCP:</strong> Region where the event occurred
(<code>us-central1</code>, <code>europe-west1</code>)</li><li><strong>Oracle
Cloud:</strong> Region where the event occurred (<code>us-ashburn-1</code>,
<code>uk-london-1</code>)</li></ul>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:region ],
        [ sh:class ocsf:Account ;
            sh:description """The Account object containing details about the cloud account, subscription, or
billing unit where the event or finding was created. This object includes
properties such as the account name, unique identifier, type, labels, and
tags.<br/><br/><strong>Examples:</strong><ul><li><strong>AWS:</strong> Account
object with <code>name</code>, <code>uid</code> (Account ID),
<code>type</code>, and other account properties</li><li><strong>Azure:</strong>
Subscription object with <code>name</code>, <code>uid</code> (Subscription ID),
<code>type</code>, and subscription metadata</li><li><strong>GCP:</strong>
Project object with <code>name</code>, <code>uid</code> (Project ID),
<code>type</code>, and project attributes</li><li><strong>Oracle
Cloud:</strong> Compartment object with <code>name</code>, <code>uid</code>
(Tenancy OCID), <code>type</code>, and compartment details</li></ul>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:account ],
        [ sh:class ocsf:Organization ;
            sh:description """The Organization object containing details about the organizational unit or
management structure that governs the account, subscription, or project where
the event or finding was created. This object includes properties such as the
organization name, unique identifier, type, and other organizational
metadata.<br/><br/><strong>Examples:</strong><ul><li><strong>AWS:</strong>
Organization object with <code>name</code>, <code>uid</code> (Organization ID),
<code>type</code>, and other organizational
properties</li><li><strong>Azure:</strong> Management Group object with
<code>name</code>, <code>uid</code> (Management Group ID), <code>type</code>,
and management group metadata</li><li><strong>GCP:</strong> Organization object
with <code>name</code>, <code>uid</code> (Organization ID), <code>type</code>,
and organizational attributes</li><li><strong>Oracle Cloud:</strong> Tenancy
object with <code>name</code>, <code>uid</code> (Tenancy OCID),
<code>type</code>, and tenancy details</li></ul>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:org ] ;
    sh:targetClass ocsf:Cloud .

ocsf:Api a sh:NodeShape ;
    rdfs:comment """The API, or Application Programming Interface, object represents  information
pertaining to an API request and response.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Verb/Operation associated with the request" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:operation ],
        [ sh:class ocsf:Service ;
            sh:description "The information pertaining to the API service." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:service ],
        [ sh:class ocsf:Token ;
            sh:description """The API or client token used to authenticate or authorize the API request. This
attribute contains the base <code>token</code> object that represents: (1)
IdP-issued client tokens (type_id: 6) such as Okta API tokens or Microsoft
Entra ID Application Registration client secrets, or (2) generic API
tokens/keys (type_id: 7) used for SaaS application authentication. Use this
attribute when the API request was authenticated using a token that should be
tracked as part of the API activity event. Note: Protocol-specific
authentication tokens (Kerberos, OIDC, SAML) should be represented using
<code>authentication_token</code> in authentication events, not in API activity
events.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:token ],
        [ sh:class ocsf:Request ;
            sh:description "Details pertaining to the API request." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:request ],
        [ sh:class ocsf:Group ;
            sh:description "The information pertaining to the API group." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:group ],
        [ sh:class ocsf:Response ;
            sh:description "Details pertaining to the API response." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:response ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the API service." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:version ] ;
    sh:targetClass ocsf:Api .

ocsf:Attack a sh:NodeShape ;
    rdfs:comment """The MITRE ATT&CK® & ATLAS™ object describes the tactic, technique,
sub-technique & mitigation associated to an attack.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:SubTechnique ;
            sh:description """The Sub-technique object describes the MITRE ATT&CK® or ATLAS™ Sub-technique ID
and/or name associated to an attack.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:sub_technique ],
        [ sh:datatype xsd:string ;
            sh:description "The ATT&CK® or ATLAS™ Matrix version." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:version ],
        [ sh:class ocsf:Tactic ;
            sh:description """The Tactic object describes the tactic ID and/or tactic name that are
associated with the attack technique, as defined by <a target='_blank'
href='https://attack.mitre.org/wiki/ATT&CK_Matrix'>ATT&CK® Matrix</a>.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:tactics ],
        [ sh:class ocsf:Technique ;
            sh:description """The Technique object describes the MITRE ATT&CK® or ATLAS™ Technique ID and/or
name associated to an attack.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:technique ],
        [ sh:class ocsf:Tactic ;
            sh:description """The Tactic object describes the MITRE ATT&CK® or ATLAS™ Tactic ID and/or name
that is associated to an attack.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:tactic ],
        [ sh:class ocsf:Mitigation ;
            sh:description """The Mitigation object describes the MITRE ATT&CK® or ATLAS™ Mitigation ID
and/or name that is associated to an attack.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:mitigation ] ;
    sh:targetClass ocsf:Attack .

ocsf:Object a sh:NodeShape ;
    rdfs:comment """An unordered collection of attributes. It defines a set of attributes available
in all objects. It can be also used as a generic object to log objects that are
not otherwise defined by the schema.""" ;
    sh:closed true ;

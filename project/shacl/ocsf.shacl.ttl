techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 39 ;
            sh:path ocsf:attacks ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 21 ;
            sh:path ocsf:severity_id ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path ocsf:metadata ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:category_name ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path ocsf:observables ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:type_uid ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:risk_details ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 34 ;
            sh:path ocsf:actor ],
        [ sh:datatype xsd:string ;
            sh:description "The result of the query." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:query_result ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 53 ;
            sh:path ocsf:risk_level_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:timezone_offset ],
        [ sh:description "The normalized identifier of the query result." ;
            sh:in ( "UNKNOWN" "EXISTS" "PARTIAL" "DOES_NOT_EXIST" "ERROR" "UNSUPPORTED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 4 ;
            sh:path ocsf:query_result_id ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:status_detail ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 9 ;
            sh:path ocsf:class_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:raw_data ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 7 ;
            sh:path ocsf:category_uid ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path ocsf:confidence_score ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 49 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 38 ;
            sh:path ocsf:action_id ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "QUERY" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path ocsf:activity_id ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path ocsf:api ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:class_name ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 46 ;
            sh:path ocsf:firewall_rule ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 31 ;
            sh:path ocsf:unmapped ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:duration ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:raw_data_size ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path ocsf:osint ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:start_time ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:message ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:enrichments ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 37 ;
            sh:path ocsf:action ],
        [ sh:class ocsf:File ;
            sh:description "The file that is the target of the query." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:file ] ;
    sh:targetClass ocsf:FileQuery .

ocsf:FileRemediationActivity a sh:NodeShape ;
    rdfs:comment """File Remediation Activity events report on attempts at remediating files. It
follows the MITRE countermeasures defined by the D3FEND™ <a target='_blank'
href='https://d3fend.mitre.org/'>Matrix</a>. Sub-techniques will include File,
such as File Removal or Restore File.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 40 ;
            sh:path ocsf:attacks ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 9 ;
            sh:path ocsf:category_uid ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 41 ;
            sh:path ocsf:authorizations ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path ocsf:enrichments ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:category_name ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 23 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:raw_data_size ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 34 ;
            sh:path ocsf:cloud ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path ocsf:observables ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:status_detail ],
        [ sh:description """Matches the MITRE D3FEND™ Tactic. Note: the Model and Detect Tactics are not
supported as remediations by the OCSF Remediation event class.""" ;
            sh:in ( "ISOLATE" "EVICT" "RESTORE" "HARDEN" "DETECT" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path ocsf:activity_id ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:class_name ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 43 ;
            sh:path ocsf:confidence_id ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 39 ;
            sh:path ocsf:action_id ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:start_time ],
        [ sh:class ocsf:Scan ;
            sh:description "The remediation scan that pertains to this event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:scan ],
        [ sh:class ocsf:D3fend ;
            sh:description "The MITRE D3FEND™ Matrix Countermeasures associated with a remediation." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:countermeasures ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:duration ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 53 ;
            sh:path ocsf:risk_level ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 44 ;
            sh:path ocsf:confidence_score ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:count ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 38 ;
            sh:path ocsf:action ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:type_name ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "DOES_NOT_EXIST" "PARTIAL" "UNSUPPORTED" "ERROR" "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path ocsf:status_id ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path ocsf:metadata ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 52 ;
            sh:path ocsf:risk_details ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 35 ;
            sh:path ocsf:actor ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 11 ;
            sh:path ocsf:class_uid ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path ocsf:is_alert ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:severity ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 33 ;
            sh:path ocsf:api ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the remediation command that pertains to this event." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:command_uid ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:status_code ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 42 ;
            sh:path ocsf:confidence ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 50 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 55 ;
            sh:path ocsf:risk_score ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path ocsf:unmapped ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 47 ;
            sh:path ocsf:firewall_rule ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:end_time ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 46 ;
            sh:path ocsf:disposition_id ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 51 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 45 ;
            sh:path ocsf:disposition ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:activity_name ],
        [ sh:class ocsf:Remediation ;
            sh:description "Describes the recommended remediation steps to address identified issue(s)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:remediation ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:time ],
        [ sh:class ocsf:File ;
            sh:description "The file that pertains to the remediation event." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:file ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path ocsf:type_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:raw_data ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 54 ;
            sh:path ocsf:risk_level_id ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path ocsf:device ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 49 ;
            sh:path ocsf:malware ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:timezone_offset ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:message ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 37 ;
            sh:path ocsf:osint ] ;
    sh:targetClass ocsf:FileRemediationActivity .

ocsf:Finding a sh:NodeShape ;
    rdfs:comment """The Finding event is a generic event that defines a set of attributes available
in the Findings category.""" ;
    sh:closed true ;
    sh:ignoredProperties ( ocsf:compliance ocsf:access_analysis_result ocsf:file ocsf:databucket ocsf:identity_activity_metrics ocsf:evidences ocsf:permission_analysis_results ocsf:data_security ocsf:applications ocsf:table ocsf:remediation ocsf:user ocsf:database ocsf:dst_endpoint ocsf:resource rdf:type ocsf:vulnerabilities ocsf:anomaly_analyses ocsf:resources ocsf:application ocsf:src_endpoint ) ;
    sh:property [ sh:class ocsf:Group ;
            sh:description "The details of the group assigned to an Incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ocsf:assignee_group ],
        [ sh:datatype xsd:string ;
            sh:description """The impact , normalized to the caption of the impact_id value. In the case of
'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:impact ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:confidence_score ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 50 ;
            sh:path ocsf:actor ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path ocsf:duration ],
        [ sh:class ocsf:Device ;
            sh:description """Describes the affected device/host. If applicable, it can be used in
conjunction with <code>Resource(s)</code>. <p> e.g. Specific details about an
AWS EC2 instance, that is affected by the Finding.</p>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:device ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A Url link used to access the original incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:src_url ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:string ;
            sh:description """The normalized status of the Finding set by the consumer normalized to the
caption of the status_id value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 44 ;
            sh:path ocsf:timezone_offset ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 29 ;
            sh:path ocsf:class_uid ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 60 ;
            sh:path ocsf:malware ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:class_name ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 40 ;
            sh:path ocsf:severity_id ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 62 ;
            sh:path ocsf:policy ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 51 ;
            sh:path ocsf:osint ],
        [ sh:class ocsf:FindingInfo ;
            sh:description "Describes the supporting information about a generated finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:finding_info ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 57 ;
            sh:path ocsf:disposition_id ],
        [ sh:datatype xsd:string ;
            sh:description "The finding activity name, as defined by the <code>activity_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:activity_name ],
        [ sh:datatype xsd:long ;
            sh:description "The time of the least recent event included in the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:start_time ],
        [ sh:datatype xsd:integer ;
            sh:description "The impact as an integer value of the finding, valid range 0-100." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:impact_score ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 38 ;
            sh:path ocsf:raw_data_size ],
        [ sh:datatype xsd:string ;
            sh:description "A user provided comment about the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:comment ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 45 ;
            sh:path ocsf:type_name ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:count ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 37 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 42 ;
            sh:path ocsf:status_detail ],
        [ sh:description """The normalized impact of the incident or finding. Per NIST, this is the
magnitude of harm that can be expected to result from the consequences of
unauthorized disclosure, modification, destruction, or loss of information or
information system availability.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 16 ;
            sh:path ocsf:impact_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 46 ;
            sh:path ocsf:type_uid ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 63 ;
            sh:path ocsf:risk_details ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 58 ;
            sh:path ocsf:firewall_rule ],
        [ sh:datatype xsd:string ;
            sh:description """The priority, normalized to the caption of the priority_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:priority ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 65 ;
            sh:path ocsf:risk_level_id ],
        [ sh:datatype xsd:boolean ;
            sh:description "A determination based on analytics as to whether a potential breach was found." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:is_suspected_breach ],
        [ sh:description "The normalized status identifier of the Finding, set by the consumer." ;
            sh:in ( "NEW" "IN_PROGRESS" "SUPPRESSED" "RESOLVED" "ARCHIVED" "DELETED" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 11 ;
            sh:path ocsf:status_id ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:category_name ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 66 ;
            sh:path ocsf:risk_score ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 61 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 54 ;
            sh:path ocsf:attacks ],
        [ sh:description "The normalized identifier of the finding activity." ;
            sh:in ( "CREATE" "UPDATE" "CLOSE" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path ocsf:activity_id ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path ocsf:status_code ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:confidence ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 35 ;
            sh:path ocsf:observables ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 64 ;
            sh:path ocsf:risk_level ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path ocsf:enrichments ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 47 ;
            sh:path ocsf:unmapped ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 49 ;
            sh:path ocsf:cloud ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path ocsf:confidence_id ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 59 ;
            sh:path ocsf:is_alert ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 39 ;
            sh:path ocsf:severity ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 52 ;
            sh:path ocsf:action ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 34 ;
            sh:path ocsf:metadata ],
        [ sh:class ocsf:User ;
            sh:description "The details of the user assigned to an Incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:assignee ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 27 ;
            sh:path ocsf:category_uid ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 56 ;
            sh:path ocsf:disposition ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path ocsf:time ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 36 ;
            sh:path ocsf:raw_data ],
        [ sh:description "The normalized verdict of an Incident." ;
            sh:in ( "UNKNOWN" "FALSE_POSITIVE" "TRUE_POSITIVE" "DISREGARD" "SUSPICIOUS" "BENIGN" "TEST" "INSUFFICIENT_DATA" "SECURITY_RISK" "MANAGED_EXTERNALLY" "DUPLICATE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 25 ;
            sh:path ocsf:verdict_id ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 53 ;
            sh:path ocsf:action_id ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 55 ;
            sh:path ocsf:authorizations ],
        [ sh:class ocsf:VendorAttributes ;
            sh:description """The Vendor Attributes object can be used to represent values of attributes
populated by the Vendor/Finding Provider. It can help distinguish between the
vendor-provided values and consumer-updated values, of key attributes like
<code>severity_id</code>.<br>The original finding producer should not populate
this object. It should be populated by consuming systems that support data
mutability.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:vendor_attributes ],
        [ sh:class ocsf:Ticket ;
            sh:description "The linked ticket in the ticketing system." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path ocsf:ticket ],
        [ sh:datatype xsd:long ;
            sh:description "The time of the most recent event included in the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:end_time ],
        [ sh:datatype xsd:string ;
            sh:description "The verdict assigned to an Incident finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:verdict ],
        [ sh:description """The normalized priority. Priority identifies the relative importance of the
incident or finding. It is a measurement of urgency.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 20 ;
            sh:path ocsf:priority_id ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 48 ;
            sh:path ocsf:api ],
        [ sh:class ocsf:Ticket ;
            sh:description """The associated ticket(s) in the ticketing system. Each ticket contains details
like ticket ID, status, etc.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path ocsf:tickets ] ;
    sh:targetClass ocsf:Finding .

ocsf:FolderQuery a sh:NodeShape ;
    rdfs:comment """Folder Query events report information about folders that are present on the
system.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:class_name ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 52 ;
            sh:path ocsf:risk_level ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "QUERY" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path ocsf:activity_id ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 40 ;
            sh:path ocsf:authorizations ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 34 ;
            sh:path ocsf:actor ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:duration ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 31 ;
            sh:path ocsf:unmapped ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 33 ;
            sh:path ocsf:cloud ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 49 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:raw_data_size ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:timezone_offset ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:start_time ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 53 ;
            sh:path ocsf:risk_level_id ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 39 ;
            sh:path ocsf:attacks ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:count ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 37 ;
            sh:path ocsf:action ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 26 ;
            sh:path ocsf:status_id ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 21 ;
            sh:path ocsf:severity_id ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 42 ;
            sh:path ocsf:confidence_id ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:type_name ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:time ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:severity ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:status_code ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:is_alert ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:risk_details ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:end_time ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 48 ;
            sh:path ocsf:malware ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path ocsf:confidence ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 38 ;
            sh:path ocsf:action_id ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 45 ;
            sh:path ocsf:disposition_id ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:status ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 46 ;
            sh:path ocsf:firewall_rule ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 9 ;
            sh:path ocsf:class_uid ],
        [ sh:description "The normalized identifier of the query result." ;
            sh:in ( "UNKNOWN" "EXISTS" "PARTIAL" "DOES_NOT_EXIST" "ERROR" "UNSUPPORTED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 4 ;
            sh:path ocsf:query_result_id ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:status_detail ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path ocsf:osint ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:category_name ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path ocsf:confidence_score ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:activity_name ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:type_uid ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 54 ;
            sh:path ocsf:risk_score ],
        [ sh:datatype xsd:string ;
            sh:description "The result of the query." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:query_result ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:raw_data ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 35 ;
            sh:path ocsf:device ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:enrichments ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path ocsf:observables ],
        [ sh:class ocsf:QueryInfo ;
            sh:description "The search details associated with the query request." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:query_info ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 50 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:message ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 7 ;
            sh:path ocsf:category_uid ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path ocsf:metadata ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path ocsf:api ],
        [ sh:class ocsf:File ;
            sh:description "The folder that is the target of the query." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:folder ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 44 ;
            sh:path ocsf:disposition ] ;
    sh:targetClass ocsf:FolderQuery .

ocsf:FtpActivity a sh:NodeShape ;
    rdfs:comment """File Transfer Protocol (FTP) Activity events report file transfers between a
server and a client as seen on the network.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 55 ;
            sh:path ocsf:unmapped ],
        [ sh:class ocsf:HttpRequest ;
            sh:description "The HTTP Request from the proxy server to the remote server." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 24 ;
            sh:path ocsf:proxy_http_request ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the data affiliated with the command." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The FTP command." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:command ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:activity_name ],
        [ sh:class ocsf:Packet ;
            sh:description "The list of packet objects describing captured network packets." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path ocsf:packet_list ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 54 ;
            sh:path ocsf:type_uid ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 40 ;
            sh:path ocsf:observables ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 66 ;
            sh:path ocsf:confidence_id ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 70 ;
            sh:path ocsf:firewall_rule ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 56 ;
            sh:path ocsf:api ],
        [ sh:datatype xsd:string ;
            sh:description "The type of FTP network connection (e.g. active, passive)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:type ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "PUT" "GET" "POLL" "DELETE" "RENAME" "LIST" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path ocsf:activity_id ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 31 ;
            sh:path ocsf:category_uid ],
        [ sh:datatype xsd:integer ;
            sh:description "The list of return codes to the FTP command." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:codes ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 36 ;
            sh:path ocsf:end_time ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 37 ;
            sh:path ocsf:enrichments ],
        [ sh:datatype xsd:string ;
            sh:description "The list of responses to the FTP command." ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:command_responses ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 46 ;
            sh:path ocsf:start_time ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 38 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 61 ;
            sh:path ocsf:action ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 73 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 77 ;
            sh:path ocsf:risk_level_id ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 57 ;
            sh:path ocsf:cloud ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 67 ;
            sh:path ocsf:confidence_score ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path ocsf:raw_data_size ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:time ],
        [ sh:class ocsf:Tls ;
            sh:description "The Transport Layer Security (TLS) attributes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path ocsf:tls ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 45 ;
            sh:path ocsf:severity_id ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 39 ;
            sh:path ocsf:metadata ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 69 ;
            sh:path ocsf:disposition_id ],
        [ sh:class ocsf:NetworkProxy ;
            sh:description "The proxy (server) in a network connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path ocsf:proxy ],
        [ sh:class ocsf:HttpResponse ;
            sh:description "The HTTP Response from the remote server to the proxy server." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 25 ;
            sh:path ocsf:proxy_http_response ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 44 ;
            sh:path ocsf:severity ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 58 ;
            sh:path ocsf:actor ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path ocsf:raw_data ],
        [ sh:class ocsf:LoadBalancer ;
            sh:description """The Load Balancer object contains information related to the device that is
distributing incoming traffic to specified destinations.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 28 ;
            sh:path ocsf:load_balancer ],
        [ sh:datatype xsd:string ;
            sh:description """The application-layer (Layer 7) protocol name identified by deep packet inspection or packet parsing (e.g., <code>https</code>, <code>quic</code>, <code>ssh</code>, <code>dns</code>), expressed as an IANA-registered service name from the IANA Service Name and Transport Protocol Port Number Registry.

<p><b>Note:</b> Port numbers alone are not always a reliable indicator of the actual application protocol in use.</p>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:app_protocol_name ],
        [ sh:datatype xsd:string ;
            sh:description """Indicates whether the source network endpoint, destination network endpoint, or
neither served as the observation point for the activity. The value is
normalized to the caption of the <code>observation_point_id</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:observation_point ],
        [ sh:class ocsf:NetworkTraffic ;
            sh:description """The network traffic refers to the amount of data moving across a network, from
proxy to remote server at a given point of time.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 27 ;
            sh:path ocsf:proxy_traffic ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 78 ;
            sh:path ocsf:risk_score ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 64 ;
            sh:path ocsf:authorizations ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 60 ;
            sh:path ocsf:osint ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 65 ;
            sh:path ocsf:confidence ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 52 ;
            sh:path ocsf:timezone_offset ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:status ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 59 ;
            sh:path ocsf:device ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 71 ;
            sh:path ocsf:is_alert ],
        [ sh:class ocsf:NetworkTraffic ;
            sh:description """The cumulative (running total) network traffic aggregated from the start of a
flow or session. Use when reporting: (1) total accumulated bytes/packets since
flow initiation, (2) combined aggregation models where both incremental deltas
and running totals are reported together (populate both <code>traffic</code>
for the delta and this attribute for the cumulative total), or (3) final
summary metrics when a long-lived connection closes. This represents the sum of
all activity from flow start to the current observation, not a delta or
point-in-time value.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:cumulative_traffic ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 34 ;
            sh:path ocsf:count ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 76 ;
            sh:path ocsf:risk_level ],
        [ sh:class ocsf:File ;
            sh:description "The file that is the target of the FTP activity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:file ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 49 ;
            sh:path ocsf:status_detail ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description "The initiator (client) of the network connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path ocsf:src_endpoint ],
        [ sh:class ocsf:NetworkConnectionInfo ;
            sh:description "The connection information from the proxy server to the remote server." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path ocsf:proxy_connection_info ],
        [ sh:datatype xsd:string ;
            sh:description """The network application name identified by tools such as NBAR or App ID (e.g.,
youtube, facebook, webex). This represents a specific network application that
uses standard protocols (such as https or quic) to deliver its service.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:app_name ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 75 ;
            sh:path ocsf:risk_details ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path ocsf:class_name ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 63 ;
            sh:path ocsf:attacks ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 62 ;
            sh:path ocsf:action_id ],
        [ sh:class ocsf:Tls ;
            sh:description "The TLS protocol negotiated between the proxy server and the remote server." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 26 ;
            sh:path ocsf:proxy_tls ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description "The responder (server) in a network connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:dst_endpoint ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 50 ;
            sh:path ocsf:status_id ],
        [ sh:description """The normalized identifier of the observation point. The observation point
identifier indicates whether the source network endpoint, destination network
endpoint, or neither served as the observation point for the activity.""" ;
            sh:in ( "UNKNOWN" "SOURCE" "DESTINATION" "NEITHER" "BOTH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 16 ;
            sh:path ocsf:observation_point_id ],
        [ sh:datatype xsd:integer ;
            sh:description "The dynamic port established for impending data transfers." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:port ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description """The network endpoint that observes or inspects network traffic as a third-party
system, used when the observer is neither the source nor the destination of the
communication (when <code>observation_point_id</code> = 3). Examples include
network taps, span ports, inline security devices, or packet capture systems
that monitor traffic between other endpoints.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ocsf:network_observation_point ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:category_name ],
        [ sh:class ocsf:NetworkProxy ;
            sh:description "The proxy (server) in a network connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path ocsf:proxy_endpoint ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 33 ;
            sh:path ocsf:class_uid ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 74 ;
            sh:path ocsf:policy ],
        [ sh:class ocsf:NetworkConnectionInfo ;
            sh:description "The network connection information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path ocsf:connection_info ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 68 ;
            sh:path ocsf:disposition ],
        [ sh:class ocsf:Ja4Fingerprint ;
            sh:description "A list of the JA4+ network fingerprints." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:ja4_fingerprint_list ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 42 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path ocsf:duration ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 53 ;
            sh:path ocsf:type_name ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path ocsf:status_code ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 72 ;
            sh:path ocsf:malware ],
        [ sh:class ocsf:NetworkTraffic ;
            sh:description """The network traffic for this observation period. Use when reporting: (1) delta
values (bytes/packets transferred since the last observation), (2)
instantaneous measurements at a specific point in time, or (3) standalone
single-event metrics. This attribute represents a point-in-time measurement or
incremental change, not a running total. For accumulated totals across multiple
observations or the lifetime of a flow, use <code>cumulative_traffic</code>
instead.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path ocsf:traffic ] ;
    sh:targetClass ocsf:FtpActivity .

ocsf:GroupManagement a sh:NodeShape ;
    rdfs:comment """Group Management events report management updates to a group, including updates
to membership and permissions.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 57 ;
            sh:path ocsf:risk_level_id ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 39 ;
            sh:path ocsf:device ],
        [ sh:class ocsf:HttpResponse ;
            sh:description "Details about the underlying HTTP response." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:http_response ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:count ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path ocsf:disposition ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:duration ],
        [ sh:class ocsf:HttpRequest ;
            sh:description "Details about the underlying HTTP request." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:http_request ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path ocsf:enrichments ],
        [ sh:class ocsf:Group ;
            sh:description "Group that was the target of the event." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:group ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:end_time ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 31 ;
            sh:path ocsf:status_id ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 50 ;
            sh:path ocsf:firewall_rule ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:is_alert ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 44 ;
            sh:path ocsf:authorizations ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path ocsf:metadata ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "ASSIGN_PRIVILEGES" "REVOKE_PRIVILEGES" "ADD_USER" "REMOVE_USER" "DELETE" "CREATE" "ADD_SUBGROUP" "REMOVE_SUBGROUP" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path ocsf:activity_id ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:class_name ],
        [ sh:class ocsf:ResourceDetails ;
            sh:description "Resource that the privileges give access to." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:resource ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:status_detail ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 42 ;
            sh:path ocsf:action_id ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 55 ;
            sh:path ocsf:risk_details ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 14 ;
            sh:path ocsf:class_uid ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path ocsf:type_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:activity_name ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:actor ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 56 ;
            sh:path ocsf:risk_level ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:raw_data ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 38 ;
            sh:path ocsf:cloud ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 58 ;
            sh:path ocsf:risk_score ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 43 ;
            sh:path ocsf:attacks ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:severity ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 26 ;
            sh:path ocsf:severity_id ],
        [ sh:class ocsf:Group ;
            sh:description "A subgroup that was added to or removed from the group." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:subgroup ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:category_name ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:message ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 40 ;
            sh:path ocsf:osint ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 53 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path ocsf:action ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:raw_data_size ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path ocsf:time ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:start_time ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 46 ;
            sh:path ocsf:confidence_id ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 37 ;
            sh:path ocsf:api ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 12 ;
            sh:path ocsf:category_uid ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 45 ;
            sh:path ocsf:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "A list of privileges assigned to the group." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:privileges ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path ocsf:unmapped ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 49 ;
            sh:path ocsf:disposition_id ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path ocsf:observables ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 54 ;
            sh:path ocsf:policy ],
        [ sh:class ocsf:User ;
            sh:description "A user that was added to or removed from the group." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:user ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:timezone_offset ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 34 ;
            sh:path ocsf:type_name ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description "Details about the source of the IAM activity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:src_endpoint ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 52 ;
            sh:path ocsf:malware ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:status_code ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:confidence_score ] ;
    sh:targetClass ocsf:GroupManagement .

ocsf:HostProfile a sh:NodeShape ;
    rdfs:comment "The attributes that identify host/device attributes." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:actor ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:device ] ;
    sh:targetClass ocsf:HostProfile .

ocsf:HttpActivity a sh:NodeShape ;
    rdfs:comment "HTTP Activity events report HTTP connection and traffic information." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Trace ;
            sh:description """The trace object contains information about distributed traces which are
critical to observability and describe how requests move through a system,
capturing each step's timing and status.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:trace ],
        [ sh:class ocsf:NetworkProxy ;
            sh:description "The proxy (server) in a network connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path ocsf:proxy_endpoint ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 72 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:datatype xsd:string ;
            sh:description """The application-layer (Layer 7) protocol name identified by deep packet inspection or packet parsing (e.g., <code>https</code>, <code>quic</code>, <code>ssh</code>, <code>dns</code>), expressed as an IANA-registered service name from the IANA Service Name and Transport Protocol Port Number Registry.

<p><b>Note:</b> Port numbers alone are not always a reliable indicator of the actual application protocol in use.</p>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:app_protocol_name ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 46 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path ocsf:severity ],
        [ sh:class ocsf:NetworkConnectionInfo ;
            sh:description "The connection information from the proxy server to the remote server." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path ocsf:proxy_connection_info ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 66 ;
            sh:path ocsf:confidence_score ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 71 ;
            sh:path ocsf:malware ],
        [ sh:datatype xsd:integer ;
            sh:description """The Hypertext Transfer Protocol (HTTP) <a target='_blank'
href='https://www.iana.org/assignments/http-status-codes/http-status-codes.xhtml'>status
code</a> returned to the client.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:http_status ],
        [ sh:class ocsf:LoadBalancer ;
            sh:description """The Load Balancer object contains information related to the device that is
distributing incoming traffic to specified destinations.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 27 ;
            sh:path ocsf:load_balancer ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path ocsf:class_name ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 69 ;
            sh:path ocsf:firewall_rule ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 39 ;
            sh:path ocsf:observables ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "CONNECT" "DELETE" "GET" "HEAD" "OPTIONS" "POST" "PUT" "TRACE" "PATCH" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path ocsf:activity_id ],
        [ sh:class ocsf:Ja4Fingerprint ;
            sh:description "A list of the JA4+ network fingerprints." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:ja4_fingerprint_list ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:category_name ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 76 ;
            sh:path ocsf:risk_level_id ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 45 ;
            sh:path ocsf:start_time ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 59 ;
            sh:path ocsf:osint ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 52 ;
            sh:path ocsf:type_name ],
        [ sh:class ocsf:Packet ;
            sh:description "The list of packet objects describing captured network packets." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path ocsf:packet_list ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 50 ;
            sh:path ocsf:time ],
        [ sh:class ocsf:NetworkConnectionInfo ;
            sh:description "The network connection information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:connection_info ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path ocsf:raw_data ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 67 ;
            sh:path ocsf:disposition ],
        [ sh:class ocsf:NetworkTraffic ;
            sh:description """The cumulative (running total) network traffic aggregated from the start of a
flow or session. Use when reporting: (1) total accumulated bytes/packets since
flow initiation, (2) combined aggregation models where both incremental deltas
and running totals are reported together (populate both <code>traffic</code>
for the delta and this attribute for the cumulative total), or (3) final
summary metrics when a long-lived connection closes. This represents the sum of
all activity from flow start to the current observation, not a delta or
point-in-time value.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path ocsf:cumulative_traffic ],
        [ sh:class ocsf:NetworkTraffic ;
            sh:description """The network traffic refers to the amount of data moving across a network, from
proxy to remote server at a given point of time.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 26 ;
            sh:path ocsf:proxy_traffic ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description "The initiator (client) of the network connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path ocsf:src_endpoint ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 58 ;
            sh:path ocsf:device ],
        [ sh:class ocsf:Tls ;
            sh:description "The TLS protocol negotiated between the proxy server and the remote server." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 25 ;
            sh:path ocsf:proxy_tls ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description "The responder (server) in a network connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:dst_endpoint ],
        [ sh:datatype xsd:string ;
            sh:description """Indicates whether the source network endpoint, destination network endpoint, or
neither served as the observation point for the activity. The value is
normalized to the caption of the <code>observation_point_id</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:observation_point ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 32 ;
            sh:path ocsf:class_uid ],
        [ sh:description """The normalized identifier of the observation point. The observation point
identifier indicates whether the source network endpoint, destination network
endpoint, or neither served as the observation point for the activity.""" ;
            sh:in ( "UNKNOWN" "SOURCE" "DESTINATION" "NEITHER" "BOTH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 15 ;
            sh:path ocsf:observation_point_id ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 55 ;
            sh:path ocsf:api ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 65 ;
            sh:path ocsf:confidence_id ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 41 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:class ocsf:Tls ;
            sh:description "The Transport Layer Security (TLS) attributes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path ocsf:tls ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:status_code ],
        [ sh:datatype xsd:string ;
            sh:description """The network application name identified by tools such as NBAR or App ID (e.g.,
youtube, facebook, webex). This represents a specific network application that
uses standard protocols (such as https or quic) to deliver its service.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:app_name ],
        [ sh:class ocsf:File ;
            sh:description "The file that is the target of the HTTP activity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:file ],
        [ sh:class ocsf:NetworkProxy ;
            sh:description "The proxy (server) in a network connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path ocsf:proxy ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 64 ;
            sh:path ocsf:confidence ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 34 ;
            sh:path ocsf:duration ],
        [ sh:class ocsf:HttpResponse ;
            sh:description "The HTTP Response from the remote server to the proxy server." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 24 ;
            sh:path ocsf:proxy_http_response ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 42 ;
            sh:path ocsf:raw_data_size ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 77 ;
            sh:path ocsf:risk_score ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:timezone_offset ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 70 ;
            sh:path ocsf:is_alert ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 30 ;
            sh:path ocsf:category_uid ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 38 ;
            sh:path ocsf:metadata ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 61 ;
            sh:path ocsf:action_id ],
        [ sh:class ocsf:HttpRequest ;
            sh:description "The HTTP Request from the proxy server to the remote server." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path ocsf:proxy_http_request ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 53 ;
            sh:path ocsf:type_uid ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path ocsf:end_time ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:activity_name ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 56 ;
            sh:path ocsf:cloud ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 44 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 75 ;
            sh:path ocsf:risk_level ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 62 ;
            sh:path ocsf:attacks ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path ocsf:enrichments ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 73 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 74 ;
            sh:path ocsf:risk_details ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 54 ;
            sh:path ocsf:unmapped ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 49 ;
            sh:path ocsf:status_id ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description """The network endpoint that observes or inspects network traffic as a third-party
system, used when the observer is neither the source nor the destination of the
communication (when <code>observation_point_id</code> = 3). Examples include
network taps, span ports, inline security devices, or packet capture systems
that monitor traffic between other endpoints.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:network_observation_point ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 63 ;
            sh:path ocsf:authorizations ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 60 ;
            sh:path ocsf:action ],
        [ sh:class ocsf:HttpCookie ;
            sh:description "The cookies object describes details about HTTP cookies" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:http_cookies ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 37 ;
            sh:path ocsf:message ],
        [ sh:class ocsf:HttpResponse ;
            sh:description "The HTTP Response from a web server to a requester." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:http_response ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 57 ;
            sh:path ocsf:actor ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path ocsf:status_detail ],
        [ sh:class ocsf:NetworkTraffic ;
            sh:description """The network traffic for this observation period. Use when reporting: (1) delta
values (bytes/packets transferred since the last observation), (2)
instantaneous measurements at a specific point in time, or (3) standalone
single-event metrics. This attribute represents a point-in-time measurement or
incremental change, not a running total. For accumulated totals across multiple
observations or the lifetime of a flow, use <code>cumulative_traffic</code>
instead.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path ocsf:traffic ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 68 ;
            sh:path ocsf:disposition_id ],
        [ sh:class ocsf:HttpRequest ;
            sh:description "The HTTP Request Object documents attributes of a request made to a web server." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:http_request ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:count ] ;
    sh:targetClass ocsf:HttpActivity .

ocsf:IamAnalysisFinding a sh:NodeShape ;
    rdfs:comment """This finding represents an IAM analysis result, which evaluates IAM policies,
access patterns, and IAM configurations for potential security risks. The
analysis can focus on either an identity (user, role, service account) or a
resource to assess permissions, access patterns, and security posture within
the IAM domain. <br><strong>Note:</strong> Use
<code>permission_analysis_results</code> for identity-centric analysis
(evaluating what an identity can do) and <code>access_analysis_result</code>
for resource-centric analysis (evaluating who can access a resource). These
complement each other for comprehensive IAM security
assessment.<br><strong>Note:</strong> If the Finding is an incident, i.e.
requires incident workflow, also apply the <code>incident</code> profile or
aggregate this finding into an <code>Incident Finding</code>.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 62 ;
            sh:path ocsf:authorizations ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path ocsf:status_code ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 66 ;
            sh:path ocsf:is_alert ],
        [ sh:class ocsf:Group ;
            sh:description "The details of the group assigned to an Incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path ocsf:assignee_group ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 60 ;
            sh:path ocsf:action_id ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 41 ;
            sh:path ocsf:metadata ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 68 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 71 ;
            sh:path ocsf:risk_level ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 59 ;
            sh:path ocsf:action ],
        [ sh:class ocsf:User ;
            sh:description "The details of the user assigned to an Incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path ocsf:assignee ],
        [ sh:description """The normalized priority. Priority identifies the relative importance of the
incident or finding. It is a measurement of urgency.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 27 ;
            sh:path ocsf:priority_id ],
        [ sh:class ocsf:FindingInfo ;
            sh:description "Describes the supporting information about a generated finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path ocsf:finding_info ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path ocsf:raw_data ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path ocsf:class_name ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 46 ;
            sh:path ocsf:severity ],
        [ sh:datatype xsd:long ;
            sh:description "The time of the most recent event included in the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:end_time ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 42 ;
            sh:path ocsf:observables ],
        [ sh:datatype xsd:string ;
            sh:description """The normalized status of the Finding set by the consumer normalized to the
caption of the status_id value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 63 ;
            sh:path ocsf:disposition ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 50 ;
            sh:path ocsf:time ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 52 ;
            sh:path ocsf:type_name ],
        [ sh:class ocsf:Ticket ;
            sh:description "The linked ticket in the ticketing system." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 29 ;
            sh:path ocsf:ticket ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 67 ;
            sh:path ocsf:malware ],
        [ sh:datatype xsd:string ;
            sh:description "A user provided comment about the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:comment ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 39 ;
            sh:path ocsf:enrichments ],
        [ sh:description "The normalized status identifier of the Finding, set by the consumer." ;
            sh:in ( "NEW" "IN_PROGRESS" "SUPPRESSED" "RESOLVED" "ARCHIVED" "DELETED" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 18 ;
            sh:path ocsf:status_id ],
        [ sh:class ocsf:ResourceDetails ;
            sh:description """Details about resources involved in the IAM analysis. For identity-centric
analysis, this represents resources the identity can access. For
resource-centric analysis, this represents the resource being analyzed and
related resources in the access chain.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:resources ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 38 ;
            sh:path ocsf:duration ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 55 ;
            sh:path ocsf:api ],
        [ sh:class ocsf:IdentityActivityMetrics ;
            sh:description """Describes usage activity and other metrics of an Identity i.e. AWS IAM User,
GCP IAM Principal, etc.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:identity_activity_metrics ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 47 ;
            sh:path ocsf:severity_id ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 34 ;
            sh:path ocsf:category_uid ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 58 ;
            sh:path ocsf:osint ],
        [ sh:datatype xsd:long ;
            sh:description "The time of the least recent event included in the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:start_time ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:category_name ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 49 ;
            sh:path ocsf:status_detail ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 70 ;
            sh:path ocsf:risk_details ],
        [ sh:class ocsf:Ticket ;
            sh:description """The associated ticket(s) in the ticketing system. Each ticket contains details
like ticket ID, status, etc.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 30 ;
            sh:path ocsf:tickets ],
        [ sh:description "The normalized verdict of an Incident." ;
            sh:in ( "UNKNOWN" "FALSE_POSITIVE" "TRUE_POSITIVE" "DISREGARD" "SUSPICIOUS" "BENIGN" "TEST" "INSUFFICIENT_DATA" "SECURITY_RISK" "MANAGED_EXTERNALLY" "DUPLICATE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 32 ;
            sh:path ocsf:verdict_id ],
        [ sh:class ocsf:Device ;
            sh:description """Describes the affected device/host. If applicable, it can be used in
conjunction with <code>Resource(s)</code>. <p> e.g. Specific details about an
AWS EC2 instance, that is affected by the Finding.</p>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:device ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:confidence_score ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 69 ;
            sh:path ocsf:policy ],
        [ sh:class ocsf:AccessAnalysisResult ;
            sh:description """Describes access relationships and pathways between identities, resources,
focusing on who can access what and through which mechanisms. This evaluates
access levels (read/write/admin), access types (direct, cross-account, public,
federated), and the conditions under which access is granted. Use this for
resource-centric security assessments such as external access discovery, public
exposure analysis, etc.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:access_analysis_result ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 73 ;
            sh:path ocsf:risk_score ],
        [ sh:class ocsf:VendorAttributes ;
            sh:description """The Vendor Attributes object can be used to represent values of attributes
populated by the Vendor/Finding Provider. It can help distinguish between the
vendor-provided values and consumer-updated values, of key attributes like
<code>severity_id</code>.<br>The original finding producer should not populate
this object. It should be populated by consuming systems that support data
mutability.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path ocsf:vendor_attributes ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 56 ;
            sh:path ocsf:cloud ],
        [ sh:class ocsf:User ;
            sh:description """Details about the identity (user, role, service account, or other principal)
that is the subject of the IAM analysis. This provides context about the
identity being evaluated for security risks and access patterns.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:user ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 57 ;
            sh:path ocsf:actor ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 36 ;
            sh:path ocsf:class_uid ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 54 ;
            sh:path ocsf:unmapped ],
        [ sh:datatype xsd:integer ;
            sh:description "The impact as an integer value of the finding, valid range 0-100." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:impact_score ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:timezone_offset ],
        [ sh:class ocsf:ApplicationObject ;
            sh:description """Details about applications, services, or systems that are accessible based on
the IAM analysis. For identity-centric analysis, this represents applications
the identity can access. For resource-centric analysis, this represents
applications that can access the resource.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:applications ],
        [ sh:class ocsf:Remediation ;
            sh:description "Describes the recommended remediation steps to address identified issue(s)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:remediation ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 44 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 72 ;
            sh:path ocsf:risk_level_id ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 61 ;
            sh:path ocsf:attacks ],
        [ sh:description """The normalized impact of the incident or finding. Per NIST, this is the
magnitude of harm that can be expected to result from the consequences of
unauthorized disclosure, modification, destruction, or loss of information or
information system availability.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 23 ;
            sh:path ocsf:impact_id ],
        [ sh:class ocsf:PermissionAnalysisResult ;
            sh:description """Describes analysis results of permissions, policies directly associated with an
identity (user, role, or service account). This evaluates what permissions an
identity has been granted through attached policies, which privileges are
actively used versus unused, and identifies potential over-privileged access.
Use this for identity-centric security assessments such as privilege audits,
dormant permission discovery, and least-privilege compliance analysis.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:permission_analysis_results ],
        [ sh:datatype xsd:string ;
            sh:description "The finding activity name, as defined by the <code>activity_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:activity_name ],
        [ sh:datatype xsd:boolean ;
            sh:description "A determination based on analytics as to whether a potential breach was found." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:is_suspected_breach ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 65 ;
            sh:path ocsf:firewall_rule ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 53 ;
            sh:path ocsf:type_uid ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A Url link used to access the original incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:src_url ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 64 ;
            sh:path ocsf:disposition_id ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 11 ;
            sh:path ocsf:confidence_id ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 45 ;
            sh:path ocsf:raw_data_size ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 37 ;
            sh:path ocsf:count ],
        [ sh:datatype xsd:string ;
            sh:description """The impact , normalized to the caption of the impact_id value. In the case of
'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:impact ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:confidence ],
        [ sh:datatype xsd:string ;
            sh:description """The priority, normalized to the caption of the priority_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:priority ],
        [ sh:description "The normalized identifier of the finding activity." ;
            sh:in ( "CREATE" "UPDATE" "CLOSE" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 7 ;
            sh:path ocsf:activity_id ],
        [ sh:datatype xsd:string ;
            sh:description "The verdict assigned to an Incident finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path ocsf:verdict ] ;
    sh:targetClass ocsf:IamAnalysisFinding .

ocsf:IamEvent a sh:NodeShape ;
    rdfs:comment """The Identity & Access Management event is a generic event that defines a set of
attributes available in the access control events. As a generic event, it could
be used to log events that are not otherwise defined by the IAM category.""" ;
    sh:closed true ;
    sh:ignoredProperties ( ocsf:user_result ocsf:logon_type_id ocsf:certificate ocsf:is_remote ocsf:account_switch_type_id ocsf:session ocsf:group ocsf:auth_protocol_id ocsf:account_switch_type ocsf:service ocsf:access_mask ocsf:auth_protocol ocsf:comment ocsf:subgroup ocsf:user ocsf:access_list ocsf:logon_type ocsf:dst_endpoint ocsf:resource ocsf:auth_factors rdf:type ocsf:entity ocsf:resources ocsf:is_mfa ocsf:privileges ocsf:policies ocsf:entity_result ocsf:authentication_token ocsf:is_cleartext ocsf:logon_process ocsf:is_new_logon ) ;
    sh:property [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:end_time ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path ocsf:api ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:duration ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 35 ;
            sh:path ocsf:osint ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 7 ;
            sh:path ocsf:category_uid ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:status_detail ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:count ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:type_uid ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 21 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:risk_level ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 41 ;
            sh:path ocsf:confidence_id ],
        [ sh:class ocsf:HttpResponse ;
            sh:description "Details about the underlying HTTP response." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:http_response ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:actor ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 45 ;
            sh:path ocsf:firewall_rule ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:start_time ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 26 ;
            sh:path ocsf:status_id ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 38 ;
            sh:path ocsf:attacks ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:status_code ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 37 ;
            sh:path ocsf:action_id ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 31 ;
            sh:path ocsf:unmapped ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 33 ;
            sh:path ocsf:cloud ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 53 ;
            sh:path ocsf:risk_score ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:category_name ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:raw_data_size ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:type_name ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:raw_data ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 42 ;
            sh:path ocsf:confidence_score ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:severity ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 52 ;
            sh:path ocsf:risk_level_id ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 48 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path ocsf:disposition ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path ocsf:confidence ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:time ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:timezone_offset ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 50 ;
            sh:path ocsf:risk_details ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 9 ;
            sh:path ocsf:class_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:class_name ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 34 ;
            sh:path ocsf:device ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path ocsf:observables ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 44 ;
            sh:path ocsf:disposition_id ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description "Details about the source of the IAM activity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:src_endpoint ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 39 ;
            sh:path ocsf:authorizations ],
        [ sh:class ocsf:HttpRequest ;
            sh:description "Details about the underlying HTTP request." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:http_request ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 47 ;
            sh:path ocsf:malware ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 4 ;
            sh:path ocsf:activity_id ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 49 ;
            sh:path ocsf:policy ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path ocsf:metadata ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 46 ;
            sh:path ocsf:is_alert ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:activity_name ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 36 ;
            sh:path ocsf:action ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:enrichments ] ;
    sh:targetClass ocsf:IamEvent .

ocsf:IncidentFinding a sh:NodeShape ;
    rdfs:comment """An Incident Finding reports the creation, update, or closure of security
incidents as a result of detections and/or analytics. <br><strong>Note:
</strong><code>Incident Finding</code> implicitly includes the
<code>incident</code> profile and it should be added to the
<code>metadata.profiles[]</code> array.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The priority, normalized to the caption of the priority_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:priority ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 30 ;
            sh:path ocsf:class_uid ],
        [ sh:description """The normalized priority. Priority identifies the relative importance of the
incident or finding. It is a measurement of urgency.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 17 ;
            sh:path ocsf:priority_id ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 28 ;
            sh:path ocsf:category_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The verdict assigned to an Incident finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:verdict ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path ocsf:status_detail ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 56 ;
            sh:path ocsf:authorizations ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 66 ;
            sh:path ocsf:risk_level_id ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 33 ;
            sh:path ocsf:enrichments ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 59 ;
            sh:path ocsf:firewall_rule ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path ocsf:observables ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path ocsf:confidence_id ],
        [ sh:description """The normalized impact of the incident or finding. Per NIST, this is the
magnitude of harm that can be expected to result from the consequences of
unauthorized disclosure, modification, destruction, or loss of information or
information system availability.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 13 ;
            sh:path ocsf:impact_id ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 65 ;
            sh:path ocsf:risk_level ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 63 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:integer ;
            sh:description "The impact as an integer value of the finding, valid range 0-100." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:impact_score ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 64 ;
            sh:path ocsf:risk_details ],
        [ sh:description "The normalized identifier of the Incident activity." ;
            sh:in ( "CREATE" "UPDATE" "CLOSE" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path ocsf:activity_id ],
        [ sh:datatype xsd:string ;
            sh:description """The impact , normalized to the caption of the impact_id value. In the case of
'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:impact ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 35 ;
            sh:path ocsf:metadata ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 57 ;
            sh:path ocsf:disposition ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:category_name ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 39 ;
            sh:path ocsf:raw_data_size ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:class_name ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 37 ;
            sh:path ocsf:raw_data ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 48 ;
            sh:path ocsf:unmapped ],
        [ sh:datatype xsd:string ;
            sh:description "Additional user supplied details for updating or closing the incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:comment ],
        [ sh:datatype xsd:long ;
            sh:description "The time of the least recent event included in the incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:start_time ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 53 ;
            sh:path ocsf:osint ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path ocsf:count ],
        [ sh:datatype xsd:string ;
            sh:description "The short description of the Incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:desc ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 61 ;
            sh:path ocsf:malware ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 42 ;
            sh:path ocsf:status_code ],
        [ sh:datatype xsd:string ;
            sh:description """The normalized status of the Incident normalized to the caption of the
status_id value. In the case of 'Other', it is defined by the source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:status ],
        [ sh:description "The normalized status identifier of the Incident." ;
            sh:in ( "NEW" "IN_PROGRESS" "ON_HOLD" "RESOLVED" "CLOSED" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 21 ;
            sh:path ocsf:status_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 45 ;
            sh:path ocsf:timezone_offset ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 50 ;
            sh:path ocsf:cloud ],
        [ sh:datatype xsd:boolean ;
            sh:description "A determination based on analytics as to whether a potential breach was found." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:is_suspected_breach ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 38 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 34 ;
            sh:path ocsf:message ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of <a target='_blank' href='https://attack.mitre.org'>MITRE
ATT&CK®</a> objects describing the tactics, techniques & sub-techniques
associated to the Incident.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:attacks ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path ocsf:duration ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:type_uid ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 44 ;
            sh:path ocsf:time ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 58 ;
            sh:path ocsf:disposition_id ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:confidence ],
        [ sh:class ocsf:Ticket ;
            sh:description "The linked ticket in the ticketing system." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path ocsf:ticket ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 46 ;
            sh:path ocsf:type_name ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 52 ;
            sh:path ocsf:device ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 41 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:string ;
            sh:description "The Incident activity name, as defined by the <code>activity_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:activity_name ],
        [ sh:class ocsf:FindingInfo ;
            sh:description "A list of <code>finding_info</code> objects associated to an incident." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:finding_info_list ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:confidence_score ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 62 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A Url link used to access the original incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:src_url ],
        [ sh:description "The normalized verdict of an Incident." ;
            sh:in ( "UNKNOWN" "FALSE_POSITIVE" "TRUE_POSITIVE" "DISREGARD" "SUSPICIOUS" "BENIGN" "TEST" "INSUFFICIENT_DATA" "SECURITY_RISK" "MANAGED_EXTERNALLY" "DUPLICATE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 26 ;
            sh:path ocsf:verdict_id ],
        [ sh:datatype xsd:long ;
            sh:description "The time of the most recent event included in the incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:end_time ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 49 ;
            sh:path ocsf:api ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path ocsf:severity ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 55 ;
            sh:path ocsf:action_id ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 67 ;
            sh:path ocsf:risk_score ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 60 ;
            sh:path ocsf:is_alert ],
        [ sh:class ocsf:Ticket ;
            sh:description """The associated ticket(s) in the ticketing system. Each ticket contains details
like ticket ID, status, etc.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path ocsf:tickets ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 51 ;
            sh:path ocsf:actor ],
        [ sh:class ocsf:VendorAttributes ;
            sh:description """The Vendor Attributes object can be used to represent values of attributes
populated by the Vendor/Finding Provider. It can help distinguish between the
vendor-provided values and consumer-updated values, of key attributes like
<code>severity_id</code>.<br>The original finding producer should not populate
this object. It should be populated by consuming systems that support data
mutability.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 24 ;
            sh:path ocsf:vendor_attributes ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 54 ;
            sh:path ocsf:action ],
        [ sh:class ocsf:Group ;
            sh:description "The details of the group assigned to an Incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:assignee_group ],
        [ sh:class ocsf:User ;
            sh:description "The details of the user assigned to an Incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:assignee ] ;
    sh:targetClass ocsf:IncidentFinding .

ocsf:IncidentProfile a sh:NodeShape ;
    rdfs:comment "The attributes that add incident handling semantics to a Finding." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Group ;
            sh:description "The details of the group assigned to an Incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:assignee_group ],
        [ sh:datatype xsd:string ;
            sh:description """The priority, normalized to the caption of the priority_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:priority ],
        [ sh:description """The normalized priority. Priority identifies the relative importance of the
incident or finding. It is a measurement of urgency.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path ocsf:priority_id ],
        [ sh:datatype xsd:integer ;
            sh:description "The impact as an integer value of the finding, valid range 0-100." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:impact_score ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A Url link used to access the original incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:src_url ],
        [ sh:class ocsf:User ;
            sh:description "The details of the user assigned to an Incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:assignee ],
        [ sh:description """The normalized impact of the incident or finding. Per NIST, this is the
magnitude of harm that can be expected to result from the consequences of
unauthorized disclosure, modification, destruction, or loss of information or
information system availability.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path ocsf:impact_id ],
        [ sh:datatype xsd:boolean ;
            sh:description "A determination based on analytics as to whether a potential breach was found." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:is_suspected_breach ],
        [ sh:description "The normalized verdict of an Incident." ;
            sh:in ( "UNKNOWN" "FALSE_POSITIVE" "TRUE_POSITIVE" "DISREGARD" "SUSPICIOUS" "BENIGN" "TEST" "INSUFFICIENT_DATA" "SECURITY_RISK" "MANAGED_EXTERNALLY" "DUPLICATE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 12 ;
            sh:path ocsf:verdict_id ],
        [ sh:class ocsf:Ticket ;
            sh:description """The associated ticket(s) in the ticketing system. Each ticket contains details
like ticket ID, status, etc.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path ocsf:tickets ],
        [ sh:datatype xsd:string ;
            sh:description """The impact , normalized to the caption of the impact_id value. In the case of
'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:impact ],
        [ sh:class ocsf:Ticket ;
            sh:description "The linked ticket in the ticketing system." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:ticket ],
        [ sh:datatype xsd:string ;
            sh:description "The verdict assigned to an Incident finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:verdict ] ;
    sh:targetClass ocsf:IncidentProfile .

ocsf:InventoryInfo a sh:NodeShape ;
    rdfs:comment """Device Inventory Info events report device inventory data that is either logged
or proactively collected. For example, when collecting device information from
a CMDB or running a network sweep of connected devices.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 7 ;
            sh:path ocsf:class_uid ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:status_code ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 46 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:count ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path ocsf:osint ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 31 ;
            sh:path ocsf:cloud ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:severity ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 30 ;
            sh:path ocsf:api ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:category_name ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:duration ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 42 ;
            sh:path ocsf:firewall_rule ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:raw_data ],
        [ sh:class ocsf:Device ;
            sh:description "The device that is being discovered by an inventory process." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:device ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 45 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 24 ;
            sh:path ocsf:status_id ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "LOG" "COLLECT" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path ocsf:activity_id ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path ocsf:is_alert ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path ocsf:disposition ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:end_time ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 37 ;
            sh:path ocsf:confidence ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ocsf:observables ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 39 ;
            sh:path ocsf:confidence_score ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:action ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:type_uid ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 50 ;
            sh:path ocsf:risk_score ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path ocsf:category_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:type_name ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:metadata ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 34 ;
            sh:path ocsf:action_id ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:status ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 41 ;
            sh:path ocsf:disposition_id ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:activity_name ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 19 ;
            sh:path ocsf:severity_id ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:actor ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:start_time ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path ocsf:risk_level ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 35 ;
            sh:path ocsf:attacks ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 49 ;
            sh:path ocsf:risk_level_id ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 44 ;
            sh:path ocsf:malware ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path ocsf:authorizations ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:risk_details ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:time ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 38 ;
            sh:path ocsf:confidence_id ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:raw_data_size ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:timezone_offset ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:class_name ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:enrichments ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 29 ;
            sh:path ocsf:unmapped ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:status_detail ] ;
    sh:targetClass ocsf:InventoryInfo .

ocsf:JobQuery a sh:NodeShape ;
    rdfs:comment "Job Query events report information about scheduled jobs." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 21 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:is_alert ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:status_detail ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:raw_data_size ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:risk_details ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:severity ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path ocsf:api ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path ocsf:confidence_score ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path ocsf:observables ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 54 ;
            sh:path ocsf:risk_score ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:class_name ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 37 ;
            sh:path ocsf:action ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 34 ;
            sh:path ocsf:actor ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:time ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 53 ;
            sh:path ocsf:risk_level_id ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path ocsf:confidence ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:duration ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:raw_data ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 31 ;
            sh:path ocsf:unmapped ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 33 ;
            sh:path ocsf:cloud ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 45 ;
            sh:path ocsf:disposition_id ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:status_code ],
        [ sh:class ocsf:QueryInfo ;
            sh:description "The search details associated with the query request." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:query_info ],
        [ sh:class ocsf:Job ;
            sh:description "The job object that pertains to the event." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:job ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 49 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:datatype xsd:string ;
            sh:description "The result of the query." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:query_result ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 42 ;
            sh:path ocsf:confidence_id ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:message ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 35 ;
            sh:path ocsf:device ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:category_name ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 40 ;
            sh:path ocsf:authorizations ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 38 ;
            sh:path ocsf:action_id ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:activity_name ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "QUERY" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path ocsf:activity_id ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 7 ;
            sh:path ocsf:category_uid ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path ocsf:osint ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:timezone_offset ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 39 ;
            sh:path ocsf:attacks ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:count ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 9 ;
            sh:path ocsf:class_uid ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:end_time ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:start_time ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:type_uid ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 26 ;
            sh:path ocsf:status_id ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 44 ;
            sh:path ocsf:disposition ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 46 ;
            sh:path ocsf:firewall_rule ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 48 ;
            sh:path ocsf:malware ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 50 ;
            sh:path ocsf:policy ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path ocsf:metadata ],
        [ sh:description "The normalized identifier of the query result." ;
            sh:in ( "UNKNOWN" "EXISTS" "PARTIAL" "DOES_NOT_EXIST" "ERROR" "UNSUPPORTED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 4 ;
            sh:path ocsf:query_result_id ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:type_name ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 52 ;
            sh:path ocsf:risk_level ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:enrichments ] ;
    sh:targetClass ocsf:JobQuery .

ocsf:KernelActivity a sh:NodeShape ;
    rdfs:comment """Kernel Activity events report when an process creates, reads, or deletes a
kernel resource.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if

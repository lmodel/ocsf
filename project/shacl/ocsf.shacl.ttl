            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:status ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 54 ;
            sh:path ocsf:risk_level_id ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 44 ;
            sh:path ocsf:confidence_score ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included

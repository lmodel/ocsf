source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:severity ] ;
    sh:targetClass ocsf:RegistryKeyActivity .

ocsf:RegistryKeyQuery a sh:NodeShape ;
    rdfs:comment """Registry Key Query events report information about discovered Windows registry
keys.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;

_fix_available ocsf:duration_hours ocsf:severity_id ocsf:detection_pattern_type_id ocsf:network_driver ocsf:profiles ocsf:autonomous_system ocsf:caption ocsf:related_events_count ocsf:tag ocsf:vram_mode_id ocsf:application ocsf:is_superseded ocsf:last_seen_time ) ;
    sh:targetClass ocsf:Object .

ocsf:Device a sh:NodeShape ;
    rdfs:comment """The Device object represents an addressable computer system or host, which is
typically connected to a computer network and participates in the transmission
or processing of data within the computer network.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Os ;
            sh:description "The endpoint operating system." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 51 ;
            sh:path ocsf:os ],
        [ sh:datatype xsd:string ;
            sh:description """The name of the hypervisor running on the device. For example,
<code>Xen</code>, <code>VMware</code>, <code>Hyper-V</code>,
<code>VirtualBox</code>, etc.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:hypervisor ],
        [ sh:datatype xsd:string ;
            sh:description """A unique identifier of the device that changes after every reboot. For example,
the value of <code>/proc/sys/kernel/random/boot_id</code> from Linux's procfs.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:boot_uid ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates whether the device has an active mobile account. For example, this is
indicated by the <code>itunesStoreAccountActive</code> value within JAMF Pro
mobile devices.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:is_mobile_account_active ],
        [ sh:datatype xsd:string ;
            sh:description """The vendor for the device. For example <code>Dell</code> or
<code>Lenovo</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path ocsf:vendor_name ],
        [ sh:datatype xsd:string ;
            sh:description """The International Mobile Equipment Identity values that are associated with the
device.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:imei_list ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the cloud autoscale configuration." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:autoscale_uid ],
        [ sh:datatype xsd:boolean ;
            sh:description "The event occurred on a personal device." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:is_personal ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier of the device. For example the Windows TargetSID or AWS
EC2 ARN.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path ocsf:uid ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the device, ordinarily as reported by the operating system." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:desc ],
        [ sh:datatype xsd:string ;
            sh:description "The International Mobile Equipment Identity that is associated with the device." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:imei ],
        [ sh:datatype xsd:boolean ;
            sh:description "The event occurred on a trusted device." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:is_trusted ],
        [ sh:class ocsf:Organization ;
            sh:description "Organization and org unit related to the device." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 31 ;
            sh:path ocsf:org ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates whether the device or resource has a backup enabled, such as an
automated snapshot or a cloud backup. For example, this is indicated by the
<code>cloudBackupEnabled</code> value within JAMF Pro mobile devices or the
registration of an AWS ARN with the AWS Backup service.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:is_backed_up ],
        [ sh:datatype xsd:string ;
            sh:description "The region where the virtual machine is located. For example, an AWS Region." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:region ],
        [ sh:datatype xsd:string ;
            sh:description "The model of the device. For example <code>ThinkPad X1 Carbon</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:model ],
        [ sh:datatype xsd:boolean ;
            sh:description "The event occurred on a compliant device." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:is_compliant ],
        [ sh:datatype xsd:string ;
            sh:description "The Virtual LAN identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 55 ;
            sh:path ocsf:vlan_uid ],
        [ sh:datatype xsd:string ;
            sh:description """The operating system assigned Machine ID. In Windows, this is the value stored
at the registry path:
<code>HKEY_LOCAL_MACHINE\\SOFTWARE\\Microsoft\\Cryptography\\MachineGuid</code>. In
Linux, this is stored in the file: <code>/etc/machine-id</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path ocsf:os_machine_uuid ;
            sh:pattern "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "The Media Access Control (MAC) address of the endpoint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 49 ;
            sh:path ocsf:mac ;
            sh:pattern "^([0-9a-fA-F]{2}[:\\-]){5}[0-9a-fA-F]{2}$" ],
        [ sh:datatype xsd:long ;
            sh:description "The most recent discovery time of the device." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:last_seen_time ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 34 ;
            sh:path ocsf:risk_level ],
        [ sh:class ocsf:Group ;
            sh:description "The pool of desktops or virtual machines to which the endpoint belongs." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 53 ;
            sh:path ocsf:pool ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of a virtual subnet." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 54 ;
            sh:path ocsf:subnet_uid ],
        [ sh:class ocsf:User ;
            sh:description """The identity of the service or user account that owns the endpoint or was last
logged into it.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 52 ;
            sh:path ocsf:owner ],
        [ sh:datatype xsd:string ;
            sh:description """The vendor or manufacturer of the endpoint's network interface controller
(NIC), as identified from the MAC address.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 50 ;
            sh:path ocsf:mac_vendor ],
        [ sh:datatype xsd:string ;
            sh:description """The Apple assigned Unique Device Identifier (UDID). For iOS, iPadOS, tvOS,
watchOS and visionOS devices, this is the UDID. For macOS devices, it is the
Provisioning UDID. For example: <code>00008020-008D4548007B4F26</code>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path ocsf:udid ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of a VM instance." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 46 ;
            sh:path ocsf:instance_uid ],
        [ sh:datatype xsd:integer ;
            sh:description """If running under a process namespace (such as in a container), the process
identifier within that process namespace.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 59 ;
            sh:path ocsf:namespace_pid ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the device was known to have been created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:created_time ],
        [ sh:datatype xsd:long ;
            sh:description "The time when the device was last known to have been modified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:modified_time ],
        [ sh:datatype xsd:string ;
            sh:description """The Mobile Equipment Identifier. It's a unique number that identifies a Code
Division Multiple Access (CDMA) mobile device.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:meid ],
        [ sh:description "The device type ID." ;
            sh:in ( "SERVER" "DESKTOP" "LAPTOP" "TABLET" "MOBILE" "VIRTUAL" "IOT" "BROWSER" "FIREWALL" "SWITCH" "HUB" "ROUTER" "IDS" "IPS" "LOAD_BALANCER" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 39 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:boolean ;
            sh:description "The event occurred on a shared device." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:is_shared ],
        [ sh:datatype xsd:long ;
            sh:description "The time the system was booted." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:boot_time ],
        [ sh:class ocsf:Location ;
            sh:description "The geographical location of the device." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 25 ;
            sh:path ocsf:location ],
        [ sh:datatype xsd:string ;
            sh:description """The device type. For example: <code>unknown</code>, <code>server</code>,
<code>desktop</code>, <code>laptop</code>, <code>tablet</code>,
<code>mobile</code>, <code>virtual</code>, <code>browser</code>, or
<code>other</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 38 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description "The device IP address, in either IPv4 or IPv6 format." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:ip ;
            sh:pattern "^((\\d{1,3}\\.){3}\\d{1,3}|[0-9a-fA-F:]{2,39})$" ],
        [ sh:class ocsf:DeviceHwInfo ;
            sh:description "The endpoint hardware information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 45 ;
            sh:path ocsf:hw_info ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the Virtual Private Cloud (VPC)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 56 ;
            sh:path ocsf:vpc_uid ],
        [ sh:class ocsf:NetworkInterface ;
            sh:description """The physical or virtual network interfaces that are associated with the device,
one for each unique MAC address/IP address/hostname/name
combination.<p><b>Note:</b> The first element of the array is the network
information that pertains to the event.</p>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 30 ;
            sh:path ocsf:network_interfaces ],
        [ sh:datatype xsd:string ;
            sh:description "The network zone or LAN segment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 57 ;
            sh:path ocsf:zone ],
        [ sh:class ocsf:Image ;
            sh:description "The image used as a template to run the virtual machine." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:image ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the network interface." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path ocsf:interface_uid ],
        [ sh:datatype xsd:string ;
            sh:description """The alternate device name, ordinarily as assigned by an administrator.
<p><b>Note:</b> The <b>Name</b> could be any other string that helps to
identify the device, such as a phone number; for example
<code>310-555-1234</code>.</p>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The subnet mask." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 37 ;
            sh:path ocsf:subnet ;
            sh:pattern "^((\\d{1,3}\\.){3}\\d{1,3}|[0-9a-fA-F:]{2,39})/(\\d|[1-9]\\d|1[0-1]\\d|12[0-8])$" ],
        [ sh:datatype xsd:boolean ;
            sh:description "The event occurred on a managed device." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:is_managed ],
        [ sh:datatype xsd:string ;
            sh:description """The Integrated Circuit Card Identification of a mobile device. Typically it is
a unique 18 to 22 digit number that identifies a SIM card.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:iccid ],
        [ sh:datatype xsd:string ;
            sh:description """An alternate unique identifier of the device if any. For example the
ActiveDirectory DN.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 42 ;
            sh:path ocsf:uid_alt ],
        [ sh:class ocsf:Group ;
            sh:description """The group names to which the device belongs. For example: <code>["Windows
Laptops", "Engineering"]</code>.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:groups ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 36 ;
            sh:path ocsf:risk_score ],
        [ sh:datatype xsd:boolean ;
            sh:description """The event occurred on a supervised device. Devices that are supervised are
typically mobile devices managed by a Mobile Device Management solution and are
restricted from specific behaviors such as Apple AirDrop.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:is_supervised ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 35 ;
            sh:path ocsf:risk_level_id ],
        [ sh:datatype xsd:string ;
            sh:description """The network domain where the device resides. For example:
<code>work.example.com</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:domain ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the network interface (e.g. eth2)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:interface_name ],
        [ sh:class ocsf:Agent ;
            sh:description """A list of <code>agent</code> objects associated with a device, endpoint, or
resource.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 44 ;
            sh:path ocsf:agent_list ],
        [ sh:datatype xsd:string ;
            sh:description """An Embedded Identity Document, is a unique serial number that identifies an
eSIM-enabled device.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:eid ],
        [ sh:datatype xsd:long ;
            sh:description "The initial discovery time of the device." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:first_seen_time ],
        [ sh:class ocsf:Container ;
            sh:description """The information describing an instance of a container. A container is a
prepackaged, portable system image that runs isolated on an existing system
using a container runtime like containerd.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 58 ;
            sh:path ocsf:container ],
        [ sh:datatype xsd:string ;
            sh:description "The device hostname." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:hostname ] ;
    sh:targetClass ocsf:Device .

ocsf:Policy a sh:NodeShape ;
    rdfs:comment """The Policy object describes the policies that are applicable. <p>Policy
attributes provide traceability to the operational state of the security
product at the time that the event was captured, facilitating forensics,
troubleshooting, and policy tuning/adjustments.</p>""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A unique identifier of the policy instance." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:uid ],
        [ sh:class ocsf:Group ;
            sh:description "The policy group." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:group ],
        [ sh:datatype xsd:string ;
            sh:description "The policy version number." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:version ],
        [ sh:datatype xsd:string ;
            sh:description "The policy name. For example: <code>AdministratorAccess Policy</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the policy." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:desc ],
        [ sh:datatype xsd:string ;
            sh:description """The policy type. For example: <code>Identity Policy, Resource Policy, Service
Control Policy, etc.</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:boolean ;
            sh:description """A determination if the content of a policy was applied to a target or request,
or not.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:is_applied ],
        [ sh:datatype xsd:string ;
            sh:description """Additional data about the policy such as the underlying JSON policy itself or
other details.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:data ] ;
    sh:targetClass ocsf:Policy .

ocsf:Fingerprint a sh:NodeShape ;
    rdfs:comment """The Fingerprint object provides detailed information about a fingerprint, which
is a compact representation of data used to identify a longer piece of
information, such as a public key, file content, or application implementation.
It contains the algorithm or scheme and value of the fingerprint, enabling
efficient and reliable identification of the associated data.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description """The identifier of the normalized algorithm or scheme, which was used to create
the fingerprint.""" ;
            sh:in ( "UNKNOWN" "MD5" "SHA_1" "SHA_256" "SHA_512" "CTPH" "TLSH" "QUICKXORHASH" "SHA_224" "SHA_384" "SHA_512_224" "SHA_512_256" "SHA3_224" "SHA3_256" "SHA3_384" "SHA3_512" "XXHASH_H3_64_BIT" "XXHASH_H3_128_BIT" "IMPHASH" "NPF" "HASSH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path ocsf:algorithm_id ],
        [ sh:datatype xsd:string ;
            sh:description """The algorithm or scheme used to create the fingerprint, normalized to the
caption of <code>algorithm_id</code>. In the case of <code>Other</code>, it is
defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:algorithm ],
        [ sh:datatype xsd:string ;
            sh:description """The fingerprint value.<p><b>Note:</b> This uses type <code>file_hash_t</code>
(&quot;Hash&quot;), which has been generalized for all fingerprints but retains
the same name and caption for backwards compatibility.</p>""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:value ] ;
    sh:targetClass ocsf:Fingerprint .


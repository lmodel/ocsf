        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:enrichments ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 42 ;
            sh:path ocsf:firewall_rule ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:status_detail ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:duration ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path ocsf:category_uid ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 49 ;
            sh:path ocsf:risk_level_id ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path ocsf:authorizations ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 34 ;
            sh:path ocsf:action_id ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:status_code ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 29 ;
            sh:path ocsf:cloud ] ;
    sh:targetClass ocsf:ApplicationEvent .

ocsf:ApplicationLifecycle a sh:NodeShape ;
    rdfs:comment """Application Lifecycle events report installation, removal, start, stop of an
application or service.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:raw_data_size ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 29 ;
            sh:path ocsf:api ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 38 ;
            sh:path ocsf:confidence ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:count ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 35 ;
            sh:path ocsf:action_id ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path ocsf:device ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 18 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:activity_name ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:observables ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 6 ;
            sh:path ocsf:class_uid ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:end_time ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 39 ;
            sh:path ocsf:confidence_id ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 4 ;
            sh:path ocsf:category_uid ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 33 ;
            sh:path ocsf:osint ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 50 ;
            sh:path ocsf:risk_level_id ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 42 ;
            sh:path ocsf:disposition_id ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path ocsf:attacks ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:severity ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path ocsf:enrichments ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:raw_data ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 46 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:class_name ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:timezone_offset ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path ocsf:disposition ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 49 ;
            sh:path ocsf:risk_level ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:status_code ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:status_detail ],
        [ sh:class ocsf:Product ;
            sh:description """The application that was affected by the lifecycle event.  This also applies to
self-updating application systems.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:app ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 47 ;
            sh:path ocsf:policy ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 45 ;
            sh:path ocsf:malware ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 43 ;
            sh:path ocsf:firewall_rule ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "INSTALL" "REMOVE" "START" "STOP" "RESTART" "ENABLE" "DISABLE" "UPDATE" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path ocsf:activity_id ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 37 ;
            sh:path ocsf:authorizations ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 34 ;
            sh:path ocsf:action ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 31 ;
            sh:path ocsf:actor ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:duration ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:category_name ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:metadata ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:time ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path ocsf:confidence_score ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 44 ;
            sh:path ocsf:is_alert ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:risk_score ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:type_uid ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 30 ;
            sh:path ocsf:cloud ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:start_time ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:type_name ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path ocsf:risk_details ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 28 ;
            sh:path ocsf:unmapped ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 23 ;
            sh:path ocsf:status_id ] ;
    sh:targetClass ocsf:ApplicationLifecycle .

ocsf:ApplicationSecurityPostureFinding a sh:NodeShape ;
    rdfs:comment """The Application Security Posture Finding event is a notification about any bug,
defect, deficiency, exploit, vulnerability, weakness or any other issue with
software and related systems. Application Security Posture Findings typically
involve reporting on the greater context including compliance, impacted
resources, remediation guidance, specific code defects, and/or vulnerability
metadata. Application Security Posture Findings can be reported by Threat &
Vulnerability Management (TVM) tools, Application Security Posture Management
(ASPM) tools, or other similar tools. Note: if the event producer is a security
control, the <code>security_control</code> profile should be applied and its
<code>attacks</code> information, if present, should be duplicated into the
<code>finding_info</code> object. <br><strong>Note: </strong>If the Finding is
an incident, i.e. requires incident workflow, also apply the
<code>incident</code> profile or aggregate this finding into an <code>Incident
Finding</code>.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "A determination based on analytics as to whether a potential breach was found." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:is_suspected_breach ],
        [ sh:class ocsf:ResourceDetails ;
            sh:description """Describes details about the resource/resources that are affected by the
vulnerability/vulnerabilities.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:resources ],
        [ sh:datatype xsd:string ;
            sh:description """The priority, normalized to the caption of the priority_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:priority ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 58 ;
            sh:path ocsf:action_id ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:confidence ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:type_uid ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A Url link used to access the original incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:src_url ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 62 ;
            sh:path ocsf:disposition_id ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:class_name ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 69 ;
            sh:path ocsf:risk_level ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 44 ;
            sh:path ocsf:severity ],
        [ sh:class ocsf:Device ;
            sh:description """Describes the affected device/host. If applicable, it can be used in
conjunction with <code>Resource(s)</code>. <p> e.g. Specific details about an
AWS EC2 instance, that is affected by the Finding.</p>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 24 ;
            sh:path ocsf:device ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path ocsf:count ],
        [ sh:description "The normalized verdict of an Incident." ;
            sh:in ( "UNKNOWN" "FALSE_POSITIVE" "TRUE_POSITIVE" "DISREGARD" "SUSPICIOUS" "BENIGN" "TEST" "INSUFFICIENT_DATA" "SECURITY_RISK" "MANAGED_EXTERNALLY" "DUPLICATE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 17 ;
            sh:path ocsf:verdict_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 49 ;
            sh:path ocsf:timezone_offset ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 37 ;
            sh:path ocsf:enrichments ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path ocsf:raw_data_size ],
        [ sh:description "The normalized identifier of the finding activity." ;
            sh:in ( "CREATE" "UPDATE" "CLOSE" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 18 ;
            sh:path ocsf:activity_id ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 45 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 61 ;
            sh:path ocsf:disposition ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 36 ;
            sh:path ocsf:duration ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 59 ;
            sh:path ocsf:attacks ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 40 ;
            sh:path ocsf:observables ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 66 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 71 ;
            sh:path ocsf:risk_score ],
        [ sh:class ocsf:Vulnerability ;
            sh:description "This object describes vulnerabilities reported in a security finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:vulnerabilities ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 32 ;
            sh:path ocsf:category_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 38 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 57 ;
            sh:path ocsf:action ],
        [ sh:datatype xsd:long ;
            sh:description "The time of the most recent event included in the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:end_time ],
        [ sh:description """The normalized priority. Priority identifies the relative importance of the
incident or finding. It is a measurement of urgency.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 12 ;
            sh:path ocsf:priority_id ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 46 ;
            sh:path ocsf:status_code ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 68 ;
            sh:path ocsf:risk_details ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 22 ;
            sh:path ocsf:confidence_id ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 55 ;
            sh:path ocsf:actor ],
        [ sh:class ocsf:ApplicationObject ;
            sh:description """An Application describes the details for an inventoried application as reported
by an Application Security tool or other Developer-centric tooling.
Applications can be defined as Kubernetes resources, Containerized resources,
or application hosting-specific cloud sources such as AWS Elastic BeanStalk,
AWS Lightsail, or Azure Logic Apps.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:application ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path ocsf:raw_data ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 39 ;
            sh:path ocsf:metadata ],
        [ sh:class ocsf:FindingInfo ;
            sh:description "Describes the supporting information about a generated finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 26 ;
            sh:path ocsf:finding_info ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path ocsf:category_name ],
        [ sh:datatype xsd:string ;
            sh:description """The normalized status of the Finding set by the consumer normalized to the
caption of the status_id value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:status ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 60 ;
            sh:path ocsf:authorizations ],
        [ sh:class ocsf:Ticket ;
            sh:description """The associated ticket(s) in the ticketing system. Each ticket contains details
like ticket ID, status, etc.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path ocsf:tickets ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 65 ;
            sh:path ocsf:malware ],
        [ sh:class ocsf:VendorAttributes ;
            sh:description """The Vendor Attributes object can be used to represent values of attributes
populated by the Vendor/Finding Provider. It can help distinguish between the
vendor-provided values and consumer-updated values, of key attributes like
<code>severity_id</code>.<br>The original finding producer should not populate
this object. It should be populated by consuming systems that support data
mutability.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 30 ;
            sh:path ocsf:vendor_attributes ],
        [ sh:class ocsf:Remediation ;
            sh:description """Describes the recommended remediation steps to address identified
vulnerabilities or weaknesses.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:remediation ],
        [ sh:datatype xsd:integer ;
            sh:description "The impact as an integer value of the finding, valid range 0-100." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:impact_score ],
        [ sh:class ocsf:Compliance ;
            sh:description """Provides compliance context to vulnerabilities and other weaknesses that are
reported as part of an Application Security or Vulnerability Management tool's
built-in compliance framework mapping.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:compliance ],
        [ sh:datatype xsd:long ;
            sh:description "The time of the least recent event included in the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:start_time ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 42 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 63 ;
            sh:path ocsf:firewall_rule ],
        [ sh:datatype xsd:string ;
            sh:description "A user provided comment about the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:comment ],
        [ sh:description """The normalized impact of the incident or finding. Per NIST, this is the
magnitude of harm that can be expected to result from the consequences of
unauthorized disclosure, modification, destruction, or loss of information or
information system availability.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path ocsf:impact_id ],
        [ sh:datatype xsd:string ;
            sh:description """The impact , normalized to the caption of the impact_id value. In the case of
'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:impact ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:confidence_score ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 53 ;
            sh:path ocsf:api ],
        [ sh:class ocsf:Group ;
            sh:description "The details of the group assigned to an Incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:assignee_group ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 52 ;
            sh:path ocsf:unmapped ],
        [ sh:description "The normalized status identifier of the Finding, set by the consumer." ;
            sh:in ( "NEW" "IN_PROGRESS" "SUPPRESSED" "RESOLVED" "ARCHIVED" "DELETED" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 29 ;
            sh:path ocsf:status_id ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path ocsf:time ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 54 ;
            sh:path ocsf:cloud ],
        [ sh:class ocsf:Ticket ;
            sh:description "The linked ticket in the ticketing system." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ocsf:ticket ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:status_detail ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 34 ;
            sh:path ocsf:class_uid ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 67 ;
            sh:path ocsf:policy ],
        [ sh:class ocsf:User ;
            sh:description "The details of the user assigned to an Incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:assignee ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 56 ;
            sh:path ocsf:osint ],
        [ sh:datatype xsd:string ;
            sh:description "The verdict assigned to an Incident finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:verdict ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 64 ;
            sh:path ocsf:is_alert ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 50 ;
            sh:path ocsf:type_name ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 70 ;
            sh:path ocsf:risk_level_id ],
        [ sh:datatype xsd:string ;
            sh:description "The finding activity name, as defined by the <code>activity_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:activity_name ] ;
    sh:targetClass ocsf:ApplicationSecurityPostureFinding .

ocsf:Authentication a sh:NodeShape ;
    rdfs:comment """Authentication events report authentication session activities, including user
attempts to log on or log off, regardless of success, as well as other key
stages within the authentication process. These events are typically generated
by authentication services, such as Kerberos, OIDC, or SAML, and may include
information about the user, the authentication method used, and the status of
the authentication attempt.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 71 ;
            sh:path ocsf:risk_score ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path ocsf:enrichments ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 28 ;
            sh:path ocsf:class_uid ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 46 ;
            sh:path ocsf:timezone_offset ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:boolean ;
            sh:description "The attempted authentication is over a remote connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:is_remote ],
        [ sh:datatype xsd:string ;
            sh:description """The authentication protocol as defined by the caption of
<code>auth_protocol_id</code>. In the case of <code>Other</code>, it is defined
by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:auth_protocol ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 49 ;
            sh:path ocsf:unmapped ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 42 ;
            sh:path ocsf:status ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 52 ;
            sh:path ocsf:device ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates whether the credentials were passed in clear text.<p><b>Note:</b>
True if the credentials were passed in a clear text protocol such as FTP or
TELNET, or if Windows detected that a user's logon password was passed to the
authentication package in clear text.</p>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:is_cleartext ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 69 ;
            sh:path ocsf:risk_level ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description "Details about the source of the IAM activity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path ocsf:src_endpoint ],
        [ sh:datatype xsd:string ;
            sh:description """The details about the authentication request. For example, possible details for
Windows logon or logoff events
are:<ul><li>Success</li><ul><li>LOGOFF_USER_INITIATED</li><li>LOGOFF_OTHER</li></ul><li>Failure</li><ul><li>USER_DOES_NOT_EXIST</li><li>INVALID_CREDENTIALS</li><li>ACCOUNT_DISABLED</li><li>ACCOUNT_LOCKED_OUT</li><li>PASSWORD_EXPIRED</li></ul></ul>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:status_detail ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path ocsf:end_time ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 45 ;
            sh:path ocsf:time ],
        [ sh:class ocsf:HttpRequest ;
            sh:description "Details about the underlying HTTP request." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path ocsf:http_request ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 55 ;
            sh:path ocsf:action_id ],
        [ sh:description """The normalized identifier of the authentication protocol used to create the
user session.""" ;
            sh:in ( "UNKNOWN" "NTLM" "KERBEROS" "DIGEST" "OPENID" "SAML" "OAUTH_2_0" "PAP" "CHAP" "EAP" "RADIUS" "BASIC_AUTHENTICATION" "LDAP" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path ocsf:auth_protocol_id ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 34 ;
            sh:path ocsf:metadata ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:activity_name ],
        [ sh:class ocsf:Process ;
            sh:description "The trusted process that validated the authentication credentials." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:logon_process ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path ocsf:status_code ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path ocsf:start_time ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 35 ;
            sh:path ocsf:observables ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:category_name ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "LOGON" "LOGOFF" "AUTHENTICATION_TICKET" "SERVICE_TICKET_REQUEST" "SERVICE_TICKET_RENEW" "PREAUTH" "ACCOUNT_SWITCH" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path ocsf:activity_id ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 68 ;
            sh:path ocsf:risk_details ],
        [ sh:description "The normalized identifier of the account switch method." ;
            sh:in ( "UNKNOWN" "SUBSTITUTE_USER" "IMPERSONATE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path ocsf:account_switch_type_id ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:type_name ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 38 ;
            sh:path ocsf:raw_data_size ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 56 ;
            sh:path ocsf:attacks ],
        [ sh:datatype xsd:string ;
            sh:description """The account switch method, normalized to the caption of the
account_switch_type_id value. In the case of 'Other', it is defined by the
event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:account_switch_type ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 61 ;
            sh:path ocsf:disposition ],
        [ sh:description "The normalized logon type identifier." ;
            sh:in ( "UNKNOWN" "SYSTEM" "INTERACTIVE" "NETWORK" "BATCH" "OS_SERVICE" "UNLOCK" "NETWORK_CLEARTEXT" "NEW_CREDENTIALS" "REMOTE_INTERACTIVE" "CACHED_INTERACTIVE" "CACHED_REMOTE_INTERACTIVE" "CACHED_UNLOCK" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 15 ;
            sh:path ocsf:logon_type_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path ocsf:type_uid ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 40 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 39 ;
            sh:path ocsf:severity ],
        [ sh:class ocsf:Service ;
            sh:description "The service or gateway to which the user or process is being authenticated" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path ocsf:service ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 58 ;
            sh:path ocsf:confidence ],
        [ sh:datatype xsd:string ;
            sh:description """The logon type, normalized to the caption of the logon_type_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:logon_type ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 60 ;
            sh:path ocsf:confidence_score ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 67 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:count ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 65 ;
            sh:path ocsf:malware ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:class_name ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 62 ;
            sh:path ocsf:disposition_id ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 63 ;
            sh:path ocsf:firewall_rule ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path ocsf:actor ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 44 ;
            sh:path ocsf:status_id ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 59 ;
            sh:path ocsf:confidence_id ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 66 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 64 ;
            sh:path ocsf:is_alert ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 54 ;
            sh:path ocsf:action ],
        [ sh:class ocsf:Session ;
            sh:description "The authenticated user or service session." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path ocsf:session ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 53 ;
            sh:path ocsf:osint ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates logon is from a device not seen before or a first time account logon." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:is_new_logon ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description "The endpoint to which the authentication was targeted." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:dst_endpoint ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 70 ;
            sh:path ocsf:risk_level_id ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 26 ;
            sh:path ocsf:category_uid ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 50 ;
            sh:path ocsf:api ],
        [ sh:class ocsf:AuthFactor ;
            sh:description """Describes a category of methods used for identity verification in an
authentication attempt.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:auth_factors ],
        [ sh:class ocsf:AuthenticationToken ;
            sh:description """The authentication token, ticket, or assertion, e.g. <code>Kerberos</code>,
<code>OIDC</code>, <code>SAML</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:authentication_token ],
        [ sh:class ocsf:HttpResponse ;
            sh:description "Details about the underlying HTTP response." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path ocsf:http_response ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 57 ;
            sh:path ocsf:authorizations ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether Multi Factor Authentication was used during authentication." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:is_mfa ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:duration ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 36 ;
            sh:path ocsf:raw_data ],
        [ sh:class ocsf:User ;
            sh:description "The subject (user/role or account) to authenticate." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path ocsf:user ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 37 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:class ocsf:Certificate ;
            sh:description """The certificate associated with the authentication or pre-authentication
(Kerberos).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:certificate ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 51 ;
            sh:path ocsf:cloud ] ;
    sh:targetClass ocsf:Authentication .

ocsf:AuthorizeSession a sh:NodeShape ;
    rdfs:comment """Authorize Session events report privileges or groups assigned to a new user
session, usually at login time.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:confidence_score ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path ocsf:time ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 56 ;
            sh:path ocsf:risk_level ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path ocsf:unmapped ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description "The Endpoint for which the user session was targeted." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:dst_endpoint ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 37 ;
            sh:path ocsf:api ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:duration ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 42 ;
            sh:path ocsf:action_id ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:end_time ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:raw_data ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 55 ;
            sh:path ocsf:risk_details ],
        [ sh:datatype xsd:string ;
            sh:description "The list of sensitive privileges, assigned to the new user session." ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:privileges ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:status_detail ],
        [ sh:class ocsf:HttpRequest ;
            sh:description "Details about the underlying HTTP request." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:http_request ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:message ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 44 ;
            sh:path ocsf:authorizations ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:activity_name ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 46 ;
            sh:path ocsf:confidence_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:count ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 53 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 52 ;
            sh:path ocsf:malware ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 39 ;
            sh:path ocsf:device ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 12 ;
            sh:path ocsf:category_uid ],
        [ sh:class ocsf:HttpResponse ;
            sh:description "Details about the underlying HTTP response." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:http_response ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:timezone_offset ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 50 ;
            sh:path ocsf:firewall_rule ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 14 ;
            sh:path ocsf:class_uid ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 40 ;
            sh:path ocsf:osint ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 54 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 34 ;
            sh:path ocsf:type_name ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:is_alert ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 45 ;
            sh:path ocsf:confidence ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "ASSIGN_PRIVILEGES" "ASSIGN_GROUPS" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path ocsf:activity_id ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:class_name ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description "Details about the source of the IAM activity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:src_endpoint ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 31 ;
            sh:path ocsf:status_id ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:status_code ],
        [ sh:class ocsf:Group ;
            sh:description "Group that was assigned to the new user session." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:group ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path ocsf:observables ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 49 ;
            sh:path ocsf:disposition_id ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path ocsf:action ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 26 ;
            sh:path ocsf:severity_id ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path ocsf:metadata ],
        [ sh:class ocsf:User ;
            sh:description "The user to which new privileges were assigned." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:user ],
        [ sh:class ocsf:Session ;
            sh:description "The user session with the assigned privileges." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:session ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:severity ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:status ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:actor ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 58 ;
            sh:path ocsf:risk_score ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path ocsf:disposition ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:category_name ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path ocsf:type_uid ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 57 ;
            sh:path ocsf:risk_level_id ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:start_time ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:raw_data_size ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 43 ;
            sh:path ocsf:attacks ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path ocsf:enrichments ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 38 ;
            sh:path ocsf:cloud ] ;
    sh:targetClass ocsf:AuthorizeSession .

ocsf:BaseEvent a sh:NodeShape ;
    rdfs:comment """The base event is a generic and concrete event. It also defines a set of
attributes available in most event classes. As a generic event that does not
belong to any event category, it could be used to log events that are not
otherwise defined by the schema.""" ;
    sh:closed true ;
    sh:ignoredProperties ( ocsf:kill_chain ocsf:injection_type_id ocsf:priority_id ocsf:num_processes ocsf:version ocsf:protocol_name ocsf:proxy_connection_info ocsf:observation_point_id ocsf:access_result ocsf:account_switch_type ocsf:query ocsf:share_type_id ocsf:remediation ocsf:dst_endpoint ocsf:finding_info_list ocsf:peripheral_device ocsf:response_time ocsf:email ocsf:lease_dur ocsf:tunnel_type_id ocsf:tls ocsf:protocol_ver ocsf:impact_score ocsf:connection_info ocsf:share_type ocsf:proxy_traffic ocsf:impact ocsf:http_request ocsf:message_trace_uid ocsf:priority ocsf:certificate ocsf:job ocsf:last_run_time ocsf:access_analysis_result ocsf:run_count ocsf:is_remote ocsf:total ocsf:win_service ocsf:connection_uid ocsf:state_id ocsf:security_level ocsf:file_result ocsf:url ocsf:data_security ocsf:ticket ocsf:vendor_attributes ocsf:open_mask ocsf:access_mask ocsf:answers ocsf:query_result ocsf:applications ocsf:user ocsf:access_list ocsf:port ocsf:launch_type_id ocsf:vulnerabilities ocsf:base_address ocsf:sbom ocsf:prev_security_level ocsf:proxy_endpoint ocsf:users ocsf:attempt ocsf:create_mask ocsf:win_resource ocsf:tree_uid ocsf:compliance ocsf:requested_permissions ocsf:evidence ocsf:num_registry_items ocsf:keyboard_info ocsf:verdict_id ocsf:folder ocsf:email_auth ocsf:from_ ocsf:finding_info ocsf:rcode_id ocsf:size ocsf:logon_type ocsf:database ocsf:is_renewal ocsf:log_type rdf:type ocsf:banner ocsf:client_hassh ocsf:dialect ocsf:resources ocsf:ja4_fingerprint_list ocsf:proxy_http_response ocsf:desc ocsf:authentication_token ocsf:cumulative_traffic ocsf:proxy_tls ocsf:assignee_group ocsf:src_url ocsf:idp ocsf:kernel ocsf:name ocsf:file ocsf:schedule_uid ocsf:num_detections ocsf:aircraft ocsf:num_folders ocsf:share ocsf:command_uid ocsf:unmanned_system_operating_area ocsf:direction ocsf:http_status ocsf:type ocsf:web_resources ocsf:process ocsf:stratum ocsf:injection_type ocsf:certificate_chain ocsf:cis_benchmark_result ocsf:email_uid ocsf:rssi ocsf:dispersion ocsf:expiration_time ocsf:unmanned_system_operator ocsf:initiator ocsf:countermeasures ocsf:exit_code ocsf:auth_type_id ocsf:query_info ocsf:region ocsf:http_response ocsf:query_evidence ocsf:initiator_id ocsf:entity_result ocsf:stratum_id ocsf:network_observation_point ocsf:logon_type_id ocsf:databucket ocsf:identity_activity_metrics ocsf:dce_rpc ocsf:permission_analysis_results ocsf:http_cookies ocsf:group ocsf:service ocsf:network_interfaces ocsf:comment ocsf:is_suspected_breach ocsf:subgroup ocsf:observation_point ocsf:launch_type ocsf:response ocsf:kb_article_list ocsf:reg_key ocsf:transaction_uid ocsf:identifier_cookie ocsf:proxy_http_request ocsf:state ocsf:privileges ocsf:rcode ocsf:logon_process ocsf:smtp_hello ocsf:num_trusted_items ocsf:verdict ocsf:finding ocsf:tunnel_interface ocsf:codes ocsf:proxy ocsf:ai_model ocsf:direction_id ocsf:client_dialects ocsf:server_hassh ocsf:log_name ocsf:message_context ocsf:packet_list ocsf:policies ocsf:assignee ocsf:num_skipped_items ocsf:is_src_dst_assignment_known ocsf:driver ocsf:src_endpoint ocsf:scan ocsf:log_type_id ocsf:command ocsf:request ocsf:command_responses ocsf:web_resources_result ocsf:component ocsf:auth_type ocsf:security_states ocsf:traffic ocsf:account_switch_type_id ocsf:module ocsf:impact_id ocsf:delay ocsf:reg_value ocsf:capabilities ocsf:data_sources ocsf:log_provider ocsf:auth_protocol ocsf:app_name ocsf:cis_csc ocsf:resource ocsf:auth_factors ocsf:prev_reg_key ocsf:entity ocsf:anomaly_analyses ocsf:num_resolutions ocsf:trace ocsf:tunnel_type ocsf:relay ocsf:prev_reg_value ocsf:to ocsf:user_result ocsf:query_result_id ocsf:classification ocsf:package ocsf:product ocsf:app_protocol_name ocsf:remote_display ocsf:prev_security_level_id ocsf:analytic ocsf:open_type ocsf:assessments ocsf:num_files ocsf:session ocsf:query_time ocsf:evidences ocsf:startup_item ocsf:auth_protocol_id ocsf:type_id ocsf:load_balancer ocsf:prev_security_states ocsf:security_level_id ocsf:table ocsf:actual_permissions ocsf:container ocsf:app ocsf:file_diff ocsf:is_mfa ocsf:nist ocsf:unmanned_aerial_system ocsf:num_network_items ocsf:is_cleartext ocsf:precision ocsf:script ocsf:is_new_logon ocsf:application ocsf:tickets ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:count ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 42 ;
            sh:path ocsf:firewall_rule ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 30 ;
            sh:path ocsf:actor ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 34 ;
            sh:path ocsf:action_id ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 37 ;
            sh:path ocsf:confidence ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:time ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:risk_details ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 29 ;
            sh:path ocsf:cloud ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path ocsf:is_alert ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 27 ;
            sh:path ocsf:unmapped ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 31 ;
            sh:path ocsf:device ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:observables ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:status_detail ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:type_uid ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 41 ;
            sh:path ocsf:disposition_id ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path ocsf:activity_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:duration ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 38 ;
            sh:path ocsf:confidence_id ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path ocsf:category_uid ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 22 ;
            sh:path ocsf:status_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:timezone_offset ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 44 ;
            sh:path ocsf:malware ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:class_name ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:action ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:start_time ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:enrichments ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path ocsf:risk_level ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:end_time ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path ocsf:class_uid ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 35 ;
            sh:path ocsf:attacks ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:status_code ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path ocsf:osint ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 49 ;
            sh:path ocsf:risk_level_id ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:category_name ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:type_name ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:status ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 46 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:raw_data_size ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:activity_name ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:metadata ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path ocsf:disposition ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 45 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 28 ;
            sh:path ocsf:api ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 39 ;
            sh:path ocsf:confidence_score ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:raw_data ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path ocsf:authorizations ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 17 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:severity ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 50 ;
            sh:path ocsf:risk_score ] ;
    sh:targetClass ocsf:BaseEvent .

ocsf:CisBenchmark a sh:NodeShape ;
    rdfs:comment """The CIS Benchmark object describes best practices for securely configuring IT
systems, software, networks, and cloud infrastructure as defined by the <a
target='_blank' href='https://www.cisecurity.org/cis-benchmarks/'>Center for
Internet Security</a>. See also <a target='_blank'
href='https://www.cisecurity.org/insights/blog/getting-to-know-the-cis-benchmarks'>Getting
to Know the CIS Benchmarks</a>.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The CIS Benchmark name. For example: <i>Ensure mounting of cramfs filesystems
is disabled.</i>""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description """The CIS Benchmark description. For example: <i>The cramfs filesystem type is a
compressed read-only Linux filesystem embedded in small footprint systems. A
cramfs image can be used without having to first decompress the image.</i>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:desc ],
        [ sh:class ocsf:CisControl ;
            sh:description """The CIS Critical Security Controls is a prioritized set of actions to protect
your organization and data from cyber-attack vectors.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:cis_controls ] ;
    sh:targetClass ocsf:CisBenchmark .

ocsf:CloudProfile a sh:NodeShape ;
    rdfs:comment """The attributes that describe information specific to Cloud
services/applications.""" ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:cloud ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:api ] ;
    sh:targetClass ocsf:CloudProfile .

ocsf:CloudResourcesInventoryInfo a sh:NodeShape ;
    rdfs:comment """Cloud Resources Inventory Info events report cloud asset inventory data. This
data can be either logged or proactively collected. For example, use this event
class when creating an inventory of cloud resource information from a
Configuration Management Database (CMDB), Cyber Asset Attack Surface Management
(CAASM), direct public cloud service provider APIs, Software-as-a-Service
(SaaS) APIs, or otherwise.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Database ;
            sh:description "A cloud-based database discovered by an inventory process." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:database ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:raw_data_size ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:category_name ],
        [ sh:class ocsf:Idp ;
            sh:description """The Identity Provider that is being discovered by an inventory process, or that
is related to the cloud resource(s) being discovered by an inventory process.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:idp ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "LOG" "COLLECT" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 8 ;
            sh:path ocsf:activity_id ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:start_time ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 48 ;
            sh:path ocsf:disposition_id ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 39 ;
            sh:path ocsf:osint ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:status_code ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 44 ;
            sh:path ocsf:confidence ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 53 ;
            sh:path ocsf:policy ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 30 ;
            sh:path ocsf:status_id ],
        [ sh:class ocsf:Databucket ;
            sh:description """A cloud-based data bucket or other object storage discovered by an inventory
process.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:databucket ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 49 ;
            sh:path ocsf:firewall_rule ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 50 ;
            sh:path ocsf:is_alert ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:class_name ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:status_detail ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:count ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path ocsf:timezone_offset ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:type_name ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 13 ;
            sh:path ocsf:class_uid ],
        [ sh:class ocsf:Container ;
            sh:description """A cloud-based container image or running container discovered by an inventory
process.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:container ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 41 ;
            sh:path ocsf:action_id ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:status ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 56 ;
            sh:path ocsf:risk_level_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:duration ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path ocsf:time ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 57 ;
            sh:path ocsf:risk_score ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 42 ;
            sh:path ocsf:attacks ],
        [ sh:class ocsf:ResourceDetails ;
            sh:description """The cloud resource(s) that are being discovered by an inventory process. Use
this object if there is not a direct object match in the class.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:resources ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 25 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:disposition ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 45 ;
            sh:path ocsf:confidence_id ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 38 ;
            sh:path ocsf:device ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 43 ;
            sh:path ocsf:authorizations ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 52 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path ocsf:metadata ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:activity_name ],
        [ sh:datatype xsd:string ;
            sh:description """The cloud region where the resource is located, e.g.,
<code>us-isof-south-1</code>, <code>eastus2</code>, <code>us-central1</code>,
etc.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:region ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 34 ;
            sh:path ocsf:type_uid ],
        [ sh:class ocsf:Cloud ;
            sh:description """Cloud service provider or SaaS platform metadata about the cloud resource(s)
that are being discovered by an inventory process.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:cloud ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path ocsf:action ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 51 ;
            sh:path ocsf:malware ],
        [ sh:class ocsf:Table ;
            sh:description "A cloud-based database table discovered by an inventory process." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:table ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 54 ;
            sh:path ocsf:risk_details ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 55 ;
            sh:path ocsf:risk_level ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:raw_data ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 37 ;
            sh:path ocsf:actor ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path ocsf:observables ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 35 ;
            sh:path ocsf:unmapped ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 11 ;
            sh:path ocsf:category_uid ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path ocsf:api ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path ocsf:enrichments ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 46 ;
            sh:path ocsf:confidence_score ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:severity ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:end_time ] ;
    sh:targetClass ocsf:CloudResourcesInventoryInfo .

ocsf:ComplianceFinding a sh:NodeShape ;
    rdfs:comment """Compliance Finding events describe results of evaluations performed against
resources, to check compliance with various Industry Frameworks or Security
Standards such as <code>NIST SP 800-53, CIS AWS Foundations Benchmark v1.4.0,
ISO/IEC 27001</code> etc. Note: if the event producer is a security control,
the <code>security_control</code> profile should be applied and its
<code>attacks</code> information, if present, should be duplicated into the
<code>finding_info</code> object. <br><strong>Note: </strong>If the Finding is
an incident, i.e. requires incident workflow, also apply the
<code>incident</code> profile or aggregate this finding into an <code>Incident
Finding</code>.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 56 ;
            sh:path ocsf:osint ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 71 ;
            sh:path ocsf:risk_score ],
        [ sh:datatype xsd:string ;
            sh:description "A user provided comment about the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:comment ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 67 ;
            sh:path ocsf:policy ],
        [ sh:class ocsf:Ticket ;
            sh:description """The associated ticket(s) in the ticketing system. Each ticket contains details
like ticket ID, status, etc.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 28 ;
            sh:path ocsf:tickets ],
        [ sh:datatype xsd:string ;
            sh:description "The finding activity name, as defined by the <code>activity_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:activity_name ],
        [ sh:datatype xsd:long ;
            sh:description "The time of the most recent event included in the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:end_time ],
        [ sh:class ocsf:Compliance ;
            sh:description """The compliance object provides context to compliance findings (e.g., a check
against a specific regulatory or best practice framework such as CIS, NIST
etc.) and contains compliance related details.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:compliance ],
        [ sh:description "The normalized verdict of an Incident." ;
            sh:in ( "UNKNOWN" "FALSE_POSITIVE" "TRUE_POSITIVE" "DISREGARD" "SUSPICIOUS" "BENIGN" "TEST" "INSUFFICIENT_DATA" "SECURITY_RISK" "MANAGED_EXTERNALLY" "DUPLICATE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 30 ;
            sh:path ocsf:verdict_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 36 ;
            sh:path ocsf:duration ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 64 ;
            sh:path ocsf:is_alert ],
        [ sh:datatype xsd:string ;
            sh:description """The impact , normalized to the caption of the impact_id value. In the case of
'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:impact ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 60 ;
            sh:path ocsf:authorizations ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 70 ;
            sh:path ocsf:risk_level_id ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path ocsf:category_name ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:confidence ],
        [ sh:datatype xsd:boolean ;
            sh:description "A determination based on analytics as to whether a potential breach was found." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:is_suspected_breach ],
        [ sh:datatype xsd:long ;
            sh:description "The time of the least recent event included in the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:start_time ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path ocsf:time ],
        [ sh:datatype xsd:integer ;
            sh:description "The impact as an integer value of the finding, valid range 0-100." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:impact_score ],
        [ sh:class ocsf:ResourceDetails ;
            sh:description """Describes details about the resource/resources that are the subject of the
compliance check.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:resources ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 39 ;
            sh:path ocsf:metadata ],
        [ sh:class ocsf:Device ;
            sh:description """Describes the affected device/host. If applicable, it can be used in
conjunction with <code>Resource(s)</code>. <p> e.g. Specific details about an
AWS EC2 instance, that is affected by the Finding.</p>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:device ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 61 ;
            sh:path ocsf:disposition ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 49 ;
            sh:path ocsf:timezone_offset ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 65 ;
            sh:path ocsf:malware ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:class_name ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 53 ;
            sh:path ocsf:api ],
        [ sh:class ocsf:VendorAttributes ;
            sh:description """The Vendor Attributes object can be used to represent values of attributes
populated by the Vendor/Finding Provider. It can help distinguish between the
vendor-provided values and consumer-updated values, of key attributes like
<code>severity_id</code>.<br>The original finding producer should not populate
this object. It should be populated by consuming systems that support data
mutability.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path ocsf:vendor_attributes ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 59 ;
            sh:path ocsf:attacks ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A Url link used to access the original incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:src_url ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 32 ;
            sh:path ocsf:category_uid ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 58 ;
            sh:path ocsf:action_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:type_uid ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 52 ;
            sh:path ocsf:unmapped ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 55 ;
            sh:path ocsf:actor ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 57 ;
            sh:path ocsf:action ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 66 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:class ocsf:User ;
            sh:description "The details of the user assigned to an Incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path ocsf:assignee ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 69 ;
            sh:path ocsf:risk_level ],
        [ sh:class ocsf:Evidences ;
            sh:description "Describes various evidence artifacts associated with the compliance finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:evidences ],
        [ sh:datatype xsd:string ;
            sh:description "The verdict assigned to an Incident finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:verdict ],
        [ sh:description "The normalized identifier of the finding activity." ;
            sh:in ( "CREATE" "UPDATE" "CLOSE" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path ocsf:activity_id ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 9 ;
            sh:path ocsf:confidence_id ],
        [ sh:class ocsf:ResourceDetails ;
            sh:description """Describes details about the resource that is the subject of the compliance
check.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:resource ],
        [ sh:class ocsf:Group ;
            sh:description "The details of the group assigned to an Incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path ocsf:assignee_group ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 46 ;
            sh:path ocsf:status_code ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 68 ;
            sh:path ocsf:risk_details ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path ocsf:count ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 44 ;
            sh:path ocsf:severity ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 50 ;
            sh:path ocsf:type_name ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path ocsf:raw_data ],
        [ sh:class ocsf:Ticket ;
            sh:description "The linked ticket in the ticketing system." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 27 ;
            sh:path ocsf:ticket ],
        [ sh:datatype xsd:string ;
            sh:description """The normalized status of the Finding set by the consumer normalized to the
caption of the status_id value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:status ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 63 ;
            sh:path ocsf:firewall_rule ],
        [ sh:class ocsf:FindingInfo ;
            sh:description "Describes the supporting information about a generated finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:finding_info ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 37 ;
            sh:path ocsf:enrichments ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:status_detail ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 54 ;
            sh:path ocsf:cloud ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 38 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path ocsf:raw_data_size ],
        [ sh:datatype xsd:string ;
            sh:description """The priority, normalized to the caption of the priority_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:priority ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 42 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 45 ;
            sh:path ocsf:severity_id ],
        [ sh:description "The normalized status identifier of the Finding, set by the consumer." ;
            sh:in ( "NEW" "IN_PROGRESS" "SUPPRESSED" "RESOLVED" "ARCHIVED" "DELETED" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 16 ;
            sh:path ocsf:status_id ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 34 ;
            sh:path ocsf:class_uid ],
        [ sh:class ocsf:Remediation ;
            sh:description "Describes the recommended remediation steps to address identified issue(s)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:remediation ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 62 ;
            sh:path ocsf:disposition_id ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 40 ;
            sh:path ocsf:observables ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:confidence_score ],
        [ sh:description """The normalized priority. Priority identifies the relative importance of the
incident or finding. It is a measurement of urgency.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 25 ;
            sh:path ocsf:priority_id ],
        [ sh:description """The normalized impact of the incident or finding. Per NIST, this is the
magnitude of harm that can be expected to result from the consequences of
unauthorized disclosure, modification, destruction, or loss of information or
information system availability.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 21 ;
            sh:path ocsf:impact_id ] ;
    sh:targetClass ocsf:ComplianceFinding .

ocsf:ConfigState a sh:NodeShape ;
    rdfs:comment """Device Config State events report device configuration data, device
assessments, and/or CIS Benchmark results.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 52 ;
            sh:path ocsf:risk_score ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 7 ;
            sh:path ocsf:category_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:category_name ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 39 ;
            sh:path ocsf:confidence ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 36 ;
            sh:path ocsf:action_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:count ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 45 ;
            sh:path ocsf:is_alert ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 34 ;
            sh:path ocsf:osint ],
        [ sh:class ocsf:Assessment ;
            sh:description "A list of assessments associated with the device." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:assessments ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 9 ;
            sh:path ocsf:class_uid ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 33 ;
            sh:path ocsf:cloud ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path ocsf:metadata ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:status_detail ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 37 ;
            sh:path ocsf:attacks ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:raw_data_size ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 21 ;
            sh:path ocsf:severity_id ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 44 ;
            sh:path ocsf:firewall_rule ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:time ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 51 ;
            sh:path ocsf:risk_level_id ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 42 ;
            sh:path ocsf:disposition ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:raw_data ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 31 ;
            sh:path ocsf:unmapped ],
        [ sh:class ocsf:CisBenchmarkResult ;
            sh:description """The CIS Benchmark Result object captures results generated from benchmark
evaluations as defined by the Center for Internet Security (<a target='_blank'
href='https://www.cisecurity.org/cis-benchmarks/'>CIS</a>).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:cis_benchmark_result ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:duration ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 38 ;
            sh:path ocsf:authorizations ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:actor ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "LOG" "COLLECT" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 4 ;
            sh:path ocsf:activity_id ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 47 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:type_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 50 ;
            sh:path ocsf:risk_level ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path ocsf:observables ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 48 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:end_time ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path ocsf:action ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:activity_name ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:timezone_offset ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 46 ;
            sh:path ocsf:malware ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:class_name ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:enrichments ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 49 ;
            sh:path ocsf:risk_details ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 40 ;
            sh:path ocsf:confidence_id ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:type_name ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:start_time ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:severity ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 26 ;
            sh:path ocsf:status_id ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path ocsf:confidence_score ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:status_code ],
        [ sh:class ocsf:Device ;
            sh:description "The device that is being discovered by an inventory process." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:device ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 43 ;
            sh:path ocsf:disposition_id ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path ocsf:api ] ;
    sh:targetClass ocsf:ConfigState .

ocsf:ContainerProfile a sh:NodeShape ;
    rdfs:comment "The container context for a process." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description """If running under a process namespace (such as in a container), the process
identifier within that process namespace.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:namespace_pid ],
        [ sh:class ocsf:Container ;
            sh:description """The information describing an instance of a container. A container is a
prepackaged, portable system image that runs isolated on an existing system
using a container runtime like containerd.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:container ] ;
    sh:targetClass ocsf:ContainerProfile .

ocsf:DataClassificationProfile a sh:NodeShape ;
    rdfs:comment """The Data Classification profile adds attributes to specific resource objects,
allowing users to describe information about classifiers & data classification
results.""" ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:DataClassification ;
            sh:description """The Data Classification object includes information about data classification
levels and data category types.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:data_classification ],
        [ sh:class ocsf:DataClassification ;
            sh:description """A list of Data Classification objects, that include information about data
classification levels and data category types, identified by a classifier.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:data_classifications ] ;
    sh:targetClass ocsf:DataClassificationProfile .

ocsf:DataSecurityFinding a sh:NodeShape ;
    rdfs:comment """A Data Security Finding describes detections or alerts generated by various
data security products such as Data Loss Prevention (DLP), Data Classification,
Secrets Management, Digital Rights Management (DRM), Data Security Posture
Management (DSPM), and similar tools. These detections or alerts can be created
using fingerprinting, statistical analysis, machine learning or other
methodologies. The finding describes the actors and endpoints who accessed or
own the sensitive data, as well as the resources which store the sensitive
data. Note: if the event producer is a security control, the
<code>security_control</code> profile should be applied and its
<code>attacks</code> information, if present, should be duplicated into the
<code>finding_info</code> object. <br><strong>Note: </strong>If the Finding is
an incident, i.e. requires incident workflow, also apply the
<code>incident</code> profile  or aggregate this finding into an <code>Incident
Finding</code>.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 74 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:string ;
            sh:description "A user provided comment about the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:comment ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 57 ;
            sh:path ocsf:time ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 43 ;
            sh:path ocsf:class_uid ],
        [ sh:class ocsf:Database ;
            sh:description """Describes the database where classified or sensitive data is stored in, or was
accessed from. Databases are typically datastore services that contain an
organized collection of structured and/or semi-structured data.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:database ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 19 ;
            sh:path ocsf:risk_level_id ],
        [ sh:datatype xsd:string ;
            sh:description """The impact , normalized to the caption of the impact_id value. In the case of
'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:impact ],
        [ sh:description "The normalized verdict of an Incident." ;
            sh:in ( "UNKNOWN" "FALSE_POSITIVE" "TRUE_POSITIVE" "DISREGARD" "SUSPICIOUS" "BENIGN" "TEST" "INSUFFICIENT_DATA" "SECURITY_RISK" "MANAGED_EXTERNALLY" "DUPLICATE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 39 ;
            sh:path ocsf:verdict_id ],
        [ sh:class ocsf:File ;
            sh:description "Describes a file that contains classified or sensitive data." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:file ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path ocsf:category_name ],
        [ sh:class ocsf:Ticket ;
            sh:description "The linked ticket in the ticketing system." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path ocsf:ticket ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 58 ;
            sh:path ocsf:timezone_offset ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. For example,
an <code>activity_id</code> of 'Create' could constitute an alertable signal
and the value would be <code>true</code>, while 'Close' likely would not and
either omit the attribute or set its value to <code>false</code>.  Note that
other events with the <code>security_control</code> profile may also be deemed
alertable signals and may also carry <code>is_alert = true</code> attributes.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:is_alert ],
        [ sh:class ocsf:Device ;
            sh:description """Describes the device where classified or sensitive data is stored in, or was
accessed from.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:device ],
        [ sh:datatype xsd:string ;
            sh:description """The priority, normalized to the caption of the priority_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:priority ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 70 ;
            sh:path ocsf:disposition_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 44 ;
            sh:path ocsf:count ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 63 ;
            sh:path ocsf:cloud ],
        [ sh:class ocsf:Table ;
            sh:description """Describes the table where classified or sensitive data is stored in, or was
accessed from. The table object represents a table within a structured
relational database, warehouse, lake, or similar.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path ocsf:table ],
        [ sh:datatype xsd:string ;
            sh:description """The normalized status of the Finding set by the consumer normalized to the
caption of the status_id value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:status ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 61 ;
            sh:path ocsf:unmapped ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 72 ;
            sh:path ocsf:malware ],
        [ sh:class ocsf:VendorAttributes ;
            sh:description """The Vendor Attributes object can be used to represent values of attributes
populated by the Vendor/Finding Provider. It can help distinguish between the
vendor-provided values and consumer-updated values, of key attributes like
<code>severity_id</code>.<br>The original finding producer should not populate
this object. It should be populated by consuming systems that support data
mutability.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 29 ;
            sh:path ocsf:vendor_attributes ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 56 ;
            sh:path ocsf:status_detail ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 42 ;
            sh:path ocsf:class_name ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:confidence ],
        [ sh:class ocsf:FindingInfo ;
            sh:description "Describes the supporting information about a generated finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 25 ;
            sh:path ocsf:finding_info ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 67 ;
            sh:path ocsf:attacks ],
        [ sh:datatype xsd:integer ;
            sh:description "The impact as an integer value of the finding, valid range 0-100." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:impact_score ],
        [ sh:datatype xsd:boolean ;
            sh:description "A determination based on analytics as to whether a potential breach was found." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path ocsf:is_suspected_breach ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 52 ;
            sh:path ocsf:raw_data_size ],
        [ sh:class ocsf:ResourceDetails ;
            sh:description """Describes details about additional resources, where classified or sensitive
data is stored in, or was accessed from. <p> You can populate this object, if
the specific resource type objects available in the class (<code>database,
databucket, table, file</code>) aren't sufficient; OR <br> You can also choose
to duplicate <code>uid, name</code> of the specific resources objects, for a
consistent access to resource uids across all findings.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path ocsf:resources ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 65 ;
            sh:path ocsf:action ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 55 ;
            sh:path ocsf:status_code ],
        [ sh:description """The normalized impact of the incident or finding. Per NIST, this is the
magnitude of harm that can be expected to result from the consequences of
unauthorized disclosure, modification, destruction, or loss of information or
information system availability.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 13 ;
            sh:path ocsf:impact_id ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:confidence_score ],
        [ sh:datatype xsd:string ;
            sh:description """The Data Security finding activity name, as defined by the
<code>activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:activity_name ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 41 ;
            sh:path ocsf:category_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:risk_score ],
        [ sh:datatype xsd:long ;
            sh:description "The time of the most recent event included in the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:end_time ],
        [ sh:datatype xsd:long ;
            sh:description "The time of the least recent event included in the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:start_time ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 46 ;
            sh:path ocsf:enrichments ],
        [ sh:class ocsf:DataSecurity ;
            sh:description """The Data Security object describes the characteristics, techniques and content
of a Data Loss Prevention (DLP), Data Loss Detection (DLD), Data
Classification, or similar tools' finding, alert, or detection mechanism(s).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:data_security ],
        [ sh:description "The normalized identifier of the Data Security Finding activity." ;
            sh:in ( "CREATE" "UPDATE" "CLOSE" "SUPPRESSED" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path ocsf:activity_id ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 53 ;
            sh:path ocsf:severity ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 50 ;
            sh:path ocsf:raw_data ],
        [ sh:class ocsf:Actor ;
            sh:description """Describes details about the actor implicated in the data security finding.
Either an actor that owns a particular digital file or information store, or an
actor which accessed classified or sensitive data.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:actor ],
        [ sh:description """The normalized priority. Priority identifies the relative importance of the
incident or finding. It is a measurement of urgency.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 34 ;
            sh:path ocsf:priority_id ],
        [ sh:datatype xsd:string ;
            sh:description "The verdict assigned to an Incident finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 38 ;
            sh:path ocsf:verdict ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 62 ;
            sh:path ocsf:api ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 60 ;
            sh:path ocsf:type_uid ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 73 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 45 ;
            sh:path ocsf:duration ],
        [ sh:class ocsf:Databucket ;
            sh:description """Describes the databucket where classified or sensitive data is stored in, or
was accessed from. The data bucket object is a basic container that holds data,
typically organized through the use of data partitions.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:databucket ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 51 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path ocsf:confidence_id ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 68 ;
            sh:path ocsf:authorizations ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 48 ;
            sh:path ocsf:metadata ],
        [ sh:class ocsf:User ;
            sh:description "The details of the user assigned to an Incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 30 ;
            sh:path ocsf:assignee ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description """Details about the source endpoint where classified or sensitive data was
accessed from.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path ocsf:src_endpoint ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 49 ;
            sh:path ocsf:observables ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:risk_level ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description """Describes the endpoint where classified or sensitive data is stored in, or was
accessed from.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path ocsf:dst_endpoint ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 64 ;
            sh:path ocsf:osint ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 71 ;
            sh:path ocsf:firewall_rule ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:risk_details ],
        [ sh:class ocsf:Group ;
            sh:description "The details of the group assigned to an Incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 31 ;
            sh:path ocsf:assignee_group ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 66 ;
            sh:path ocsf:action_id ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A Url link used to access the original incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path ocsf:src_url ],
        [ sh:description "The normalized status identifier of the Finding, set by the consumer." ;
            sh:in ( "NEW" "IN_PROGRESS" "SUPPRESSED" "RESOLVED" "ARCHIVED" "DELETED" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 28 ;
            sh:path ocsf:status_id ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 54 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 59 ;
            sh:path ocsf:type_name ],
        [ sh:class ocsf:Ticket ;
            sh:description """The associated ticket(s) in the ticketing system. Each ticket contains details
like ticket ID, status, etc.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 37 ;
            sh:path ocsf:tickets ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 69 ;
            sh:path ocsf:disposition ] ;
    sh:targetClass ocsf:DataSecurityFinding .

ocsf:DatastoreActivity a sh:NodeShape ;
    rdfs:comment """Datastore events describe general activities (Read, Update, Query, Delete,
etc.) which affect datastores or data within those datastores, e.g. (AWS RDS,
AWS S3).""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 60 ;
            sh:path ocsf:risk_level ],
        [ sh:description "The normalized datastore resource type identifier." ;
            sh:in ( "UNKNOWN" "DATABASE" "DATABUCKET" "TABLE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 11 ;
            sh:path ocsf:type_id ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:confidence_score ],
        [ sh:class ocsf:Database ;
            sh:description """The database object is used for databases which are typically datastore
services that contain an organized collection of structured and unstructured
data or a types of data.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:database ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 25 ;
            sh:path ocsf:observables ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 47 ;
            sh:path ocsf:attacks ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 34 ;
            sh:path ocsf:status_detail ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 39 ;
            sh:path ocsf:type_uid ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 41 ;
            sh:path ocsf:api ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 61 ;
            sh:path ocsf:risk_level_id ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 57 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description "Details about the source of the activity." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:src_endpoint ],
        [ sh:class ocsf:AiModel ;
            sh:description """The AI Model object describes the characteristics of an AI/ML model. Examples
include language models like GPT-4, embedding models like
text-embedding-ada-002, and computer vision models like CLIP.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:ai_model ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 45 ;
            sh:path ocsf:action ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 56 ;
            sh:path ocsf:malware ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 50 ;
            sh:path ocsf:confidence_id ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:end_time ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:raw_data ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 62 ;
            sh:path ocsf:risk_score ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 24 ;
            sh:path ocsf:metadata ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 18 ;
            sh:path ocsf:class_uid ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:duration ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path ocsf:start_time ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "READ" "UPDATE" "CONNECT" "QUERY" "WRITE" "CREATE" "DELETE" "LIST" "ENCRYPT" "DECRYPT" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path ocsf:activity_id ],
        [ sh:class ocsf:QueryInfo ;
            sh:description """The query info object holds information related to data access within a
datastore. To access, manipulate, delete, or retrieve data from a datastore, a
database query must be written using a specific syntax.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:query_info ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:activity_name ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 52 ;
            sh:path ocsf:disposition ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path ocsf:enrichments ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 53 ;
            sh:path ocsf:disposition_id ],
        [ sh:class ocsf:Databucket ;
            sh:description """The data bucket object is a basic container that holds data, typically
organized through the use of data partitions.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:databucket ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 54 ;
            sh:path ocsf:firewall_rule ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:raw_data_size ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 35 ;
            sh:path ocsf:status_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:count ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 46 ;
            sh:path ocsf:action_id ],
        [ sh:datatype xsd:string ;
            sh:description "The datastore resource type (e.g. database, datastore, or table)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:category_name ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 42 ;
            sh:path ocsf:cloud ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 48 ;
            sh:path ocsf:authorizations ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 16 ;
            sh:path ocsf:category_uid ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 27 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:class ocsf:MessageContext ;
            sh:description """Communication context for AI system interactions including protocols, roles,
clients, and session information for MCP and other AI communication systems.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:message_context ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 37 ;
            sh:path ocsf:timezone_offset ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 49 ;
            sh:path ocsf:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 59 ;
            sh:path ocsf:risk_details ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 36 ;
            sh:path ocsf:time ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:severity ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 58 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 55 ;
            sh:path ocsf:is_alert ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description "Details about the endpoint hosting the datastore application or service." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:dst_endpoint ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 38 ;
            sh:path ocsf:type_name ],
        [ sh:class ocsf:Table ;
            sh:description """The table object represents a table within a structured relational database or
datastore, which contains columns and rows of data that are able to be create,
updated, deleted and queried.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:table ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:class_name ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 40 ;
            sh:path ocsf:unmapped ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 44 ;
            sh:path ocsf:osint ],
        [ sh:class ocsf:HttpResponse ;
            sh:description "Details about the underlying http response." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:http_response ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:actor ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:status_code ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 30 ;
            sh:path ocsf:severity_id ],
        [ sh:class ocsf:HttpRequest ;
            sh:description "Details about the underlying http request." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:http_request ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:message ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 43 ;
            sh:path ocsf:device ] ;
    sh:targetClass ocsf:DatastoreActivity .

ocsf:DatetimeProfile a sh:NodeShape ;
    rdfs:comment """This profile defines date/time attributes as defined in RFC-3339. For example
1985-04-12T23:20:50.52Z.""" ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass ocsf:DatetimeProfile .

ocsf:DetectionFinding a sh:NodeShape ;
    rdfs:comment """A Detection Finding describes detections or alerts generated by security
products using correlation engines, detection engines or other methodologies.
Note: if the event producer is a security control, the
<code>security_control</code> profile should be applied and its
<code>attacks</code> information, if present, should be duplicated into the
<code>finding_info</code> object. <br><strong>Note: </strong>If the Finding is
an incident, i.e. requires incident workflow, also apply the
<code>incident</code> profile  or aggregate this finding into an <code>Incident
Finding</code>.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Evidences ;
            sh:description """Describes various evidence artifacts associated to the activity/activities that
triggered a security detection.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:evidences ],
        [ sh:description "The normalized identifier of the finding activity." ;
            sh:in ( "CREATE" "UPDATE" "CLOSE" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 18 ;
            sh:path ocsf:activity_id ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 50 ;
            sh:path ocsf:raw_data_size ],
        [ sh:class ocsf:VendorAttributes ;
            sh:description """The Vendor Attributes object can be used to represent values of attributes
populated by the Vendor/Finding Provider. It can help distinguish between the
vendor-provided values and consumer-updated values, of key attributes like
<code>severity_id</code>.<br>The original finding producer should not populate
this object. It should be populated by consuming systems that support data
mutability.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 27 ;
            sh:path ocsf:vendor_attributes ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 65 ;
            sh:path ocsf:action_id ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 39 ;
            sh:path ocsf:category_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The finding activity name, as defined by the <code>activity_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:activity_name ],
        [ sh:class ocsf:Vulnerability ;
            sh:description "Describes vulnerabilities reported in a Detection Finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path ocsf:vulnerabilities ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:severity ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 63 ;
            sh:path ocsf:osint ],
        [ sh:class ocsf:ResourceDetails ;
            sh:description """Describes details about resources that were the target of the activity that
triggered the finding.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:resources ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 49 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 61 ;
            sh:path ocsf:cloud ],
        [ sh:datatype xsd:string ;
            sh:description """The normalized status of the Finding set by the consumer normalized to the
caption of the status_id value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 56 ;
            sh:path ocsf:timezone_offset ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 68 ;
            sh:path ocsf:disposition ],
        [ sh:class ocsf:Malware ;
            sh:description "Describes malware reported in a Detection Finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:malware ],
        [ sh:description """The normalized priority. Priority identifies the relative importance of the
incident or finding. It is a measurement of urgency.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 32 ;
            sh:path ocsf:priority_id ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path ocsf:class_name ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:risk_level ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 71 ;
            sh:path ocsf:policy ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 62 ;
            sh:path ocsf:actor ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 47 ;
            sh:path ocsf:observables ],
        [ sh:datatype xsd:boolean ;
            sh:description "A determination based on analytics as to whether a potential breach was found." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:is_suspected_breach ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 42 ;
            sh:path ocsf:count ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path ocsf:duration ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:risk_score ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path ocsf:confidence_id ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 57 ;
            sh:path ocsf:type_name ],
        [ sh:description "The normalized verdict of an Incident." ;
            sh:in ( "UNKNOWN" "FALSE_POSITIVE" "TRUE_POSITIVE" "DISREGARD" "SUSPICIOUS" "BENIGN" "TEST" "INSUFFICIENT_DATA" "SECURITY_RISK" "MANAGED_EXTERNALLY" "DUPLICATE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 37 ;
            sh:path ocsf:verdict_id ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 64 ;
            sh:path ocsf:action ],
        [ sh:description "The normalized status identifier of the Finding, set by the consumer." ;
            sh:in ( "NEW" "IN_PROGRESS" "SUPPRESSED" "RESOLVED" "ARCHIVED" "DELETED" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 26 ;
            sh:path ocsf:status_id ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 66 ;
            sh:path ocsf:attacks ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 69 ;
            sh:path ocsf:disposition_id ],
        [ sh:class ocsf:Group ;
            sh:description "The details of the group assigned to an Incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 29 ;
            sh:path ocsf:assignee_group ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 38 ;
            sh:path ocsf:category_name ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 54 ;
            sh:path ocsf:status_detail ],
        [ sh:datatype xsd:integer ;
            sh:description "The impact as an integer value of the finding, valid range 0-100." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:impact_score ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. For example,
an <code>activity_id</code> of 'Create' could constitute an alertable signal
and the value would be <code>true</code>, while 'Close' likely would not and
either omit the attribute or set its value to <code>false</code>.  Note that
other events with the <code>security_control</code> profile may also be deemed
alertable signals and may also carry <code>is_alert = true</code> attributes.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:is_alert ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 59 ;
            sh:path ocsf:unmapped ],
        [ sh:datatype xsd:long ;
            sh:description "The time of the least recent event included in the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:start_time ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 15 ;
            sh:path ocsf:risk_level_id ],
        [ sh:datatype xsd:string ;
            sh:description "The verdict assigned to an Incident finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 36 ;
            sh:path ocsf:verdict ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:confidence ],
        [ sh:class ocsf:Ticket ;
            sh:description """The associated ticket(s) in the ticketing system. Each ticket contains details
like ticket ID, status, etc.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 35 ;
            sh:path ocsf:tickets ],
        [ sh:class ocsf:FindingInfo ;
            sh:description "Describes the supporting information about a generated finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path ocsf:finding_info ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 70 ;
            sh:path ocsf:firewall_rule ],
        [ sh:class ocsf:Device ;
            sh:description """Describes the affected device/host. If applicable, it can be used in
conjunction with <code>Resource(s)</code>. <p> e.g. Specific details about an
AWS EC2 instance, that is affected by the Finding.</p>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path ocsf:device ],
        [ sh:datatype xsd:string ;
            sh:description """The impact , normalized to the caption of the impact_id value. In the case of
'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:impact ],
        [ sh:class ocsf:User ;
            sh:description "The details of the user assigned to an Incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 28 ;
            sh:path ocsf:assignee ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 60 ;
            sh:path ocsf:api ],
        [ sh:class ocsf:Ticket ;
            sh:description "The linked ticket in the ticketing system." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 34 ;
            sh:path ocsf:ticket ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 44 ;
            sh:path ocsf:enrichments ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 52 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A Url link used to access the original incident." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:src_url ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 41 ;
            sh:path ocsf:class_uid ],
        [ sh:datatype xsd:string ;
            sh:description "A user provided comment about the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:comment ],
        [ sh:datatype xsd:long ;
            sh:description "The time of the most recent event included in the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:end_time ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 45 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 55 ;
            sh:path ocsf:time ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 53 ;
            sh:path ocsf:status_code ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path ocsf:raw_data ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description "Describes details about malware scan job that triggered this Detection Finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:confidence_score ],
        [ sh:description """The normalized impact of the incident or finding. Per NIST, this is the
magnitude of harm that can be expected to result from the consequences of
unauthorized disclosure, modification, destruction, or loss of information or
information system availability.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path ocsf:impact_id ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 46 ;
            sh:path ocsf:metadata ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 58 ;
            sh:path ocsf:type_uid ],
        [ sh:class ocsf:AnomalyAnalysis ;
            sh:description """Describes baseline information about normal activity patterns, along with any
detected deviations or anomalies that triggered this finding.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:anomaly_analyses ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:risk_details ],
        [ sh:class ocsf:Remediation ;
            sh:description "Describes the recommended remediation steps to address identified issue(s)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:remediation ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 67 ;
            sh:path ocsf:authorizations ],
        [ sh:datatype xsd:string ;
            sh:description """The priority, normalized to the caption of the priority_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path ocsf:priority ] ;
    sh:targetClass ocsf:DetectionFinding .

ocsf:DeviceConfigStateChange a sh:NodeShape ;
    rdfs:comment """Device Config State Change events report state changes that impact the security
of the device.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 52 ;
            sh:path ocsf:malware ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:raw_data_size ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:severity ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:end_time ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 43 ;
            sh:path ocsf:attacks ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 58 ;
            sh:path ocsf:risk_score ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 27 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 45 ;
            sh:path ocsf:confidence ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 38 ;
            sh:path ocsf:api ],
        [ sh:class ocsf:SecurityState ;
            sh:description "The previous security states of the device." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:prev_security_states ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 13 ;
            sh:path ocsf:category_uid ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path ocsf:enrichments ],
        [ sh:datatype xsd:string ;
            sh:description "The previous security level of the entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:prev_security_level ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 54 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path ocsf:disposition ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path ocsf:metadata ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:activity_name ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:raw_data ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:category_name ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:is_alert ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:class_name ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 32 ;
            sh:path ocsf:status_id ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 44 ;
            sh:path ocsf:authorizations ],
        [ sh:description "The previous security level of the entity" ;
            sh:in ( "UNKNOWN" "SECURE" "AT_RISK" "COMPROMISED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path ocsf:prev_security_level_id ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 56 ;
            sh:path ocsf:risk_level ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 15 ;
            sh:path ocsf:class_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path ocsf:action ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 24 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:class ocsf:SecurityState ;
            sh:description "The current security states of the device." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:security_states ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 42 ;
            sh:path ocsf:action_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 36 ;
            sh:path ocsf:type_uid ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 37 ;
            sh:path ocsf:unmapped ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 46 ;
            sh:path ocsf:confidence_id ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 55 ;
            sh:path ocsf:risk_details ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 39 ;
            sh:path ocsf:cloud ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:status_code ],
        [ sh:description "The current security level of the entity" ;
            sh:in ( "UNKNOWN" "SECURE" "AT_RISK" "COMPROMISED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path ocsf:security_level_id ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 50 ;
            sh:path ocsf:firewall_rule ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path ocsf:type_name ],
        [ sh:class ocsf:Device ;
            sh:description "The device that is impacted by the state change." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:device ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path ocsf:observables ],
        [ sh:description "The Config Change State of the managed entity." ;
            sh:in ( "UNKNOWN" "DISABLED" "ENABLED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 9 ;
            sh:path ocsf:state_id ],
        [ sh:datatype xsd:string ;
            sh:description "The current security level of the entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:security_level ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:count ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path ocsf:status_detail ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:message ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 49 ;
            sh:path ocsf:disposition_id ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 57 ;
            sh:path ocsf:risk_level_id ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:actor ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 53 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:start_time ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:time ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 40 ;
            sh:path ocsf:osint ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:confidence_score ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:duration ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "LOG" "COLLECT" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 10 ;
            sh:path ocsf:activity_id ],
        [ sh:datatype xsd:string ;
            sh:description """The Config Change Stat, normalized to the caption of the state_id value. In the
case of 'Other', it is defined by the source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:state ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 34 ;
            sh:path ocsf:timezone_offset ] ;
    sh:targetClass ocsf:DeviceConfigStateChange .

ocsf:DhcpActivity a sh:NodeShape ;
    rdfs:comment """DHCP Activity events report MAC to IP assignment via DHCP from a client or
server.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 50 ;
            sh:path ocsf:time ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 66 ;
            sh:path ocsf:disposition_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 53 ;
            sh:path ocsf:type_uid ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 39 ;
            sh:path ocsf:observables ],
        [ sh:class ocsf:HttpRequest ;
            sh:description "The HTTP Request from the proxy server to the remote server." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path ocsf:proxy_http_request ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 69 ;
            sh:path ocsf:malware ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:count ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 38 ;
            sh:path ocsf:metadata ],
        [ sh:class ocsf:NetworkTraffic ;
            sh:description """The network traffic for this observation period. Use when reporting: (1) delta
values (bytes/packets transferred since the last observation), (2)
instantaneous measurements at a specific point in time, or (3) standalone
single-event metrics. This attribute represents a point-in-time measurement or
incremental change, not a running total. For accumulated totals across multiple
observations or the lifetime of a flow, use <code>cumulative_traffic</code>
instead.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path ocsf:traffic ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:activity_name ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 32 ;
            sh:path ocsf:class_uid ],
        [ sh:datatype xsd:string ;
            sh:description """The network application name identified by tools such as NBAR or App ID (e.g.,
youtube, facebook, webex). This represents a specific network application that
uses standard protocols (such as https or quic) to deliver its service.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:app_name ],
        [ sh:description """The normalized identifier of the observation point. The observation point
identifier indicates whether the source network endpoint, destination network
endpoint, or neither served as the observation point for the activity.""" ;
            sh:in ( "UNKNOWN" "SOURCE" "DESTINATION" "NEITHER" "BOTH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 16 ;
            sh:path ocsf:observation_point_id ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 62 ;
            sh:path ocsf:confidence ],
        [ sh:class ocsf:NetworkInterface ;
            sh:description "The network relay that is associated with the event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:relay ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:category_name ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 63 ;
            sh:path ocsf:confidence_id ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 70 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:class ocsf:NetworkConnectionInfo ;
            sh:description "The network connection information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:connection_info ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 42 ;
            sh:path ocsf:raw_data_size ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 30 ;
            sh:path ocsf:category_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 58 ;
            sh:path ocsf:action ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path ocsf:severity ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 44 ;
            sh:path ocsf:severity_id ],
        [ sh:class ocsf:NetworkTraffic ;
            sh:description """The cumulative (running total) network traffic aggregated from the start of a
flow or session. Use when reporting: (1) total accumulated bytes/packets since
flow initiation, (2) combined aggregation models where both incremental deltas
and running totals are reported together (populate both <code>traffic</code>
for the delta and this attribute for the cumulative total), or (3) final
summary metrics when a long-lived connection closes. This represents the sum of
all activity from flow start to the current observation, not a delta or
point-in-time value.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:cumulative_traffic ],
        [ sh:datatype xsd:integer ;
            sh:description """This represents the length of the DHCP lease in seconds. This is present in
DHCP Ack events.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:lease_dur ],
        [ sh:class ocsf:NetworkProxy ;
            sh:description "The proxy (server) in a network connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path ocsf:proxy_endpoint ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:api ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description """The network endpoint that observes or inspects network traffic as a third-party
system, used when the observer is neither the source nor the destination of the
communication (when <code>observation_point_id</code> = 3). Examples include
network taps, span ports, inline security devices, or packet capture systems
that monitor traffic between other endpoints.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ocsf:network_observation_point ],
        [ sh:class ocsf:HttpResponse ;
            sh:description "The HTTP Response from the remote server to the proxy server." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 24 ;
            sh:path ocsf:proxy_http_response ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 37 ;
            sh:path ocsf:message ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 67 ;
            sh:path ocsf:firewall_rule ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier of the transaction. This is typically a random number
generated from the client to associate a dhcp request/response pair.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:transaction_uid ],
        [ sh:class ocsf:NetworkTraffic ;
            sh:description """The network traffic refers to the amount of data moving across a network, from
proxy to remote server at a given point of time.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 26 ;
            sh:path ocsf:proxy_traffic ],
        [ sh:class ocsf:Ja4Fingerprint ;
            sh:description "A list of the JA4+ network fingerprints." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:ja4_fingerprint_list ],
        [ sh:class ocsf:Tls ;
            sh:description "The Transport Layer Security (TLS) attributes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path ocsf:tls ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 64 ;
            sh:path ocsf:confidence_score ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path ocsf:raw_data ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 34 ;
            sh:path ocsf:duration ],
        [ sh:class ocsf:NetworkProxy ;
            sh:description "The proxy (server) in a network connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path ocsf:proxy ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 56 ;
            sh:path ocsf:device ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 41 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 68 ;
            sh:path ocsf:is_alert ],
        [ sh:class ocsf:Packet ;
            sh:description "The list of packet objects describing captured network packets." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path ocsf:packet_list ],
        [ sh:class ocsf:LoadBalancer ;
            sh:description """The Load Balancer object contains information related to the device that is
distributing incoming traffic to specified destinations.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 27 ;
            sh:path ocsf:load_balancer ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 52 ;
            sh:path ocsf:type_name ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path ocsf:status_detail ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 72 ;
            sh:path ocsf:risk_details ],
        [ sh:class ocsf:Tls ;
            sh:description "The TLS protocol negotiated between the proxy server and the remote server." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 25 ;
            sh:path ocsf:proxy_tls ],
        [ sh:datatype xsd:string ;
            sh:description """Indicates whether the source network endpoint, destination network endpoint, or
neither served as the observation point for the activity. The value is
normalized to the caption of the <code>observation_point_id</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:observation_point ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:timezone_offset ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 60 ;
            sh:path ocsf:attacks ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description "The responder (server) of the DHCP connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:dst_endpoint ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this is a lease/session renewal event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:is_renewal ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path ocsf:enrichments ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 45 ;
            sh:path ocsf:start_time ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description "The initiator (client) of the DHCP connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:src_endpoint ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 65 ;
            sh:path ocsf:disposition ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 74 ;
            sh:path ocsf:risk_level_id ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path ocsf:end_time ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 73 ;
            sh:path ocsf:risk_level ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:status_code ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 57 ;
            sh:path ocsf:osint ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path ocsf:class_name ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 59 ;
            sh:path ocsf:action_id ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 55 ;
            sh:path ocsf:actor ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 75 ;
            sh:path ocsf:risk_score ],
        [ sh:class ocsf:NetworkConnectionInfo ;
            sh:description "The connection information from the proxy server to the remote server." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path ocsf:proxy_connection_info ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 71 ;
            sh:path ocsf:policy ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 61 ;
            sh:path ocsf:authorizations ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 49 ;
            sh:path ocsf:status_id ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "DISCOVER" "OFFER" "REQUEST" "DECLINE" "ACK" "NAK" "RELEASE" "INFORM" "EXPIRE" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path ocsf:activity_id ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:cloud ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 54 ;
            sh:path ocsf:unmapped ],
        [ sh:datatype xsd:string ;
            sh:description """The application-layer (Layer 7) protocol name identified by deep packet inspection or packet parsing (e.g., <code>https</code>, <code>quic</code>, <code>ssh</code>, <code>dns</code>), expressed as an IANA-registered service name from the IANA Service Name and Transport Protocol Port Number Registry.

<p><b>Note:</b> Port numbers alone are not always a reliable indicator of the actual application protocol in use.</p>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:app_protocol_name ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 46 ;
            sh:path ocsf:status ] ;
    sh:targetClass ocsf:DhcpActivity .

ocsf:DiscoveryEvent a sh:NodeShape ;
    rdfs:comment """The Discovery event is a generic event that defines a set of attributes
available in Discovery category events. As a generic event, it could be used to
log events that are not otherwise defined by the Discovery specific event
classes.""" ;
    sh:closed true ;
    sh:ignoredProperties ( ocsf:idp ocsf:package ocsf:product ocsf:prev_security_level_id ocsf:databucket ocsf:security_states ocsf:assessments ocsf:state_id ocsf:security_level ocsf:prev_security_states ocsf:security_level_id ocsf:table ocsf:user ocsf:database ocsf:cis_benchmark_result ocsf:kb_article_list rdf:type ocsf:container ocsf:resources ocsf:region ocsf:sbom ocsf:prev_security_level ocsf:state ) ;
    sh:property [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:metadata ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:activity_name ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 44 ;
            sh:path ocsf:malware ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 37 ;
            sh:path ocsf:confidence ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:time ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 39 ;
            sh:path ocsf:confidence_score ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 41 ;
            sh:path ocsf:disposition_id ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:type_name ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 34 ;
            sh:path ocsf:action_id ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:action ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path ocsf:osint ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 31 ;
            sh:path ocsf:device ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 29 ;
            sh:path ocsf:cloud ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 50 ;
            sh:path ocsf:risk_score ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 28 ;
            sh:path ocsf:api ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 30 ;
            sh:path ocsf:actor ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:start_time ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:class_name ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:duration ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:message ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path ocsf:category_uid ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:observables ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 22 ;
            sh:path ocsf:status_id ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:severity ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:raw_data ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 49 ;
            sh:path ocsf:risk_level_id ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:end_time ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:category_name ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path ocsf:is_alert ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:risk_details ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path ocsf:disposition ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 17 ;
            sh:path ocsf:severity_id ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path ocsf:class_uid ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:status_code ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path ocsf:authorizations ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 35 ;
            sh:path ocsf:attacks ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 45 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 38 ;
            sh:path ocsf:confidence_id ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 46 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:count ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 42 ;
            sh:path ocsf:firewall_rule ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 27 ;
            sh:path ocsf:unmapped ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "LOG" "COLLECT" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path ocsf:activity_id ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:status_detail ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path ocsf:risk_level ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:type_uid ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:enrichments ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:timezone_offset ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:raw_data_size ] ;
    sh:targetClass ocsf:DiscoveryEvent .

ocsf:DiscoveryResult a sh:NodeShape ;
    rdfs:comment "Discovery Result events report the results of a discovery request." ;
    sh:closed true ;
    sh:ignoredProperties ( ocsf:job ocsf:kernel ocsf:name ocsf:last_run_time ocsf:file ocsf:run_count ocsf:module ocsf:state_id ocsf:session ocsf:startup_item ocsf:reg_value ocsf:group ocsf:folder ocsf:service ocsf:process ocsf:network_interfaces ocsf:user ocsf:reg_key rdf:type ocsf:peripheral_device ocsf:query_evidence ocsf:state ocsf:connection_info ocsf:users ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:class_name ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:risk_level ],
        [ sh:datatype xsd:string ;
            sh:description "The result of the query." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:query_result ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 8 ;
            sh:path ocsf:class_uid ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:end_time ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "QUERY" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path ocsf:activity_id ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 42 ;
            sh:path ocsf:confidence_score ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:category_name ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 25 ;
            sh:path ocsf:status_id ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path ocsf:disposition ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 53 ;
            sh:path ocsf:risk_score ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 38 ;
            sh:path ocsf:attacks ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 41 ;
            sh:path ocsf:confidence_id ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:status_detail ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 52 ;
            sh:path ocsf:risk_level_id ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:status ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 30 ;
            sh:path ocsf:unmapped ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:time ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:status_code ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 39 ;
            sh:path ocsf:authorizations ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 49 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:duration ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:enrichments ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 31 ;
            sh:path ocsf:api ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:count ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 44 ;
            sh:path ocsf:disposition_id ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 36 ;
            sh:path ocsf:action ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 37 ;
            sh:path ocsf:action_id ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:activity_name ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 47 ;
            sh:path ocsf:malware ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:raw_data ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:type_uid ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 46 ;
            sh:path ocsf:is_alert ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 34 ;
            sh:path ocsf:device ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:timezone_offset ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path ocsf:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 50 ;
            sh:path ocsf:risk_details ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 48 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 20 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:type_name ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path ocsf:observables ],
        [ sh:description "The normalized identifier of the query result." ;
            sh:in ( "UNKNOWN" "EXISTS" "PARTIAL" "DOES_NOT_EXIST" "ERROR" "UNSUPPORTED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path ocsf:query_result_id ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 45 ;
            sh:path ocsf:firewall_rule ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 6 ;
            sh:path ocsf:category_uid ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path ocsf:cloud ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ocsf:metadata ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:severity ],
        [ sh:class ocsf:QueryInfo ;
            sh:description "The search details associated with the query request." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:query_info ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 35 ;
            sh:path ocsf:osint ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:raw_data_size ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:start_time ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 33 ;
            sh:path ocsf:actor ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path ocsf:raw_data_hash ] ;
    sh:targetClass ocsf:DiscoveryResult .

ocsf:Dns a sh:NodeShape ;
    rdfs:comment """The Domain Name System (DNS) object represents the shared information
associated with the DNS query and answer objects.""" ;
    sh:closed true ;
    sh:ignoredProperties ( ocsf:flags ocsf:ttl ocsf:rdata ocsf:opcode ocsf:flag_ids rdf:type ocsf:hostname ocsf:opcode_id ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description """The DNS packet identifier assigned by the program that generated the query. The
identifier is copied to the response.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:packet_uid ],
        [ sh:datatype xsd:string ;
            sh:description """The type of resource records being queried. See <a target='_blank'
href='https://www.rfc-editor.org/rfc/rfc1035.txt'>RFC1035</a>. For example: A,
AAAA, CNAME, MX, and NS.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description """The class of resource records being queried. See <a target='_blank'
href='https://www.rfc-editor.org/rfc/rfc1035.txt'>RFC1035</a>. For example:
<code>IN</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:class_ ] ;
    sh:targetClass ocsf:Dns .

ocsf:DnsActivity a sh:NodeShape ;
    rdfs:comment "DNS Activity events report DNS queries and answers as seen on the network." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The DNS server response code, normalized to the caption of the rcode_id value.
In the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:rcode ],
        [ sh:class ocsf:NetworkProxy ;
            sh:description "The proxy (server) in a network connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path ocsf:proxy ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:count ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 49 ;
            sh:path ocsf:status_id ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:activity_name ],
        [ sh:class ocsf:NetworkProxy ;
            sh:description "The proxy (server) in a network connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path ocsf:proxy_endpoint ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path ocsf:class_name ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 39 ;
            sh:path ocsf:observables ],
        [ sh:class ocsf:NetworkTraffic ;
            sh:description """The cumulative (running total) network traffic aggregated from the start of a
flow or session. Use when reporting: (1) total accumulated bytes/packets since
flow initiation, (2) combined aggregation models where both incremental deltas
and running totals are reported together (populate both <code>traffic</code>
for the delta and this attribute for the cumulative total), or (3) final
summary metrics when a long-lived connection closes. This represents the sum of
all activity from flow start to the current observation, not a delta or
point-in-time value.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:cumulative_traffic ],
        [ sh:class ocsf:LoadBalancer ;
            sh:description """The Load Balancer object contains information related to the device that is
distributing incoming traffic to specified destinations.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 27 ;
            sh:path ocsf:load_balancer ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 65 ;
            sh:path ocsf:confidence_id ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 72 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 37 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:string ;
            sh:description """Indicates whether the source network endpoint, destination network endpoint, or
neither served as the observation point for the activity. The value is
normalized to the caption of the <code>observation_point_id</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:observation_point ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 30 ;
            sh:path ocsf:category_uid ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 69 ;
            sh:path ocsf:firewall_rule ],
        [ sh:class ocsf:Packet ;
            sh:description "The list of packet objects describing captured network packets." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path ocsf:packet_list ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 55 ;
            sh:path ocsf:api ],
        [ sh:description """The normalized identifier of the observation point. The observation point
identifier indicates whether the source network endpoint, destination network
endpoint, or neither served as the observation point for the activity.""" ;
            sh:in ( "UNKNOWN" "SOURCE" "DESTINATION" "NEITHER" "BOTH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 16 ;
            sh:path ocsf:observation_point_id ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 32 ;
            sh:path ocsf:class_uid ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 68 ;
            sh:path ocsf:disposition_id ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description """The network endpoint that observes or inspects network traffic as a third-party
system, used when the observer is neither the source nor the destination of the
communication (when <code>observation_point_id</code> = 3). Examples include
network taps, span ports, inline security devices, or packet capture systems
that monitor traffic between other endpoints.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ocsf:network_observation_point ],
        [ sh:description """The normalized identifier of the DNS server response code. See <a
target='_blank'
href='https://datatracker.ietf.org/doc/html/rfc6895'>RFC-6895</a>.""" ;
            sh:in ( "NOERROR" "FORMERROR" "SERVERROR" "NXDOMAIN" "NOTIMP" "REFUSED" "YXDOMAIN" "YXRRSET" "NXRRSET" "NOTAUTH" "NOTZONE" "DSOTYPENI" "BADSIG_VERS" "BADKEY" "BADTIME" "BADMODE" "BADNAME" "BADALG" "BADTRUNC" "BADCOOKIE" "UNASSIGNED" "RESERVED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path ocsf:rcode_id ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 76 ;
            sh:path ocsf:risk_level_id ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path ocsf:status_detail ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 66 ;
            sh:path ocsf:confidence_score ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 74 ;
            sh:path ocsf:risk_details ],
        [ sh:class ocsf:NetworkTraffic ;
            sh:description """The network traffic refers to the amount of data moving across a network, from
proxy to remote server at a given point of time.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 26 ;
            sh:path ocsf:proxy_traffic ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 50 ;
            sh:path ocsf:time ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 71 ;
            sh:path ocsf:malware ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "QUERY" "RESPONSE" "TRAFFIC" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path ocsf:activity_id ],
        [ sh:class ocsf:HttpRequest ;
            sh:description "The HTTP Request from the proxy server to the remote server." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path ocsf:proxy_http_request ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 73 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 60 ;
            sh:path ocsf:action ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:timezone_offset ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 42 ;
            sh:path ocsf:raw_data_size ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:status_code ],
        [ sh:class ocsf:DnsAnswer ;
            sh:description "The Domain Name System (DNS) answers." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:answers ],
        [ sh:datatype xsd:long ;
            sh:description "The Domain Name System (DNS) response time." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:response_time ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 61 ;
            sh:path ocsf:action_id ],
        [ sh:class ocsf:DnsQuery ;
            sh:description "The Domain Name System (DNS) query." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:query ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 59 ;
            sh:path ocsf:osint ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:category_name ],
        [ sh:datatype xsd:string ;
            sh:description """The network application name identified by tools such as NBAR or App ID (e.g.,
youtube, facebook, webex). This represents a specific network application that
uses standard protocols (such as https or quic) to deliver its service.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:app_name ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 45 ;
            sh:path ocsf:start_time ],
        [ sh:datatype xsd:long ;
            sh:description "The Domain Name System (DNS) query time." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:query_time ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 75 ;
            sh:path ocsf:risk_level ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description "The responder (server) in a network connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:dst_endpoint ],
        [ sh:class ocsf:NetworkTraffic ;
            sh:description """The network traffic for this observation period. Use when reporting: (1) delta
values (bytes/packets transferred since the last observation), (2)
instantaneous measurements at a specific point in time, or (3) standalone
single-event metrics. This attribute represents a point-in-time measurement or
incremental change, not a running total. For accumulated totals across multiple
observations or the lifetime of a flow, use <code>cumulative_traffic</code>
instead.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:traffic ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 77 ;
            sh:path ocsf:risk_score ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 58 ;
            sh:path ocsf:device ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 64 ;
            sh:path ocsf:confidence ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 57 ;
            sh:path ocsf:actor ],
        [ sh:class ocsf:NetworkConnectionInfo ;
            sh:description "The network connection information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:connection_info ],
        [ sh:class ocsf:Tls ;
            sh:description "The TLS protocol negotiated between the proxy server and the remote server." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 25 ;
            sh:path ocsf:proxy_tls ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path ocsf:raw_data ],
        [ sh:class ocsf:NetworkConnectionInfo ;
            sh:description "The connection information from the proxy server to the remote server." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path ocsf:proxy_connection_info ],
        [ sh:class ocsf:Ja4Fingerprint ;
            sh:description "A list of the JA4+ network fingerprints." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:ja4_fingerprint_list ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 63 ;
            sh:path ocsf:authorizations ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 54 ;
            sh:path ocsf:unmapped ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 52 ;
            sh:path ocsf:type_name ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path ocsf:end_time ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 44 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 70 ;
            sh:path ocsf:is_alert ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path ocsf:enrichments ],
        [ sh:class ocsf:HttpResponse ;
            sh:description "The HTTP Response from the remote server to the proxy server." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 24 ;
            sh:path ocsf:proxy_http_response ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 53 ;
            sh:path ocsf:type_uid ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 46 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:string ;
            sh:description """The application-layer (Layer 7) protocol name identified by deep packet inspection or packet parsing (e.g., <code>https</code>, <code>quic</code>, <code>ssh</code>, <code>dns</code>), expressed as an IANA-registered service name from the IANA Service Name and Transport Protocol Port Number Registry.

<p><b>Note:</b> Port numbers alone are not always a reliable indicator of the actual application protocol in use.</p>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:app_protocol_name ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 62 ;
            sh:path ocsf:attacks ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path ocsf:severity ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 67 ;
            sh:path ocsf:disposition ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 34 ;
            sh:path ocsf:duration ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 56 ;
            sh:path ocsf:cloud ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 38 ;
            sh:path ocsf:metadata ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description "The initiator (client) of the network connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path ocsf:src_endpoint ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 41 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:class ocsf:Tls ;
            sh:description "The Transport Layer Security (TLS) attributes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path ocsf:tls ] ;
    sh:targetClass ocsf:DnsActivity .

ocsf:DroneFlightsActivity a sh:NodeShape ;
    rdfs:comment """Drone Flights Activity events report the activity of Unmanned Aerial Systems
(UAS), their Operators, and mission-planning and authorization metadata as
reported by the UAS platforms themselves, by Counter-UAS (CUAS) systems, or
other remote monitoring or sensing infrastructure. Based on the Remote ID
defined in Standard Specification for Remote ID and Tracking (ASTM Designation:
F3411-22a) <a target='_blank'
href='https://cdn.standards.iteh.ai/samples/112830/71297057ac42432880a203654f213709/ASTM-F3411-22a.pdf'>ASTM
F3411-22a</a>""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Tls ;
            sh:description "The Transport Layer Security (TLS) attributes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path ocsf:tls ],
        [ sh:class ocsf:UnmannedSystemOperatingArea ;
            sh:description """The UAS Operating Area object describes details about a precise area of
operations for a UAS flight or mission.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:unmanned_system_operating_area ],
        [ sh:class ocsf:UnmannedAerialSystem ;
            sh:description """The Unmanned Aerial System object describes the characteristics, Position
Location Information (PLI), and other metadata of Unmanned Aerial Systems (UAS)
and other unmanned and drone systems used in Remote ID. Remote ID is defined in
the Standard Specification for Remote ID and Tracking (ASTM Designation:
F3411-22a) <a target='_blank'
href='https://cdn.standards.iteh.ai/samples/112830/71297057ac42432880a203654f213709/ASTM-F3411-22a.pdf'>ASTM
F3411-22a</a>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path ocsf:unmanned_aerial_system ],
        [ sh:description """The normalized identifier of the authentication type used to authorize a flight
plan or mission.""" ;
            sh:in ( "UNKNOWN" "NONE" "UAS_ID_SIGNATURE" "OPERATOR_ID_SIGNATURE" "MESSAGE_SET_SIGNATURE" "AUTHENTICATION_PROVIDED_BY_NETWORK_REMOTE_ID" "SPECIFIC_AUTHENTICATION_METHOD" "RESERVED" "PRIVATE_USER" "OTHER" "EAP" "RADIUS" "BASIC_AUTHENTICATION" "LDAP" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path ocsf:auth_protocol_id ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 36 ;
            sh:path ocsf:status_detail ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 19 ;
            sh:path ocsf:category_uid ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 48 ;
            sh:path ocsf:action_id ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 44 ;
            sh:path ocsf:actor ],
        [ sh:datatype xsd:string ;
            sh:description """UA Classification - Allows a region to classify UAS in a regional specific
manner. The format may differ from region to region.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:classification ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 64 ;
            sh:path ocsf:risk_score ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path ocsf:severity ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 46 ;
            sh:path ocsf:osint ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path ocsf:type_uid ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 25 ;
            sh:path ocsf:enrichments ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 34 ;
            sh:path ocsf:start_time ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:confidence ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 33 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:duration ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 28 ;
            sh:path ocsf:observables ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 63 ;
            sh:path ocsf:risk_level_id ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 41 ;
            sh:path ocsf:unmapped ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:class_name ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "UNKNOWN" "CAPTURE" "RECORD" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path ocsf:activity_id ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 37 ;
            sh:path ocsf:time ],
        [ sh:class ocsf:NetworkConnectionInfo ;
            sh:description "The network connection information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:connection_info ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 59 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 42 ;
            sh:path ocsf:api ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 54 ;
            sh:path ocsf:disposition ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description """The source network endpoint of the Unmanned Aerial System (UAS), Counter
Unmanned Aerial System (CUAS) platform, or other unmanned systems monitoring
and/or sensing infrastructure.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:src_endpoint ],
        [ sh:class ocsf:NetworkProxy ;
            sh:description "The proxy (server) in a network connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path ocsf:proxy_endpoint ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 27 ;
            sh:path ocsf:metadata ],
        [ sh:datatype xsd:string ;
            sh:description """This optional, free-text field enables the operator to describe the purpose of
a flight, if so desired.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:comment ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path ocsf:status_code ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 43 ;
            sh:path ocsf:cloud ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 50 ;
            sh:path ocsf:authorizations ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description """The destination network endpoint of the Unmanned Aerial System (UAS), Counter
Unmanned Aerial System (CUAS) platform, or other unmanned systems monitoring
and/or sensing infrastructure.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ocsf:dst_endpoint ],
        [ sh:description """The normalized Operational status identifier for the Unmanned Aerial System
(UAS).""" ;
            sh:in ( "UNDECLARED" "GROUND" "AIRBORNE" "EMERGENCY" "REMOTE_ID_SYSTEM_FAILURE" "RESERVED" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path ocsf:status_id ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 61 ;
            sh:path ocsf:risk_details ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 53 ;
            sh:path ocsf:confidence_score ],
        [ sh:class ocsf:NetworkTraffic ;
            sh:description """Traffic refers to the amount of data transmitted from a Unmanned Aerial System
(UAS) or Counter Unmanned Aerial System (UAS) (CUAS) system at a given point of
time. Ex: <code>bytes_in</code> and <code>bytes_out</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:traffic ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 60 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path ocsf:raw_data_size ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 39 ;
            sh:path ocsf:type_name ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 38 ;
            sh:path ocsf:timezone_offset ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 30 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 55 ;
            sh:path ocsf:disposition_id ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:raw_data ],
        [ sh:datatype xsd:string ;
            sh:description """The networking protocol associated with the Remote ID device or beacon. E.g.
<code>BLE</code>, <code>LTE</code>, <code>802.11</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:protocol_name ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 56 ;
            sh:path ocsf:firewall_rule ],
        [ sh:class ocsf:User ;
            sh:description "The human or machine operator of an Unmanned System." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:unmanned_system_operator ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 52 ;
            sh:path ocsf:confidence_id ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 45 ;
            sh:path ocsf:device ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 62 ;
            sh:path ocsf:risk_level ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:activity_name ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 58 ;
            sh:path ocsf:malware ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:count ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:category_name ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:end_time ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 21 ;
            sh:path ocsf:class_uid ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 57 ;
            sh:path ocsf:is_alert ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 49 ;
            sh:path ocsf:attacks ],
        [ sh:datatype xsd:string ;
            sh:description """The normalized Operational status for the Unmanned Aerial System (UAS)
normalized to the caption of the <code>status_id</code> value. In the case of
'Other', it is defined by the source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:action ],
        [ sh:datatype xsd:string ;
            sh:description """The authentication type as defined by the caption of
<code>auth_protocol_id</code>. In the case of 'Other', it is defined by the
event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:auth_protocol ] ;
    sh:targetClass ocsf:DroneFlightsActivity .

ocsf:EmailActivity a sh:NodeShape ;
    rdfs:comment """Email Activity events report SMTP protocol and email activities including those
with embedded URLs and files. See the <code>Email</code> object for details.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 17 ;
            sh:path ocsf:category_uid ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 50 ;
            sh:path ocsf:authorizations ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 19 ;
            sh:path ocsf:class_uid ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 34 ;
            sh:path ocsf:status_code ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:status ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 42 ;
            sh:path ocsf:api ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "SEND" "RECEIVE" "SCAN" "TRACE" "MTA_RELAY" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path ocsf:activity_id ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description "The responder (server) receiving the email." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:dst_endpoint ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 49 ;
            sh:path ocsf:attacks ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 28 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 52 ;
            sh:path ocsf:confidence_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:count ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 39 ;
            sh:path ocsf:type_name ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 62 ;
            sh:path ocsf:risk_level ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 41 ;
            sh:path ocsf:unmapped ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:raw_data_size ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:confidence ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 45 ;
            sh:path ocsf:device ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:message ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 63 ;
            sh:path ocsf:risk_level_id ],
        [ sh:datatype xsd:string ;
            sh:description "The value of the SMTP HELO or EHLO command sent by the initiator (client)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:smtp_hello ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path ocsf:enrichments ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 54 ;
            sh:path ocsf:disposition ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 44 ;
            sh:path ocsf:actor ],
        [ sh:class ocsf:Email ;
            sh:description "The email object." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:email ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 57 ;
            sh:path ocsf:is_alert ],
        [ sh:datatype xsd:string ;
            sh:description "The command issued by the initiator (client), such as SMTP HELO or EHLO." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:command ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 26 ;
            sh:path ocsf:observables ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 46 ;
            sh:path ocsf:osint ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:end_time ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 25 ;
            sh:path ocsf:metadata ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 61 ;
            sh:path ocsf:risk_details ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:duration ],
        [ sh:datatype xsd:integer ;
            sh:description "The attempt number for attempting to deliver the email." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:attempt ],
        [ sh:datatype xsd:string ;
            sh:description """The recipient address from the transmission envelope. This may differ from the
'To' header and represents where the message was actually delivered.""" ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:to ;
            sh:pattern "^[\\w.+\\-]+@[\\w\\-]+(\\.[\\w\\-]+)+$" ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:category_name ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:action ],
        [ sh:datatype xsd:string ;
            sh:description "The direction of the email, as defined by the <code>direction_id</code> value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:direction ],
        [ sh:description """<p>The direction of the email relative to the scanning host or
organization.</p>Email scanned at an internet gateway might be characterized as
inbound to the organization from the Internet, outbound from the organization
to the Internet, or internal within the organization. Email scanned at a
workstation might be characterized as inbound to, or outbound from the
workstation.""" ;
            sh:in ( "UNKNOWN" "INBOUND" "OUTBOUND" "INTERNAL" "OTHER" "LOCAL" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path ocsf:direction_id ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 60 ;
            sh:path ocsf:policy ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 48 ;
            sh:path ocsf:action_id ],
        [ sh:datatype xsd:string ;
            sh:description """The sender address from the transmission envelope. This reflects the actual
sending party and may differ from the 'From' header in the message.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:from_ ;
            sh:pattern "^[\\w.+\\-]+@[\\w\\-]+(\\.[\\w\\-]+)+$" ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description "The initiator (client) sending the email." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:src_endpoint ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 36 ;
            sh:path ocsf:status_id ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:severity ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 58 ;
            sh:path ocsf:malware ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 37 ;
            sh:path ocsf:time ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path ocsf:type_uid ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 56 ;
            sh:path ocsf:firewall_rule ],
        [ sh:class ocsf:EmailAuth ;
            sh:description "The SPF, DKIM and DMARC attributes of an email." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:email_auth ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 55 ;
            sh:path ocsf:disposition_id ],
        [ sh:datatype xsd:string ;
            sh:description """The identifier that tracks a message that travels through multiple points of a
messaging service.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:message_trace_uid ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 43 ;
            sh:path ocsf:cloud ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path ocsf:status_detail ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 59 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:class_name ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path ocsf:start_time ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 64 ;
            sh:path ocsf:risk_score ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 31 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 38 ;
            sh:path ocsf:timezone_offset ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:raw_data ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 53 ;
            sh:path ocsf:confidence_score ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:activity_name ],
        [ sh:datatype xsd:string ;
            sh:description """The initial connection response that a messaging server receives after it
connects to an email server.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:banner ],
        [ sh:datatype xsd:string ;
            sh:description """The Protocol Name specifies the email communication protocol, such as SMTP,
IMAP, or POP3.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:protocol_name ] ;
    sh:targetClass ocsf:EmailActivity .

ocsf:EmailFileActivity a sh:NodeShape ;
    rdfs:comment "Email File Activity events report files within emails." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:status_code ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 30 ;
            sh:path ocsf:api ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:type_uid ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:category_name ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:count ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 29 ;
            sh:path ocsf:unmapped ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 45 ;
            sh:path ocsf:is_alert ],
        [ sh:class ocsf:File ;
            sh:description "The email file attachment." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:file ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 34 ;
            sh:path ocsf:osint ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 48 ;
            sh:path ocsf:policy ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 51 ;
            sh:path ocsf:risk_level_id ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path ocsf:category_uid ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:raw_data_size ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:timezone_offset ],
        [ sh:datatype xsd:string ;
            sh:description """The unique identifier of the email, used to correlate related email alert and
activity events.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:email_uid ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 46 ;
            sh:path ocsf:malware ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 37 ;
            sh:path ocsf:attacks ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "SEND" "RECEIVE" "SCAN" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path ocsf:activity_id ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:enrichments ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:duration ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 31 ;
            sh:path ocsf:cloud ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:severity ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 36 ;
            sh:path ocsf:action_id ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 40 ;
            sh:path ocsf:confidence_id ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:message ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 33 ;
            sh:path ocsf:device ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 24 ;
            sh:path ocsf:status_id ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:start_time ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 47 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 52 ;
            sh:path ocsf:risk_score ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:status_detail ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 43 ;
            sh:path ocsf:disposition_id ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:time ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:metadata ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path ocsf:confidence_score ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 50 ;
            sh:path ocsf:risk_level ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 49 ;
            sh:path ocsf:risk_details ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 38 ;
            sh:path ocsf:authorizations ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:type_name ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 39 ;
            sh:path ocsf:confidence ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ocsf:observables ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 42 ;
            sh:path ocsf:disposition ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path ocsf:action ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 19 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:raw_data ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:class_name ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path ocsf:actor ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 7 ;
            sh:path ocsf:class_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:activity_name ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:end_time ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 44 ;
            sh:path ocsf:firewall_rule ] ;
    sh:targetClass ocsf:EmailFileActivity .

ocsf:EmailUrlActivity a sh:NodeShape ;
    rdfs:comment "Email URL Activity events report URLs within an email." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """The unique identifier of the email, used to correlate related email alert and
activity events.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:email_uid ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:count ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 31 ;
            sh:path ocsf:cloud ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:start_time ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 46 ;
            sh:path ocsf:malware ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:activity_name ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "SEND" "RECEIVE" "SCAN" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path ocsf:activity_id ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 7 ;
            sh:path ocsf:class_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:type_name ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 42 ;
            sh:path ocsf:disposition ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:metadata ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:raw_data_size ],
        [ sh:class ocsf:Url ;
            sh:description "The URL included in the email content." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:url ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:timezone_offset ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 44 ;
            sh:path ocsf:firewall_rule ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 24 ;
            sh:path ocsf:status_id ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 47 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 51 ;
            sh:path ocsf:risk_level_id ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 39 ;
            sh:path ocsf:confidence ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:duration ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:raw_data ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 37 ;
            sh:path ocsf:attacks ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:status_detail ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:category_name ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path ocsf:confidence_score ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:message ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:enrichments ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 33 ;
            sh:path ocsf:device ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:end_time ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path ocsf:category_uid ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:time ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path ocsf:actor ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 40 ;
            sh:path ocsf:confidence_id ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 38 ;
            sh:path ocsf:authorizations ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 30 ;
            sh:path ocsf:api ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 50 ;
            sh:path ocsf:risk_level ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 48 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:class_name ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ocsf:observables ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 49 ;
            sh:path ocsf:risk_details ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:severity ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 29 ;
            sh:path ocsf:unmapped ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 52 ;
            sh:path ocsf:risk_score ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 34 ;
            sh:path ocsf:osint ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:type_uid ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 45 ;
            sh:path ocsf:is_alert ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 36 ;
            sh:path ocsf:action_id ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 43 ;
            sh:path ocsf:disposition_id ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:status_code ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 19 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path ocsf:action ] ;
    sh:targetClass ocsf:EmailUrlActivity .

ocsf:Endpoint a sh:NodeShape ;
    rdfs:comment """The Endpoint object describes a physical or virtual device that connects to and
exchanges information with a computer network. Some examples of endpoints are
mobile devices, desktop computers, virtual machines, embedded devices, and
servers. Internet-of-Things devices—like cameras, lighting, refrigerators,
security systems, smart speakers, and thermostats—are also endpoints.""" ;
    sh:closed true ;
    sh:ignoredProperties ( ocsf:isp_org ocsf:svc_name ocsf:imei ocsf:vendor_name ocsf:risk_level ocsf:network_scope ocsf:eid ocsf:is_mobile_account_active ocsf:hypervisor ocsf:org ocsf:is_personal ocsf:is_managed ocsf:intermediate_ips ocsf:udid ocsf:is_backed_up ocsf:imei_list ocsf:is_compliant ocsf:created_time ocsf:network_interfaces ocsf:os_machine_uuid ocsf:network_scope_id ocsf:is_shared ocsf:groups ocsf:is_trusted ocsf:autoscale_uid ocsf:modified_time ocsf:port ocsf:fingerprints ocsf:isp ocsf:risk_level_id rdf:type ocsf:first_seen_time ocsf:boot_uid ocsf:model ocsf:boot_time ocsf:region ocsf:uid_alt ocsf:autonomous_system ocsf:meid ocsf:proxy_endpoint ocsf:risk_score ocsf:desc ocsf:iccid ocsf:image ocsf:is_supervised ocsf:subnet ocsf:last_seen_time ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The Media Access Control (MAC) address of the endpoint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:mac ;
            sh:pattern "^([0-9a-fA-F]{2}[:\\-]){5}[0-9a-fA-F]{2}$" ],
        [ sh:datatype xsd:string ;
            sh:description """The name of the domain that the endpoint belongs to or that corresponds to the
endpoint.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:domain ],
        [ sh:datatype xsd:string ;
            sh:description """The vendor or manufacturer of the endpoint's network interface controller
(NIC), as identified from the MAC address.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:mac_vendor ],
        [ sh:class ocsf:Os ;
            sh:description "The endpoint operating system." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:os ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the Virtual Private Cloud (VPC)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:vpc_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The short name of the endpoint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:name ],
        [ sh:class ocsf:Agent ;
            sh:description """A list of <code>agent</code> objects associated with a device, endpoint, or
resource.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:agent_list ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the network interface." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:interface_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The IP address of the endpoint, in either IPv4 or IPv6 format." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:ip ;
            sh:pattern "^((\\d{1,3}\\.){3}\\d{1,3}|[0-9a-fA-F:]{2,39})$" ],
        [ sh:datatype xsd:string ;
            sh:description "The Virtual LAN identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:vlan_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The fully qualified name of the endpoint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:hostname ],
        [ sh:class ocsf:Location ;
            sh:description "The geographical location of the endpoint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:location ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the network interface (e.g. eth2)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:interface_name ],
        [ sh:datatype xsd:string ;
            sh:description """The endpoint type. For example: <code>unknown</code>, <code>server</code>,
<code>desktop</code>, <code>laptop</code>, <code>tablet</code>,
<code>mobile</code>, <code>virtual</code>, <code>browser</code>, or
<code>other</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:type ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of a VM instance." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:instance_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The network zone or LAN segment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:zone ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the endpoint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:uid ],
        [ sh:class ocsf:Group ;
            sh:description "The pool of desktops or virtual machines to which the endpoint belongs." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ocsf:pool ],
        [ sh:class ocsf:DeviceHwInfo ;
            sh:description "The endpoint hardware information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:hw_info ],
        [ sh:datatype xsd:integer ;
            sh:description """If running under a process namespace (such as in a container), the process
identifier within that process namespace.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:namespace_pid ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of a virtual subnet." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:subnet_uid ],
        [ sh:description "The endpoint type ID." ;
            sh:in ( "SERVER" "DESKTOP" "LAPTOP" "TABLET" "MOBILE" "VIRTUAL" "IOT" "BROWSER" "FIREWALL" "SWITCH" "HUB" "ROUTER" "IDS" "IPS" "LOAD_BALANCER" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 17 ;
            sh:path ocsf:type_id ],
        [ sh:class ocsf:User ;
            sh:description """The identity of the service or user account that owns the endpoint or was last
logged into it.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:owner ],
        [ sh:class ocsf:Container ;
            sh:description """The information describing an instance of a container. A container is a
prepackaged, portable system image that runs isolated on an existing system
using a container runtime like containerd.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path ocsf:container ] ;
    sh:targetClass ocsf:Endpoint .

ocsf:Entity a sh:NodeShape ;
    rdfs:comment """The Entity object is an unordered collection of attributes, with a name and
unique identifier. It serves as a base object that defines a set of attributes
and default constraints available in all objects that extend it.""" ;
    sh:closed true ;
    sh:ignoredProperties ( ocsf:vpc_uid ocsf:service_type_id ocsf:svc_name ocsf:message ocsf:url_string ocsf:integrity ocsf:version ocsf:track_direction ocsf:bytes ocsf:fingerprint ocsf:protocol_name ocsf:pool ocsf:query_string ocsf:classification_ids ocsf:account ocsf:severity ocsf:open_ports ocsf:data ocsf:nodes ocsf:is_locked ocsf:cpid ocsf:storage_class ocsf:query ocsf:email_addr ocsf:mac_vendor ocsf:created_time ocsf:parent_process ocsf:dst_endpoint ocsf:isp ocsf:hashes ocsf:code ocsf:email ocsf:log_level ocsf:subnet_prefix ocsf:tls ocsf:meid ocsf:connection_info ocsf:http_request ocsf:service_category_id ocsf:ext ocsf:interface_name ocsf:subnet_uid ocsf:cloud_partition ocsf:job ocsf:loaded_modules ocsf:pid ocsf:relation ocsf:service_file ocsf:win_service ocsf:details ocsf:vendor_id_list ocsf:data_classification ocsf:attributes ocsf:eid ocsf:state_id ocsf:hypervisor ocsf:ldap_person ocsf:zone ocsf:is_personal ocsf:url ocsf:location ocsf:api ocsf:drive_type_id ocsf:user ocsf:mime_type ocsf:port ocsf:related_analytics ocsf:is_readonly ocsf:uid_alt ocsf:ptid ocsf:credential_uid ocsf:proxy_endpoint ocsf:hostname ocsf:log_version ocsf:isp_org ocsf:edges ocsf:rate_limit ocsf:owner ocsf:load_order_group ocsf:match_details ocsf:service_start_name ocsf:is_mobile_account_active ocsf:ancestry ocsf:phone_number ocsf:environment_variables ocsf:namespace ocsf:policy ocsf:verdict_id ocsf:confidentiality ocsf:intermediate_ips ocsf:values ocsf:size ocsf:os_machine_uuid ocsf:database ocsf:groups ocsf:is_on_premises_sync_enabled ocsf:accessor ocsf:company_name ocsf:condition rdf:type ocsf:first_seen_time ocsf:boot_uid ocsf:resources ocsf:ja4_fingerprint_list ocsf:match_location ocsf:forward_addr ocsf:service_category ocsf:sensitivity ocsf:desc ocsf:hosting_process ocsf:full_name ocsf:signature ocsf:src_url ocsf:ou_uid ocsf:signatures ocsf:criticality ocsf:file ocsf:vendor_name ocsf:files ocsf:provider ocsf:endpoint_connections ocsf:device ocsf:num_infected ocsf:parent_folder ocsf:type ocsf:imei_list ocsf:process ocsf:creator ocsf:is_public ocsf:speed_accuracy ocsf:start_time ocsf:data_classifications ocsf:metrics ocsf:countermeasures ocsf:working_directory ocsf:service_type ocsf:lang ocsf:egid ocsf:region ocsf:embedding_model ocsf:duration ocsf:http_response ocsf:sso ocsf:hw_info ocsf:security_descriptor ocsf:programmatic_credentials ocsf:ai_provider ocsf:vertical_speed ocsf:actor ocsf:confidentiality_id ocsf:meets_criteria ocsf:internal_name ocsf:service_dependencies ocsf:databucket ocsf:network_scope ocsf:uri ocsf:event_uid ocsf:is_directed ocsf:org ocsf:tid ocsf:group ocsf:service ocsf:is_backed_up ocsf:cves ocsf:has_mfa ocsf:euid ocsf:network_interfaces ocsf:hosted_services ocsf:reg_key ocsf:lineage ocsf:target ocsf:service_start_type ocsf:state ocsf:privileges ocsf:prompt_tokens ocsf:encryption_details ocsf:is_encrypted ocsf:labels ocsf:algorithm ocsf:subnet ocsf:transmit_time ocsf:sandbox ocsf:verdict ocsf:imei ocsf:risk_level ocsf:completion_tokens ocsf:service_error_control ocsf:role ocsf:udid ocsf:mac ocsf:drive_type ocsf:is_truncated ocsf:is_compliant ocsf:classifications ocsf:cpe_name ocsf:num_volumes ocsf:network_scope_id ocsf:domain ocsf:fingerprints ocsf:risk_level_id ocsf:feature ocsf:category ocsf:error_message ocsf:log_name ocsf:integrity_id ocsf:image ocsf:end_time ocsf:tags ocsf:is_supervised ocsf:untruncated_size ocsf:src_endpoint ocsf:uuid ocsf:query_language ocsf:instance_uid ocsf:log_format ocsf:namespace_pid ocsf:total_tokens ocsf:os ocsf:reg_value ocsf:auid ocsf:log_provider ocsf:terminated_time ocsf:ip ocsf:path ocsf:status_detail ocsf:is_system ocsf:ou_name ocsf:ai_role ocsf:agent_list ocsf:source ocsf:volume ocsf:auth_factors ocsf:query_language_id ocsf:boot_time ocsf:xattributes ocsf:iccid ocsf:cloud ocsf:serial_number ocsf:cmd_line ocsf:modifier ocsf:is_managed ocsf:vlan_uid ocsf:classification ocsf:imported_symbols ocsf:product ocsf:ai_role_id ocsf:speed ocsf:role_id ocsf:time ocsf:display_name ocsf:unique_malware_count ocsf:interface_uid ocsf:issuer ocsf:num_files ocsf:session ocsf:query_time ocsf:type_id ocsf:service_dll_file ocsf:service_start_type_id ocsf:scim ocsf:is_shared ocsf:tenant_uid ocsf:is_disabled ocsf:service_error_control_id ocsf:is_trusted ocsf:autoscale_uid ocsf:is_applied ocsf:modified_time ocsf:class_ ocsf:severity_id ocsf:container ocsf:logged_time ocsf:model ocsf:is_deleted ocsf:autonomous_system ocsf:accessed_time ocsf:risk_score ocsf:tag ocsf:resource_relationship ocsf:script ocsf:application ocsf:last_seen_time ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The name of the entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:uid ] ;
    sh:targetClass ocsf:Entity .

ocsf:EntityManagement a sh:NodeShape ;
    rdfs:comment """Entity Management events report activity by a managed client, a micro service,
or a user at a management console. The activity can be a create, read, update,
and delete operation on a managed entity.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:end_time ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 50 ;
            sh:path ocsf:firewall_rule ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:category_name ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "CREATE" "READ" "UPDATE" "DELETE" "MOVE" "ENROLL" "UNENROLL" "ENABLE" "DISABLE" "ACTIVATE" "DEACTIVATE" "SUSPEND" "RESUME" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path ocsf:activity_id ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:start_time ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:duration ],
        [ sh:class ocsf:ManagedEntity ;
            sh:description "The managed entity that is being acted upon." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:entity ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:class_name ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 54 ;
            sh:path ocsf:policy ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 37 ;
            sh:path ocsf:api ],
        [ sh:datatype xsd:integer ;
            sh:description "The access mask in a platform-native format." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:access_mask ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:status_detail ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path ocsf:time ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 46 ;
            sh:path ocsf:confidence_id ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:status_code ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 56 ;
            sh:path ocsf:risk_level ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:is_alert ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 40 ;
            sh:path ocsf:osint ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description "Details about the source of the IAM activity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:src_endpoint ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 44 ;
            sh:path ocsf:authorizations ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 31 ;
            sh:path ocsf:status_id ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 57 ;
            sh:path ocsf:risk_level_id ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 39 ;
            sh:path ocsf:device ],
        [ sh:class ocsf:HttpResponse ;
            sh:description "Details about the underlying HTTP response." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:http_response ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 43 ;
            sh:path ocsf:attacks ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 12 ;
            sh:path ocsf:category_uid ],
        [ sh:class ocsf:HttpRequest ;
            sh:description "Details about the underlying HTTP request." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:http_request ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:severity ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path ocsf:observables ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:count ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:actor ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 49 ;
            sh:path ocsf:disposition_id ],
        [ sh:class ocsf:ManagedEntity ;
            sh:description "The updated managed entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:entity_result ],
        [ sh:datatype xsd:string ;
            sh:description "The user provided comment about why the entity was changed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:comment ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:activity_name ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:string ;
            sh:description "The list of requested access rights." ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:access_list ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 45 ;
            sh:path ocsf:confidence ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path ocsf:type_uid ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path ocsf:metadata ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 53 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path ocsf:disposition ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path ocsf:action ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 26 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:timezone_offset ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 55 ;
            sh:path ocsf:risk_details ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:raw_data ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 42 ;
            sh:path ocsf:action_id ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:raw_data_size ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:confidence_score ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 52 ;
            sh:path ocsf:malware ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 34 ;
            sh:path ocsf:type_name ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 14 ;
            sh:path ocsf:class_uid ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 58 ;
            sh:path ocsf:risk_score ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path ocsf:enrichments ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path ocsf:unmapped ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 38 ;
            sh:path ocsf:cloud ] ;
    sh:targetClass ocsf:EntityManagement .

ocsf:EventLogActvity a sh:NodeShape ;
    rdfs:comment """Event Log Activity events report actions pertaining to the system's event
logging service(s), such as disabling logging or clearing the log data.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:NetworkEndpoint ;
            sh:description "The source endpoint for the event log activity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:src_endpoint ],
        [ sh:class ocsf:Actor ;
            sh:description "The actor that performed the activity." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:actor ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:category_name ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:timezone_offset ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 54 ;
            sh:path ocsf:risk_details ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br />Example:
<code>0</code>, <code>8</code>, or <code>21</code> for <a target='_blank'
href='https://learn.microsoft.com/en-us/previous-versions/windows/desktop/eventlogprov/cleareventlog-method-in-class-win32-nteventlogfile'>Windows
ClearEventLog</a>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:status_code ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 37 ;
            sh:path ocsf:api ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 44 ;
            sh:path ocsf:confidence ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 53 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path ocsf:time ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path ocsf:unmapped ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 28 ;
            sh:path ocsf:severity_id ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path ocsf:metadata ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path ocsf:action ],
        [ sh:datatype xsd:string ;
            sh:description """The name of the event log <p style='display:inline;color:red'>targeted by</p>
the activity. Example: Windows <code>Security</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:log_name ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:status ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 41 ;
            sh:path ocsf:action_id ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 25 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "CLEAR" "DELETE" "EXPORT" "ARCHIVE" "ROTATE" "START" "STOP" "RESTART" "ENABLE" "DISABLE" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path ocsf:activity_id ],
        [ sh:datatype xsd:string ;
            sh:description """The log type, normalized to the caption of the <code>log_type_id</code> value.
In the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:log_type ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 46 ;
            sh:path ocsf:confidence_score ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 50 ;
            sh:path ocsf:is_alert ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:severity ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 51 ;
            sh:path ocsf:malware ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description """The <p style='display:inline;color:red'>targeted</p> endpoint for the event log
activity.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:dst_endpoint ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 43 ;
            sh:path ocsf:authorizations ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:raw_data ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 49 ;
            sh:path ocsf:firewall_rule ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 45 ;
            sh:path ocsf:confidence_id ],
        [ sh:class ocsf:Device ;
            sh:description "The device that reported the event." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:device ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 56 ;
            sh:path ocsf:risk_level_id ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 31 ;
            sh:path ocsf:status_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:duration ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 55 ;
            sh:path ocsf:risk_level ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 39 ;
            sh:path ocsf:osint ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:start_time ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 16 ;
            sh:path ocsf:class_uid ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path ocsf:enrichments ],
        [ sh:description "The normalized log type identifier." ;
            sh:in ( "UNKNOWN" "OS" "APPLICATION" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path ocsf:log_type_id ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 57 ;
            sh:path ocsf:risk_score ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 38 ;
            sh:path ocsf:cloud ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 34 ;
            sh:path ocsf:type_name ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 48 ;
            sh:path ocsf:disposition_id ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 52 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 42 ;
            sh:path ocsf:attacks ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path ocsf:observables ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:count ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:class_name ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path ocsf:type_uid ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:end_time ],
        [ sh:datatype xsd:string ;
            sh:description """The logging provider or logging service <p
style='display:inline;color:red'>targeted by</p> the activity.<br />Example:
<code>Microsoft-Windows-Security-Auditing</code>, <code>Auditd</code>, or
<code>Syslog</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:log_provider ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:activity_name ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:raw_data_size ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:disposition ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event outcome.<br
/>Example: <code>Success</code>, <code>Privilege Missing</code>, or
<code>Invalid Parameter</code> for <a target='_blank'
href='https://learn.microsoft.com/en-us/previous-versions/windows/desktop/eventlogprov/cleareventlog-method-in-class-win32-nteventlogfile'>Windows
ClearEventLog</a>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:status_detail ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 14 ;
            sh:path ocsf:category_uid ],
        [ sh:class ocsf:File ;
            sh:description """The file <p style='display:inline;color:red'>targeted by</p> the activity.
Example: <code>/var/log/audit.log</code>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:file ] ;
    sh:targetClass ocsf:EventLogActvity .

ocsf:EvidenceInfo a sh:NodeShape ;
    rdfs:comment """Data collected directly from devices that represents forensic information
pulled, queried, or discovered from devices that may indicate malicious
activity. It contains a number of child objects, each representing a distinct
evidence domain (network connections, file artifacts, registry entries, etc.).
When mapping raw telemetry data users should select Query Evidence and then the
appropriate child object that best matches the evidence type.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:category_name ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path ocsf:observables ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 40 ;
            sh:path ocsf:authorizations ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:end_time ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 8 ;
            sh:path ocsf:category_uid ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 38 ;
            sh:path ocsf:action_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:duration ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:status_code ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:type_name ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 49 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 34 ;
            sh:path ocsf:cloud ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:activity_name ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 46 ;
            sh:path ocsf:firewall_rule ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:start_time ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 42 ;
            sh:path ocsf:confidence_id ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 44 ;
            sh:path ocsf:disposition ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 35 ;
            sh:path ocsf:actor ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 48 ;
            sh:path ocsf:malware ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:risk_details ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "QUERY" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path ocsf:activity_id ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 53 ;
            sh:path ocsf:risk_level_id ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:is_alert ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:count ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 27 ;
            sh:path ocsf:status_id ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path ocsf:type_uid ],
        [ sh:description "The normalized identifier of the query result." ;
            sh:in ( "UNKNOWN" "EXISTS" "PARTIAL" "DOES_NOT_EXIST" "ERROR" "UNSUPPORTED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path ocsf:query_result_id ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 39 ;
            sh:path ocsf:attacks ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:raw_data_size ],
        [ sh:datatype xsd:string ;
            sh:description "The result of the query." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:query_result ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path ocsf:confidence_score ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 52 ;
            sh:path ocsf:risk_level ],
        [ sh:class ocsf:QueryEvidence ;
            sh:description """The specific resulting evidence information that was queried or discovered
based on the query type. Contains various child objects corresponding to the
query_type_id values.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:query_evidence ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:class_name ],
        [ sh:class ocsf:QueryInfo ;
            sh:description "The search details associated with the query request." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:query_info ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 22 ;
            sh:path ocsf:severity_id ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 45 ;
            sh:path ocsf:disposition_id ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path ocsf:unmapped ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path ocsf:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 37 ;
            sh:path ocsf:action ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:time ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 54 ;
            sh:path ocsf:risk_score ],
        [ sh:class ocsf:Device ;
            sh:description """An addressable device, computer system or host from which evidence was
collected.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:device ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:timezone_offset ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:severity ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path ocsf:osint ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 50 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:raw_data ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 33 ;
            sh:path ocsf:api ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ocsf:enrichments ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 10 ;
            sh:path ocsf:class_uid ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:status_detail ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path ocsf:metadata ] ;
    sh:targetClass ocsf:EvidenceInfo .

ocsf:FileActivity a sh:NodeShape ;
    rdfs:comment """File System Activity events report when a process performs an action on a file
or folder.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 54 ;
            sh:path ocsf:risk_details ],
        [ sh:class ocsf:Actor ;
            sh:description "The actor that performed the activity on the <code>file</code> object" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:actor ],
        [ sh:datatype xsd:string ;
            sh:description "The original Windows mask that is required to create the object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:create_mask ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path ocsf:action ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 55 ;
            sh:path ocsf:risk_level ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path ocsf:metadata ],
        [ sh:datatype xsd:integer ;
            sh:description "The access mask in a platform-native format." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:access_mask ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:count ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 49 ;
            sh:path ocsf:firewall_rule ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path ocsf:enrichments ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path ocsf:type_uid ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path ocsf:observables ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "CREATE" "READ" "UPDATE" "DELETE" "RENAME" "SET_ATTRIBUTES" "SET_SECURITY" "GET_ATTRIBUTES" "GET_SECURITY" "ENCRYPT" "DECRYPT" "MOUNT" "UNMOUNT" "OPEN" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path ocsf:activity_id ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 41 ;
            sh:path ocsf:action_id ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 39 ;
            sh:path ocsf:osint ],
        [ sh:datatype xsd:string ;
            sh:description "The network connection identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:connection_uid ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 14 ;
            sh:path ocsf:class_uid ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 53 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:severity ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:status_code ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:class_name ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:disposition ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:duration ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 12 ;
            sh:path ocsf:category_uid ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path ocsf:unmapped ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 52 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 42 ;
            sh:path ocsf:attacks ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:class ocsf:File ;
            sh:description "The file that is the target of the activity." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:file ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:timezone_offset ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 31 ;
            sh:path ocsf:status_id ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 45 ;
            sh:path ocsf:confidence_id ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:raw_data_size ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 43 ;
            sh:path ocsf:authorizations ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:start_time ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:end_time ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:status ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 38 ;
            sh:path ocsf:cloud ],
        [ sh:datatype xsd:string ;
            sh:description """File content differences used for change detection. For example, a common use
case is to identify itemized changes within INI or configuration/property
setting values.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:file_diff ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 34 ;
            sh:path ocsf:type_name ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 51 ;
            sh:path ocsf:malware ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 46 ;
            sh:path ocsf:confidence_score ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 37 ;
            sh:path ocsf:api ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 26 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:raw_data ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 57 ;
            sh:path ocsf:risk_score ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 44 ;
            sh:path ocsf:confidence ],
        [ sh:datatype xsd:string ;
            sh:description """<p>The name or relative pathname of a sub-component of the data object, if
applicable. </p>For example: <code>attachment.doc</code>,
<code>attachment.zip/bad.doc</code>, or
<code>part.mime/part.cab/part.uue/part.doc</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:component ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:activity_name ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path ocsf:time ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 48 ;
            sh:path ocsf:disposition_id ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:status_detail ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:device ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 50 ;
            sh:path ocsf:is_alert ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:category_name ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 56 ;
            sh:path ocsf:risk_level_id ],
        [ sh:class ocsf:File ;
            sh:description "The resulting file object when the activity was allowed and successful." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:file_result ] ;
    sh:targetClass ocsf:FileActivity .

ocsf:FileHosting a sh:NodeShape ;
    rdfs:comment """File Hosting Activity events report the actions taken by file management
applications, including file sharing servers like Sharepoint and services such
as Box, MS OneDrive, Google Drive, or network file share services.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The share name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:share ],
        [ sh:class ocsf:NetworkConnectionInfo ;
            sh:description "The network connection information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:connection_info ],
        [ sh:datatype xsd:string ;
            sh:description "The list of access check results." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:access_result ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 46 ;
            sh:path ocsf:osint ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 56 ;
            sh:path ocsf:firewall_rule ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:raw_data ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 24 ;
            sh:path ocsf:enrichments ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path ocsf:type_uid ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 50 ;
            sh:path ocsf:authorizations ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:duration ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 27 ;
            sh:path ocsf:observables ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 44 ;
            sh:path ocsf:cloud ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 43 ;
            sh:path ocsf:api ],
        [ sh:datatype xsd:string ;
            sh:description """The share type, normalized to the caption of the share_type_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:share_type ],
        [ sh:class ocsf:File ;
            sh:description "The file that is the target of the activity." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:file ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 29 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 57 ;
            sh:path ocsf:is_alert ],
        [ sh:datatype xsd:long ;
            sh:description "The share expiration time." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:expiration_time ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 64 ;
            sh:path ocsf:risk_score ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:activity_name ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 48 ;
            sh:path ocsf:action_id ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 52 ;
            sh:path ocsf:confidence_id ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 20 ;
            sh:path ocsf:class_uid ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:start_time ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 63 ;
            sh:path ocsf:risk_level_id ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description "The endpoint that received the activity on the target file." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ocsf:dst_endpoint ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 62 ;
            sh:path ocsf:risk_level ],
        [ sh:class ocsf:HttpRequest ;
            sh:description "Details about the underlying HTTP request." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path ocsf:http_request ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 32 ;
            sh:path ocsf:severity_id ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 42 ;
            sh:path ocsf:unmapped ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:category_name ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path ocsf:type_name ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:confidence ],
        [ sh:datatype xsd:integer ;
            sh:description "The sum of hexadecimal values of requested access rights." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:access_mask ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path ocsf:severity ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 45 ;
            sh:path ocsf:device ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 38 ;
            sh:path ocsf:time ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 37 ;
            sh:path ocsf:status_id ],
        [ sh:class ocsf:File ;
            sh:description "The resulting file object when the activity was allowed and successful." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:file_result ],
        [ sh:description "The normalized identifier of the share type." ;
            sh:in ( "UNKNOWN" "FILE" "PIPE" "PRINT" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 14 ;
            sh:path ocsf:share_type_id ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 54 ;
            sh:path ocsf:disposition ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 36 ;
            sh:path ocsf:status_detail ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 39 ;
            sh:path ocsf:timezone_offset ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path ocsf:status_code ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description "The endpoint that performed the activity on the target file." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path ocsf:src_endpoint ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:class_name ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "UPLOAD" "DOWNLOAD" "UPDATE" "DELETE" "RENAME" "COPY" "MOVE" "RESTORE" "PREVIEW" "LOCK" "UNLOCK" "SHARE" "UNSHARE" "OPEN" "SYNC" "UNSYNC" "ACCESS_CHECK" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path ocsf:activity_id ],
        [ sh:datatype xsd:string ;
            sh:description "The list of requested access rights." ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:access_list ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 60 ;
            sh:path ocsf:policy ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 18 ;
            sh:path ocsf:category_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:action ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 59 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:count ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 34 ;
            sh:path ocsf:status ],
        [ sh:class ocsf:HttpResponse ;
            sh:description "Details about the HTTP response, if available." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:http_response ],
        [ sh:class ocsf:Actor ;
            sh:description "The actor that performed the activity on the target file." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:actor ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 49 ;
            sh:path ocsf:attacks ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 53 ;
            sh:path ocsf:confidence_score ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 26 ;
            sh:path ocsf:metadata ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:end_time ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 58 ;
            sh:path ocsf:malware ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 61 ;
            sh:path ocsf:risk_details ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:raw_data_size ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 55 ;
            sh:path ocsf:disposition_id ] ;
    sh:targetClass ocsf:FileHosting .

ocsf:FileQuery a sh:NodeShape ;
    rdfs:comment """File Query events report information about files that are present on the
system.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:QueryInfo ;
            sh:description "The search details associated with the query request." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:query_info ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 54 ;
            sh:path ocsf:risk_score ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 35 ;
            sh:path ocsf:device ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:end_time ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 26 ;
            sh:path ocsf:status_id ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:is_alert ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:severity ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 44 ;
            sh:path ocsf:disposition ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 42 ;
            sh:path ocsf:confidence_id ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 52 ;
            sh:path ocsf:risk_level ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:status_code ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 45 ;
            sh:path ocsf:disposition_id ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path ocsf:confidence ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:time ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control

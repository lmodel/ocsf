            sh:order 34 ;
            sh:path ocsf:actor ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:raw_data_size ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:risk_details ],
        [ sh:description "The normalized identifier of the query result." ;
            sh:in ( "UNKNOWN" "EXISTS" "PARTIAL" "DOES_NOT_EXIST" "ERROR" "UNSUPPORTED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 4 ;
            sh:path ocsf:query_result_id ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:activity_name ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 40 ;
            sh:path ocsf:authorizations ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:count ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 42 ;
            sh:path ocsf:confidence_id ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 39 ;
            sh:path ocsf:attacks ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:start_time ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path ocsf:api ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:raw_data ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:type_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:message ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 7 ;
            sh:path ocsf:category_uid ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 49 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:class_name ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:is_alert ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 38 ;
            sh:path ocsf:action_id ],
        [ sh:class ocsf:PeripheralDevice ;
            sh:description "The peripheral device that triggered the event." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:peripheral_device ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:severity ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path ocsf:confidence ] ;
    sh:targetClass ocsf:PeripheralDeviceQuery .

ocsf:PrefetchQuery a sh:NodeShape ;
    rdfs:comment "Prefetch Query events report information about Windows prefetch files." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 42 ;
            sh:path ocsf:authorizations ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path ocsf:observables ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 47 ;
            sh:path ocsf:disposition_id ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:raw_data_size ],
        [ sh:description "The normalized identifier of the query result." ;
            sh:in ( "UNKNOWN" "EXISTS" "PARTIAL" "DOES_NOT_EXIST" "ERROR" "UNSUPPORTED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 6 ;
            sh:path ocsf:query_result_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:duration ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 52 ;
            sh:path ocsf:policy ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 23 ;
            sh:path ocsf:severity_id ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 9 ;
            sh:path ocsf:category_uid ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:status_detail ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 35 ;
            sh:path ocsf:cloud ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 38 ;
            sh:path ocsf:osint ],
        [ sh:datatype xsd:integer ;
            sh:description "The prefetch file run count." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:run_count ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 51 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 40 ;
            sh:path ocsf:action_id ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 50 ;
            sh:path ocsf:malware ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 44 ;
            sh:path ocsf:confidence_id ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path ocsf:enrichments ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path ocsf:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:raw_data ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:start_time ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:count ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:end_time ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 41 ;
            sh:path ocsf:attacks ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 54 ;
            sh:path ocsf:risk_level ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:status_code ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 45 ;
            sh:path ocsf:confidence_score ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 53 ;
            sh:path ocsf:risk_details ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 11 ;
            sh:path ocsf:class_uid ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path ocsf:actor ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 28 ;
            sh:path ocsf:status_id ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path ocsf:type_name ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 39 ;
            sh:path ocsf:action ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:class_name ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:category_name ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 37 ;
            sh:path ocsf:device ],
        [ sh:datatype xsd:long ;
            sh:description "The prefetch file last run time." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ocsf:last_run_time ],
        [ sh:datatype xsd:string ;
            sh:description "The result of the query." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:query_result ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:time ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path ocsf:metadata ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:activity_name ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 56 ;
            sh:path ocsf:risk_score ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 33 ;
            sh:path ocsf:unmapped ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 48 ;
            sh:path ocsf:firewall_rule ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the prefetch file that is the target of the query." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:name ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 46 ;
            sh:path ocsf:disposition ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:message ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 34 ;
            sh:path ocsf:api ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:status ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 55 ;
            sh:path ocsf:risk_level_id ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:severity ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 49 ;
            sh:path ocsf:is_alert ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path ocsf:type_uid ],
        [ sh:class ocsf:QueryInfo ;
            sh:description "The search details associated with the query request." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:query_info ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:timezone_offset ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "QUERY" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path ocsf:activity_id ] ;
    sh:targetClass ocsf:PrefetchQuery .

ocsf:ProcessActivity a sh:NodeShape ;
    rdfs:comment """Process Activity events report when a process launches, injects, opens or
terminates another process, successful or otherwise.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 43 ;
            sh:path ocsf:osint ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 35 ;
            sh:path ocsf:status_id ],
        [ sh:class ocsf:MessageContext ;
            sh:description """Communication context for AI system interactions including protocols, roles,
clients, and session information for MCP and other AI communication systems.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:message_context ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 60 ;
            sh:path ocsf:risk_level_id ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 45 ;
            sh:path ocsf:action_id ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 34 ;
            sh:path ocsf:status_detail ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 47 ;
            sh:path ocsf:authorizations ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 27 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path ocsf:confidence ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 40 ;
            sh:path ocsf:unmapped ],
        [ sh:datatype xsd:integer ;
            sh:description "The permissions mask that was requested by the process." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:requested_permissions ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path ocsf:enrichments ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 61 ;
            sh:path ocsf:risk_score ],
        [ sh:datatype xsd:string ;
            sh:description """The specific type of <code>Launch</code> activity, normalized to the caption of
the <code>launch_type_id</code> value. In the case of <code>Other</code> it is
defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:launch_type ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 57 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 38 ;
            sh:path ocsf:type_name ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor that performed the activity on the target <code>process</code>. For
example, the process that started a new process or injected code into another
process.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:actor ],
        [ sh:datatype xsd:integer ;
            sh:description "The permissions that were granted to the process in a platform-native format." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:actual_permissions ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 44 ;
            sh:path ocsf:action ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:raw_data_size ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:device ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 55 ;
            sh:path ocsf:malware ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 49 ;
            sh:path ocsf:confidence_id ],
        [ sh:class ocsf:Process ;
            sh:description "The process that was launched, injected into, opened, or terminated." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:process ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 18 ;
            sh:path ocsf:class_uid ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:duration ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 58 ;
            sh:path ocsf:risk_details ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 25 ;
            sh:path ocsf:observables ],
        [ sh:datatype xsd:integer ;
            sh:description """The exit code reported by a process when it terminates. The convention is that
zero indicates success and any non-zero exit code indicates that some error
occurred.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:exit_code ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 30 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:class_name ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 53 ;
            sh:path ocsf:firewall_rule ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 41 ;
            sh:path ocsf:api ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 46 ;
            sh:path ocsf:attacks ],
        [ sh:class ocsf:Module ;
            sh:description "The module that was injected by the actor process." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path ocsf:module ],
        [ sh:description "The normalized identifier of the process injection method." ;
            sh:in ( "UNKNOWN" "REMOTE_THREAD" "LOAD_LIBRARY" "QUEUE_APC" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path ocsf:injection_type_id ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 36 ;
            sh:path ocsf:time ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:disposition ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:severity ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 42 ;
            sh:path ocsf:cloud ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 54 ;
            sh:path ocsf:is_alert ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 50 ;
            sh:path ocsf:confidence_score ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:status_code ],
        [ sh:class ocsf:AiModel ;
            sh:description """The AI Model object describes the characteristics of an AI/ML model. Examples
include language models like GPT-4, embedding models like
text-embedding-ada-002, and computer vision models like CLIP.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:ai_model ],
        [ sh:datatype xsd:string ;
            sh:description """The process injection method, normalized to the caption of the
injection_type_id value. In the case of 'Other', it is defined by the event
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:injection_type ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:message ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 56 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 39 ;
            sh:path ocsf:type_uid ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 16 ;
            sh:path ocsf:category_uid ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 24 ;
            sh:path ocsf:metadata ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path ocsf:status ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 52 ;
            sh:path ocsf:disposition_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 37 ;
            sh:path ocsf:timezone_offset ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path ocsf:start_time ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "LAUNCH" "TERMINATE" "OPEN" "INJECT" "SET_USER_ID" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path ocsf:activity_id ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:end_time ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:count ],
        [ sh:description """The normalized identifier for the specific type of <code>Launch</code>
activity.""" ;
            sh:in ( "UNKNOWN" "SPAWN" "FORK" "EXEC" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path ocsf:launch_type_id ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:raw_data ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:activity_name ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:category_name ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 59 ;
            sh:path ocsf:risk_level ] ;
    sh:targetClass ocsf:ProcessActivity .

ocsf:ProcessQuery a sh:NodeShape ;
    rdfs:comment "Process Query events report information about running processes." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:QueryInfo ;
            sh:description "The search details associated with the query request." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:query_info ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:class_name ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:duration ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:is_alert ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:count ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:type_uid ],
        [ sh:description "The normalized identifier of the query result." ;
            sh:in ( "UNKNOWN" "EXISTS" "PARTIAL" "DOES_NOT_EXIST" "ERROR" "UNSUPPORTED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 4 ;
            sh:path ocsf:query_result_id ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 48 ;
            sh:path ocsf:malware ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "QUERY" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path ocsf:activity_id ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path ocsf:api ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 33 ;
            sh:path ocsf:cloud ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 31 ;
            sh:path ocsf:unmapped ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 42 ;
            sh:path ocsf:confidence_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:timezone_offset ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 46 ;
            sh:path ocsf:firewall_rule ],
        [ sh:class ocsf:Process ;
            sh:description "The process object." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:process ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:category_name ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 39 ;
            sh:path ocsf:attacks ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:raw_data ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path ocsf:observables ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 49 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 34 ;
            sh:path ocsf:actor ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:message ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path ocsf:osint ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 38 ;
            sh:path ocsf:action_id ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:start_time ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:datatype xsd:string ;
            sh:description "The result of the query." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:query_result ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:time ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:severity ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:enrichments ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 44 ;
            sh:path ocsf:disposition ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 54 ;
            sh:path ocsf:risk_score ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:end_time ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 35 ;
            sh:path ocsf:device ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 9 ;
            sh:path ocsf:class_uid ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 52 ;
            sh:path ocsf:risk_level ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ocsf:activity_name ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 37 ;
            sh:path ocsf:action ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 50 ;
            sh:path ocsf:policy ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 53 ;
            sh:path ocsf:risk_level_id ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 45 ;
            sh:path ocsf:disposition_id ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 21 ;
            sh:path ocsf:severity_id ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 7 ;
            sh:path ocsf:category_uid ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:raw_data_size ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:type_name ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:risk_details ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:status_detail ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 40 ;
            sh:path ocsf:authorizations ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path ocsf:confidence_score ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 26 ;
            sh:path ocsf:status_id ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path ocsf:metadata ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path ocsf:confidence ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:status_code ] ;
    sh:targetClass ocsf:ProcessQuery .

ocsf:ProcessRemediationActivity a sh:NodeShape ;
    rdfs:comment """Process Remediation Activity events report on attempts at remediating
processes. It follows the MITRE countermeasures defined by the D3FEND™ <a
target='_blank' href='https://d3fend.mitre.org/'>Matrix</a>. Sub-techniques
will include Process, such as Process Termination or Kernel-based Process
Isolation.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Remediation ;
            sh:description "Describes the recommended remediation steps to address identified issue(s)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:remediation ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path ocsf:is_alert ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:status_code ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:type_name ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 46 ;
            sh:path ocsf:disposition_id ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:status_detail ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:class_name ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path ocsf:type_uid ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 33 ;
            sh:path ocsf:api ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path ocsf:device ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path ocsf:unmapped ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the remediation command that pertains to this event." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:command_uid ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:duration ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 50 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path ocsf:metadata ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path ocsf:observables ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 54 ;
            sh:path ocsf:risk_level_id ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "DOES_NOT_EXIST" "PARTIAL" "UNSUPPORTED" "ERROR" "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path ocsf:status_id ],
        [ sh:class ocsf:D3fend ;
            sh:description "The MITRE D3FEND™ Matrix Countermeasures associated with a remediation." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:countermeasures ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 51 ;
            sh:path ocsf:policy ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 39 ;
            sh:path ocsf:action_id ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:category_name ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path ocsf:start_time ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 53 ;
            sh:path ocsf:risk_level ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:severity ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:count ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 52 ;
            sh:path ocsf:risk_details ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 40 ;
            sh:path ocsf:attacks ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 42 ;
            sh:path ocsf:confidence ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 45 ;
            sh:path ocsf:disposition ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 44 ;
            sh:path ocsf:confidence_score ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 55 ;
            sh:path ocsf:risk_score ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 43 ;
            sh:path ocsf:confidence_id ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 47 ;
            sh:path ocsf:firewall_rule ],
        [ sh:class ocsf:Process ;
            sh:description "The process that pertains to the remediation event." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:process ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 11 ;
            sh:path ocsf:class_uid ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 41 ;
            sh:path ocsf:authorizations ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 34 ;
            sh:path ocsf:cloud ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path ocsf:enrichments ],
        [ sh:description """Matches the MITRE D3FEND™ Tactic. Note: the Model and Detect Tactics are not
supported as remediations by the OCSF Remediation event class.""" ;
            sh:in ( "ISOLATE" "EVICT" "RESTORE" "HARDEN" "DETECT" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path ocsf:activity_id ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 37 ;
            sh:path ocsf:osint ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:time ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:end_time ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 35 ;
            sh:path ocsf:actor ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:raw_data ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 9 ;
            sh:path ocsf:category_uid ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 23 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:raw_data_size ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ocsf:activity_name ],
        [ sh:class ocsf:Scan ;
            sh:description "The remediation scan that pertains to this event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:scan ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 49 ;
            sh:path ocsf:malware ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path ocsf:timezone_offset ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 38 ;
            sh:path ocsf:action ] ;
    sh:targetClass ocsf:ProcessRemediationActivity .

ocsf:RdpActivity a sh:NodeShape ;
    rdfs:comment """Remote Desktop Protocol (RDP) Activity events report post-authentication remote
client connections between clients and servers over the network.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:HttpRequest ;
            sh:description "The HTTP Request from the proxy server to the remote server." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 28 ;
            sh:path ocsf:proxy_http_request ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description "The responder (server) in a network connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path ocsf:dst_endpoint ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 50 ;
            sh:path ocsf:start_time ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 36 ;
            sh:path ocsf:class_name ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 41 ;
            sh:path ocsf:enrichments ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 54 ;
            sh:path ocsf:status_id ],
        [ sh:description """The normalized identifier of the observation point. The observation point
identifier indicates whether the source network endpoint, destination network
endpoint, or neither served as the observation point for the activity.""" ;
            sh:in ( "UNKNOWN" "SOURCE" "DESTINATION" "NEITHER" "BOTH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 20 ;
            sh:path ocsf:observation_point_id ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 70 ;
            sh:path ocsf:confidence_score ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 61 ;
            sh:path ocsf:cloud ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 46 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:datatype xsd:string ;
            sh:description """The network application name identified by tools such as NBAR or App ID (e.g.,
youtube, facebook, webex). This represents a specific network application that
uses standard protocols (such as https or quic) to deliver its service.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ocsf:app_name ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 63 ;
            sh:path ocsf:osint ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 35 ;
            sh:path ocsf:category_uid ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 45 ;
            sh:path ocsf:raw_data ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 55 ;
            sh:path ocsf:time ],
        [ sh:datatype xsd:string ;
            sh:description "The Remote Desktop Protocol version." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:protocol_ver ],
        [ sh:datatype xsd:string ;
            sh:description """Indicates whether the source network endpoint, destination network endpoint, or
neither served as the observation point for the activity. The value is
normalized to the caption of the <code>observation_point_id</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path ocsf:observation_point ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description "The initiator (client) of the network connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path ocsf:src_endpoint ],
        [ sh:class ocsf:NetworkTraffic ;
            sh:description """The cumulative (running total) network traffic aggregated from the start of a
flow or session. Use when reporting: (1) total accumulated bytes/packets since
flow initiation, (2) combined aggregation models where both incremental deltas
and running totals are reported together (populate both <code>traffic</code>
for the delta and this attribute for the cumulative total), or (3) final
summary metrics when a long-lived connection closes. This represents the sum of
all activity from flow start to the current observation, not a delta or
point-in-time value.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path ocsf:cumulative_traffic ],
        [ sh:class ocsf:File ;
            sh:description "The file that is the target of the RDP activity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:file ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 81 ;
            sh:path ocsf:risk_score ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 59 ;
            sh:path ocsf:unmapped ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path ocsf:end_time ],
        [ sh:class ocsf:NetworkTraffic ;
            sh:description """The network traffic refers to the amount of data moving across a network, from
proxy to remote server at a given point of time.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 31 ;
            sh:path ocsf:proxy_traffic ],
        [ sh:class ocsf:User ;
            sh:description "The target user associated with the RDP activity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path ocsf:user ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 65 ;
            sh:path ocsf:action_id ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 57 ;
            sh:path ocsf:type_name ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 80 ;
            sh:path ocsf:risk_level_id ],
        [ sh:class ocsf:Tls ;
            sh:description "The Transport Layer Security (TLS) attributes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 24 ;
            sh:path ocsf:tls ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 39 ;
            sh:path ocsf:duration ],
        [ sh:class ocsf:Tls ;
            sh:description "The TLS protocol negotiated between the proxy server and the remote server." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 30 ;
            sh:path ocsf:proxy_tls ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 75 ;
            sh:path ocsf:malware ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 53 ;
            sh:path ocsf:status_detail ],
        [ sh:class ocsf:KeyboardInfo ;
            sh:description "The keyboard detailed information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ocsf:keyboard_info ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 68 ;
            sh:path ocsf:confidence ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor object describes details about the user/role/process that was the
source of the activity. Note that this is not the threat actor of a campaign
but may be part of a campaign.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 62 ;
            sh:path ocsf:actor ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 73 ;
            sh:path ocsf:firewall_rule ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:activity_name ],
        [ sh:class ocsf:HttpResponse ;
            sh:description "The HTTP Response from the remote server to the proxy server." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 29 ;
            sh:path ocsf:proxy_http_response ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 37 ;
            sh:path ocsf:class_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 64 ;
            sh:path ocsf:action ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 78 ;
            sh:path ocsf:risk_details ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 42 ;
            sh:path ocsf:message ],
        [ sh:class ocsf:LoadBalancer ;
            sh:description """The Load Balancer object contains information related to the device that is
distributing incoming traffic to specified destinations.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path ocsf:load_balancer ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 56 ;
            sh:path ocsf:timezone_offset ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 77 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:string ;
            sh:description """The application-layer (Layer 7) protocol name identified by deep packet inspection or packet parsing (e.g., <code>https</code>, <code>quic</code>, <code>ssh</code>, <code>dns</code>), expressed as an IANA-registered service name from the IANA Service Name and Transport Protocol Port Number Registry.

<p><b>Note:</b> Port numbers alone are not always a reliable indicator of the actual application protocol in use.</p>""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:app_protocol_name ],
        [ sh:class ocsf:NetworkEndpoint ;
            sh:description """The network endpoint that observes or inspects network traffic as a third-party
system, used when the observer is neither the source nor the destination of the
communication (when <code>observation_point_id</code> = 3). Examples include
network taps, span ports, inline security devices, or packet capture systems
that monitor traffic between other endpoints.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path ocsf:network_observation_point ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 38 ;
            sh:path ocsf:count ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 60 ;
            sh:path ocsf:api ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 71 ;
            sh:path ocsf:disposition ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 66 ;
            sh:path ocsf:attacks ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 43 ;
            sh:path ocsf:metadata ],
        [ sh:datatype xsd:string ;
            sh:description "The client identifier cookie during client/server exchange." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:identifier_cookie ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 69 ;
            sh:path ocsf:confidence_id ],
        [ sh:class ocsf:Response ;
            sh:description "The server response in an RDP network connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:response ],
        [ sh:class ocsf:NetworkTraffic ;
            sh:description """The network traffic for this observation period. Use when reporting: (1) delta
values (bytes/packets transferred since the last observation), (2)
instantaneous measurements at a specific point in time, or (3) standalone
single-event metrics. This attribute represents a point-in-time measurement or
incremental change, not a running total. For accumulated totals across multiple
observations or the lifetime of a flow, use <code>cumulative_traffic</code>
instead.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 25 ;
            sh:path ocsf:traffic ],
        [ sh:class ocsf:Packet ;
            sh:description "The list of packet objects describing captured network packets." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path ocsf:packet_list ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 79 ;
            sh:path ocsf:risk_level ],
        [ sh:class ocsf:Ja4Fingerprint ;
            sh:description "A list of the JA4+ network fingerprints." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path ocsf:ja4_fingerprint_list ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 76 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:class ocsf:NetworkProxy ;
            sh:description "The proxy (server) in a network connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path ocsf:proxy ],
        [ sh:class ocsf:Request ;
            sh:description "The client request in an RDP network connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path ocsf:request ],
        [ sh:datatype xsd:string ;
            sh:description "The list of observed certificates in an RDP TLS connection." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ocsf:certificate_chain ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 74 ;
            sh:path ocsf:is_alert ],
        [ sh:class ocsf:Display ;
            sh:description "The remote display affiliated with the event" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ocsf:remote_display ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:raw_data_size ],
        [ sh:class ocsf:NetworkConnectionInfo ;
            sh:description "The connection information from the proxy server to the remote server." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 26 ;
            sh:path ocsf:proxy_connection_info ],
        [ sh:class ocsf:NetworkProxy ;
            sh:description "The proxy (server) in a network connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 27 ;
            sh:path ocsf:proxy_endpoint ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 67 ;
            sh:path ocsf:authorizations ],
        [ sh:class ocsf:Device ;
            sh:description "The device instigating the RDP connection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ocsf:device ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 34 ;
            sh:path ocsf:category_name ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 44 ;
            sh:path ocsf:observables ],
        [ sh:class ocsf:NetworkConnectionInfo ;
            sh:description """The remote desktop connection details, either connection-based or
connectionless.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ocsf:connection_info ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 52 ;
            sh:path ocsf:status_code ],
        [ sh:datatype xsd:string ;
            sh:description "A list of RDP capabilities." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ocsf:capabilities ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 49 ;
            sh:path ocsf:severity_id ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "INITIAL_REQUEST" "INITIAL_RESPONSE" "CONNECT_REQUEST" "CONNECT_RESPONSE" "TLS_HANDSHAKE" "TRAFFIC" "DISCONNECT" "RECONNECT" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path ocsf:activity_id ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path ocsf:severity ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 72 ;
            sh:path ocsf:disposition_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 58 ;
            sh:path ocsf:type_uid ] ;
    sh:targetClass ocsf:RdpActivity .

ocsf:RegistryKeyActivity a sh:NodeShape ;
    rdfs:comment """Registry Key Activity events report when a process performs an action on a
Windows registry key.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path ocsf:time ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:message ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:type_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 38 ;
            sh:path ocsf:action ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 52 ;
            sh:path ocsf:risk_details ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:raw_data_size ],
        [ sh:class ocsf:RegKey ;
            sh:description "The registry key before the mutation" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ocsf:prev_reg_key ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 34 ;
            sh:path ocsf:unmapped ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 46 ;
            sh:path ocsf:disposition_id ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:status_detail ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path ocsf:type_name ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:status_code ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:raw_data ],
        [ sh:datatype xsd:integer ;
            sh:description "The Windows options needed to open a registry key." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:open_mask ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 53 ;
            sh:path ocsf:risk_level ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:category_name ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ocsf:class_name ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 41 ;
            sh:path ocsf:authorizations ],
        [ sh:class ocsf:Actor ;
            sh:description "The actor that performed the activity on the <code>reg_key</code> object." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path ocsf:actor ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 42 ;
            sh:path ocsf:confidence ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 35 ;
            sh:path ocsf:api ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 12 ;
            sh:path ocsf:class_uid ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 51 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path ocsf:is_alert ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 10 ;
            sh:path ocsf:category_uid ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 49 ;
            sh:path ocsf:malware ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path ocsf:duration ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 29 ;
            sh:path ocsf:status_id ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 55 ;
            sh:path ocsf:risk_score ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 43 ;
            sh:path ocsf:confidence_id ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case

    sh:targetClass ocsf:OcsfObject .

ocsf:OsintInventoryInfo a sh:NodeShape ;
    rdfs:comment """OSINT Inventory Info events report open source intelligence or threat
intelligence inventory data that is either logged or proactively collected. For
example, when collecting OSINT information from Threat Intelligence Platforms
(TIPs) or Extended Detection and Response (XDR) platforms, or collecting data
from OSINT or other generic threat intelligence and enrichment feeds such as
APIs and datastores.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path ocsf:is_alert ],
        [ sh:datatype xsd:string ;
            sh:description """The disposition name, normalized to the caption of the disposition_id value. In
the case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path ocsf:disposition ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:enrichments ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:status_detail ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 42 ;
            sh:path ocsf:firewall_rule ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:type_uid ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 19 ;
            sh:path ocsf:severity_id ],
        [ sh:class ocsf:MalwareScanInfo ;
            sh:description """Describes details about the scan job that identified malware on the target
system.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 45 ;
            sh:path ocsf:malware_scan_info ],
        [ sh:datatype xsd:string ;
            sh:description """The confidence, normalized to the caption of the confidence_id value. In the
case of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 37 ;
            sh:path ocsf:confidence ],
        [ sh:class ocsf:Observable ;
            sh:description "The observables associated with the event or a finding." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ocsf:observables ],
        [ sh:datatype xsd:string ;
            sh:description "The risk level, normalized to the caption of the risk_level_id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path ocsf:risk_level ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:status ],
        [ sh:class ocsf:Cloud ;
            sh:description """Describes details about the Cloud environment where the event or finding was
created.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 31 ;
            sh:path ocsf:cloud ],
        [ sh:datatype xsd:long ;
            sh:description "The normalized event occurrence time or the finding creation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path ocsf:time ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
control checks, malware detections or various types of policy violations.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "BLOCKED" "QUARANTINED" "ISOLATED" "DELETED" "DROPPED" "CUSTOM_ACTION" "APPROVED" "RESTORED" "EXONERATED" "CORRECTED" "PARTIALLY_CORRECTED" "UNCORRECTED" "DELAYED" "DETECTED" "NO_ACTION" "LOGGED" "TAGGED" "ALERT" "COUNT" "RESET" "CAPTCHA" "CHALLENGE" "ACCESS_REVOKED" "REJECTED" "UNAUTHORIZED" "ERROR" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 41 ;
            sh:path ocsf:disposition_id ],
        [ sh:datatype xsd:string ;
            sh:description "The description of the event/finding, as defined by the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ocsf:message ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "LOG" "COLLECT" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path ocsf:activity_id ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:raw_data ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:count ],
        [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:start_time ],
        [ sh:description "The normalized risk level id." ;
            sh:in ( "INFO" "LOW" "MEDIUM" "HIGH" "CRITICAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 49 ;
            sh:path ocsf:risk_level_id ],
        [ sh:datatype xsd:string ;
            sh:description """The event/finding severity, normalized to the caption of the
<code>severity_id</code> value. In the case of 'Other', it is defined by the
source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path ocsf:severity ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the risk associated with the finding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path ocsf:risk_details ],
        [ sh:datatype xsd:string ;
            sh:description "The event activity name, as defined by the activity_id." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ocsf:activity_name ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path ocsf:category_uid ],
        [ sh:datatype xsd:integer ;
            sh:description "The confidence score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 39 ;
            sh:path ocsf:confidence_score ],
        [ sh:class ocsf:Osint ;
            sh:description "The OSINT that is being discovered by an inventory process." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ocsf:osint ],
        [ sh:datatype xsd:integer ;
            sh:description """The event duration or aggregate time, the amount of time the event covers from
<code>start_time</code> to <code>end_time</code> in milliseconds.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ocsf:duration ],
        [ sh:class ocsf:Authorization ;
            sh:description """Provides details about an authorization, such as authorization outcome, and any
associated policies related to the activity/event.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path ocsf:authorizations ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:status_code ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 50 ;
            sh:path ocsf:risk_score ],
        [ sh:class ocsf:Malware ;
            sh:description "A list of Malware objects, describing details about the identified malware." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 44 ;
            sh:path ocsf:malware ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of minutes that the reported event <code>time</code> is ahead or
behind UTC, in the range -1,080 to +1,080.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path ocsf:timezone_offset ],
        [ sh:datatype xsd:long ;
            sh:description """The end time of a time period, or the time of the most recent event included in
the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ocsf:end_time ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 7 ;
            sh:path ocsf:class_uid ],
        [ sh:class ocsf:Api ;
            sh:description "Describes details about a typical API (Application Programming Interface) call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 30 ;
            sh:path ocsf:api ],
        [ sh:description """The action taken by a control or other policy-based system leading to an
outcome or disposition. An unknown action may still correspond to a known
disposition. Refer to <code>disposition_id</code> for the outcome of the
action.""" ;
            sh:in ( "UNKNOWN" "ALLOWED" "DENIED" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 34 ;
            sh:path ocsf:action_id ],
        [ sh:datatype xsd:string ;
            sh:description "The event class name, as defined by class_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ocsf:class_name ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 24 ;
            sh:path ocsf:status_id ],
        [ sh:class ocsf:Device ;
            sh:description "An addressable device, computer system or host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path ocsf:device ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:type_name ],
        [ sh:class ocsf:Metadata ;
            sh:description "The metadata associated with the event or a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path ocsf:metadata ],
        [ sh:class ocsf:Attack ;
            sh:description """An array of MITRE ATT&CK® objects describing identified tactics, techniques &
sub-techniques. The objects are compatible with MITRE ATLAS™ tactics,
techniques & sub-techniques.""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 35 ;
            sh:path ocsf:attacks ],
        [ sh:class ocsf:Object ;
            sh:description """The attributes that are not mapped to the event schema. The names and values of
those attributes are specific to the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 29 ;
            sh:path ocsf:unmapped ],
        [ sh:class ocsf:Actor ;
            sh:description """The actor describes the process that was the source of the inventory activity.
In the case of OSINT inventory data, that could be a particular process or
script that is run to scrape the OSINT or threat intelligence data. For
example, it could be a Python process that runs to pull data from a MISP or
Shodan API.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:actor ],
        [ sh:datatype xsd:string ;
            sh:description "The normalized caption of <code>action_id</code>." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path ocsf:action ],
        [ sh:datatype xsd:integer ;
            sh:description "The size of the raw data which was transformed into an OCSF event, in bytes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ocsf:raw_data_size ],
        [ sh:class ocsf:Fingerprint ;
            sh:description "The hash, which describes the content of the raw_data field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path ocsf:raw_data_hash ],
        [ sh:class ocsf:Policy ;
            sh:description """The policy that pertains to the control that triggered the event, if
applicable. For example the name of an anti-malware policy or an access control
policy.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 46 ;
            sh:path ocsf:policy ],
        [ sh:datatype xsd:string ;
            sh:description "The event category name, as defined by category_uid value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ocsf:category_name ],
        [ sh:description """The normalized confidence refers to the accuracy of the rule that created the
finding. A rule with a low confidence means that the finding scope is wide and
may create finding reports that may not be malicious in nature.""" ;
            sh:in ( "UNKNOWN" "LOW" "MEDIUM" "HIGH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 38 ;
            sh:path ocsf:confidence_id ] ;
    sh:targetClass ocsf:OsintInventoryInfo .

ocsf:OsintProfile a sh:NodeShape ;
    rdfs:comment """The OSINT (Open Source Intelligence) profile contains one or more indicators
and associated analysis and details, such as registrar (WHOIS) information and
commentary about a hostname, or information about a digital certificate and its
usage within a campaign. This information can be used to further enrich a
detection or finding by providing decisioning support to other analysts and
engineers within the profile itself.""" ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path ocsf:osint ] ;
    sh:targetClass ocsf:OsintProfile .

ocsf:PatchState a sh:NodeShape ;
    rdfs:comment """Operating System Patch State reports the installation of an OS patch to a
device and any associated knowledgebase articles.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:long ;
            sh:description """The start time of a time period, or the time of the least recent event included
in the aggregate event.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path ocsf:start_time ],
        [ sh:class ocsf:Osint ;
            sh:description """The OSINT (Open Source Intelligence) object contains details related to an
indicator such as the indicator itself, related indicators, geolocation,
registrar information, subdomains, analyst commentary, and other contextual
information. This information can be used to further enrich a detection or
finding by providing decisioning support to other analysts and engineers.""" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 33 ;
            sh:path ocsf:osint ],
        [ sh:class ocsf:Enrichment ;
            sh:description """The additional information from an external data source, which is associated
with the event or a finding. For example add location information for the IP
address in the DNS answers:</p><code>[{"name": "answers.ip", "value":
"92.24.47.250", "type": "location", "data": {"city": "Socotra", "continent":
"Asia", "coordinates": [-25.4153, 17.0743], "country": "YE", "desc":
"Yemen"}}]</code>""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ocsf:enrichments ],
        [ sh:datatype xsd:string ;
            sh:description "The event/finding type name, as defined by the type_uid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path ocsf:type_name ],
        [ sh:description """The unique identifier of a class. A class describes the attributes available in
an event.""" ;
            sh:in ( "BASE_EVENT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 7 ;
            sh:path ocsf:class_uid ],
        [ sh:datatype xsd:string ;
            sh:description "The raw event/finding data as received from the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ocsf:raw_data ],
        [ sh:description "The normalized identifier of the event status." ;
            sh:in ( "UNKNOWN" "SUCCESS" "FAILURE" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 24 ;
            sh:path ocsf:status_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The event/finding type ID. It identifies the event's semantics and structure.
The value is calculated by the logging system as: <code>class_uid * 100 +
activity_id</code>.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path ocsf:type_uid ],
        [ sh:datatype xsd:string ;
            sh:description """The event status code, as reported by the event source.<br /><br />For example,
in a Windows Failed Authentication event, this would be the value of 'Failure
Code', e.g. 0x18.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path ocsf:status_code ],
        [ sh:datatype xsd:string ;
            sh:description """The status detail contains additional information about the event/finding
outcome.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path ocsf:status_detail ],
        [ sh:description "The normalized identifier of the activity that triggered the event." ;
            sh:in ( "LOG" "COLLECT" "UNKNOWN" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path ocsf:activity_id ],
        [ sh:description """<p>The normalized identifier of the event/finding severity.</p>The normalized
severity is a measurement the effort and expense required to manage and resolve
an event or incident. Smaller numerical values represent lower impact events,
and larger numerical values represent higher impact events.""" ;
            sh:in ( "UNKNOWN" "INFORMATIONAL" "LOW" "MEDIUM" "HIGH" "CRITICAL" "FATAL" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 19 ;
            sh:path ocsf:severity_id ],
        [ sh:datatype xsd:integer ;
            sh:description """The number of times that events in the same logical group occurred during the
event <strong>Start Time</strong> to <strong>End Time</strong> period.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ocsf:count ],
        [ sh:datatype xsd:boolean ;
            sh:description """Indicates that the event is considered to be an alertable signal. Should be set
to <code>true</code> if <code>disposition_id = Alert</code> among other
dispositions, and/or <code>risk_level_id</code> or <code>severity_id</code> of
the event is elevated. Not all control events will be alertable, for example if
<code>disposition_id = Exonerated</code> or <code>disposition_id =
Allowed</code>.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 44 ;
            sh:path ocsf:is_alert ],
        [ sh:description "The category unique identifier of the event." ;
            sh:in ( "UNCATEGORIZED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path ocsf:category_uid ],
        [ sh:datatype xsd:string ;
            sh:description """The event status, normalized to the caption of the status_id value. In the case
of 'Other', it is defined by the event source.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path ocsf:status ],
        [ sh:datatype xsd:integer ;
            sh:description "The risk score as reported by the event source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path ocsf:risk_score ],
        [ sh:class ocsf:FirewallRule ;
            sh:description """The firewall rule that pertains to the control that triggered the event, if
applicable.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 43 ;
            sh:path ocsf:firewall_rule ],
        [ sh:description """Describes the outcome or action taken by a security control, such as access
